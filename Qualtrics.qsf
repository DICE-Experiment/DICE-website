QuestionText_Unsafe":"$e{3*10} + $e{2} = ???","QuestionType":"MC","Randomization":{"Advanced":null,"TotalRandSubset":"","Type":"All"},"RecodeValues":{"1":"0","2":"-1","3":"1","4":"99","5":"9"},"Selector":"SAHR","SubSelector":"TX","Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}}}},{"SurveyID":"SV_b3mHBVkuioRMhng","Element":"SQ","PrimaryAttribute":"QID89","SecondaryAttribute":"$e{4*10} + $e{3} = ???","TertiaryAttribute":null,"Payload":{"ChoiceOrder":[1,2,3,4,5],"Choices":{"1":{"Display":"$e{4*10+3}"},"2":{"Display":"$e{4*10+3 - ${rand:\/\/int\/1:9}}"},"3":{"Display":"$e{4*10+3 + ${rand:\/\/int\/1:9}}"},"4":{"Display":"$e{4*10}"},"5":{"Display":"$e{3}"}},"Configuration":{"LabelPosition":"BELOW","QuestionDescriptionOption":"UseText"},"DataExportTag":"sum2.24","DataVisibility":{"Hidden":false,"Private":false},"DefaultChoices":false,"GradingData":[],"Language":{"ES":{"QuestionText":"$e{4*10} + $e{3} = ???","Choices":{"1":{"Display":"$e{4*10+3}"},"4":{"Display":"$e{4*10}"},"5":{"Display":"$e{3}"}}}},"NextAnswerId":1,"NextChoiceId":6,"QuestionDescription":"$e{4*10} + $e{3} = ???","QuestionID":"QID89","QuestionText":"$e{4*10} + $e{3} = ???","QuestionText_Unsafe":"$e{4*10} + $e{3} = ???","QuestionType":"MC","Randomization":{"Advanced":null,"TotalRandSubset":"","Type":"All"},"RecodeValues":{"1":"0","2":"-1","3":"1","4":"99","5":"9"},"Selector":"SAHR","SubSelector":"TX","Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}}}},{"SurveyID":"SV_b3mHBVkuioRMhng","Element":"SQ","PrimaryAttribute":"QID9","SecondaryAttribute":"Before we begin Part 2, please enter your estimate (i.e., your guess) about the reported numbers...","TertiaryAttribute":null,"Payload":{"QuestionText":"<div style=\"text-align: center;\">Before we begin Part 2, please enter your <b>estimate <\/b>(i.e., your guess) about the reported numbers of the dice of the other participants.<br><\/div><div style=\"text-align: center;\">So, if there were 100 participants playing the same game as you, how many (i.e., what percentage) do you think reported the number 1, how may reported the number 2, etc.?.<\/div>\n\n<div style=\"text-align: center;\"><br>\nIf your guess is correct, you earn <b>50 MUs<\/b>. For every percentage point you deviate from the correct percentage, your payoff will be reduced by 0.4 MUs. You will receive a minimum of 5 MUs. Note that the <b>percentages <\/b>have to add up to 100 percent.<\/div><div style=\"text-align: center;\">(please enter only whole numbers, no decimal points)<\/div><div style=\"text-align: center;\">(please enter numbers&nbsp;<b>without <\/b>the \"%\" symbol)<\/div>","DefaultChoices":false,"DataExportTag":"DescriptiveNorm","QuestionType":"CS","Selector":"VRTL","Configuration":{"QuestionDescriptionOption":"UseText","CSSliderMin":0,"CSSliderMax":100,"GridLines":10,"NumDecimals":"0"},"QuestionDescription":"Before we begin Part 2, please enter your estimate (i.e., your guess) about the reported numbers...","Choices":{"1":{"Display":"What <strong>percentage <\/strong>of participants reported a number 1 (a payoff of 10 MUs)?"},"2":{"Display":"What <strong>percentage <\/strong>of participants reported a number 2 (a payoff of 20 MUs)?"},"3":{"Display":"What <strong>percentage <\/strong>of participants reported a number 3 (a payoff of 30 MUs)?"},"4":{"Display":"What <strong>percentage <\/strong>of participants reported a number 4 (a payoff of 40 MUs)?"},"5":{"Display":"What <strong>percentage <\/strong>of participants reported a number 5 (a payoff of 50 MUs)?"},"6":{"Display":"What <strong>percentage <\/strong>of participants reported a number 6 (a payoff of 0 MUs)?"}},"ChoiceOrder":[1,2,3,4,5,6],"Validation":{"Settings":{"EnforceRange":"ON","Type":"ChoicesTotal","ChoiceTotal":"100"}},"GradingData":[],"Language":{"CS":{"QuestionText":"<div style=\"text-align: center;\">Ne\u017e za\u010dneme \u010c\u00e1st 2, propros\u00edme V\u00e1s, abyste se pokusil(a) <b>odhadnout<\/b>, jak\u00e1 \u010d\u00edsla nahl\u00e1sili ostatn\u00ed \u00fa\u010dastn\u00edci. Kdyby stejnou hru jako Vy hr\u00e1lo 100 \u00fa\u010dastn\u00edk\u016f, kolik z nich (tj. jak\u00e9 procento)\u00a0by podle V\u00e1s n\u00e1hl\u00e1silo \u010d\u00edsla 1, 2, 3, ..., 6.\u00a0<\/div>\n\n<div style=\"text-align: center;\"><br \/>\nPokud je v\u00e1\u0161 odhad spr\u00e1vn\u00fd, z\u00edsk\u00e1te <b>50 EMJ<\/b>. Za ka\u017ed\u00fd procentn\u00ed bod, o kter\u00fd se odch\u00fdl\u00edte od spr\u00e1vn\u00e9ho procenta na libovoln\u00e9m z \u0161esti \u0159\u00e1dk\u016f, na kter\u00e9 budete ps\u00e1t svoje odhady, V\u00e1m bude z t\u011bchto\u00a050 EMJ str\u017eeno 0,4 EMJ. Obdr\u017e\u00edte minim\u00e1ln\u011b 5 EMJ. M\u011bjte na pam\u011bti, \u017ee <b>procenta<\/b> mus\u00ed dohromady d\u00e1t 100 procent.<\/div>\n\n<div style=\"text-align: center;\">(zad\u00e1vejte, pros\u00edm, pouze cel\u00e1 \u010d\u00edsla bez desetinn\u00fdch m\u00edst)<\/div>\n\n<div style=\"text-align: center;\">(zad\u00e1vejte, pros\u00edm, \u010d\u00edsla <b>bez<\/b> pou\u017eit\u00ed symbolu \"%\")<\/div>\n","Choices":{"1":{"Display":"Jak\u00e9 <strong>procento<\/strong> \u00fa\u010dastn\u00edk\u016f uvedlo \u010d\u00edslo 1 (a obdr\u017eelo 10 EMJ)?"},"2":{"Display":"Jak\u00e9 <strong>procento<\/strong> \u00fa\u010dastn\u00edk\u016f uvedlo \u010d\u00edslo 2 (a obdr\u017eelo 20 EMJ)?"},"3":{"Display":"Jak\u00e9 <strong>procento<\/strong> \u00fa\u010dastn\u00edk\u016f uvedlo \u010d\u00edslo 3 (a obdr\u017eelo 30 EMJ)?"},"4":{"Display":"Jak\u00e9 <strong>procento<\/strong> \u00fa\u010dastn\u00edk\u016f uvedlo \u010d\u00edslo 4 (a obdr\u017eelo 40 EMJ)?"},"5":{"Display":"Jak\u00e9 <strong>procento<\/strong> \u00fa\u010dastn\u00edk\u016f uvedlo \u010d\u00edslo 5 (a obdr\u017eelo 50 EMJ)?"},"6":{"Display":"Jak\u00e9 <strong>procento<\/strong> \u00fa\u010dastn\u00edk\u016f uvedlo \u010d\u00edslo 6 (a obdr\u017eelo 0 EMJ)?"}}},"EL":{"QuestionText":"<div style=\"text-align: center;\">\u03a0\u03c1\u03b9\u03bd \u03be\u03b5\u03ba\u03b9\u03bd\u03ae\u03c3\u03bf\u03c5\u03bc\u03b5 \u03c4\u03bf \u039c\u03ad\u03c1\u03bf\u03c2 2, \u03c0\u03b1\u03c1\u03b1\u03ba\u03b1\u03bb\u03ce \u03c0\u03b5\u03af\u03c4\u03b5 \u03bc\u03b1\u03c2 \u03c4\u03b7\u03bd \u03b5\u03ba\u03c4\u03af\u03bc\u03b7\u03c3\u03ae \u03c3\u03b1\u03c2 \u03b3\u03b9\u03b1 \u03c4\u03bf \u03c4\u03b9 \u03c0\u03b9\u03c3\u03c4\u03b5\u03cd\u03b5\u03c4\u03b5 \u03cc\u03c4\u03b9 \u03bf\u03b9 \u03c5\u03c0\u03cc\u03bb\u03bf\u03c0\u03bf\u03b9 \u03c3\u03c5\u03bc\u03b5\u03c4\u03b5\u03c7\u03bf\u03bd\u03b1\u03c4\u03b5\u03c2 \u03c3\u03c4\u03b7 \u03b1\u03af\u03b8\u03bf\u03c5\u03c3\u03b1 \u03b4\u03b7\u03bb\u03c9\u03c3\u03b1\u03bd \u03cc\u03c4\u03b9 \u03c4\u03bf\u03c5\u03c2 \u03b5\u03c4\u03c5\u03c7\u03b5 \u03c3\u03c4\u03bf \u03b6\u03ac\u03c1\u03b9.<\/div>\n\n<div style=\"text-align: center;\"><br \/>\n\u0395\u03ac\u03bd \u03bc\u03b1\u03bd\u03c4\u03ad\u03c8\u03b5\u03c4\u03b5 \u03b5\u03bd\u03c4\u03b5\u03bb\u03ce\u03c2 \u03c3\u03c9\u03c3\u03c4\u03ac, \u03b8\u03b1 \u03ba\u03b5\u03c1\u03b4\u03af\u03c3\u03b5\u03c4\u03b5 <b>50 \u039d\u039c<\/b>. \u0393\u03b9\u03b1 \u03ba\u03ac\u03b8\u03b5 \u03c0\u03bf\u03c3\u03bf\u03c3\u03c4\u03b9\u03b1\u03af\u03b1 \u03bc\u03bf\u03bd\u03ac\u03b4\u03b1 \u03c0\u03bf\u03c5 \u03b8\u03b1 \u03b1\u03c0\u03bf\u03ba\u03bb\u03af\u03bd\u03b5\u03c4\u03b5 \u03b1\u03c0\u03cc \u03c4\u03b1 \u03c3\u03c9\u03c3\u03c4\u03ac \u03c0\u03bf\u03c3\u03bf\u03c3\u03c4\u03ac, \u03b7 \u03c0\u03bb\u03b7\u03c1\u03c9\u03bc\u03ae \u03c3\u03b1\u03c2 \u03b8\u03b1 \u03bc\u03b5\u03b9\u03ce\u03bd\u03b5\u03c4\u03b1\u03b9 \u03ba\u03b1\u03c4\u03ac 0,4 \u039d\u039c. \u03a3\u03b5 \u03ba\u03ac\u03b8\u03b5 \u03c0\u03b5\u03c1\u03af\u03c0\u03c4\u03c9\u03c3\u03b7 \u03cc\u03bc\u03c9\u03c2, \u03b8\u03b1 \u03bb\u03ac\u03b2\u03b5\u03c4\u03b5 \u03c4\u03bf\u03c5\u03bb\u03ac\u03c7\u03b9\u03c3\u03c4\u03bf\u03bd 5 \u039d\u039c. \u03a3\u03b7\u03bc\u03b5\u03b9\u03ce\u03c3\u03c4\u03b5 \u03cc\u03c4\u03b9 \u03c4\u03b1 <b>\u03c0\u03bf\u03c3\u03bf\u03c3\u03c4\u03ac<\/b>\u00a0\u03c0\u03c1\u03ad\u03c0\u03b5\u03b9 \u03bd\u03b1 \u03b1\u03b8\u03c1\u03bf\u03af\u03b6\u03bf\u03c5\u03bd \u03b1\u03ba\u03c1\u03b9\u03b2\u03ce\u03c2 100.<br \/>\n<br \/>\n\u03a0\u03b1\u03c1\u03b1\u03ba\u03b1\u03bb\u03ce \u03b5\u03b9\u03c3\u03ac\u03b3\u03b5\u03c4\u03b5 \u03b1\u03ba\u03ad\u03c1\u03b1\u03b9\u03bf\u03c5\u03c2 \u03b1\u03c1\u03b9\u03b8\u03bc\u03bf\u03cd\u03c2, \u03c7\u03c9\u03c1\u03af\u03c2 \u03c4\u03bf \u03c3\u03cd\u03bc\u03b2\u03bf\u03bb\u03bf \"%\" \u03ba\u03b1\u03b9 \u03c7\u03c9\u03c1\u03af\u03c2 \u03b4\u03b5\u03ba\u03b1\u03b4\u03b9\u03ba\u03ac \u03c8\u03b7\u03c6\u03af\u03b1.<\/div>\n","Choices":{"1":{"Display":"\u03a4\u03b9 <strong>\u03c0\u03bf\u03c3\u03bf\u03c3\u03c4\u03cc<\/strong> \u03c4\u03c9\u03bd \u03c3\u03c5\u03bc\u03bc\u03b5\u03c4\u03b5\u03c7\u03cc\u03bd\u03c4\u03c9\u03bd \u03b4\u03ae\u03bb\u03c9\u03c3\u03b5 \u03bf\u03c4\u03b9 \u03c4\u03bf\u03c5 \u03ad\u03c4\u03c5\u03c7\u03b5 \u03bf \u03b1\u03c1\u03b9\u03b8\u03bc\u03cc\u03c2 1 (\u03bc\u03b5 \u03b1\u03c0\u03cc\u03b4\u03bf\u03c3\u03b7 10 \u039d\u039c);"},"2":{"Display":"\u03a4\u03b9 <strong>\u03c0\u03bf\u03c3\u03bf\u03c3\u03c4\u03cc<\/strong> \u03c4\u03c9\u03bd \u03c3\u03c5\u03bc\u03bc\u03b5\u03c4\u03b5\u03c7\u03cc\u03bd\u03c4\u03c9\u03bd \u03b4\u03ae\u03bb\u03c9\u03c3\u03b5 \u03bf\u03c4\u03b9 \u03c4\u03bf\u03c5 \u03ad\u03c4\u03c5\u03c7\u03b5 \u03bf \u03b1\u03c1\u03b9\u03b8\u03bc\u03cc\u03c2 2 (\u03bc\u03b5 \u03b1\u03c0\u03cc\u03b4\u03bf\u03c3\u03b7 20 \u039d\u039c);"},"3":{"Display":"\u03a4\u03b9 <strong>\u03c0\u03bf\u03c3\u03bf\u03c3\u03c4\u03cc<\/strong> \u03c4\u03c9\u03bd \u03c3\u03c5\u03bc\u03bc\u03b5\u03c4\u03b5\u03c7\u03cc\u03bd\u03c4\u03c9\u03bd \u03b4\u03ae\u03bb\u03c9\u03c3\u03b5 \u03bf\u03c4\u03b9 \u03c4\u03bf\u03c5 \u03ad\u03c4\u03c5\u03c7\u03b5 \u03bf \u03b1\u03c1\u03b9\u03b8\u03bc\u03cc\u03c2 3\u00a0 (\u03bc\u03b5 \u03b1\u03c0\u03cc\u03b4\u03bf\u03c3\u03b7 30 \u039d\u039c);"},"4":{"Display":"\u03a4\u03b9 <strong>\u03c0\u03bf\u03c3\u03bf\u03c3\u03c4\u03cc<\/strong> \u03c4\u03c9\u03bd \u03c3\u03c5\u03bc\u03bc\u03b5\u03c4\u03b5\u03c7\u03cc\u03bd\u03c4\u03c9\u03bd \u03b4\u03ae\u03bb\u03c9\u03c3\u03b5 \u03bf\u03c4\u03b9 \u03c4\u03bf\u03c5 \u03ad\u03c4\u03c5\u03c7\u03b5 \u03bf \u03b1\u03c1\u03b9\u03b8\u03bc\u03cc\u03c2 4 (\u03bc\u03b5 \u03b1\u03c0\u03cc\u03b4\u03bf\u03c3\u03b7 40 \u039d\u039c);"},"5":{"Display":"\u03a4\u03b9 <strong>\u03c0\u03bf\u03c3\u03bf\u03c3\u03c4\u03cc<\/strong> \u03c4\u03c9\u03bd \u03c3\u03c5\u03bc\u03bc\u03b5\u03c4\u03b5\u03c7\u03cc\u03bd\u03c4\u03c9\u03bd \u03b4\u03ae\u03bb\u03c9\u03c3\u03b5 \u03bf\u03c4\u03b9 \u03c4\u03bf\u03c5 \u03ad\u03c4\u03c5\u03c7\u03b5 \u03bf \u03b1\u03c1\u03b9\u03b8\u03bc\u03cc\u03c2 5 (\u03bc\u03b5 \u03b1\u03c0\u03cc\u03b4\u03bf\u03c3\u03b7 50 \u039d\u039c);"},"6":{"Display":"\u03a4\u03b9 <strong>\u03c0\u03bf\u03c3\u03bf\u03c3\u03c4\u03cc<\/strong> \u03c4\u03c9\u03bd \u03c3\u03c5\u03bc\u03bc\u03b5\u03c4\u03b5\u03c7\u03cc\u03bd\u03c4\u03c9\u03bd \u03b4\u03ae\u03bb\u03c9\u03c3\u03b5 \u03bf\u03c4\u03b9 \u03c4\u03bf\u03c5 \u03ad\u03c4\u03c5\u03c7\u03b5 \u03bf \u03b1\u03c1\u03b9\u03b8\u03bc\u03cc\u03c2 6 (\u03bc\u03b5 \u03b1\u03c0\u03cc\u03b4\u03bf\u03c3\u03b7 0 \u039d\u039c);"}}},"ES":{"QuestionText":"<div style=\"text-align: center;\">Antes de comenzar la Parte 2, ingrese su <strong>estimaci\u00f3n <\/strong>(es decir, adivine) sobre cu\u00e1ntas personas en la sesi\u00f3n (sala) han reportado cada n\u00famero.<br \/>\n<br \/>\nSi su estimaci\u00f3n es correcta, va a ganar <strong>50 UMs<\/strong>. Por cada punto porcentual que se desv\u00ede del porcentaje correcto, su pago se reducir\u00e1 en 0,4 UM. Independientemente de su estimaci\u00f3n, recibir\u00e1 un m\u00ednimo de 5 UM. Por favor, tenga en cuenta que los <strong>porcentajes <\/strong>deben sumar 100 por ciento.<\/div>\n","Choices":{"1":{"Display":"\u00bfQu\u00e9 <strong>porcentaje <\/strong>de participantes report\u00f3 el n\u00famero 1 (recibe un pago de 10 UM)?"},"2":{"Display":"\u00bfQu\u00e9 <strong>porcentaje <\/strong>de participantes report\u00f3 el n\u00famero 2 (recibe un pago de 20 UM)?"},"3":{"Display":"\u00bfQu\u00e9 <strong>porcentaje<\/strong> de participantes report\u00f3 el n\u00famero 3 (recibe un pago de 30 UM)?"},"4":{"Display":"\u00bfQu\u00e9 <strong>porcentaje <\/strong>de participantes report\u00f3 el n\u00famero 4 (recibe un pago de 40 UM)?"},"5":{"Display":"\u00bfQu\u00e9 <strong>porcentaje <\/strong>de participantes report\u00f3 el n\u00famero 5 (recibe un pago de 50 UM)?"},"6":{"Display":"\u00bfQu\u00e9 <strong>porcentaje <\/strong>de participantes report\u00f3 el n\u00famero 6 (recibe un pago de 0 UM)?"}}},"FR":{"QuestionText":"<div style=\"text-align: center;\">\u00a0\n<div style=\"text-align: center;\"><span style=\"line-height:130%\"><span style=\"font-family:Arial\"><span lang=\"FR\" style=\"color:#525252\">Avant de commencer la partie 2, veuillez saisir votre <b>estimation <\/b>sur les num\u00e9ros de d\u00e9s obtenus par le reste des participants \u00e0 cette session (salle).\u00a0<\/span><\/span><\/span>Si, par exemple, il y avait 100 participants jouant au m\u00eame jeu que vous, combien (c'est-\u00e0-dire, quel pourcentage) pensez-vous ont choisi le num\u00e9ro 1, combien ont choisi le num\u00e9ro 2, etc. ?<br \/>\n<br \/>\n<span style=\"line-height:130%\"><span style=\"font-family:Arial\"><span lang=\"FR\" style=\"color:#525252\">Si votre r\u00e9ponse est correcte, vous gagnez <b>50 UM<\/b>. Pour chaque point de pourcentage d\u2019\u00e9cart par rapport au pourcentage correct, votre gain sera r\u00e9duit de 0,4 MU.\u00a0<\/span><\/span><\/span>Vous recevrez un minimum de 5 UM. <span lang=\"FR\"><span style=\"font-family:Arial\"><span style=\"color:#525252\">Notez que les <b>pourcentages <\/b>doivent totaliser 100 pour cent.<\/span><\/span><\/span><\/div>\n<\/div>\n\n<div style=\"text-align: center;\"><span style=\"line-height:130%\"><span style=\"font-family:Arial\"><span lang=\"FR\" style=\"color:#525252\">(Veuillez saisir uniquement des nombres entiers, pas de d\u00e9cimaux) (veuillez saisir des chiffres <b>sans <\/b>le symbole \"%\")<\/span><\/span><\/span><\/div>\n","Choices":{"1":{"Display":"Quel <strong>pourcentage<\/strong> de participants ont obtenu le num\u00e9ro 1 selon vous\u00a0 (un gain de 10 UM)\u00a0?"},"2":{"Display":"Quel <strong>pourcentage<\/strong> de participants ont obtenu le num\u00e9ro 2 selon vous (un gain de 20 UM)\u00a0?"},"3":{"Display":"Quel <strong>pourcentage<\/strong> de participants ont obtenu le num\u00e9ro 3 selon vous (un gain de 30 UM)\u00a0?"},"4":{"Display":"Quel <strong>pourcentage<\/strong> de participants ont obtenu le num\u00e9ro 4 selon vous (un gain de 40 UM)\u00a0?"},"5":{"Display":"Quel <strong>pourcentage<\/strong> de participants ont obtenu le num\u00e9ro 5 selon vous (un gain de 50 UM)\u00a0?"},"6":{"Display":"Quel <strong>pourcentage<\/strong> de participants ont obtenu le num\u00e9ro 6 selon vous (un gain de 0 UM)\u00a0?"}}},"RU":{"QuestionText":"<div style=\"text-align: center;\">\u041f\u0440\u0435\u0436\u0434\u0435 \u0447\u0435\u043c \u043c\u044b \u043d\u0430\u0447\u043d\u0435\u043c \u0447\u0430\u0441\u0442\u044c 2, \u043f\u043e\u0436\u0430\u043b\u0443\u0439\u0441\u0442\u0430, \u0432\u0432\u0435\u0434\u0438\u0442\u0435 \u0441\u0432\u043e\u044e <b>\u043e\u0446\u0435\u043d\u043a\u0443<\/b> (\u0442. \u0435. \u0412\u0430\u0448\u0435 \u043f\u0440\u0435\u0434\u043f\u043e\u043b\u043e\u0436\u0435\u043d\u0438\u0435) \u043e\u0442\u043d\u043e\u0441\u0438\u0442\u0435\u043b\u044c\u043d\u043e \u0442\u043e\u0433\u043e \u0447\u0438\u0441\u043b\u0430 \u043e\u0447\u043a\u043e\u0432, \u043a\u043e\u0442\u043e\u0440\u043e\u0435 \u0441\u043e\u043e\u0431\u0449\u0430\u0442 \u0434\u0440\u0443\u0433\u0438\u0435 \u0443\u0447\u0430\u0441\u0442\u043d\u0438\u043a\u0438:<\/div>\n\n<div style=\"text-align: center;\">\u041a\u0430\u043a \u0412\u044b \u0434\u0443\u043c\u0430\u0435\u0442\u0435, \u0438\u0437 100 \u0443\u0447\u0430\u0441\u0442\u043d\u0438\u043a\u043e\u0432, \u043a\u043e\u0442\u043e\u0440\u044b\u0435 \u0441\u044b\u0433\u0440\u0430\u043b\u0438 \u0432 \u0442\u0443 \u0436\u0435 \u0438\u0433\u0440\u0443, \u0447\u0442\u043e \u0438 \u0412\u044b, \u0441\u043a\u043e\u043b\u044c\u043a\u043e (\u0442. \u0435. \u043a\u0430\u043a\u043e\u0439 \u043f\u0440\u043e\u0446\u0435\u043d\u0442) \u0441\u043e\u043e\u0431\u0449\u0438\u0442 \u0447\u0442\u043e \u0443 \u043d\u0438\u0445 \u0432\u044b\u043f\u0430\u043b\u043e \u0447\u0438\u0441\u043b\u043e 1, \u0441\u043a\u043e\u043b\u044c\u043a\u043e \u0441\u043e\u043e\u0431\u0449\u0438\u0442 \u0447\u0442\u043e \u0432\u044b\u043f\u0430\u043b\u043e \u0447\u0438\u0441\u043b\u043e 2 \u0438 \u0442. \u0434.?<\/div>\n\n<div style=\"text-align: center;\"><br \/>\n\u0415\u0441\u043b\u0438 \u0412\u0430\u0448\u0430 \u0434\u043e\u0433\u0430\u0434\u043a\u0430 \u0432\u0435\u0440\u043d\u0430, \u0412\u044b \u0437\u0430\u0440\u0430\u0431\u043e\u0442\u0430\u0435\u0442\u0435 <b>50 \u0414\u0415<\/b>. \u0417\u0430 \u043a\u0430\u0436\u0434\u044b\u0439 \u043f\u0440\u043e\u0446\u0435\u043d\u0442 \u043e\u0442\u043a\u043b\u043e\u043d\u0435\u043d\u0438\u044f \u043e\u0442 \u043f\u0440\u0430\u0432\u0438\u043b\u044c\u043d\u043e\u0433\u043e \u043e\u0442\u0432\u0435\u0442\u0430 \u0412\u0430\u0448 \u0432\u044b\u0438\u0433\u0440\u044b\u0448 \u0431\u0443\u0434\u0435\u0442 \u0443\u043c\u0435\u043d\u044c\u0448\u0435\u043d \u043d\u0430 0,4 \u0414\u0415, \u043d\u043e \u043e\u043d \u0441\u043e\u0441\u0442\u0430\u0432\u0438\u0442 \u043d\u0435 \u043c\u0435\u043d\u0435\u0435 5 \u0414\u0415. \u041e\u0431\u0440\u0430\u0442\u0438\u0442\u0435 \u0432\u043d\u0438\u043c\u0430\u043d\u0438\u0435, \u0447\u0442\u043e \u0441\u0443\u043c\u043c\u0430 <b>\u043f\u0440\u043e\u0446\u0435\u043d\u0442\u043e\u0432<\/b> \u0434\u043e\u043b\u0436\u043d\u0430 \u0441\u043e\u0441\u0442\u0430\u0432\u043b\u044f\u0442\u044c 100 \u043f\u0440\u043e\u0446\u0435\u043d\u0442\u043e\u0432.<\/div>\n\n<div style=\"text-align: center;\">(\u043f\u043e\u0436\u0430\u043b\u0443\u0439\u0441\u0442\u0430, \u0432\u0432\u043e\u0434\u0438\u0442\u0435 \u0442\u043e\u043b\u044c\u043a\u043e \u0446\u0435\u043b\u044b\u0435 \u0447\u0438\u0441\u043b\u0430, \u0431\u0435\u0437 \u0434\u0435\u0441\u044f\u0442\u0438\u0447\u043d\u044b\u0445 \u0437\u043d\u0430\u043a\u043e\u0432)<\/div>\n\n<div style=\"text-align: center;\">(\u043f\u043e\u0436\u0430\u043b\u0443\u0439\u0441\u0442\u0430, \u0432\u0432\u043e\u0434\u0438\u0442\u0435 \u0442\u043e\u043b\u044c\u043a\u043e \u0447\u0438\u0441\u043b\u0430, <b>\u0431\u0435\u0437<\/b> \u0441\u0438\u043c\u0432\u043e\u043b\u0430 \u00ab%\u00bb)<\/div>\n","Choices":{"1":{"Display":"\u041a\u0430\u043a\u043e\u0439 <strong>\u043f\u0440\u043e\u0446\u0435\u043d\u0442<\/strong> \u0443\u0447\u0430\u0441\u0442\u043d\u0438\u043a\u043e\u0432 \u0441\u043e\u043e\u0431\u0449\u0438\u043b \u0447\u0442\u043e \u0432\u044b\u043f\u0430\u043b\u043e \u0447\u0438\u0441\u043b\u043e 1 (\u0432\u044b\u0438\u0433\u0440\u044b\u0448 10 \u0414E)?"},"2":{"Display":"\u041a\u0430\u043a\u043e\u0439 <strong>\u043f\u0440\u043e\u0446\u0435\u043d\u0442<\/strong> \u0443\u0447\u0430\u0441\u0442\u043d\u0438\u043a\u043e\u0432 \u0441\u043e\u043e\u0431\u0449\u0438\u043b \u0447\u0442\u043e \u0432\u044b\u043f\u0430\u043b\u043e \u0447\u0438\u0441\u043b\u043e 2 (\u0432\u044b\u0438\u0433\u0440\u044b\u0448 20 \u0414E)?"},"3":{"Display":"\u041a\u0430\u043a\u043e\u0439 <strong>\u043f\u0440\u043e\u0446\u0435\u043d\u0442<\/strong> \u0443\u0447\u0430\u0441\u0442\u043d\u0438\u043a\u043e\u0432 \u0441\u043e\u043e\u0431\u0449\u0438\u043b \u0447\u0442\u043e \u0432\u044b\u043f\u0430\u043b\u043e \u0447\u0438\u0441\u043b\u043e 3 (\u0432\u044b\u0438\u0433\u0440\u044b\u0448 30 \u0414E)?"},"4":{"Display":"\u041a\u0430\u043a\u043e\u0439 <strong>\u043f\u0440\u043e\u0446\u0435\u043d\u0442<\/strong> \u0443\u0447\u0430\u0441\u0442\u043d\u0438\u043a\u043e\u0432 \u0441\u043e\u043e\u0431\u0449\u0438\u043b \u0447\u0442\u043e \u0432\u044b\u043f\u0430\u043b\u043e \u0447\u0438\u0441\u043b\u043e 4 (\u0432\u044b\u0438\u0433\u0440\u044b\u0448 40 \u0414E)?"},"5":{"Display":"\u041a\u0430\u043a\u043e\u0439 <strong>\u043f\u0440\u043e\u0446\u0435\u043d\u0442<\/strong> \u0443\u0447\u0430\u0441\u0442\u043d\u0438\u043a\u043e\u0432 \u0441\u043e\u043e\u0431\u0449\u0438\u043b \u0447\u0442\u043e \u0432\u044b\u043f\u0430\u043b\u043e \u0447\u0438\u0441\u043b\u043e 5 (\u0432\u044b\u0438\u0433\u0440\u044b\u0448 50 \u0414E)?"},"6":{"Display":"\u041a\u0430\u043a\u043e\u0439 <strong>\u043f\u0440\u043e\u0446\u0435\u043d\u0442<\/strong> \u0443\u0447\u0430\u0441\u0442\u043d\u0438\u043a\u043e\u0432 \u0441\u043e\u043e\u0431\u0449\u0438\u043b \u0447\u0442\u043e \u0432\u044b\u043f\u0430\u043b\u043e \u0447\u0438\u0441\u043b\u043e 6 (\u0432\u044b\u0438\u0433\u0440\u044b\u0448 0 \u0414E)?"}}},"HU":{"QuestionText":"<div style=\"text-align: center;\">Miel\u0151tt elkezden\u00e9 a 2. r\u00e9szt, k\u00e9rj\u00fck, adjon\u00a0<b>becsl\u00e9st<\/b> (vagyis tippet) arr\u00f3l, hogy a t\u00f6bbi r\u00e9sztvev\u0151 milyen dobott sz\u00e1mot adott meg.<\/div>\n\n<div style=\"text-align: center;\">P\u00e9ld\u00e1ul, ha 100 r\u00e9sztvev\u0151 j\u00e1tszan\u00e1 ugyanazt a j\u00e1t\u00e9kot, amit \u00d6n is, \u00d6n szerint h\u00e1nyan (azaz h\u00e1ny sz\u00e1zal\u00e9kban) adt\u00e1k meg v\u00e1laszk\u00e9nt az 1-es, 2-es, stb. sz\u00e1mot?<\/div>\n\n<div style=\"text-align: center;\"><br \/>\nHa a becsl\u00e9se helyes, akkor\u00a0<b>50 PE-t<\/b> keres. A helyes v\u00e1laszt\u00f3l val\u00f3 minden sz\u00e1zal\u00e9kpontnyi elt\u00e9r\u00e9s 0,4 PE-vel cs\u00f6kkenti a kifizet\u00e9st. Legrosszabb esetben is kap 5 PE-t. Vegye figyelembe, hogy a megadott\u00a0<b>sz\u00e1zal\u00e9kos \u00e9rt\u00e9kek<\/b>\u00a0\u00f6sszeg\u00e9nek 100 sz\u00e1zal\u00e9knak kell lennie.<\/div>\n\n<div style=\"text-align: center;\">(K\u00e9rj\u00fck, hogy csak eg\u00e9sz sz\u00e1mokat adjon meg, tizedespontokat ne!)<\/div>\n\n<div style=\"text-align: center;\">(K\u00e9rj\u00fck, hogy sz\u00e1mokat adjon meg a \"%\" szimb\u00f3lum <b>n\u00e9lk\u00fcl!<\/b>)<\/div>\n","Choices":{"1":{"Display":"A r\u00e9sztvev\u0151k h\u00e1ny <strong>sz\u00e1zal\u00e9ka<\/strong> adta meg az 1-es sz\u00e1mot (ami 10 PE nyerem\u00e9nyt jelent)?"},"2":{"Display":"A r\u00e9sztvev\u0151k h\u00e1ny <strong>sz\u00e1zal\u00e9ka<\/strong> adta meg a 2-es sz\u00e1mot (ami 20 PE nyerem\u00e9nyt jelent)?"},"3":{"Display":"A r\u00e9sztvev\u0151k h\u00e1ny <strong>sz\u00e1zal\u00e9ka<\/strong> adta meg a 3-as sz\u00e1mot (ami 30 PE nyerem\u00e9nyt jelent)?"},"4":{"Display":"A r\u00e9sztvev\u0151k h\u00e1ny <strong>sz\u00e1zal\u00e9ka<\/strong> adta meg a 4-es sz\u00e1mot (ami 40 PE nyerem\u00e9nyt jelent)?"},"5":{"Display":"A r\u00e9sztvev\u0151k h\u00e1ny <strong>sz\u00e1zal\u00e9ka<\/strong> adta meg az 5-\u00f6s sz\u00e1mot (ami 50 PE nyerem\u00e9nyt jelent)?"},"6":{"Display":"A r\u00e9sztvev\u0151k h\u00e1ny <strong>sz\u00e1zal\u00e9ka<\/strong> adta meg a 6-os sz\u00e1mot (ami 0 PE nyerem\u00e9nyt jelent)?"}}},"IT":{"QuestionText":"<div style=\"text-align: center;\">Prima di iniziare la Parte 2, inserisci la tua <b>stima<\/b> (cio\u00e8 la tua ipotesi) sui numeri dei dadi riportati dagli altri partecipanti.<\/div>\n\n<div style=\"text-align: center;\">Quindi, se ci fossero 100 partecipanti che giocano lo stesso gioco, quanti (cio\u00e8, quale percentuale) pensi che abbiano riportato il numero 1, quanti il numero 2, ecc.?.<\/div>\n\n<div style=\"text-align: center;\"><br \/>\nSe la tua ipotesi \u00e8 corretta, guadagni <b>50 MU<\/b> . Per ogni punto percentuale di deviazione dalla percentuale corretta, il tuo guadagno sar\u00e0 ridotto di 0,4 MU. Riceverai un minimo di 5 MU. Tieni presente che la <b>somma delle percentuali<\/b> deve corrispondere al 100%.<\/div>\n\n<div style=\"text-align: center;\">(inserisci solo numeri interi, senza punti decimali)<\/div>\n\n<div style=\"text-align: center;\">(inserisci i numeri <b>senza<\/b> il simbolo \"%\")<\/div>\n","Choices":{"1":{"Display":"Quale <strong>percentuale<\/strong> di partecipanti ha riportato il numero 1 (un guadagno di 10 MU)?"},"2":{"Display":"Quale <strong>percentuale<\/strong> di partecipanti ha riportato il numero 2 (un guadagno di 20 MU)?"},"3":{"Display":"Quale <strong>percentuale<\/strong> di partecipanti ha riportato il numero 3 (un guadagno di 30 MU)?"},"4":{"Display":"Quale <strong>percentuale<\/strong> di partecipanti ha riportato il numero 4 (un guadagno di 40 MU)?"},"5":{"Display":"Quale <strong>percentuale<\/strong> di partecipanti ha riportato il numero 5 (un guadagno di 50 MU)?"},"6":{"Display":"Quale <strong>percentuale<\/strong> di partecipanti ha riportato il numero 6 (un gudagno di 0 MU)?"}}},"PL":{"QuestionText":"<div style=\"text-align: center;\">Zanim zaczniemy cz\u0119\u015b\u0107 2, wprowad\u017a swoje <b>szacunki<\/b> (tj. przypuszczenia) dotycz\u0105ce zg\u0142oszonych liczb na kostkach pozosta\u0142ych uczestnik\u00f3w.<\/div>\n\n<div style=\"text-align: center;\">Zatem, je\u015bli 100 uczestnik\u00f3w gra\u0142oby w t\u0119 sam\u0105 gr\u0119 co Ty, jak my\u015blisz, ilu (tj. jaki procent) zg\u0142osi\u0142o liczb\u0119 1, jaki \u2013 liczb\u0119 2 itd.?<\/div>\n\n<div style=\"text-align: center;\"><br \/>\nJe\u015bli Twoje przypuszczenia s\u0105 prawid\u0142owe, zarabiasz <b>50 MU<\/b> . Za ka\u017cdy punkt procentowy, kt\u00f3ry odbiegasz od prawid\u0142owego procentu, Twoja wyp\u0142ata zostanie zmniejszona o 0,4 MU. Otrzymasz minimum 5 jednostek MU. Nale\u017cy pami\u0119ta\u0107, \u017ce <b>warto\u015bci procentowe<\/b> musz\u0105 sumowa\u0107 si\u0119 do 100 procent.<\/div>\n\n<div style=\"text-align: center;\">(prosz\u0119 wpisa\u0107 tylko liczby ca\u0142kowite, bez kropek dziesi\u0119tnych)<\/div>\n\n<div style=\"text-align: center;\">(prosz\u0119 wpisa\u0107 liczby <b>bez<\/b> symbolu \u201e%\u201d)<\/div>\n","Choices":{"1":{"Display":"Jaki <strong>procent<\/strong> uczestnik\u00f3w zg\u0142osi\u0142 liczb\u0119 1 (wyp\u0142ata 10 MU)?"},"2":{"Display":"Jaki <strong>procent<\/strong> uczestnik\u00f3w zg\u0142osi\u0142 liczb\u0119 2 (wyp\u0142ata 20 MU)?"},"3":{"Display":"Jaki <strong>procent<\/strong> uczestnik\u00f3w zg\u0142osi\u0142 liczb\u0119 3 (wyp\u0142ata 30 MU)?"},"4":{"Display":"Jaki <strong>procent<\/strong> uczestnik\u00f3w zg\u0142osi\u0142 liczb\u0119 4 (wyp\u0142ata 40 MU)?"},"5":{"Display":"Jaki <strong>procent<\/strong> uczestnik\u00f3w zg\u0142osi\u0142 liczb\u0119 5 (wyp\u0142ata 50 MU)?"},"6":{"Display":"Jaki <strong>procent<\/strong> uczestnik\u00f3w zg\u0142osi\u0142 liczb\u0119 6 (wyp\u0142ata 0 MU)?"}}},"PT":{"QuestionText":"<div>Antes de iniciarmos a Parte 2, introduza a sua <strong>estimativa<\/strong> (ou seja, o seu palpite) sobre os n\u00fameros dos dados reportados pelos outros participantes.<br \/>\nSe houvesse 100 participantes a jogar o mesmo jogo, quantos (que percentagem) pensa que reportaram o n\u00famero 1, quantos reportaram o n\u00famero 2, etc.?<br \/>\n<br \/>\nSe o seu palpite estiver correto, ganha 50 UMs. Por cada ponto percentual que se desviar da percentagem correta, o seu pagamento ser\u00e1 reduzido em 0,4 UMs. Receber\u00e1 no m\u00ednimo 5 UMs. Note que as percentagens devem somar 100 por cento.<br \/>\n<br \/>\n(inserir apenas n\u00fameros inteiros, sem casas decimais)<br \/>\n(inserir n\u00fameros sem o s\u00edmbolo \"%\")<\/div>\n","Choices":{"1":{"Display":"Que <strong>percentagem<\/strong> de participantes reportou o n\u00famero 1 (pagamento de 10 UMs)?"},"2":{"Display":"Que <strong>percentagem<\/strong> de participantes reportou o n\u00famero 2 (pagamento de 20 UMs)?"},"3":{"Display":"Que <strong>percentagem<\/strong> de participantes reportou o n\u00famero 3 (pagamento de 30 UMs)?"},"4":{"Display":"Que <strong>percentagem<\/strong> de participantes reportou o n\u00famero 4 (pagamento de 40 UMs)?"},"5":{"Display":"Que <strong>percentagem<\/strong> de participantes reportou o n\u00famero 5 (pagamento de 50 UMs)?"},"6":{"Display":"Que <strong>percentagem<\/strong> de participantes reportou o n\u00famero 6 (pagamento de 0 UMs)?"}}},"ZH-S":{"QuestionText":"<div style=\"text-align: center;\">\u5728\u5f00\u59cb\u7b2c 2 \u90e8\u5206\u4e4b\u524d\uff0c\u8bf7\u8f93\u5165\u60a8\u5bf9\u5176\u4ed6\u53c2\u4e0e\u8005\u63b7\u51fa\u7684\u9ab0\u5b50\u6570\u5b57\u7684<b>\u4f30\u8ba1<\/b>\uff08\u5373\u60a8\u7684\u731c\u6d4b\uff09\u3002<\/div>\n\n<div style=\"text-align: center;\">\u90a3\u4e48\uff0c\u5982\u679c\u6709 100 \u540d\u53c2\u4e0e\u8005\u548c\u60a8\u73a9\u540c\u4e00\u4e2a\u6e38\u620f\uff0c\u60a8\u8ba4\u4e3a\u6709\u591a\u5c11\u4eba\uff08\u5373\u767e\u5206\u6bd4\u662f\u591a\u5c11\uff09\u62a5\u544a\u4e86\u6570\u5b57 1\uff0c\u6709\u591a\u5c11\u4eba\u62a5\u544a\u4e86\u6570\u5b57 2\uff0c\u7b49\u7b49\uff1f<\/div>\n\n<div style=\"text-align: center;\"><br \/>\n\u5982\u679c\u60a8\u7684\u731c\u6d4b\u6b63\u786e\uff0c\u60a8\u5c06\u83b7\u5f97 <b>50 MU<\/b>\u3002\u6bcf\u504f\u79bb\u6b63\u786e\u767e\u5206\u6bd4\u4e00\u4e2a\u767e\u5206\u70b9\uff0c\u60a8\u7684\u6536\u76ca\u5c06\u51cf\u5c11 0.4 MU\u3002\u60a8\u5c06\u81f3\u5c11\u83b7\u5f97 5 MU\u3002\u8bf7\u6ce8\u610f\uff0c<b>\u767e\u5206\u6bd4<\/b>\u5fc5\u987b\u52a0\u8d77\u6765\u4e3a 100%\u3002<\/div>\n\n<div style=\"text-align: center;\">\uff08\u8bf7\u4ec5\u8f93\u5165\u6574\u6570\uff0c\u4e0d\u8981\u8f93\u5165\u5c0f\u6570\u70b9\uff09<\/div>\n\n<div style=\"text-align: center;\">\uff08\u8bf7\u8f93\u5165<b>\u4e0d\u5e26<\/b>\u201c%\u201d\u7b26\u53f7\u7684\u6570\u5b57\uff09<\/div>\n","Choices":{"1":{"Display":"\u6709\u591a\u5c11<strong>\u767e\u5206\u6bd4<\/strong>\u7684\u53c2\u4e0e\u8005\u62a5\u544a\u4e86\u6570\u5b57 1\uff08\u6536\u76ca\u4e3a 10 MU\uff09\uff1f"},"2":{"Display":"\u6709\u591a\u5c11<strong>\u767e\u5206\u6bd4<\/strong>\u7684\u53c2\u4e0e\u8005\u62a5\u544a\u4e86\u6570\u5b57 2\uff08\u6536\u76ca\u4e3a 20 MU\uff09\uff1f"},"3":{"Display":"\u6709\u591a\u5c11<strong>\u767e\u5206\u6bd4<\/strong>\u7684\u53c2\u4e0e\u8005\u62a5\u544a\u4e86\u6570\u5b57 3\uff08\u6536\u76ca\u4e3a 30 MU\uff09\uff1f"},"4":{"Display":"\u6709\u591a\u5c11<strong>\u767e\u5206\u6bd4<\/strong>\u7684\u53c2\u4e0e\u8005\u62a5\u544a\u4e86\u6570\u5b57 4\uff08\u6536\u76ca\u4e3a 40 MU\uff09\uff1f"},"5":{"Display":"\u6709\u591a\u5c11<strong>\u767e\u5206\u6bd4<\/strong>\u7684\u53c2\u4e0e\u8005\u62a5\u544a\u4e86\u6570\u5b57 5\uff08\u6536\u76ca\u4e3a 50 MU\uff09\uff1f"},"6":{"Display":"\u6709\u591a\u5c11<strong>\u767e\u5206\u6bd4<\/strong>\u7684\u53c2\u4e0e\u8005\u62a5\u544a\u4e86\u6570\u5b57 6\uff08\u6536\u76ca\u4e3a 0 MU\uff09\uff1f"}}},"FR-FR":{"QuestionText":"<div style=\"text-align: center;\">Avant de commencer la partie 2, vous allez pouvoir essayer de <strong>deviner <\/strong>les chiffres qui ont \u00e9t\u00e9 <strong>entr\u00e9s<\/strong> par les autres participants.<\/div>\n\n<div style=\"text-align: center;\">S'il y avait 100 participants qui jouaient \u00e0 ce jeu, combien selon vous d\u00e9clareraient le chiffre 1 (c'est-\u00e0-dire quel <strong>pourcentage<\/strong>), combien d\u00e9clareraient le chiffre 2, etc.?.<\/div>\n\n<div style=\"text-align: center;\"><br \/>\nSi votre pr\u00e9diction est parfaitement juste, vous gagnerez <b>50 UM<\/b> suppl\u00e9mentaires. Pour chaque erreur de 1%, ce gain diminuera de 0,4 UM. Vous recevrez toujours un minimum de 5 UM. Notez que la somme de tous les <strong>pourcentages<\/strong><b> <\/b>doit valoir 100.<\/div>\n\n<div style=\"text-align: center;\">(Vous pouvez saisir uniquement des nombres entiers, pas de chiffre apr\u00e8s la virgule)<\/div>\n\n<div style=\"text-align: center;\">(Merci de saisir des nombres <b>sans <\/b>le symbole \"%\")<\/div>\n","Choices":{"1":{"Display":"Quel <strong>pourcentage <\/strong>de participants ont entr\u00e9 le chiffre 1 (gain de 10\u00a0UM)\u00a0?"},"2":{"Display":"Quel <strong>pourcentage <\/strong>de participants ont entr\u00e9 le chiffre 2 (gain de 20\u00a0UM)\u00a0?"},"3":{"Display":"Quel <strong>pourcentage <\/strong>de participants ont entr\u00e9 le chiffre 3 (gain de 30\u00a0UM)\u00a0?"},"4":{"Display":"Quel <strong>pourcentage <\/strong>de participants ont entr\u00e9 le chiffre 4 (gain de 40\u00a0UM)\u00a0?"},"5":{"Display":"Quel <strong>pourcentage <\/strong>de participants ont entr\u00e9 le chiffre 5 (gain de 50\u00a0UM)\u00a0?"},"6":{"Display":"Quel <strong>pourcentage <\/strong>de participants ont entr\u00e9 le chiffre 6 (gain de 0\u00a0UM)\u00a0?"}}},"ES-ES":{"QuestionText":"<div style=\"text-align: center;\">Antes de comenzar la Parte 2, ingrese su <b>estimaci\u00f3n <\/b>(es decir, su conjetura) sobre los n\u00fameros reportados de los dados de los otros participantes.<br ><\/div><div style=\"text-align: center;\">Entonces, si hubiera 100 participantes jugando el mismo juego que t\u00fa, \u00bfcu\u00e1ntos (es decir, qu\u00e9 porcentaje) crees que informaron el n\u00famero 1, cu\u00e1ntos inform\u00f3 el n\u00famero 2, etc.?.<\/div>\n\n<div style=\"text-align: center;\"><br>\nSi tu suposici\u00f3n es correcta, ganar\u00e1s <b>50 MU<\/b>. Por cada punto porcentual que se desv\u00ede del porcentaje correcto, su pago se reducir\u00e1 en 0,4 MU. Recibir\u00e1s un m\u00ednimo de 5 MU. Tenga en cuenta que los <b>porcentajes <\/b>tienen que sumar 100 por ciento.<\/div><div style=\"text-align: center;\">(ingrese solo n\u00fameros enteros, sin puntos decimales)<\/div ><div style=\"text-align: center;\">(ingrese n\u00fameros<b>sin <\/b>el s\u00edmbolo \"%\")<\/div>","Choices":{"1":{"Display":"\u00bfQu\u00e9 <strong>porcentaje<\/strong> de participantes reportaron un n\u00famero 1 (una recompensa de 10 UM)?"},"2":{"Display":"\u00bfQu\u00e9 <strong>porcentaje<\/strong> de participantes reportaron un n\u00famero 2 (una recompensa de 20 UM)?"},"3":{"Display":"\u00bfQu\u00e9 <strong>porcentaje<\/strong> de participantes reportaron un n\u00famero 3 (una recompensa de 30 UM)?"},"4":{"Display":"\u00bfQu\u00e9 <strong>porcentaje<\/strong> de participantes reportaron un n\u00famero 4 (una recompensa de 40 UM)?"},"5":{"Display":"\u00bfQu\u00e9 <strong>porcentaje<\/strong> de participantes reportaron un n\u00famero 5 (una recompensa de 50 UM)?"},"6":{"Display":"\u00bfQu\u00e9 <strong>porcentaje<\/strong> de participantes reportaron un n\u00famero 6 (un resultado de 0 UM)?"}}},"ES-AR":{"QuestionText":"<div style=\"text-align: center;\">Antes de comenzar la Parte 2, ingrese su <b>estimaci\u00f3n <\/b>(es decir, su conjetura) sobre los n\u00fameros de los dados que otros participantes han reportado.<br \/>\n<br \/>\nSi hubiera 100 participantes jugando el mismo juego que usted, \u00bfcu\u00e1ntos (es decir, qu\u00e9 porcentaje) cree que informaron el n\u00famero 1, cu\u00e1ntos informaron el n\u00famero 2, etc.?.<br \/>\n<br \/>\nSi su suposici\u00f3n es correcta, ganar\u00e1\u00a0<b>50 UM<\/b>. Por cada punto porcentual que se desv\u00ede del porcentaje correcto, su pago se reducir\u00e1 en 0,4 UM. Recibir\u00e1 un m\u00ednimo de 5 UM. Tenga en cuenta que los <b>porcentajes <\/b>tienen que sumar 100 por ciento.<br \/>\n<br \/>\n(ingrese solo n\u00fameros enteros, sin puntos decimales)<br \/>\n(ingrese n\u00fameros\u00a0<b>sin <\/b>el s\u00edmbolo \"%\")<\/div>\n","Choices":{"1":{"Display":"\u00bfQu\u00e9 <strong>porcentaje<\/strong> de participantes reportaron haber obtenido un 1 en la tirada del dado (una recompensa de 10 UM)?"},"2":{"Display":"\u00bfQu\u00e9 <strong>porcentaje<\/strong> de participantes reportaron haber obtenido un 2 en la tirada del dado (una recompensa de 20 UM)?"},"3":{"Display":"\u00bfQu\u00e9 <strong>porcentaje<\/strong> de participantes reportaron haber obtenido un 3 en la tirada del dado (una recompensa de 30 UM)?"},"4":{"Display":"\u00bfQu\u00e9 <strong>porcentaje<\/strong> de participantes reportaron haber obtenido un 4 en la tirada del dado (una recompensa de 40 UM)?"},"5":{"Display":"\u00bfQu\u00e9 <strong>porcentaje<\/strong> de participantes reportaron haber obtenido un 5 en la tirada del dado (una recompensa de 50 UM)?"},"6":{"Display":"\u00bfQu\u00e9 <strong>porcentaje<\/strong> de participantes reportaron haber obtenido un 6 en la tirada del dado (una recompensa de 0 UM)?"}}},"JA":{"QuestionText":"<div style=\"text-align: center;\">\u30d1\u30fc\u30c8 2 \u3092\u59cb\u3081\u308b\u524d\u306b\u3001\u4ed6\u306e\u53c2\u52a0\u8005\u306e\u30b5\u30a4\u30b3\u30ed\u306e\u6570\u5b57\u306b\u3064\u3044\u3066\u306e <b>\u63a8\u5b9a\u5024<\/b> (\u3064\u307e\u308a\u3001\u63a8\u6e2c) \u3092\u5165\u529b\u3057\u3066\u304f\u3060\u3055\u3044\u3002<\/div>\n\n<div style=\"text-align: center;\">\u3064\u307e\u308a\u3001\u3042\u306a\u305f\u3068\u540c\u3058\u30b2\u30fc\u30e0\u3092\u30d7\u30ec\u30a4\u3057\u3066\u3044\u308b\u53c2\u52a0\u8005\u304c 100 \u4eba\u3044\u305f\u5834\u5408\u3001\u4f55\u4eba (\u3064\u307e\u308a\u3001\u4f55\u30d1\u30fc\u30bb\u30f3\u30c8) \u304c\u6570\u5b57 1 \u3092\u5831\u544a\u3057\u3001\u4f55\u4eba\u304c\u6570\u5b57 2 \u3092\u5831\u544a\u3057\u305f\u3068\u601d\u3044\u307e\u3059\u304b\u3002\u540c\u69d8\u306b\u4f55\u4eba\uff08\u3064\u307e\u308a\u4f55\u30d1\u30fc\u30bb\u30f3\u30c8\uff09\u304c\u6570\u5b57\uff13\u3001\u6570\u5b57\uff14\u3001\u6570\u5b57\uff15\u3001\u6570\u5b57\uff16\u3092\u5831\u544a\u3057\u305f\u3068\u601d\u3044\u307e\u3059\u304b\u3002<\/div>\n\n<div style=\"text-align: center;\"><br \/>\n\u63a8\u6e2c\u304c\u6b63\u3057\u3051\u308c\u3070\u3001<b>50 MU<\/b> \u3092\u7372\u5f97\u3067\u304d\u307e\u3059\u3002\u6b63\u3057\u3044\u30d1\u30fc\u30bb\u30f3\u30c6\u30fc\u30b8\u304b\u3089 1 \u30d1\u30fc\u30bb\u30f3\u30c8\u30dd\u30a4\u30f3\u30c8\u305a\u308c\u308b\u3054\u3068\u306b\u3001\u5831\u916c\u306f 0.4 MU \u6e1b\u5c11\u3057\u307e\u3059\u3002\u6700\u4f4e\u3067\u3082 5 MU \u3092\u7372\u5f97\u3067\u304d\u307e\u3059\u3002 <b>\u30d1\u30fc\u30bb\u30f3\u30c6\u30fc\u30b8<\/b>\u306f\u5408\u8a08\u304c 100 \u30d1\u30fc\u30bb\u30f3\u30c8\u306b\u306a\u308b\u5fc5\u8981\u304c\u3042\u308b\u3053\u3068\u306b\u6ce8\u610f\u3057\u3066\u304f\u3060\u3055\u3044\u3002<\/div>\n\n<div style=\"text-align: center;\">(\u5c0f\u6570\u70b9\u306a\u3057\u306e\u6574\u6570\u306e\u307f\u3092\u5165\u529b\u3057\u3066\u304f\u3060\u3055\u3044)<\/div>\n\n<div style=\"text-align: center;\">(\u300c%\u300d\u8a18\u53f7\u306a\u3057\u3067<b>\u6570\u5024\u3092\u5165\u529b\u3057\u3066\u304f\u3060\u3055\u3044)<\/b><\/div>\n","Choices":{"1":{"Display":"\u53c2\u52a0\u8005\u306e\u4f55\u30d1\u30fc\u30bb\u30f3\u30c8\u304c\u6570\u5b57 1 (10 MU \u306e\u5831\u916c) \u3092\u5831\u544a\u3057\u307e\u3057\u305f\u304b?"},"2":{"Display":"\u53c2\u52a0\u8005\u306e\u4f55\u30d1\u30fc\u30bb\u30f3\u30c8\u304c\u6570\u5b57 2 (20 MU \u306e\u5831\u916c) \u3092\u5831\u544a\u3057\u307e\u3057\u305f\u304b?"},"3":{"Display":"\u53c2\u52a0\u8005\u306e\u4f55\u30d1\u30fc\u30bb\u30f3\u30c8\u304c\u6570\u5b57 3 (30 MU \u306e\u5831\u916c) \u3092\u5831\u544a\u3057\u307e\u3057\u305f\u304b?"},"4":{"Display":"\u53c2\u52a0\u8005\u306e\u4f55\u30d1\u30fc\u30bb\u30f3\u30c8\u304c\u6570\u5b57 4 (40 MU \u306e\u5831\u916c) \u3092\u5831\u544a\u3057\u307e\u3057\u305f\u304b?"},"5":{"Display":"\u53c2\u52a0\u8005\u306e\u4f55\u30d1\u30fc\u30bb\u30f3\u30c8\u304c\u6570\u5b57 5 (50 MU \u306e\u5831\u916c) \u3092\u5831\u544a\u3057\u307e\u3057\u305f\u304b?"},"6":{"Display":"\u53c2\u52a0\u8005\u306e\u4f55\u30d1\u30fc\u30bb\u30f3\u30c8\u304c\u6570\u5b57 6 (0 MU\u306e\u5831\u916c ) \u3092\u5831\u544a\u3057\u307e\u3057\u305f\u304b?"}}},"DE":{"QuestionText":"<div style=\"text-align: center;\">Bevor wir mit Teil 2 beginnen, geben Sie bitte Ihre <b>Sch\u00e4tzung <\/b> (d. h. Ihre Vermutung) zu den gemeldeten W\u00fcrfelzahlen der anderen Teilnehmer ein.<br><\/div><div style=\"text-align: center;\">Wenn also 100 Teilnehmer dasselbe Spiel wie Sie spielen w\u00fcrden, wie viele (d. h. wie viel Prozent) w\u00fcrden Ihrer Meinung nach die Zahl 1 melden, wie viele die Zahl 2 usw.?<\/div>\n\n<div style=\"text-align: center;\"><br>\nWenn Ihre Vermutung richtig ist, erhalten Sie <b>50 MUs<\/b>. F\u00fcr jeden Prozentpunkt, den Sie vom korrekten Prozentsatz abweichen, wird Ihre Auszahlung um 0,4 MUs reduziert. Sie erhalten mindestens 5 MUs. Beachten Sie, dass die <b>Prozentangaben <\/b>100 Prozent ergeben m\u00fcssen.<\/div><div style=\"text-align: center;\">(bitte nur ganze Zahlen eingeben, keine Dezimalstellen)<\/div><div style=\"text-align: center;\">(bitte Zahlen <b>ohne <\/b>das \"%\"-Zeichen eingeben)<\/div>","Choices":{"1":{"Display":"Wie viel Prozent der Teilnehmer gaben eine Zahl 1 an (eine Auszahlung von 10 MUs)?"},"2":{"Display":"Wie viel Prozent der Teilnehmer gaben eine Zahl 2 an (eine Auszahlung von 20 MUs)?"},"3":{"Display":"Wie viel Prozent der Teilnehmer gaben eine Zahl 3 an (eine Auszahlung von 30 MUs)?"},"4":{"Display":"Wie viel Prozent der Teilnehmer gaben eine Zahl 4 an (eine Auszahlung von 40 MUs)?"},"5":{"Display":"Wie viel Prozent der Teilnehmer gaben eine Zahl 5 an (eine Auszahlung von 50 MUs)?"},"6":{"Display":"Wie viel Prozent der Teilnehmer gaben eine Zahl 6 an (eine Auszahlung von 0 MUs)?"}}},"ZH-T":{"QuestionText":"<div style=\"text-align: center;\">\u9032\u5165\u7b2c 2 \u90e8\u5206\u4e4b\u524d\uff0c\u8acb\u60a8<strong>\u9810<\/strong><b>\u6e2c<\/b>\u5176\u4ed6\u53d7\u8a66\u8005\u56de\u5831\u7684\u9ab0\u5b50\u9ede\u6578\u3002<\/div>\n\n<div style=\"text-align: center;\">\u4e5f\u5c31\u662f\u8aaa\uff0c\u5982\u679c\u6709 100 \u4f4d\u53d7\u8a66\u8005\u8207\u60a8\u73a9\u540c\u6a23\u7684\u904a\u6232\uff0c\u60a8\u8a8d\u70ba\u6709\u591a\u5c11\u4eba\uff08\u5373\u767e\u5206\u6bd4\uff09\u6703\u56de\u5831\u6578\u5b57 1\uff0c\u6709\u591a\u5c11\u4eba\u6703\u56de\u5831\u6578\u5b57 2\uff0c\u4f9d\u6b64\u985e\u63a8\uff1f\n<div style=\"text-align: center;\"><br \/>\n\u5982\u679c\u60a8\u7684\u9810\u6e2c\u6b63\u78ba\uff0c\u60a8\u6703\u7372\u5f97 <b>50 \u6cd5\u5e63<\/b>\u3002\u6bcf\u504f\u96e2\u6b63\u78ba\u767e\u5206\u6bd4\u4e00\u500b\u767e\u5206\u9ede\uff0c\u60a8\u5c31\u6703\u5c11\u7372\u5f97 0.4 \u6cd5\u5e63\u3002\u60a8\u81f3\u5c11\u53ef\u4ee5\u7372\u5f97 5 \u6cd5\u5e63\u3002\u8acb\u6ce8\u610f\uff0c<b>\u767e\u5206\u6bd4<\/b>\u52a0\u8d77\u4f86\u5fc5\u9808\u9054\u5230 100%\u3002<br \/>\n\uff08\u8acb\u8f38\u5165\u6574\u6578\uff0c\u4e0d\u5f97\u6709\u5c0f\u6578\u9ede\uff09<br \/>\n\uff08\u8acb\u8f38\u5165<b>\u4e0d\u542b<\/b>\u300c%\u300d\u7b26\u865f\u7684\u6578\u5b57\uff09<\/div>\n<\/div>\n","Choices":{"1":{"Display":"\u6709\u591a\u5c11<strong>\u767e\u5206\u6bd4<\/strong>\u7684\u53d7\u8a66\u8005\u6703\u56de\u5831\u6578\u5b57 1\uff08\u5831\u916c\u662f 10 \u6cd5\u5e63\uff09\uff1f"},"2":{"Display":"\u6709\u591a\u5c11<strong>\u767e\u5206\u6bd4<\/strong>\u7684\u53d7\u8a66\u8005\u6703\u56de\u5831\u6578\u5b57 2\uff08\u5831\u916c\u662f 20 \u6cd5\u5e63\uff09\uff1f"},"3":{"Display":"\u6709\u591a\u5c11<strong>\u767e\u5206\u6bd4<\/strong>\u7684\u53d7\u8a66\u8005\u6703\u56de\u5831\u6578\u5b57 3\uff08\u5831\u916c\u662f 30 \u6cd5\u5e63\uff09\uff1f"},"4":{"Display":"\u6709\u591a\u5c11<strong>\u767e\u5206\u6bd4<\/strong>\u7684\u53d7\u8a66\u8005\u6703\u56de\u5831\u6578\u5b57 4\uff08\u5831\u916c\u662f 40 \u6cd5\u5e63\uff09\uff1f"},"5":{"Display":"\u6709\u591a\u5c11<strong>\u767e\u5206\u6bd4<\/strong>\u7684\u53d7\u8a66\u8005\u6703\u56de\u5831\u6578\u5b57 5\uff08\u5831\u916c\u662f 50 \u6cd5\u5e63\uff09\uff1f"},"6":{"Display":"\u6709\u591a\u5c11<strong>\u767e\u5206\u6bd4<\/strong>\u7684\u53d7\u8a66\u8005\u6703\u56de\u5831\u6578\u5b57 6\uff08\u5831\u916c\u662f 0 \u6cd5\u5e63\uff09\uff1f"}}},"KO":{"QuestionText":"<div style=\"text-align: center;\">2\ubd80\ub97c \uc2dc\uc791\ud558\uae30 \uc804\uc5d0, \ub2e4\ub978 \ucc38\uac00\uc790\uac00 \uc8fc\uc0ac\uc704 \uc22b\uc790\ub97c \uc5b4\ub5bb\uac8c \uc785\ub825\ud588\uc744 \uc9c0\uc5d0 \ub300\ud55c <b>\ucd94\uc815\uce58<\/b>(\uc989, \ucd94\uce21)\ub97c \uc785\ub825\ud558\uc138\uc694.<\/div>\n\n<div style=\"text-align: center;\">\ub2f9\uc2e0\uacfc \uac19\uc740 \uac8c\uc784\uc744 \ud558\ub294 \ucc38\uac00\uc790\uac00 100\uba85\uc774\ub77c\uba74, 1\uc5d0\uc11c 6\uae4c\uc9c0\uc758 \uac01 \uc22b\uc790\ub97c \uc785\ub825\ud55c \uc0ac\ub78c\uc740 \uba87 \uba85(\uc989, \uba87 \ud37c\uc13c\ud2b8)\uc774\ub77c\uace0 \uc0dd\uac01\ud558\uc2ed\ub2c8\uae4c?<\/div>\n\n<div style=\"text-align: center;\"><br \/>\n\ucd94\uce21\uc774 \ub9de\uc73c\uba74 <b>50 MU<\/b>\ub97c \uc5bb\uc2b5\ub2c8\ub2e4. \uc815\ud655\ud55c \ubc31\ubd84\uc728\uc5d0\uc11c \ubc97\uc5b4\ub09c \ubc31\ubd84\uc728 \ud3ec\uc778\ud2b8 1\uac1c\ub2f9 \ubcf4\uc0c1\uc740 0.4 MU\uc529 \uc904\uac8c \ub418\uace0, \uc5bb\uc744 \uc218 \uc788\ub294 \ucd5c\uc18c \ubcf4\uc0c1\uc740 5 MU\uc785\ub2c8\ub2e4. \uc544\ub798\uc758 \uc5ec\uc12f \uac1c\uc758 \uc9c8\ubb38\uc5d0 \uc751\ub2f5\ud558\ub418,\u00a0<b>\ubc31\ubd84\uc728<\/b>\uc740 \ud569\uc774 100%\uac00 \ub418\uc5b4\uc57c \ud569\ub2c8\ub2e4.<\/div>\n\n<div style=\"text-align: center;\">(\"%\" \uae30\ud638 \uc5c6\uc774 <b>\uc815\uc218\ub9cc \uc785\ub825\ud558\uc138\uc694)<\/b><\/div>\n","Choices":{"1":{"Display":"\ucc38\uac00\uc790 \uc911 \uba87 <strong>%<\/strong>\uac00 \uc22b\uc790 1(10MU\uc758 \ubcf4\uc0c1)\uc744 \ubcf4\uace0\ud588\ub2e4\uace0 \uc0dd\uac01\ud558\uc2ed\ub2c8\uae4c?"},"2":{"Display":"\ucc38\uac00\uc790 \uc911 \uba87 <strong>%<\/strong>\uac00 \uc22b\uc790 2(20 MU\uc758 \ubcf4\uc0c1)\ub97c \ubcf4\uace0\ud588\ub2e4\uace0 \uc0dd\uac01\ud558\uc2ed\ub2c8\uae4c?"},"3":{"Display":"\ucc38\uac00\uc790 \uc911 \uba87 <strong>%<\/strong>\uac00 \uc22b\uc790 3(30 MU\uc758 \ubcf4\uc0c1)\uc744 \ubcf4\uace0\ud588\ub2e4\uace0 \uc0dd\uac01\ud558\uc2ed\ub2c8\uae4c?"},"4":{"Display":"\ucc38\uac00\uc790 \uc911 \uba87 <strong>%<\/strong>\uac00 \uc22b\uc790 4(40 MU\uc758 \ubcf4\uc0c1)\ub97c \ubcf4\uace0\ud588\ub2e4\uace0 \uc0dd\uac01\ud558\uc2ed\ub2c8\uae4c?"},"5":{"Display":"\ucc38\uac00\uc790 \uc911 \uba87 <strong>%<\/strong>\uac00 \uc22b\uc790 5(50 MU\uc758 \ubcf4\uc0c1)\ub97c \ubcf4\uace0\ud588\ub2e4\uace0 \uc0dd\uac01\ud558\uc2ed\ub2c8\uae4c?"},"6":{"Display":"\ucc38\uac00\uc790 \uc911 \uba87 <strong>%<\/strong>\uac00 \uc22b\uc790 6(0 MU\uc758 \ubcf4\uc0c1)\uc744 \ubcf4\uace0\ud588\ub2e4\uace0 \uc0dd\uac01\ud558\uc2ed\ub2c8\uae4c?"}}},"DE-AT":{"QuestionText":"<div style=\"text-align: center;\">Bevor wir mit Teil 2 beginnen, geben Sie bitte Ihre <b>Sch\u00e4tzung <\/b> (d. h. Ihre Vermutung) zu den von anderen Teilnehmern angegebenen W\u00fcrfelzahlen ein.<\/div>\n\n<div style=\"text-align: center;\">Wenn also 100 Teilnehmer dasselbe Spiel wie Sie spielen w\u00fcrden, wie viele (d. h. wie viel Prozent) w\u00fcrden Ihrer Meinung nach die Zahl 1 melden, wie viele die Zahl 2 usw.?<\/div>\n\n<div style=\"text-align: center;\"><br \/>\nWenn Ihre Vermutung richtig ist, erhalten Sie <b>50 GE<\/b>. F\u00fcr jeden Prozentpunkt, den Sie vom korrekten Prozentsatz abweichen, wird Ihre Auszahlung um 0,4 GE reduziert. Sie erhalten mindestens 5 GE. Beachten Sie, dass die Summe der\u00a0<b>Prozentangaben <\/b>100 Prozent ergeben muss.<\/div>\n\n<div style=\"text-align: center;\">(Bitte geben Sie nur ganze Zahlen ein, keine Dezimalstellen.)<\/div>\n\n<div style=\"text-align: center;\">(Bitte geben Sie Zahlen <b>ohne <\/b>das \"%\"-Zeichen ein.)<\/div>\n","Choices":{"1":{"Display":"Wie viel Prozent der Teilnehmer gaben die Zahl 1 an (eine Auszahlung von 10 GE)?"},"2":{"Display":"Wie viel Prozent der Teilnehmer gaben die Zahl 2 an (eine Auszahlung von 20 GE)?"},"3":{"Display":"Wie viel Prozent der Teilnehmer gaben die Zahl 3 an (eine Auszahlung von 30 GE)?"},"4":{"Display":"Wie viel Prozent der Teilnehmer gaben die Zahl 4 an (eine Auszahlung von 40 GE)?"},"5":{"Display":"Wie viel Prozent der Teilnehmer gaben die Zahl 5 an (eine Auszahlung von 50 GE)?"},"6":{"Display":"Wie viel Prozent der Teilnehmer gaben die Zahl 6 an (eine Auszahlung von 0 GE)?"}}},"TR":{"QuestionText":"<div style=\"text-align: center;\">2. B\u00f6l\u00fcme ba\u015flamadan \u00f6nce, di\u011fer kat\u0131l\u0131mc\u0131lar\u0131n att\u0131klar\u0131 zar neticesinde gelen say\u0131ya dair yapt\u0131klar\u0131 bildirimleri <b>tahmin <\/b>etmeniz istenmektedir.<\/div>\n\n<div style=\"text-align: center;\">Sizce, bu deney kapsam\u0131nda zar atan kat\u0131l\u0131mc\u0131lar\u0131n y\u00fczde ka\u00e7\u0131 att\u0131klar\u0131 zar\u0131n sonucunda gelen say\u0131y\u0131 1 olarak bildirmi\u015ftir, y\u00fczde ka\u00e7\u0131 2 olarak bildirmi\u015ftir, vb.?<\/div>\n\n<div style=\"text-align: center;\"><br \/>\nBu b\u00f6l\u00fcmden kazanc\u0131n\u0131z en az <strong>5<\/strong>, en fazla <strong>50 DPB<\/strong> olacakt\u0131r. Tahminlerinizin tamam\u0131 do\u011fruysa, <b>50 DPB<\/b> kazan\u0131rs\u0131n\u0131z. A\u015fa\u011f\u0131da yapaca\u011f\u0131n\u0131z her bir tahminin do\u011fru orandan her %1'lik sap\u0131\u015f\u0131nda, kazanc\u0131n\u0131z 0,4 DPB azal\u0131r.<br \/>\n<br \/>\n<b>Tahminlerinizin\u00a0<\/b>toplam\u0131n\u0131n %100 olmas\u0131 gerekti\u011fini unutmay\u0131n.<\/div>\n\n<div style=\"text-align: center;\">(L\u00fctfen sadece tam say\u0131lar girin, ondal\u0131k say\u0131 girmeyin.)<\/div>\n\n<div style=\"text-align: center;\">(L\u00fctfen \"%\" sembol\u00fc <b>olmadan, <\/b>do\u011frudan say\u0131lar\u0131 girin)<\/div>\n","Choices":{"1":{"Display":"Kat\u0131l\u0131mc\u0131lar\u0131n <strong>y\u00fczde ka\u00e7\u0131<\/strong>\u00a01 rakam\u0131n\u0131 (yani 10 DPB'lik bir getiri) bildirmi\u015ftir?"},"2":{"Display":"Kat\u0131l\u0131mc\u0131lar\u0131n <strong>y\u00fczde ka\u00e7\u0131<\/strong>\u00a02 rakam\u0131n\u0131 (yani 20 DPB'lik bir getiri) bildirmi\u015ftir?"},"3":{"Display":"Kat\u0131l\u0131mc\u0131lar\u0131n <strong>y\u00fczde ka\u00e7\u0131<\/strong> 3 rakam\u0131n\u0131 (yani 30 DPB'lik bir getiri) bildirmi\u015ftir?"},"4":{"Display":"Kat\u0131l\u0131mc\u0131lar\u0131n <strong>y\u00fczde ka\u00e7\u0131<\/strong> 4 rakam\u0131n\u0131 (yani 40 DPB'lik bir getiri) bildirmi\u015ftir?"},"5":{"Display":"Kat\u0131l\u0131mc\u0131lar\u0131n <strong>y\u00fczde ka\u00e7\u0131<\/strong> 5 rakam\u0131n\u0131 (yani 50 DPB'lik bir getiri) bildirmi\u015ftir?"},"6":{"Display":"Kat\u0131l\u0131mc\u0131lar\u0131n <strong>y\u00fczde ka\u00e7\u0131<\/strong> 6 rakam\u0131n\u0131 (yani 0 DPB'lik bir getiri) bildirmi\u015ftir?"}}},"ZH-HK":{"QuestionText":"<div style=\"text-align: center;\">\u5728\u6211\u5011\u958b\u59cb\u7b2c 2 \u90e8\u5206\u4e4b\u524d\uff0c\u8acb\u60a8<b>\u9810\u6e2c<\/b>\u5176\u4ed6\u53c3\u8207\u8005\u5831\u544a\u7684\u9ab0\u5b50\u9ede\u6578\u3002\u4e5f\u5c31\u662f\u8aaa\uff0c\u5982\u679c\u6709 100 \u540d\u53c3\u8207\u8005\u8207\u60a8\u73a9\u540c\u4e00\u500b\u904a\u6232\uff0c\u60a8\u8a8d\u70ba\u6709\u591a\u5c11\u4eba\uff08\u5373\u767e\u5206\u6bd4\uff09\u5831\u544a\u4e86\u6578\u5b57 1\uff0c\u6709\u591a\u5c11\u4eba\u5831\u544a\u4e86\u6578\u5b57 2\uff0c\u4f9d\u6b64\u985e\u63a8\uff1f<\/div>\n\n<div style=\"text-align: center;\"><br \/>\n\u5982\u679c\u60a8\u7684\u9810\u6e2c\u6b63\u78ba\uff0c\u60a8\u6703\u7372\u5f97 <strong>50<\/strong> <b>MU<\/b>\u3002\u6bcf\u504f\u96e2\u6b63\u78ba\u767e\u5206\u6bd4\u4e00\u500b\u767e\u5206\u9ede\uff0c\u60a8\u7684\u6536\u76ca\u5c31\u6703\u6e1b\u5c11 0.4 MU\u3002\u60a8\u5c07\u6536\u5230\u81f3\u5c11 5 \u500b MU\u3002\u8acb\u6ce8\u610f\uff0c<b>\u767e\u5206\u6bd4<\/b>\u7e3d\u548c\u5fc5\u9808\u70ba 100%\u3002<\/div>\n\n<div style=\"text-align: center;\">\uff08\u8acb\u53ea\u8f38\u5165\u6574\u6578\uff0c\u4e0d\u8981\u8f38\u5165\u5c0f\u6578\u9ede\uff09<\/div>\n\n<div style=\"text-align: center;\">\uff08\u8acb\u8f38\u5165<b>\u4e0d\u542b<\/b>\u300c%\u300d\u7b26\u865f\u7684\u6578\u5b57\uff09<\/div>\n","Choices":{"1":{"Display":"<p>\u6709\u591a\u5c11<b>\u767e\u5206\u6bd4<\/b>\u7684\u53c3\u8207\u8005\u6703\u56de\u5831\u6578\u5b57 1\uff08\u5831\u916c\u662f 10\u500bMU\uff09\uff1f<\/p>\n"},"2":{"Display":"<p>\u6709\u591a\u5c11<b>\u767e\u5206\u6bd4<\/b>\u7684\u53c3\u8207\u8005\u6703\u56de\u5831\u6578\u5b57 2\uff08\u5831\u916c\u662f 20\u500bMU\uff09\uff1f<\/p>\n"},"3":{"Display":"<p>\u6709\u591a\u5c11<b>\u767e\u5206\u6bd4<\/b>\u7684\u53d7\u8a66\u8005\u6703\u56de\u5831\u6578\u5b57 3\uff08\u5831\u916c\u662f 30 \u500b MU\uff09\uff1f<\/p>\n"},"4":{"Display":"<p>\u6709\u591a\u5c11<b>\u767e\u5206\u6bd4<\/b>\u7684\u53c3\u8207\u8005\u6703\u56de\u5831\u6578\u5b57 4\uff08\u5831\u916c\u662f 40 \u500b MU\uff09\uff1f<\/p>\n"},"5":{"Display":"<p>\u6709\u591a\u5c11<b>\u767e\u5206\u6bd4<\/b>\u7684\u53c3\u8207\u8005\u6703\u56de\u5831\u6578\u5b57 5\uff08\u5831\u916c\u662f 50 \u500b MU\uff09\uff1f<\/p>\n"},"6":{"Display":"<p>\u6709\u591a\u5c11<b>\u767e\u5206\u6bd4<\/b>\u7684\u53c3\u8207\u8005\u6703\u56de\u5831\u6578\u5b57 6\uff08\u5831\u916c\u662f 0 \u500b MU\uff09\uff1f<\/p>\n"}}},"KZ-RU":[],"AR":{"QuestionText":"<div style=\"text-align: center;;text-align:right;direction:rtl\">\u0642\u0628\u0644 \u0623\u0646 \u0646\u0628\u062f\u0623 \u0627\u0644\u062c\u0632\u0621 \u0627\u0644\u062b\u0627\u0646\u064a\u060c \u064a\u0631\u062c\u0649 \u0625\u062f\u062e\u0627\u0644 <b>\u062a\u0642\u062f\u064a\u0631\u0643<\/b> (\u0623\u064a \u062a\u062e\u0645\u064a\u0646\u0643) \u062d\u0648\u0644 \u0627\u0644\u0623\u0639\u062f\u0627\u062f \u0627\u0644\u0645\u0628\u0644\u063a \u0639\u0646\u0647\u0627 \u0644\u0632\u0647\u0631\u0627\u0644\u0645\u0634\u0627\u0631\u0643\u064a\u0646 \u0627\u0644\u0622\u062e\u0631\u064a\u0646.<\/div>\n\n<div style=\"text-align: center;;text-align:right;direction:rtl\">\u0644\u0630\u0627\u060c \u0625\u0630\u0627 \u0643\u0627\u0646 \u0647\u0646\u0627\u0643 100 \u0645\u0634\u0627\u0631\u0643 \u064a\u0644\u0639\u0628\u0648\u0646 \u0646\u0641\u0633 \u0627\u0644\u0644\u0639\u0628\u0629 \u0627\u0644\u062a\u064a \u062a\u0644\u0639\u0628\u0647\u0627\u060c \u0641\u0643\u0645 \u0645\u0646\u0647\u0645 (\u0623\u064a \u0627\u0644\u0646\u0633\u0628\u0629 \u0627\u0644\u0645\u0626\u0648\u064a\u0629) \u062a\u0639\u062a\u0642\u062f \u0623\u0646\u0647\u0645 \u0623\u0628\u0644\u063a\u0648\u0627 \u0639\u0646 \u0627\u0644\u0631\u0642\u0645 1\u060c \u0648\u0643\u0645 \u0645\u0646\u0647\u0645 \u0623\u0628\u0644\u063a\u0648\u0627 \u0639\u0646 \u0627\u0644\u0631\u0642\u0645 2\u060c \u0648\u0647\u0643\u0630\u0627\u061f.<\/div>\n\n<div style=\"text-align: center;;text-align:right;direction:rtl\"><br \/>\n\u0625\u0630\u0627 \u0643\u0627\u0646 \u062a\u062e\u0645\u064a\u0646\u0643 \u0635\u062d\u064a\u062d\u064b\u0627\u060c \u0641\u0633\u062a\u0631\u0628\u062d <b>50 \u0648\u062d\u062f\u0629 \u0645\u0646 \u0627\u0644\u0648\u062d\u062f\u0627\u062a \u0627\u0644\u0646\u0642\u062f\u064a\u0629<\/b> . \u0644\u0643\u0644 \u0646\u0642\u0637\u0629 \u0645\u0626\u0648\u064a\u0629 \u062a\u0628\u062a\u0639\u062f \u0641\u064a\u0647\u0627 \u0639\u0646 \u0627\u0644\u0646\u0633\u0628\u0629 \u0627\u0644\u0645\u0626\u0648\u064a\u0629 \u0627\u0644\u0635\u062d\u064a\u062d\u0629\u060c \u0633\u064a\u062a\u0645 \u062a\u0642\u0644\u064a\u0644 \u0645\u0643\u0627\u0641\u0623\u062a\u0643 \u0628\u0645\u0642\u062f\u0627\u0631 0.4 \u0648\u062d\u062f\u0629 \u0645\u0646 \u0627\u0644\u0648\u062d\u062f\u0627\u062a \u0627\u0644\u0646\u0642\u062f\u064a\u0629. \u0633\u062a\u062d\u0635\u0644 \u0639\u0644\u0649 \u062d\u062f \u0623\u062f\u0646\u0649 5 \u0648\u062d\u062f\u0627\u062a \u0645\u0646 \u0627\u0644\u0648\u062d\u062f\u0627\u062a \u0627\u0644\u0646\u0642\u062f\u064a\u0629. \u0644\u0627\u062d\u0638 \u0623\u0646 <b>\u0627\u0644\u0646\u0633\u0628 \u0627\u0644\u0645\u0626\u0648\u064a\u0629<\/b> \u064a\u062c\u0628 \u0623\u0646 \u062a\u0635\u0644 \u0625\u0644\u0649 100 \u0628\u0627\u0644\u0645\u0627\u0626\u0629.<\/div>\n\n<div style=\"text-align: center;;text-align:right;direction:rtl\">(\u064a\u0631\u062c\u0649 \u0625\u062f\u062e\u0627\u0644 \u0623\u0631\u0642\u0627\u0645 \u0635\u062d\u064a\u062d\u0629 \u0641\u0642\u0637\u060c \u0628\u062f\u0648\u0646 \u0646\u0642\u0627\u0637 \u0639\u0634\u0631\u064a\u0629)<\/div>\n\n<div style=\"text-align: center;;text-align:right;direction:rtl\">(\u064a\u0631\u062c\u0649 \u0625\u062f\u062e\u0627\u0644 \u0627\u0644\u0623\u0631\u0642\u0627\u0645 <b>\u0628\u062f\u0648\u0646<\/b> \u0627\u0644\u0631\u0645\u0632 \"%\")<\/div>\n","Choices":{"1":{"Display":"\u0645\u0627 \u0647\u064a <strong>\u0646\u0633\u0628\u0629<\/strong> \u0627\u0644\u0645\u0634\u0627\u0631\u0643\u064a\u0646 \u0627\u0644\u0630\u064a\u0646 \u0623\u0628\u0644\u063a\u0648\u0627 \u0639\u0646 \u0627\u0644\u0631\u0642\u0645 1 (\u0645\u0643\u0627\u0641\u0623\u0629 \u0642\u062f\u0631\u0647\u0627 10 \u0648\u062d\u062f\u0627\u062a \u0646\u0642\u062f\u064a\u0629)\u061f"},"2":{"Display":"\u0645\u0627 \u0647\u064a <strong>\u0646\u0633\u0628\u0629<\/strong> \u0627\u0644\u0645\u0634\u0627\u0631\u0643\u064a\u0646 \u0627\u0644\u0630\u064a\u0646 \u0623\u0628\u0644\u063a\u0648\u0627 \u0639\u0646 \u0627\u0644\u0631\u0642\u0645 2 (\u0645\u0643\u0627\u0641\u0623\u0629 \u0642\u062f\u0631\u0647\u0627 20 \u0648\u062d\u062f\u0629 \u0646\u0642\u062f\u064a\u0629)\u061f"},"3":{"Display":"\u0645\u0627 \u0647\u064a <strong>\u0646\u0633\u0628\u0629<\/strong> \u0627\u0644\u0645\u0634\u0627\u0631\u0643\u064a\u0646 \u0627\u0644\u0630\u064a\u0646 \u0623\u0628\u0644\u063a\u0648\u0627 \u0639\u0646 \u0627\u0644\u0631\u0642\u0645 3 (\u0645\u0643\u0627\u0641\u0623\u0629 \u0642\u062f\u0631\u0647\u0627 30 \u0648\u062d\u062f\u0629 \u0646\u0642\u062f\u064a\u0629)\u061f"},"4":{"Display":"\u0645\u0627 \u0647\u064a <strong>\u0646\u0633\u0628\u0629<\/strong> \u0627\u0644\u0645\u0634\u0627\u0631\u0643\u064a\u0646 \u0627\u0644\u0630\u064a\u0646 \u0623\u0628\u0644\u063a\u0648\u0627 \u0639\u0646 \u0627\u0644\u0631\u0642\u0645 4 (\u0645\u0643\u0627\u0641\u0623\u0629 \u0642\u062f\u0631\u0647\u0627 40 \u0648\u062d\u062f\u0629 \u0646\u0642\u062f\u064a\u0629)\u061f"},"5":{"Display":"\u0645\u0627 \u0647\u064a <strong>\u0646\u0633\u0628\u0629<\/strong> \u0627\u0644\u0645\u0634\u0627\u0631\u0643\u064a\u0646 \u0627\u0644\u0630\u064a\u0646 \u0623\u0628\u0644\u063a\u0648\u0627 \u0639\u0646 \u0627\u0644\u0631\u0642\u0645 5 (\u0645\u0643\u0627\u0641\u0623\u0629 \u0642\u062f\u0631\u0647\u0627 50 \u0648\u062d\u062f\u0629 \u0646\u0642\u062f\u064a\u0629)\u061f"},"6":{"Display":"\u0645\u0627 \u0647\u064a <strong>\u0646\u0633\u0628\u0629<\/strong> \u0627\u0644\u0645\u0634\u0627\u0631\u0643\u064a\u0646 \u0627\u0644\u0630\u064a\u0646 \u0623\u0628\u0644\u063a\u0648\u0627 \u0639\u0646 \u0631\u0642\u0645 6 (\u0645\u0643\u0627\u0641\u0623\u0629 0 \u0648\u062d\u062f\u0629 \u0646\u0642\u062f\u064a\u0629)\u061f"}}},"DE-DE":{"QuestionText":"<div style=\"text-align: center;\">Bevor wir mit Teil 2 beginnen, gebt Sie bitte ihre\u00a0<b>Einsch\u00e4tzung<\/b> (also Ihren Sch\u00e4tzwert) zu den gemeldeten W\u00fcrfelzahlen der anderen TeilnehmerInnen ab.<\/div>\n\n<div style=\"text-align: center;\">Wenn also 100 TeilnehmerInnen das gleiche Spiel wie Sie spielen w\u00fcrden, wie viele (d. h. wie viel Prozent) haben Ihrer Meinung nach die Nummer 1 genannt, wie viele haben die Nummer 2 genannt usw.?<\/div>\n\n<div style=\"text-align: center;\"><br \/>\nWenn Ihre Sch\u00e4tzung richtig ist, erhalten Sie <b>50 GE<\/b>\u00a0. F\u00fcr jeden Prozentpunkt, den Sie vom korrekten Prozentsatz abweichen, wird Ihre Auszahlung um 0,4 GE reduziert. Sie erhalten mindestens 5 GE. Beachten Sie, dass die <b>Prozents\u00e4tze<\/b> zusammen 100 Prozent ergeben m\u00fcssen.<\/div>\n\n<div style=\"text-align: center;\">(bitte nur ganze Zahlen eingeben, keine Dezimalstellen)<\/div>\n\n<div style=\"text-align: center;\">(Zahlen bitte <b>ohne<\/b> das \"%\"-Zeichen eingeben)<\/div>\n","Choices":{"1":{"Display":"Wie viel <strong>Prozent<\/strong> der TeilnehmerInnen meldeten eine Zahl 1 (eine Auszahlung von 10 GE)?"},"2":{"Display":"Wie viel <strong>Prozent<\/strong> der TeilnehmerInnen meldeten eine Zahl 2 (eine Auszahlung von 20 GE)?"},"3":{"Display":"Wie viel <strong>Prozent<\/strong> der TeilnehmerInnen meldeten eine Zahl 3 (eine Auszahlung von 30 GE)?"},"4":{"Display":"Wie viel <strong>Prozent<\/strong> der TeilnehmerInnen meldeten eine Zahl 4 (eine Auszahlung von 40 GE)?"},"5":{"Display":"Wie viel <strong>Prozent<\/strong> der TeilnehmerInnen meldeten eine Zahl 5 (eine Auszahlung von 50 GE)?"},"6":{"Display":"Wie viel <strong>Prozent<\/strong> der TeilnehmerInnen meldeten eine Zahl 6 (eine Auszahlung von 0 GE)?"}}}},"NextChoiceId":8,"NextAnswerId":1,"Labels":[],"ClarifyingSymbolType":"None","QuestionID":"QID9","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"QuestionText_Unsafe":"<div style=\"text-align: center;\">Before we begin Part 2, please enter your <b>estimate <\/b>(i.e., your guess) about the reported numbers of the dice of the other participants.<br><\/div><div style=\"text-align: center;\">So, if there were 100 participants playing the same game as you, how many (i.e., what percentage) do you think reported the number 1, how may reported the number 2, etc.?.<\/div>\n\n<div style=\"text-align: center;\"><br>\nIf your guess is correct, you earn <b>50 MUs<\/b>. For every percentage point you deviate from the correct percentage, your payoff will be reduced by 0.4 MUs. You will receive a minimum of 5 MUs. Note that the <b>percentages <\/b>have to add up to 100 percent.<\/div><div style=\"text-align: center;\">(please enter only whole numbers, no decimal points)<\/div><div style=\"text-align: center;\">(please enter numbers&nbsp;<b>without <\/b>the \"%\" symbol)<\/div>"}},{"SurveyID":"SV_b3mHBVkuioRMhng","Element":"SQ","PrimaryAttribute":"QID90","SecondaryAttribute":"$e{5*10} + $e{4} = ???","TertiaryAttribute":null,"Payload":{"ChoiceOrder":[1,2,3,4,5],"Choices":{"1":{"Display":"$e{5*10+4}"},"2":{"Display":"$e{5*10+4 - ${rand:\/\/int\/1:9}}"},"3":{"Display":"$e{5*10+4 + ${rand:\/\/int\/1:9}}"},"4":{"Display":"$e{5*10}"},"5":{"Display":"$e{4}"}},"Configuration":{"LabelPosition":"BELOW","QuestionDescriptionOption":"UseText"},"DataExportTag":"sum2.25","DataVisibility":{"Hidden":false,"Private":false},"DefaultChoices":false,"GradingData":[],"Language":{"ES":{"QuestionText":"$e{5*10} + $e{4} = ???","Choices":{"1":{"Display":"$e{5*10+4}"},"4":{"Display":"$e{5*10}"},"5":{"Display":"$e{4}"}}}},"NextAnswerId":1,"NextChoiceId":6,"QuestionDescription":"$e{5*10} + $e{4} = ???","QuestionID":"QID90","QuestionText":"$e{5*10} + $e{4} = ???","QuestionText_Unsafe":"$e{5*10} + $e{4} = ???","QuestionType":"MC","Randomization":{"Advanced":null,"TotalRandSubset":"","Type":"All"},"RecodeValues":{"1":"0","2":"-1","3":"1","4":"99","5":"9"},"Selector":"SAHR","SubSelector":"TX","Validation":{"Settings":{"ForceResponse":"OFF","Type":"N