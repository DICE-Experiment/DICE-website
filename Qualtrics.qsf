1\u03a5\u03a4\u0397\u039d \u03a4\u0397\u039d \u0395\u03a1\u03a9\u03a4\u0397\u03a3\u0397)<br \/>\n\u039a\u03b1\u03b9, \u03c4\u03ad\u03bb\u03bf\u03c2, \u03c3\u03b5 \u03ba\u03ac\u03b8\u03b5 \u03c3\u03b5\u03b9\u03c1\u03ac \u03c0\u03b1\u03c1\u03b1\u03ba\u03ac\u03c4\u03c9, \u03c0\u03ce\u03c2 \u03b8\u03b1 \u03bc\u03bf\u03b9\u03c1\u03ac\u03b6\u03b1\u03c4\u03b5 1000 \u03bd\u03bf\u03bc\u03b9\u03c3\u03bc\u03b1\u03c4\u03b9\u03ba\u03ad\u03c2 \u03bc\u03bf\u03bd\u03ac\u03b4\u03b5\u03c2 \u03bc\u03b5\u03c4\u03b1\u03be\u03cd \u03b5\u03bd\u03cc\u03c2 \u03c4\u03c5\u03c7\u03b1\u03af\u03b1 \u03b5\u03c0\u03b9\u03bb\u03b5\u03b3\u03bc\u03ad\u03bd\u03bf\u03c5 \u03b1\u03c4\u03cc\u03bc\u03bf\u03c5 \u03c0\u03bf\u03c5 \u03b6\u03b5\u03b9 \u03c3\u03c4\u03b7 \u03c7\u03ce\u03c1\u03b1 \u03c3\u03b1\u03c2 (\u03b1\u03c1\u03b9\u03c3\u03c4\u03b5\u03c1\u03ac) \u03ba\u03b1\u03b9 \u03c4\u03bf\u03c5 \u03b1\u03c4\u03cc\u03bc\u03bf\u03c5 \u03c3\u03c4\u03b1 \u03b4\u03b5\u03be\u03b9\u03ac (\u03c0\u03bf\u03c5 \u03b1\u03bd\u03ae\u03ba\u03b5\u03b9 \u03c3\u03b5 \u03bc\u03b9\u03b1 \u03c3\u03c5\u03b3\u03ba\u03b5\u03ba\u03c1\u03b9\u03bc\u03ad\u03bd\u03b7 \u03ba\u03bf\u03b9\u03bd\u03c9\u03bd\u03b9\u03ba\u03ae \u03bf\u03bc\u03ac\u03b4\u03b1); \u03a5\u03c0\u03bf\u03b8\u03ad\u03c3\u03c4\u03b5 \u03cc\u03c4\u03b9 \u03cc\u03bb\u03b1 \u03c4\u03b1 \u03ac\u03c4\u03bf\u03bc\u03b1 \u03ad\u03c7\u03bf\u03c5\u03bd \u03c4\u03bf \u03af\u03b4\u03b9\u03bf \u03b5\u03b9\u03c3\u03cc\u03b4\u03b7\u03bc\u03b1, \u03cc\u03bb\u03b1 \u03b6\u03bf\u03c5\u03bd \u03c3\u03c4\u03b7\u03bd \u03af\u03b4\u03b9\u03b1 \u03c7\u03ce\u03c1\u03b1 \u03ba\u03b1\u03b9 \u03ba\u03b1\u03bd\u03b5\u03af\u03c2 \u03b4\u03b5\u03bd \u03b8\u03b1 \u03b1\u03bd\u03b1\u03ba\u03ac\u03bb\u03c5\u03c0\u03c4\u03b5 \u03c0\u03bf\u03c4\u03ad \u03cc\u03c4\u03b9 \u03b5\u03c3\u03b5\u03af\u03c2 \u03c3\u03c4\u03b5\u03af\u03bb\u03b1\u03c4\u03b5 \u03c4\u03b1 \u03c7\u03c1\u03ae\u03bc\u03b1\u03c4\u03b1. \u038c\u03c3\u03bf \u03c0\u03b9\u03bf \u03ba\u03bf\u03bd\u03c4\u03ac \u03c3\u03cd\u03c1\u03b5\u