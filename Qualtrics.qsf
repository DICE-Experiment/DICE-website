mg src=\"https:\/\/investigadoresloyola.eu.qualtrics.com\/CP\/Graphic.php?IM=IM_009rj6laxThpWV8\" style=\"width: 499px; height: 368px;\" \/><\/div>\n","Choices":{"1":{"Display":"\u30aa\u30d7\u30b7\u30e7\u30f3A"},"9":{"Display":"\u30aa\u30d7\u30b7\u30e7\u30f3B"}}},"DE":{"QuestionText":"<div style=\"text-align: center;\"><img src=\"https:\/\/investigadoresloyola.eu.qualtrics.com\/CP\/Graphic.php?IM=IM_39NlGehYB1neV5c\" style=\"Breite: 499px; H\u00f6he: 368px;\" \/><\/div>","Choices":{"1":{"Display":"Option A"},"9":{"Display":"Option B"}}},"ZH-T":{"QuestionText":"<div style=\"text-align: center;\"><b id=\"docs-internal-guid-6403d596-7fff-b910-5c22-3e236cf3ce29\"><img height=\"368px;\" src=\"https:\/\/lh7-rt.googleusercontent.com\/slidesz\/AGV_vUfjOrF83g1ZZm0nPBVHuS_CGEcKrREQtTcYxlsbRlqtVA8XoTJSxqEHJlfDVYfBwBiUb4cjTqknsFIaO5YA5a1tU7nP1rH_ViKHj0pHnbwmDLTPeMkD0s08rk0CVem7u5JnuDqKegYW9krNiA3Lgf16DxExztRe=s2048?key=eLdMXuEoTViukxDM6z2k5Q\" width=\"498px;\" \/><\/b><\/div>\n","Choices":{"1":{"Display":"\u9078\u9805A"},"9":{"Display":"\u9078\u9805B"}}},"KO":{"QuestionText":"<div style=\"text-align: center;\"><img src=\"https:\/\/investigadoresloyola.eu.qualtrics.com\/CP\/Graphic.php?IM=IM_5nAx7XiuigH5qNo\" style=\"width: 499px; height: 368px;\" \/><\/div>\n","Choices":{"1":{"Display":"\uc635\uc158 A"},"9":{"Display":"\uc635\uc158 B"}}},"DE-AT":{"QuestionText":"<div style=\"text-align: center;\"><img src=\"https:\/\/investigadoresloyola.eu.qualtrics.com\/CP\/Graphic.php?IM=IM_5aul5w0xFq8JouW\" style=\"width: 499px; height: 368px;\" \/><\/div>\n","Choices":{"1":{"Display":"Option A"},"9":{"Display":"Option B"}}},"TR":{"QuestionText":"<div style=\"text-align: center;\"><img height=\"369\" src=\"https:\/\/investigadoresloyola.eu.qualtrics.com\/CP\/Graphic.php?IM=IM_2furJCwJZkZaM3Y\" style=\"width: 499px; height: 369px;\" width=\"499\" \/><\/div>\n","Choices":{"1":{"Display":"A Se\u00e7ene\u011fi"},"9":{"Display":"B Se\u00e7ene\u011fi"}}},"ZH-HK":{"QuestionText":"<div style=\"text-align: center;\"><img src=\"https:\/\/investigadoresloyola.eu.qualtrics.com\/CP\/Graphic.php?IM=IM_8vPfeiN6cqWNspw\" style=\"width: 854px; height: 631px;\" \/><\/div>\n","Choices":{"1":{"Display":"\u9078\u9805A"},"9":{"Display":"\u9078\u9805B"}}},"KZ-RU":[],"AR":{"QuestionText":"<img src=\"https:\/\/investigadoresloyola.eu.qualtrics.com\/CP\/Graphic.php?IM=IM_eX7kKTbETnuBS06\" style=\"width: 485px; height: 355px;\" \/>","Choices":{"1":{"Display":"\u0627\u0644\u062e\u064a\u0627\u0631 \u0623"},"9":{"Display":"\u0627\u0644\u062e\u064a\u0627\u0631 \u0628"}}},"DE-DE":{"QuestionText":"<div style=\"text-align: center;\"><img src=\"https:\/\/investigadoresloyola.eu.qualtrics.com\/CP\/Graphic.php?IM=IM_5aul5w0xFq8JouW\" \/><\/div>\n","Choices":{"1":{"Display":"Option A"},"9":{"Display":"Option B"}}}},"NextChoiceId":11,"NextAnswerId":1,"QuestionID":"QID237","DataVisibility":{"Private":false,"Hidden":false},"SubSelector":"TX","QuestionText_Unsafe":"<div style=\"text-align: center;\"><img src=\"https:\/\/investigadoresloyola.eu.qualtrics.com\/CP\/Graphic.php?IM=IM_39NlGehYB1neV5c\" style=\"width: 499px; height: 368px;\" \/><\/div>"}},{"SurveyID":"SV_b3mHBVkuioRMhng","Element":"SQ","PrimaryAttribute":"QID238","SecondaryAttribute":"PART 5 In this part you will be asked to make six decisions. Depending on these decisions you wil...","TertiaryAttribute":null,"Payload":{"QuestionText":"<div style=\"text-align: center;\"><b>PART 5<\/b><\/div><div style=\"text-align: center;\"><br><\/div><div style=\"text-align: center;\">In this part you will be asked to make six decisions.<\/div><div style=\"text-align: center;\"><br><\/div><div style=\"text-align: center;\">Depending on these decisions you will win extra Monetary Units (MUs) in the same conversation rate as before.<\/div><div style=\"text-align: center;\"><br><\/div>\n\n<div style=\"text-align: center;\">After the survey is completed,&nbsp;one of the six decisions will be randomly chosen to determine your payoff. You and the other participants will be paid according to your choices in this decision.<\/div>","DefaultChoices":false,"DataExportTag":"MD_Intro1","QuestionType":"DB","Selector":"TB","Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"PART 5 In this part you will be asked to make six decisions. Depending on these decisions you wil...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":{"EL":{"QuestionText":"<div style=\"text-align: center;\"><b>\u039c\u0395\u03a1\u039f\u03a3 5<\/b><\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">\u03a3\u03b5 \u03b1\u03c5\u03c4\u03cc \u03c4\u03bf \u03bc\u03ad\u03c1\u03bf\u03c2 \u03b8\u03b1 \u03b5\u03c0\u03b9\u03bb\u03ad\u03be\u03b5\u03c4\u03b5 \u03bc\u03b5\u03c4\u03b1\u03be\u03cd \u03b4\u03c5\u03bf \u03b5\u03c0\u03b9\u03bb\u03bf\u03b3\u03ce\u03bd \u03c3\u03b5 \u03ad\u03be\u03b9 \u03ba\u03b1\u03c4\u03b1\u03c3\u03c4\u03ac\u03c3\u03b5\u03b9\u03c2.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">\u0391\u03bd\u03ac\u03bb\u03bf\u03b3\u03b1 \u03bc\u03b5 \u03c4\u03b9\u03c2 \u03b1\u03c0\u03bf\u03c6\u03ac\u03c3\u03b5\u03b9\u03c2 \u03c3\u03b1\u03c2, \u03b8\u03b1 \u03ba\u03b5\u03c1\u03b4\u03af\u03c3\u03b5\u03c4\u03b5 \u03b5\u03c0\u03b9\u03c0\u03bb\u03ad\u03bf\u03bd \u039d\u03bf\u03bc\u03b9\u03c3\u03bc\u03b1\u03c4\u03b9\u03ba\u03ad\u03c2 \u039c\u03bf\u03bd\u03ac\u03b4\u03b5\u03c2 (\u039d\u039c) \u03bc\u03b5 \u03c4\u03bf\u03bd \u03af\u03b4\u03b9\u03b1 \u03b9\u03c3\u03bf\u03c4\u03b7\u03bc\u03af\u03b1 \u03cc\u03c0\u03c9\u03c2 \u03c0\u03c1\u03b9\u03bd: 10 \u039d\u039c=70 \u03c3\u03b5\u03bd\u03c4\u03c2<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">\u039c\u03b5\u03c4\u03ac \u03c4\u03b7\u03bd \u03bf\u03bb\u03bf\u03ba\u03bb\u03ae\u03c1\u03c9\u03c3\u03b7 \u03c4\u03b7\u03c2 \u03ad\u03c1\u03b5\u03c5\u03bd\u03b1\u03c2, \u03bc\u03af\u03b1 \u03b1\u03c0\u03cc \u03b1\u03c5\u03c4\u03ad\u03c2 \u03c4\u03b9\u03c2 \u03ad\u03be\u03b9 \u03ba\u03b1\u03c4\u03b1\u03c3\u03c4\u03ac\u03c3\u03b5\u03b9\u03c2 \u03b8\u03b1 \u03b5\u03c0\u03b9\u03bb\u03b5\u03b3\u03b5\u03af \u03c4\u03c5\u03c7\u03b1\u03af\u03b1 \u03ba\u03b1\u03b9 \u03c3\u03cd\u03bc\u03c6\u03c9\u03bd\u03b1 \u03bc\u03b5 \u03c4\u03b7\u03bd \u03b5\u03c0\u03b9\u03bb\u03bf\u03b3\u03ae \u03c3\u03b1\u03c2 \u03c3\u03b5 \u03b1\u03c5\u03c4\u03ae\u03bd \u03c4\u03b7\u03bd \u03ba\u03b1\u03c4\u03ac\u03c3\u03c4\u03b1\u03c3\u03b7, \u03b8\u03b1 \u03ba\u03b1\u03b8\u03bf\u03c1\u03b9\u03c3\u03c4\u03b5\u03af \u03b7 \u03b5\u03c0\u03b9\u03c0\u03bb\u03ad\u03bf\u03bd \u03c0\u03bb\u03b7\u03c1\u03c9\u03bc\u03ae \u03c3\u03b1\u03c2.<\/div>\n"},"ES":{"QuestionText":"<div style=\"text-align: center;\"><b>PARTE 5<\/b><\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">En esta parte se le pedir\u00e1 que tome seis decisiones.<br \/>\n<br \/>\nDependiendo de estas decisiones, ganar\u00e1 Unidades Monetarias (UM) adicionales en la misma tasa de conversi\u00f3n que antes.<br \/>\n<br \/>\nUna vez completada la encuesta, se elegir\u00e1 al azar una de las seis decisiones para determinar su pago. Usted y los dem\u00e1s participantes recibir\u00e1n un pago de acuerdo con sus elecciones en esta decisi\u00f3n.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n"},"FR":{"QuestionText":"<div style=\"text-align: center;\"><b>PARTIE 5<\/b><\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">Dans cette partie, il vous sera demand\u00e9 de prendre six d\u00e9cisions.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">En fonction de ces d\u00e9cisions, vous gagnerez des unit\u00e9s mon\u00e9taires (UM) suppl\u00e9mentaires au m\u00eame taux de conversation qu'auparavant.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">Une fois l'enqu\u00eate termin\u00e9e, l'une des six d\u00e9cisions sera choisie au hasard pour d\u00e9terminer votre gain. Vous et les autres participants serez r\u00e9mun\u00e9r\u00e9s selon vos choix.<\/div>\n"},"CS":{"QuestionText":"<div style=\"text-align: center;\"><b>\u010c\u00c1ST 5<\/b><\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">V t\u00e9to \u010d\u00e1sti budete po\u017e\u00e1d\u00e1n(a), abyste u\u010dinil(a) \u0161est rozhodnut\u00ed.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">V z\u00e1vislosti na t\u011bchto rozhodnut\u00edch vyhrajete dal\u0161\u00ed experiment\u00e1ln\u00ed m\u011bnov\u00e9 jednotky (EMJ), kter\u00e9 budou p\u0159epo\u010d\u00edt\u00e1ny na koruny ve stejn\u00e9m kurzu jako p\u0159edt\u00edm.\n<div class=\"elementToProof\" style=\"font-family: Aptos, Aptos_EmbeddedFont, Aptos_MSFontService, Calibri, Helvetica, sans-serif; font-size: 12pt; color: rgb(0, 0, 0);\">\u00a0<\/div>\nNa konci experimentu bude jedno ze t\u011bchto \u0161esti rozhodnut\u00ed n\u00e1hodn\u011b vybr\u00e1no a dostanete za n\u011bj zaplaceno. Kolik dostanete vy a ostatn\u00ed \u00fa\u010dastn\u00edci zaplaceno bude z\u00e1le\u017eet na tom, jak se rozhodnete.<\/div>\n"},"RU":{"QuestionText":"<div style=\"text-align: center;\"><b>\u0427\u0410\u0421\u0422\u042c 5<\/b><\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">\u0412 \u044d\u0442\u043e\u0439 \u0447\u0430\u0441\u0442\u0438 \u0412\u0430\u043c \u0431\u0443\u0434\u0435\u0442 \u043f\u0440\u0435\u0434\u043b\u043e\u0436\u0435\u043d\u043e \u043f\u0440\u0438\u043d\u044f\u0442\u044c \u0448\u0435\u0441\u0442\u044c \u0440\u0435\u0448\u0435\u043d\u0438\u0439.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">\u0412 \u0437\u0430\u0432\u0438\u0441\u0438\u043c\u043e\u0441\u0442\u0438 \u043e\u0442 \u044d\u0442\u0438\u0445 \u0440\u0435\u0448\u0435\u043d\u0438\u0439 \u0412\u044b \u0432\u044b\u0438\u0433\u0440\u0430\u0435\u0442\u0435 \u0434\u043e\u043f\u043e\u043b\u043d\u0438\u0442\u0435\u043b\u044c\u043d\u044b\u0435 \u0434\u0435\u043d\u0435\u0436\u043d\u044b\u0435 \u0435\u0434\u0438\u043d\u0438\u0446\u044b (\u0414\u0415) \u043f\u0440\u0438 \u0442\u043e\u0439 \u0436\u0435 \u043e\u0431\u043c\u0435\u043d\u043d\u043e\u0439 \u0441\u0442\u0430\u0432\u043a\u0435, \u0447\u0442\u043e \u0438 \u0440\u0430\u043d\u044c\u0448\u0435.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">\u041f\u043e\u0441\u043b\u0435 \u0437\u0430\u0432\u0435\u0440\u0448\u0435\u043d\u0438\u044f \u043e\u043f\u0440\u043e\u0441\u0430 \u043e\u0434\u043d\u043e \u0438\u0437 \u0448\u0435\u0441\u0442\u0438 \u0440\u0435\u0448\u0435\u043d\u0438\u0439 \u0431\u0443\u0434\u0435\u0442 \u0432\u044b\u0431\u0440\u0430\u043d\u043e \u0441\u043b\u0443\u0447\u0430\u0439\u043d\u044b\u043c \u043e\u0431\u0440\u0430\u0437\u043e\u043c \u0434\u043b\u044f \u043e\u043f\u0440\u0435\u0434\u0435\u043b\u0435\u043d\u0438\u044f \u0432\u0430\u0448\u0435\u0433\u043e \u0432\u044b\u0438\u0433\u0440\u044b\u0448\u0430. \u0412\u0430\u043c \u0438 \u0434\u0440\u0443\u0433\u0438\u043c \u0443\u0447\u0430\u0441\u0442\u043d\u0438\u043a\u0430\u043c \u0431\u0443\u0434\u0435\u0442 \u0432\u044b\u043f\u043b\u0430\u0447\u0435\u043d\u043e \u0432\u043e\u0437\u043d\u0430\u0433\u0440\u0430\u0436\u0434\u0435\u043d\u0438\u0435 \u0432 \u0441\u043e\u043e\u0442\u0432\u0435\u0442\u0441\u0442\u0432\u0438\u0438 \u0441 \u0432\u0430\u0448\u0438\u043c \u0432\u044b\u0431\u043e\u0440\u043e\u043c \u0432 \u044d\u0442\u043e\u043c \u0440\u0435\u0448\u0435\u043d\u0438\u0438.<\/div>\n"},"HU":{"QuestionText":"<div style=\"text-align: center;\"><b>5. R\u00c9SZ<\/b><\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">Ebben a r\u00e9szben hat d\u00f6nt\u00e9st kell meghoznia.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">A d\u00f6nt\u00e9sek alapj\u00e1n tov\u00e1bbi p\u00e9nzt (PE-ket) nyerhet, ugyanolyan \u00e1tv\u00e1lt\u00e1si \u00e1rfolyamon, mint kor\u00e1bban.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">A felm\u00e9r\u00e9s kit\u00f6lt\u00e9se ut\u00e1n a hat feladat k\u00f6z\u00fcl v\u00e9letlenszer\u0171en kiv\u00e1lasztunk egyet, amely meghat\u00e1rozza az \u00d6n kifizet\u00e9s\u00e9t. \u00d6n \u00e9s a t\u00f6bbi r\u00e9sztvev\u0151 az ebben a v\u00e9letlenszer\u0171en kiv\u00e1lasztott feladatban hozott d\u00f6nt\u00e9seiknek megfelel\u0151en kapnak kifizet\u00e9st.<\/div>\n"},"IT":{"QuestionText":"<div style=\"text-align: center;\"><b>PARTE 5<\/b><\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">In questa parte ti verr\u00e0 chiesto di prendere sei decisioni.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">A seconda di queste decisioni vincerai unit\u00e0 monetarie\u00a0(MU) extra allo stesso tasso di conversazione di prima.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">Una volta completato il lo studio, una delle sei decisioni verr\u00e0 scelta casualmente per determinare il tuo profitto. Tu e gli altri partecipanti sarete pagati in base alle vostre scelte in questa decisione.<\/div>\n"},"PL":{"QuestionText":"<div style=\"text-align: center;\"><b>CZ\u0118\u015a\u0106 5<\/b><\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">W tej cz\u0119\u015bci zostaniesz poproszony o podj\u0119cie sze\u015bciu decyzji.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">W zale\u017cno\u015bci od tych decyzji wygrasz dodatkowe jednostki monetarne (MU) przy takim samym kursie wymiany jak poprzednio.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">Po zako\u0144czeniu ankiety zostanie losowo wybrana jedna z sze\u015bciu decyzji, kt\u00f3ra okre\u015bli Twoj\u0105 wyp\u0142at\u0119. Ty i inni uczestnicy otrzymacie wynagrodzenie zgodnie z wyborami dokonanymi w tej decyzji.<\/div>\n"},"PT":{"QuestionText":"<div style=\"text-align: center;\"><b>PARTE 5<\/b><\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">Nesta parte ser-lhe-\u00e0 pedido que tome seis decis\u00f5es.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">Dependendo destas decis\u00f5es ganhar\u00e1 Unidades Monet\u00e1rias (UMs) adicionais \u00e0 mesma taxa de conversa\u00e7\u00e3o anterior.<\/div>\n\n<div style=\"text-align: center;\">\u00a0\n<div style=\"text-align: center;\">Ap\u00f3s a conclus\u00e3o do question\u00e1rio, uma das seis decis\u00f5es ser\u00e1 escolhida aleatoriamente para pagamento. Tanto o seu pagamento como o dos outros participantes ser\u00e1 determinado de acordo com as suas escolhas nesta decis\u00e3o.<\/div>\n<\/div>\n"},"ZH-S":{"QuestionText":"<div style=\"text-align: center;\"><b>\u7b2c 5 \u90e8\u5206<\/b><\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">\u5728\u6b64\u90e8\u5206\uff0c\u60a8\u5c06\u88ab\u8981\u6c42\u505a\u51fa\u516d\u4e2a\u51b3\u7b56\u3002<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">\u6839\u636e\u8fd9\u4e9b\u51b3\u7b56\uff0c\u60a8\u5c06\u4ee5\u4e0e\u4e4b\u524d\u76f8\u540c\u7684\u5151\u6362\u7387\u8d62\u5f97\u989d\u5916\u7684\u8d27\u5e01\u5355\u4f4d (MU)\u3002<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">\u8c03\u67e5\u5b8c\u6210\u540e\uff0c\u5c06\u968f\u673a\u9009\u62e9\u516d\u4e2a\u51b3\u7b56\u4e2d\u7684\u4e00\u4e2a\u6765\u786e\u5b9a\u60a8\u7684\u6536\u76ca\u3002\u60a8\u548c\u5176\u4ed6\u53c2\u4e0e\u8005\u5c06\u6839\u636e\u60a8\u5728\u8fd9\u4e2a\u51b3\u7b56\u4e2d\u7684\u9009\u62e9\u83b7\u5f97\u62a5\u916c\u3002<\/div>\n"},"FR-FR":{"QuestionText":"<div style=\"text-align: center;\"><b>PARTIE 5<\/b><\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">Dans cette partie, il vous sera demand\u00e9 de prendre six d\u00e9cisions.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\" text-align: center;\">En fonction de ces d\u00e9cisions, vous gagnerez des unit\u00e9s mon\u00e9taires (UM) suppl\u00e9mentaires au m\u00eame taux de conversion qu'auparavant.<\/div>\n\n<div style=\"text-align: center;\">\u00a0\n<div style=\"text-align: center;\">Une fois l'exp\u00e9rience termin\u00e9e, l'une des six d\u00e9cisions sera choisie au hasard pour d\u00e9terminer votre gain. Vous et les autres participants serez pay\u00e9s selon vos choix dans cette d\u00e9cision.<\/div>\n<\/div>\n"},"ES-ES":{"QuestionText":"<div style=\"text-align: center;\"><b>PARTE 5<\/b><\/div><div style=\"text-align: center;\"><br><\/div><div style= \"text-align: center;\">En esta parte se le pedir\u00e1 que tome seis decisiones.<\/div><div style=\"text-align: center;\"><br><\/div><div style=\" text-align: center;\">Dependiendo de estas decisiones, ganar\u00e1s unidades monetarias (UM) adicionales con la misma tasa de conversaci\u00f3n que antes.<\/div><div style=\"text-align: center;\"><br>< \/div>\n\n<div style=\"text-align: center;\">Una vez completada la encuesta, se elegir\u00e1 al azar una de las seis decisiones para determinar su beneficio. A usted y a los dem\u00e1s participantes se les pagar\u00e1 seg\u00fan sus elecciones en esta decisi\u00f3n.<\/div>"},"ES-AR":{"QuestionText":"<div style=\"text-align: center;\"><b>PARTE 5<\/b><br \/>\n<br \/>\nEn esta parte se le pedir\u00e1 que tome seis decisiones.<br \/>\n<br \/>\nDependiendo de estas decisiones, ganar\u00e1 unidades monetarias (UM) adicionales con la misma tasa de conversi\u00f3n que antes.<br \/>\n<br \/>\nUna vez completada la encuesta, se escoger\u00e1 una de las seis decisiones aleatoriamente para determinar su beneficio. Tanto a usted como a los dem\u00e1s participantes se les pagar\u00e1 seg\u00fan sus elecciones en esta decisi\u00f3n elegida al azar.<\/div>\n"},"JA":{"QuestionText":"<div style=\"text-align: center;\"><b>\u30d1\u30fc\u30c8 5<\/b><\/div><div style=\"text-align: center;\"><br><\/div><div style=\"text-align: center;\">\u3053\u306e\u30d1\u30fc\u30c8\u3067\u306f\u30016 \u3064\u306e\u6c7a\u5b9a\u3092\u4e0b\u3059\u3088\u3046\u6c42\u3081\u3089\u308c\u307e\u3059\u3002<\/div><div style=\"text-align: center;\"><br><\/div><div style=\"text-align: center;\">\u3053\u308c\u3089\u306e\u6c7a\u5b9a\u306b\u5fdc\u3058\u3066\u3001\u4ee5\u524d\u3068\u540c\u3058\u4ea4\u63db\u30ec\u30fc\u30c8\u3067\u8ffd\u52a0\u306e\u901a\u8ca8\u5358\u4f4d (MU) \u3092\u7372\u5f97\u3067\u304d\u307e\u3059\u3002<\/div><div style=\"text-align: center;\"><br><\/div>\n\n<div style=\"text-align: center;\">\u30a2\u30f3\u30b1\u30fc\u30c8\u304c\u5b8c\u4e86\u3059\u308b\u3068\u30016 \u3064\u306e\u6c7a\u5b9a\u306e\u3046\u3061 1 \u3064\u304c\u30e9\u30f3\u30c0\u30e0\u306b\u9078\u629e\u3055\u308c\u3001\u5831\u916c\u304c\u6c7a\u5b9a\u3055\u308c\u307e\u3059\u3002\u3042\u306a\u305f\u3068\u4ed6\u306e\u53c2\u52a0\u8005\u306b\u306f\u3001\u3053\u306e\u6c7a\u5b9a\u3067\u306e\u9078\u629e\u306b\u5fdc\u3058\u3066\u5831\u916c\u304c\u652f\u6255\u308f\u308c\u307e\u3059\u3002<\/div>"},"DE":{"QuestionText":"<div style=\"text-align: center;\"><b>TEIL 5<\/b><\/div><div style=\"text-align: center;\"><br><\/div><div style=\"text-align: center;\">In diesem Teil werden Sie gebeten, sechs Entscheidungen zu treffen.<\/div><div style=\"text-align: center;\"><br><\/div><div style=\"text-align: center;\">Abh\u00e4ngig von diesen Entscheidungen gewinnen Sie zus\u00e4tzliche Geldeinheiten (MUs) zum gleichen Konversationskurs wie zuvor.<\/div><div style=\"text-align: center;\"><br><\/div>\n\n<div style=\"text-align: center;\">Nach Abschluss der Umfrage wird eine der sechs Entscheidungen nach dem Zufallsprinzip ausgew\u00e4hlt, um Ihre Auszahlung zu bestimmen. Sie und die anderen Teilnehmer werden entsprechend Ihrer Entscheidungen bei dieser Entscheidung bezahlt.<\/div>"},"ZH-T":{"QuestionText":"<div style=\"text-align: center;\"><b>\u7b2c 5 \u90e8\u5206<\/b><\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">\u5728\u9019\u4e00\u90e8\u5206\uff0c\u60a8\u5fc5\u9808\u505a\u516d\u9805\u6c7a\u7b56\u3002<br \/>\n<br \/>\n\u60a8\u6703\u4f9d\u64da\u9019\u4e9b\u6c7a\u7b56\u984d\u5916\u7372\u5f97\u514c\u63db\u7387\u8207\u4e4b\u524d\u76f8\u540c\u7684\u6cd5\u5e63\u3002<br \/>\n\u00a0\n<div style=\"text-align: center;\">\u554f\u5377\u7d50\u675f\u5f8c\uff0c\u7cfb\u7d71\u6703\u96a8\u6a5f\u9078\u53d6\u516d\u9805\u6c7a\u7b56\u7576\u4e2d\u7684\u4e00\u9805\u4f86\u6c7a\u5b9a\u60a8\u7684\u5831\u916c\u3002\u60a8\u8207\u5176\u4ed6\u53d7\u8a66\u8005\u7684\u5831\u916c\u591a\u5be1\u5c07\u53d6\u6c7a\u65bc\u60a8\u5011\u5728\u8a72\u9805\u6c7a\u7b56\u505a\u7684\u9078\u64c7\u3002<\/div>\n<\/div>\n"},"KO":{"QuestionText":"<div style=\"text-align: center;\"><b>5\ubd80<\/b><\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">5\ubd80\uc5d0\uc11c\ub294 \uc5ec\uc12f \uac00\uc9c0 \uacb0\uc815\uc744 \ub0b4\ub824\uc57c \ud569\ub2c8\ub2e4.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">\uc774\ub7ec\ud55c \uacb0\uc815\uc5d0 \ub530\ub77c \ucd94\uac00\ub85c MU(\ud654\ud3d0 \ub2e8\uc704)\ub97c \ud68d\ub4dd\ud558\uac8c \ub418\uace0, \uc774\ub294 \uc774\uc804\uc5d0 \uc5b8\uae09\ud55c \ub3d9\uc77c\ud55c \uad50\ud658\uc728\ub85c \uad50\ud658\ub429\ub2c8\ub2e4.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">\uc124\ubb38 \uc870\uc0ac\uac00 \uc644\ub8cc\ub418\uba74 6\uac00\uc9c0 \uacb0\uc815 \uc911 \ud558\ub098\uac00 \ubb34\uc791\uc704\ub85c \uc120\ud0dd\ub429\ub2c8\ub2e4. \uadc0\ud558\uc640 \ub2e4\ub978 \ucc38\uac00\uc790\ub294 \uc774 \uacb0\uc815\uc5d0\uc11c \uc120\ud0dd\ud55c \ub0b4\uc6a9\uc5d0 \ub530\ub77c \ubcf4\uc0c1\uc744 \ubc1b\uac8c \ub429\ub2c8\ub2e4.<\/div>\n"},"EN-TW":{"QuestionText":"<div style=\"text-align: center;\"><b>PART 5<\/b><\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">In this part you will be asked to make six decisions.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">Depending on these decisions you will win extra Monetary Units (MUs) in the same conversion rate as before.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">After the survey is completed,\u00a0one of the six decisions will be randomly chosen to determine your payoff. You and the other participants will be paid according to your choices in this decision.<\/div>\n"},"DE-AT":{"QuestionText":"<div style=\"text-align: center;\"><b>TEIL 5<\/b><\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">In diesem Teil werden Sie aufgefordert, sechs Entscheidungen zu treffen.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">Abh\u00e4ngig von diesen Entscheidungen gewinnen Sie zus\u00e4tzliche Geldeinheiten (GE) zum gleichen Umrechnungskurs wie zuvor.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">Nach Abschluss der Umfrage wird eine der sechs Entscheidungen zuf\u00e4llig ausgew\u00e4hlt, um Ihre Auszahlung zu bestimmen. Sie und die anderen Teilnehmer werden entsprechend Ihrer Entscheidungen in der zuf\u00e4lli gew\u00e4hlten Entscheidungssituation bezahlt.<\/div>\n"},"TR":{"QuestionText":"<div style=\"text-align: center;\"><b>B\u00d6L\u00dcM 5<\/b><\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">Bu b\u00f6l\u00fcmde sizden 6 durum i\u00e7in karar alman\u0131z istenecektir.<br \/>\n\u00a0<\/div>\n\n<div style=\"text-align: center;\">Oturum tamamland\u0131ktan sonra, bu 6 durumdan biri rastgele se\u00e7ilecek ve oturumda yer alan t\u00fcm kat\u0131l\u0131mc\u0131lar o durum i\u00e7in ald\u0131klar\u0131 kararlara g\u00f6re DPB kazanacakt\u0131r.<\/div>\n"},"EN-UK":{"QuestionText":"<div style=\"text-align: center;\"><b>PART 5<\/b><\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">In this part you will be asked to make six decisions.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">Depending on these decisions you will win extra Monetary Units (MUs) in the same exchange rate as before.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">After the survey is completed,\u00a0one of the six decisions will be randomly chosen to determine your payoff. You and the other participants will be paid according to your choices in this decision.<\/div>\n"},"ZH-HK":{"QuestionText":"<div style=\"text-align: center;\"><b>\u7b2c5\u90e8\u5206<\/b><\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">\u5728\u9019\u4e00\u90e8\u5206\u4e2d\uff0c\u60a8\u5fc5\u9808\u505a\u516d\u9805\u6c7a\u7b56\u3002<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">\u60a8\u6703\u4f9d\u64da\u9019\u4e9b\u6c7a\u7b56\u984d\u5916\u7372\u5f97\u514c\u63db\u7387\u8207\u4e4b\u524d\u76f8\u540c\u7684\u8ca8\u5e63\u55ae\u4f4d (MU)\u3002<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">\n<p>\u554f\u5377\u7d50\u675f\u5f8c\uff0c\u7cfb\u7d71\u6703\u96a8\u6a5f\u9078\u53d6\u516d\u9805\u6c7a\u7b56\u7576\u4e2d\u7684\u4e00\u9805\u4f86\u6c7a\u5b9a\u60a8\u7684\u5831\u916c\u3002\u60a8\u8207\u5176\u4ed6\u53d7\u8a66\u8005\u7684\u5831\u916c\u591a\u5be1\u5c07\u53d6\u6c7a\u65bc\u60a8\u5011\u5728\u8a72\u9805\u6c7a\u7b56\u505a\u7684\u9078\u64c7\u3002<\/p>\n<\/div>\n"},"KZ-RU":[],"AR":{"QuestionText":"<div style=\"text-align: center;;text-align:right;direction:rtl\"><b>\u0627\u0644\u062c\u0632\u0621 \u0627\u0644\u062e\u0627\u0645\u0633<\/b><\/div>\n\n<div style=\"text-align: center;;text-align:right;direction:rtl\">\u00a0<\/div>\n\n<div style=\"text-align: center;;text-align:right;direction:rtl\">\u0641\u064a \u0647\u0630\u0627 \u0627\u0644\u062c\u0632\u0621 \u0633\u064a\u064f\u0637\u0644\u0628 \u0645\u0646\u0643 \u0627\u062a\u062e\u0627\u0630 \u0633\u062a\u0629 \u0642\u0631\u0627\u0631\u0627\u062a.<\/div>\n\n<div style=\"text-align: center;;text-align:right;direction:rtl\">\u00a0<\/div>\n\n<div style=\"text-align: center;;text-align:right;direction:rtl\">\u0627\u0639\u062a\u0645\u0627\u062f\u064b\u0627 \u0639\u0644\u0649 \u0647\u0630\u0647 \u0627\u0644\u0642\u0631\u0627\u0631\u0627\u062a\u060c \u0633\u0648\u0641 \u062a\u0631\u0628\u062d \u0648\u062d\u062f\u0627\u062a \u0646\u0642\u062f\u064a\u0629 \u0625\u0636\u0627\u0641\u064a\u0629 (\u0648.\u0646.) \u0628\u0646\u0641\u0633 \u0645\u0639\u062f\u0644 \u0627\u0644\u062a\u062d\u0648\u064a\u0644 \u0643\u0645\u0627 \u0641\u064a \u0627\u0644\u0633\u0627\u0628\u0642.<\/div>\n\n<div style=\"text-align: center;;text-align:right;direction:rtl\">\u00a0<\/div>\n\n<div style=\"text-align: center;;text-align:right;direction:rtl\">\u0628\u0639\u062f \u0627\u0644\u0627\u0646\u062a\u0647\u0627\u0621 \u0645\u0646 \u0627\u0644\u0627\u0633\u062a\u0637\u0644\u0627\u0639\u060c \u0633\u064a\u062a\u0645 \u0627\u062e\u062a\u064a\u0627\u0631 \u0623\u062d\u062f \u0627\u0644\u0642\u0631\u0627\u0631\u0627\u062a \u0627\u0644\u0633\u062a\u0629 \u0628\u0634\u0643\u0644 \u0639\u0634\u0648\u0627\u0626\u064a \u0644\u062a\u062d\u062f\u064a\u062f \u0645\u0643\u0627\u0641\u0623\u062a\u0643. \u0633\u064a\u062a\u0645 \u0627\u0644\u062f\u0641\u0639 \u0644\u0643 \u0648\u0644\u0644\u0645\u0634\u0627\u0631\u0643\u064a\u0646 \u0627\u0644\u0622\u062e\u0631\u064a\u0646 \u0648\u0641\u0642\u064b\u0627 \u0644\u0627\u062e\u062a\u064a\u0627\u0631\u0627\u062a\u0643 \u0641\u064a \u0647\u0630\u0627 \u0627\u0644\u0642\u0631\u0627\u0631.<\/div>\n"},"DE-DE":{"QuestionText":"<div style=\"text-align: center;\"><b>TEIL 5<\/b><\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">In diesem Teil werden Sie aufgefordert, sechs Entscheidungen zu treffen.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">Abh\u00e4ngig von diesen Entscheidungen gewinnen Sie zus\u00e4tzliche Geldeinheiten (GE) zum gleichen Umrechnungskurs wie zuvor.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">Nach Abschluss der Umfrage wird eine der sechs Entscheidungen nach dem Zufallsprinzip ausgew\u00e4hlt, um Ihre Auszahlung zu bestimmen. Sie und die anderen TeilnehmerInnen werden entsprechend Ihrer Entscheidungen bei dieser Entscheidung bezahlt.<\/div>\n"}},"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID238","DataVisibility":{"Private":false,"Hidden":false},"QuestionText_Unsafe":"<div style=\"text-align: center;\"><b>PART 5<\/b><\/div><div style=\"text-align: center;\"><br><\/div><div style=\"text-align: center;\">In this part you will be asked to make six decisions.<\/div><div style=\"text-align: center;\"><br><\/div><div style=\"text-align: center;\">Depending on these decisions you will win extra Monetary Units (MUs) in the same conversation rate as before.<\/div><div style=\"text-align: center;\"><br><\/div>\n\n<div style=\"text-align: center;\">After the survey is completed,&nbsp;one of the six decisions will be randomly chosen to determine your payoff. You and the other participants will be paid according to your choices in this decision.<\/div>"}},{"SurveyID":"SV_b3mHBVkuioRMhng","Element":"SQ","PrimaryAttribute":"QID239","SecondaryAttribute":"Each decision consists of choosing between two allocations of monetary points units between yours...","TertiaryAttribute":null,"Payload":{"QuestionText":"<div style=\"text-align: center;\">Each decision consists of choosing between two allocations of monetary points units between yourself and another participant in the room: \u201cOption A\u201d and \u201cOption B\u201d.<\/div><div style=\"text-align: center;\"><br><\/div><div style=\"text-align: center;\">For example:<\/div><div style=\"text-align: center;\">Option A: 10 MUs for you and 10 MUs for the other participant.&nbsp;<\/div><div style=\"text-align: center;\">Option B: 12 MUs for you and 8 MUs for the other participant.&nbsp;<\/div><div style=\"text-align: center;\"><br>\nOption A will be the same across the six decisions: 10 MUs for you and 10 MUs for the other participant. However, the allocation in Option B will change each time.<\/div><div style=\"text-align: center;\"><br><\/div><div style=\"text-align: center;\">In each decision, you will be paired with a different participant in the room.<br>\n<br>\nNote that the other participant will never be informed of your personal identity and you will not be informed of the other participant\u2019s personal identity.<br>\n<br>\nIf you are ready to begin, go to the next page<\/div>","DefaultChoices":false,"DataExportTag":"MD_Intro2","QuestionID":"QID239","QuestionType":"DB","Selector":"TB","Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Each decision consists of choosing between two allocations of monetary points units between yours...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":{"ES":{"QuestionText":"<div style=\"text-align: center;\">Cada decisi\u00f3n consiste en elegir entre dos asignaciones de UM entre usted y el otro participante: \u201cOpci\u00f3n A\u201d y \u201cOpci\u00f3n B\u201d.<br \/>\n<br \/>\nPor ejemplo:<br \/>\nOpci\u00f3n A: 10 UMs para usted y 10 UMs para el otro participante.<br \/>\nOpci\u00f3n B: 12 UMs para usted y 8 UMs para el otro participante.<br \/>\n<br \/>\nLa opci\u00f3n A ser\u00e1 la misma en las seis decisiones: 10 UM para usted y 10 UM para el otro participante. Sin embargo, la asignaci\u00f3n en la Opci\u00f3n B cambiar\u00e1 en cada decisi\u00f3n.<br \/>\n<br \/>\nEn cada decisi\u00f3n, se le emparejar\u00e1 con un participante diferente en la sala.<br \/>\nLe puede tocar tanto ser quien toma la decisi\u00f3n como quien recibe la asignaci\u00f3n que decida el otro participante.<br \/>\n<br \/>\nTenga en cuenta que el otro participante nunca ser\u00e1 informado de su identidad personal y usted no ser\u00e1 informado de la identidad personal del otro participante.<br \/>\n<br \/>\nSi est\u00e1 listo para comenzar, vaya a la p\u00e1gina siguiente.<\/div>\n"},"EL":{"QuestionText":"<div style=\"text-align: center;\">\u039a\u03ac\u03b8\u03b5 \u03ba\u03b1\u03c4\u03ac\u03c3\u03c4\u03b1\u03c3\u03b7 \u03c3\u03c5\u03bd\u03af\u03c3\u03c4\u03b1\u03c4\u03b1\u03b9 \u03c3\u03c4\u03b7\u03bd \u03b5\u03c0\u03b9\u03bb\u03bf\u03b3\u03ae \u03bc\u03b5\u03c4\u03b1\u03be\u03cd \u03b4\u03cd\u03bf \u03c0\u03b9\u03b8\u03b1\u03bd\u03ce\u03bd \u03ba\u03b1\u03c4\u03b1\u03bd\u03bf\u03bc\u03ce\u03bd \u03bd\u03bf\u03bc\u03b7\u03c3\u03bc\u03b1\u03c4\u03b9\u03ba\u03ce\u03bd \u03bc\u03bf\u03bd\u03ac\u03b4\u03c9\u03bd \u03bc\u03b5\u03c4\u03b1\u03be\u03cd \u03b5\u03c3\u03ac\u03c2 \u03ba\u03b1\u03b9 \u03b5\u03bd\u03cc\u03c2 \u03ac\u03bb\u03bb\u03bf\u03c5\u00a0(\u03c4\u03c5\u03c7\u03b1\u03af\u03b1 \u03b5\u03c0\u03b9\u03bb\u03b5\u03b3\u03bc\u03ad\u03bd\u03bf\u03c5) \u03c3\u03c5\u03bc\u03bc\u03b5\u03c4\u03ad\u03c7\u03bf\u03bd\u03c4\u03b1 \u03c3\u03c4\u03b7\u03bd \u03b1\u03af\u03b8\u03bf\u03c5\u03c3\u03b1: \u00ab\u039a\u03b1\u03c4\u03b1\u03bd\u03bf\u03bc\u03ae \u0391\u00bb \u03ba\u03b1\u03b9 \u00ab\u039a\u03b1\u03c4\u03b1\u03bd\u03bf\u03bc\u03ae \u0392\u00bb.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">\u0393\u03b9\u03b1 \u03c0\u03b1\u03c1\u03ac\u03b4\u03b5\u03b9\u03b3\u03bc\u03b1:<\/div>\n\n<div style=\"text-align: center;\"><strong>\u039a\u03b1\u03c4\u03b1\u03bd\u03bf\u03bc\u03ae \u0391<\/strong>: 10 \u039d\u039c \u03b3\u03b9\u03b1 \u03b5\u03c3\u03ac\u03c2 \u03ba\u03b1\u03b9 10 \u039d\u039c \u03b3\u03b9\u03b1 \u03c4\u03bf\u03bd \u03ac\u03bb\u03bb\u03bf \u03c3\u03c5\u03bc\u03bc\u03b5\u03c4\u03ad\u03c7\u03bf\u03bd\u03c4\u03b1.<\/div>\n\n<div style=\"text-align: center;\"><strong>\u039a\u03b1\u03c4\u03b1\u03bd\u03bf\u03bc\u03ae \u0392:<\/strong> 12 \u039d\u039c \u03b3\u03b9\u03b1 \u03b5\u03c3\u03ac\u03c2 \u03ba\u03b1\u03b9 8 \u039d\u039c \u03b3\u03b9\u03b1 \u03c4\u03bf\u03bd \u03ac\u03bb\u03bb\u03bf \u03c3\u03c5\u03bc\u03bc\u03b5\u03c4\u03ad\u03c7\u03bf\u03bd\u03c4\u03b1.<\/div>\n\n<div style=\"text-align: center;\"><br \/>\n\u0397 \u03ba\u03b1\u03c4\u03b1\u03bd\u03bf\u03bc\u03ae \u0391 \u03b8\u03b1 \u03b5\u03af\u03bd\u03b1\u03b9 \u03b7 \u03af\u03b4\u03b9\u03b1 \u03b3\u03b9\u03b1 \u03c4\u03b9\u03c2 \u03ad\u03be\u03b9 \u03b1\u03c0\u03bf\u03c6\u03ac\u03c3\u03b5\u03b9\u03c2: 10 \u039d\u039c \u03b3\u03b9\u03b1 \u03b5\u03c3\u03ac\u03c2 \u03ba\u03b1\u03b9 10 \u039d\u039c \u03b3\u03b9\u03b1 \u03c4\u03bf\u03bd \u03ac\u03bb\u03bb\u03bf \u03c3\u03c5\u03bc\u03bc\u03b5\u03c4\u03ad\u03c7\u03bf\u03bd\u03c4\u03b1. \u03a9\u03c3\u03c4\u03cc\u03c3\u03bf, \u03b7 \u03ba\u03b1\u03c4\u03b1\u03bd\u03bf\u03bc\u03ae \u03c3\u03c4\u03b7\u03bd \u03ba\u03b1\u03c4\u03b1\u03bd\u03bf\u03bc\u03ae \u0392 \u03b8\u03b1 \u03b1\u03bb\u03bb\u03ac\u03b6\u03b5\u03b9 \u03ba\u03ac\u03b8\u03b5 \u03c6\u03bf\u03c1\u03ac.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">\u03a3\u03b5 \u03ba\u03ac\u03b8\u03b5 \u03b1\u03c0\u03cc\u03c6\u03b1\u03c3\u03b7, \u03b8\u03b1 \u03c0\u03b1\u03b9\u03be\u03b5\u03c4\u03b5 \u03bc\u03b5 \u03b4\u03b9\u03b1\u03c6\u03bf\u03c1\u03b5\u03c4\u03b9\u03ba\u03cc \u03c3\u03c5\u03bc\u03bc\u03b5\u03c4\u03ad\u03c7\u03bf\u03bd\u03c4\u03b1 \u03c3\u03c4\u03bf \u03b4\u03c9\u03bc\u03ac\u03c4\u03b9\u03bf.\u00a0\u03a3\u03b7\u03bc\u03b5\u03b9\u03ce\u03c3\u03c4\u03b5 \u03cc\u03bc\u03c9\u03c2 \u03cc\u03c4\u03b9 \u03c0\u03bf\u03c4\u03ad \u03b4\u03b5 \u03b8\u03b1 \u03bc\u03ac\u03b8\u03b5\u03c4\u03b5 \u03c4\u03b7\u03bd\u00a0\u03c4\u03b1\u03c5\u03c4\u03cc\u03c4\u03b7\u03c4\u03b1 \u03c4\u03c9\u03bd \u03ac\u03bb\u03bb\u03c9\u03bd, \u03bf\u03cd\u03c4\u03b5 \u03b1\u03c5\u03c4\u03bf\u03af \u03c4\u03b7 \u03b4\u03b9\u03ba\u03ae \u03c3\u03b1\u03c2.<br \/>\n<br \/>\n\u0395\u03ac\u03bd \u03b5\u03af\u03c3\u03c4\u03b5 \u03ad\u03c4\u03bf\u03b9\u03bc\u03bf\u03b9 \u03bd\u03b1 \u03be\u03b5\u03ba\u03b9\u03bd\u03ae\u03c3\u03b5\u03c4\u03b5, \u03bc\u03b5\u03c4\u03b1\u03b2\u03b5\u03af\u03c4\u03b5 \u03c3\u03c4\u03b7\u03bd \u03b5\u03c0\u03cc\u03bc\u03b5\u03bd\u03b7 \u03c3\u03b5\u03bb\u03af\u03b4\u03b1.<\/div>\n"},"FR":{"QuestionText":"<div style=\"text-align: center;\">Chaque d\u00e9cision consiste \u00e0 choisir entre deux allocations d'unit\u00e9s de points mon\u00e9taires entre vous et un autre participant dans la salle : \u00ab Option A \u00bb et \u00ab Option B \u00bb.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">Par exemple:<\/div>\n\n<div style=\"text-align: center;\">Option A : 10 UM pour vous et 10 UM pour l'autre participant.<\/div>\n\n<div style=\"text-align: center;\">Option B : 12 UM pour vous et 8 UM pour l'autre participant.<\/div>\n\n<div style=\"text-align: center;\"><br \/>\nL'option A sera la m\u00eame pour les six d\u00e9cisions : 10 UM pour vous et 10 UM pour l'autre participant. Cependant, la r\u00e9partition dans l'option B changera \u00e0 chaque fois.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">Pour chaque d\u00e9cision, vous serez associ\u00e9 \u00e0 un participant diff\u00e9rent dans la salle.<br \/>\n<br \/>\nNotez que l'autre participant ne sera jamais inform\u00e9 de votre identit\u00e9 personnelle et que vous ne serez pas inform\u00e9 de son identit\u00e9 non plus.<br \/>\n<br \/>\nSi vous \u00eates pr\u00eat \u00e0 commencer, passez \u00e0 la page suivante<\/div>\n"},"CS":{"QuestionText":"<div style=\"text-align: center;\">Ka\u017ed\u00e9 rozhodnut\u00ed spo\u010d\u00edv\u00e1 ve tom, \u017ee si must\u00edte vybrat mezi dv\u011bmi rozdel\u011bn\u00edmi EMJ mezi v\u00e1mi a dal\u0161\u00edm \u00fa\u010dastn\u00edkem zde v m\u00edstnosti, kter\u00fdm budeme \u0159\u00edkat \u201eMo\u017enost A\u201c a \u201eMo\u017enost B\u201c.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">Nap\u0159\u00edklad:<\/div>\n\n<div style=\"text-align: center;\">Mo\u017enost A: 10 EMJ pro V\u00e1s a 10 EMJ pro jin\u00e9ho \u00fa\u010dastn\u00edka.<\/div>\n\n<div style=\"text-align: center;\">Mo\u017enost B: 12 EMJ pro V\u00e1s a 8 EMJ pro jin\u00e9ho \u00fa\u010dastn\u00edka.<\/div>\n\n<div style=\"text-align: center;\"><br \/>\nMo\u017enost A bude stejn\u00e1 b\u011bhem v\u0161ech \u0161esti rozhodnut\u00edch: 10 EMJ pro V\u00e1s a 10 EMJ pro jin\u00e9ho \u00fa\u010dastn\u00edka. Rozd\u011blen\u00ed EMJ v Mo\u017enosti B v\u0161ak bude poka\u017ed\u00e9 jin\u00e9.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">V ka\u017ed\u00e9m rozhodnut\u00ed se budete d\u011blit s jin\u00fdm \u00fa\u010dastn\u00edkem z t\u00e9to m\u00edstnosti.\u00a0Tak\u00e9 dostanete zaplaceno na z\u00e1klad\u011b n\u00e1hodn\u011b vybran\u00e9ho rozhodnut\u00ed jin\u00e9ho rozhodovatele, pro kter\u00e9ho vy jste t\u00edm jin\u00fdm \u00fa\u010dastn\u00edkem.<br \/>\n<br \/>\nM\u011bjte na pam\u011bti, \u017ee ostatn\u00ed \u00fa\u010dastn\u00edci, se kter\u00fdmi budete v t\u00e9to h\u0159e sp\u00e1rovan\u00ed, nebudou informov\u00e1n\u00ed o Va\u0161\u00ed identit\u011b a Vy nebudete informov\u00e1n\u00ed o jejich identit\u011b.\u00a0<br \/>\n<br \/>\nPokud jste p\u0159ipraveni za\u010d\u00edt, p\u0159ejd\u011bte na dal\u0161\u00ed str\u00e1nku<\/div>\n"},"RU":{"QuestionText":"<div style=\"text-align: center;\">\u041a\u0430\u0436\u0434\u043e\u0435 \u0440\u0435\u0448\u0435\u043d\u0438\u0435 \u0441\u043e\u0441\u0442\u043e\u0438\u0442 \u0438\u0437 \u0432\u044b\u0431\u043e\u0440\u0430 \u043c\u0435\u0436\u0434\u0443 \u0434\u0432\u0443\u043c\u044f \u0440\u0430\u0441\u043f\u0440\u0435\u0434\u0435\u043b\u0435\u043d\u0438\u044f\u043c\u0438 \u0434\u0435\u043d\u0435\u0436\u043d\u044b\u0445 \u0435\u0434\u0438\u043d\u0438\u0446 \u043c\u0435\u0436\u0434\u0443 \u0412\u0430\u043c\u0438 \u0438 \u0434\u0440\u0443\u0433\u0438\u043c \u0443\u0447\u0430\u0441\u0442\u043d\u0438\u043a\u043e\u043c \u044d\u0442\u043e\u0439 \u0441\u0435\u0441\u0441\u0438\u0438: \u00ab\u0412\u0430\u0440\u0438\u0430\u043d\u0442 \u0410\u00bb \u0438 \u00ab\u0412\u0430\u0440\u0438\u0430\u043d\u0442 \u0411\u00bb.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">\u041d\u0430\u043f\u0440\u0438\u043c\u0435\u0440:<\/div>\n\n<div style=\"text-align: center;\">\u0412\u0430\u0440\u0438\u0430\u043d\u0442 \u0410: 10 \u0414\u0415 \u0434\u043b\u044f \u0412\u0430\u0441 \u0438 10 \u0414\u0415 \u0434\u043b\u044f \u0434\u0440\u0443\u0433\u043e\u0433\u043e \u0443\u0447\u0430\u0441\u0442\u043d\u0438\u043a\u0430.<\/div>\n\n<div style=\"text-align: center;\">\u0412\u0430\u0440\u0438\u0430\u043d\u0442 \u0411: 12 \u0414\u0415 \u0434\u043b\u044f \u0412\u0430\u0441 \u0438 8 \u0414\u0415 \u0434\u043b\u044f \u0434\u0440\u0443\u0433\u043e\u0433\u043e \u0443\u0447\u0430\u0441\u0442\u043d\u0438\u043a\u0430.<\/div>\n\n<div style=\"text-align: center;\"><br \/>\n\u0412\u0430\u0440\u0438\u0430\u043d\u0442 \u0410 \u0431\u0443\u0434\u0435\u0442 \u043e\u0434\u0438\u043d\u0430\u043a\u043e\u0432\u044b\u043c \u0434\u043b\u044f \u0432\u0441\u0435\u0445 \u0448\u0435\u0441\u0442\u0438 \u0440\u0435\u0448\u0435\u043d\u0438\u0439: 10 \u0414\u0415 \u0434\u043b\u044f \u0412\u0430\u0441 \u0438 10 \u0414\u0415 \u0434\u043b\u044f \u0434\u0440\u0443\u0433\u043e\u0433\u043e \u0443\u0447\u0430\u0441\u0442\u043d\u0438\u043a\u0430. \u041e\u0434\u043d\u0430\u043a\u043e \u0440\u0430\u0441\u043f\u0440\u0435\u0434\u0435\u043b\u0435\u043d\u0438\u0435 \u0432 \u0412\u0430\u0440\u0438\u0430\u043d\u0442\u0435 \u0411 \u0431\u0443\u0434\u0435\u0442 \u043c\u0435\u043d\u044f\u0442\u044c\u0441\u044f \u043a\u0430\u0436\u0434\u044b\u0439 \u0440\u0430\u0437.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">\u0412 \u043a\u0430\u0436\u0434\u043e\u043c \u0440\u0435\u0448\u0435\u043d\u0438\u0438 \u0412\u044b \u0431\u0443\u0434\u0435\u0442\u0435 \u0432 \u043f\u0430\u0440\u0435 \u0441 \u0440\u0430\u0437\u043d\u044b\u043c\u0438 \u0443\u0447\u0430\u0441\u0442\u043d\u0438\u043a\u0430\u043c\u0438 \u0438\u0437 \u044d\u0442\u043e\u0439 \u0441\u0435\u0441\u0441\u0438\u0438.<br \/>\n<br \/>\n\u041e\u0431\u0440\u0430\u0442\u0438\u0442\u0435 \u0432\u043d\u0438\u043c\u0430\u043d\u0438\u0435, \u0447\u0442\u043e \u0434\u0440\u0443\u0433\u043e\u0439 \u0443\u0447\u0430\u0441\u0442\u043d\u0438\u043a \u043d\u0438\u043a\u043e\u0433\u0434\u0430 \u043d\u0435 \u0431\u0443\u0434\u0435\u0442 \u043f\u0440\u043e\u0438\u043d\u0444\u043e\u0440\u043c\u0438\u0440\u043e\u0432\u0430\u043d \u043e \u0442\u043e\u043c, \u043a\u0442\u043e \u0412\u044b, \u0430 \u0412\u044b \u043d\u0435 \u0431\u0443\u0434\u0435\u0442\u0435 \u043f\u0440\u043e\u0438\u043d\u0444\u043e\u0440\u043c\u0438\u0440\u043e\u0432\u0430\u043d\u044b \u043e \u043b\u0438\u0447\u043d\u043e\u0441\u0442\u0438 \u0434\u0440\u0443\u0433\u043e\u0433\u043e \u0443\u0447\u0430\u0441\u0442\u043d\u0438\u043a\u0430.<br \/>\n<br \/>\n\u0415\u0441\u043b\u0438 \u0412\u044b \u0433\u043e\u0442\u043e\u0432\u044b \u043d\u0430\u0447\u0430\u0442\u044c, \u043f\u0435\u0440\u0435\u0439\u0434\u0438\u0442\u0435 \u043d\u0430 \u0441\u043b\u0435\u0434\u0443\u044e\u0449\u0443\u044e \u0441\u0442\u0440\u0430\u043d\u0438\u0446\u0443.<\/div>\n"},"HU":{"QuestionText":"<div style=\"text-align: center;\">Minden d\u00f6nt\u00e9s abb\u00f3l \u00e1ll, hogy k\u00e9t p\u00e9nzfeloszt\u00e1s (\u201eA lehet\u0151s\u00e9g\u201d \u00e9s \u201eB lehet\u0151s\u00e9g\u201d) k\u00f6z\u00fcl kell v\u00e1lasztania, ami meghat\u00e1rozza a kifizet\u00e9seket \u00f6nmaga \u00e9s a teremben tart\u00f3zkod\u00f3 m\u00e1sik r\u00e9sztvev\u0151 sz\u00e1m\u00e1ra.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">P\u00e9ld\u00e1ul:<\/div>\n\n<div style=\"text-align: center;\">A lehet\u0151s\u00e9g: 10 PE nekem \u00e9s 10 PE a m\u00e1sik r\u00e9sztvev\u0151nek.<\/div>\n\n<div style=\"text-align: center;\">B lehet\u0151s\u00e9g: 12 PE nekem \u00e9s 8 PE a m\u00e1sik r\u00e9sztvev\u0151nek.<\/div>\n\n<div style=\"text-align: center;\"><br \/>\nAz A lehet\u0151s\u00e9g ugyanaz lesz a hat d\u00f6nt\u00e9s sor\u00e1n: 10 PE az \u00d6n sz\u00e1m\u00e1ra \u00e9s 10 PE a m\u00e1sik r\u00e9sztvev\u0151 sz\u00e1m\u00e1ra. A B lehet\u0151s\u00e9g azonban minden alkalommal m\u00e1s lesz.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">Minden d\u00f6nt\u00e9sn\u00e9l m\u00e1s-m\u00e1s r\u00e9sztvev\u0151vel lesz \u00f6sszep\u00e1ros\u00edtva.<br \/>\n<br \/>\nNe feledje, hogy a m\u00e1sik r\u00e9sztvev\u0151 soha nem fogja megtudni az \u00d6n szem\u00e9lyazonoss\u00e1g\u00e1t, \u00e9s \u00d6n sem fogja megtudni a m\u00e1sik r\u00e9sztvev\u0151 szem\u00e9lyazonoss\u00e1g\u00e1t.<br \/>\n<br \/>\nHa k\u00e9szen \u00e1ll a kezd\u00e9sre, l\u00e9pjen a k\u00f6vetkez\u0151 oldalra!<\/div>\n"},"IT":{"QuestionText":"<div style=\"text-align: center;\">Ogni decisione consiste nello scegliere tra due assegnazioni di MU tra te e un altro partecipante nella stanza: \u201cOpzione A\u201d e \u201cOpzione B\u201d.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">Per esempio:<\/div>\n\n<div style=\"text-align: center;\">Opzione A: 10 MU per te e 10 MU per l'altro partecipante.<\/div>\n\n<div style=\"text-align: center;\">Opzione B: 12 \u200b\u200bMU per te e 8 MU per l'altro partecipante.<\/div>\n\n<div style=\"text-align: center;\"><br \/>\nL'opzione A sar\u00e0 la stessa per tutte le sei decisioni: 10 MU per te e 10 MU per l'altro partecipante. Tuttavia, l\u2019assegnazione nell\u2019Opzione B cambier\u00e0 ogni volta.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">In ogni decisione, verrai accoppiato con un partecipante diverso nella stanza.<br \/>\n<br \/>\nTieni presente che l'altro partecipante non verr\u00e0 mai informato della tua identit\u00e0 personale e tu non sarai mai informato dell'identit\u00e0 personale dell'altro partecipante.<br \/>\n<br \/>\nSe sei pronto per iniziare, vai alla pagina successiva<\/div>\n"},"PL":{"QuestionText":"<div style=\"text-align: center;\">Ka\u017cda decyzja polega na wyborze pomi\u0119dzy dwoma przydzia\u0142ami jednostek punkt\u00f3w pieni\u0119\u017cnych pomi\u0119dzy tob\u0105 a innym uczestnikiem pokoju: \u201eOpcja A\u201d i \u201eOpcja B\u201d.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">Na przyk\u0142ad:<\/div>\n\n<div style=\"text-align: center;\">Opcja A: 10 jednostek MU dla Ciebie i 10 jednostek MU dla drugiego uczestnika.<\/div>\n\n<div style=\"text-align: center;\">Opcja B: 12 \u200b\u200bjednostek MU dla Ciebie i 8 jednostek MU dla drugiego uczestnika.<\/div>\n\n<div style=\"text-align: center;\"><br \/>\nOpcja A b\u0119dzie taka sama w przypadku sze\u015bciu decyzji: 10 jednostek MU dla Ciebie i 10 jednostek MU dla drugiego uczestnika. Jednak\u017ce podzia\u0142 MU w Opcji B b\u0119dzie si\u0119 ka\u017cdorazowo zmienia\u0107.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">W ka\u017cdej decyzji zostaniesz po\u0142\u0105czony w par\u0119 z innym uczestnikiem pokoju.<br \/>\n<br \/>\nPami\u0119taj, \u017ce drugi uczestnik nigdy nie zostanie poinformowany o Twojej to\u017csamo\u015bci, a Ty nie zostaniesz poinformowany o to\u017csamo\u015bci drugiej uczestnika.<br \/>\n<br \/>\nJe\u015bli jeste\u015b gotowy, aby rozpocz\u0105\u0107, przejd\u017a do nast\u0119pnej strony<\/div>\n"},"PT":{"QuestionText":"<div style=\"text-align: center;\">Cada decis\u00e3o consiste em escolher entre duas aloca\u00e7\u00f5es de UMs<span style=\"font-family:Arial,Helvetica,sans-serif;\">\u00a0en<\/span>tre si e outro participante da sala: \u201cOp\u00e7\u00e3o A\u201d e \u201cOp\u00e7\u00e3o B\u201d.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">Por exemplo:<\/div>\n\n<div style=\"text-align: center;\">Op\u00e7\u00e3o A: 10 UMs para si e 10 UMs para o outro participante.<\/div>\n\n<div style=\"text-align: center;\">Op\u00e7\u00e3o B: 12 UMs para si e 8 UMs para o outro participante. \u00a0<\/div>\n\n<div style=\"text-align: center;\"><br \/>\nA op\u00e7\u00e3o A ser\u00e1 a mesma nas seis decis\u00f5es: 10 UMs para si e 10 UMs para o outro participante. No entanto, a aloca\u00e7\u00e3o na Op\u00e7\u00e3o B mudar\u00e1 em cada decis\u00e3o.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">Em cada decis\u00e3o, ser\u00e1 emparelhado com um participante diferente da sala.<br \/>\n<br \/>\nNote que o outro participante nunca ser\u00e1 informado sobre sua identidade pessoal, tal como n\u00e3o ser\u00e1 informado sobre a identidade pessoal do outro participante.<br \/>\n<br \/>\nSe estiver preparado para come\u00e7ar, v\u00e1 para a pr\u00f3xima p\u00e1gina<\/div>\n"},"ZH-S":{"QuestionText":"<div style=\"text-align: center;\">\u6bcf\u4e2a\u51b3\u7b56\u90fd\u5728\u60a8\u81ea\u5df1\u548c\u623f\u95f4\u4e2d\u7684\u53e6\u4e00\u4e2a\u53c2\u4e0e\u8005\u4e4b\u95f4\u8fdb\u884c\uff0c\u5305\u542b\u4e24\u79cd\u8d27\u5e01\u70b9\u6570\u5206\u914d\u7684\u9009\u62e9\uff1a\u201c\u9009\u9879 A\u201d\u548c\u201c\u9009\u9879 B\u201d\u3002<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">\u4f8b\u5982\uff1a<\/div>\n\n<div style=\"text-align: center;\">\u9009\u9879 A\uff1a\u60a8\u83b7\u5f97 10 \u4e2a MU\uff0c\u53e6\u4e00\u4e2a\u53c2\u4e0e\u8005\u83b7\u5f97 10 \u4e2a MU\u3002<\/div>\n\n<div style=\"text-align: center;\">\u9009\u9879 B\uff1a\u60a8\u83b7\u5f97 12 \u4e2a MU\uff0c\u53e6\u4e00\u4e2a\u53c2\u4e0e\u8005\u83b7\u5f97 8 \u4e2a MU\u3002<\/div>\n\n<div style=\"text-align: center;\"><br \/>\n\u9009\u9879 A \u5728\u516d\u4e2a\u51b3\u7b56\u4e2d\u5747\u76f8\u540c\uff1a\u60a8\u83b7\u5f97 10 \u4e2a MU\uff0c\u53e6\u4e00\u4e2a\u53c2\u4e0e\u8005\u83b7\u5f97 10 \u4e2a MU\u3002\u4f46\u662f\uff0c\u9009\u9879 B \u4e2d\u7684\u5206\u914d\u6bcf\u6b21\u90fd\u4f1a\u53d1\u751f\u53d8\u5316\u3002<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">\u5728\u6bcf\u6b21\u51b3\u7b56\u4e2d\uff0c\u60a8\u90fd\u4f1a\u4e0e\u623f\u95f4\u4e2d\u7684\u4e0d\u540c\u53c2\u4e0e\u8005\u914d\u5bf9\u3002<br \/>\n<br \/>\n\u8bf7\u6ce8\u610f\uff0c\u5176\u4ed6\u53c2\u4e0e\u8005\u6c38\u8fdc\u4e0d\u4f1a\u88ab\u544a\u77e5\u60a8\u7684\u4e2a\u4eba\u8eab\u4efd\uff0c\u60a8\u4e5f\u4e0d\u4f1a\u88ab\u544a\u77e5\u5176\u4ed6\u53c2\u4e0e\u8005\u7684\u4e2a\u4eba\u8eab\u4efd\u3002<br \/>\n<br \/>\n\u5982\u679c\u60a8\u5df2\u51c6\u5907\u597d\u5f00\u59cb\uff0c\u8bf7\u8f6c\u5230\u4e0b\u4e00\u9875<\/div>\n"},"FR-FR":{"QuestionText":"<div style=\"text-align: center;\">Chaque d\u00e9cision consiste \u00e0 choisir entre deux r\u00e9partitions d'unit\u00e9s mon\u00e9taires (UM) entre vous et un autre participant dans la session : \u00ab Option A \u00bb et \u00ab Option B \u00bb.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">Par exemple\u00a0:<\/div>\n\n<div style=\"text-align: center;\">Option A\u00a0: 10 UM pour vous et 10 UM pour l'autre participant.\u00a0<\/div>\n\n<div style=\"text-align: center;\">Option B\u00a0: 12 UM pour vous et 8 UM pour l'autre participant. \u00a0<\/div>\n\n<div style=\"text-align: center;\"><br \/>\nL'option A sera la m\u00eame pour les six d\u00e9cisions : 10 UM pour vous et 10 UM pour l'autre participant. En revanche, la r\u00e9partition dans l'option B changera \u00e0 chaque fois.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">\u00c0 chaque d\u00e9cision, vous serez jumel\u00e9 au hasard \u00e0 un autre participant dans la session.<br \/>\n<br \/>\nNotez que l'autre participant ne sera jamais inform\u00e9 de votre identit\u00e9, et vous ne serez pas non plus inform\u00e9 de son identit\u00e9.<br \/>\n<br \/>\nSi vous \u00eates pr\u00eat \u00e0 commencer, passez \u00e0 la page suivante.<\/div>\n"},"ES-ES":{"QuestionText":"<div style=\"text-align: center;\">Cada decisi\u00f3n consiste en elegir entre dos asignaciones de unidades de puntos monetarios entre usted y otro participante de la sala: \u201cOpci\u00f3n A\u201d y \u201cOpci\u00f3n B\u201d.<\/div><div style=\"text-align: center;\"><br><\/div><div style=\"text-align: center;\">Por ejemplo:<\/div><div style=\"text-align: center;\" >Opci\u00f3n A: 10 MU para usted y 10 MU para el otro participante.<\/div><div style=\"text-align: center;\">Opci\u00f3n B: 12 MU para usted y 8 MU para el otro participante. &nbsp;<\/div><div style=\"text-align: center;\"><br>\nLa opci\u00f3n A ser\u00e1 la misma en las seis decisiones: 10 MU para usted y 10 MU para el otro participante. Sin embargo, la asignaci\u00f3n en la Opci\u00f3n B cambiar\u00e1 cada vez.<\/div><div style=\"text-align: center;\"><br><\/div><div style=\"text-align: center;\">En En cada decisi\u00f3n, se le asignar\u00e1 un participante diferente en la sala.<br>\n<br>\nTenga en cuenta que el otro participante nunca ser\u00e1 informado de su identidad personal y usted no ser\u00e1 informado de la identidad personal del otro participante.<br>\n<br>\nSi est\u00e1 listo para comenzar, vaya a la p\u00e1gina siguiente<\/div>"},"ES-AR":{"QuestionText":"<div style=\"text-align: center;\">Cada decisi\u00f3n consiste en elegir entre dos asignaciones de unidades monetarias entre usted y otro participante de la sala: \u201cOpci\u00f3n A\u201d y \u201cOpci\u00f3n B\u201d.<br \/>\n<br \/>\nPor ejemplo:<br \/>\nOpci\u00f3n A: 10 UM para usted y 10 UM para el otro participante.<br \/>\nOpci\u00f3n B: 12 UM para usted y 8 UM para el otro participante. \u00a0<br \/>\nLa opci\u00f3n A ser\u00e1 la misma en las seis decisiones: 10 UM para usted y 10 UM para el otro participante. Sin embargo, la asignaci\u00f3n en la Opci\u00f3n B cambiar\u00e1 cada vez.<br \/>\n<br \/>\nEn cada decisi\u00f3n, se le asignar\u00e1 un participante diferente en la sala.<br \/>\n<br \/>\nTenga en cuenta que el otro participante nunca ser\u00e1 informado de su identidad personal y usted no ser\u00e1 informado de la identidad personal del otro participante.<\/div>\n<br \/>\nSi est\u00e1 listo para comenzar, vaya a la p\u00e1gina siguiente"},"JA":{"QuestionText":"<div style=\"text-align: center;\">\u5404\u6c7a\u5b9a\u306f\u3001\u81ea\u5206\u3068\u90e8\u5c4b\u306e\u4ed6\u306e\u53c2\u52a0\u8005\u306e\u9593\u3067\u306e\u91d1\u92ad\u30dd\u30a4\u30f3\u30c8\u5358\u4f4d\u306e\u5272\u308a\u5f53\u3066\u306e 2 \u3064\u3001\u300c\u30aa\u30d7\u30b7\u30e7\u30f3 A\u300d\u3068\u300c\u30aa\u30d7\u30b7\u30e7\u30f3 B\u300d\u304b\u3089\u9078\u629e\u3059\u308b\u3053\u3068\u304b\u3089\u69cb\u6210\u3055\u308c\u307e\u3059\u3002<\/div><div style=\"text-align: center;\"><br><\/div><div style=\"text-align: center;\">\u4f8b:<\/div><div style=\"text-align: center;\">\u30aa\u30d7\u30b7\u30e7\u30f3 A: \u81ea\u5206\u306b 10 MU\u3001\u4ed6\u306e\u53c2\u52a0\u8005\u306b 10 MU\u3002&nbsp;<\/div><div style=\"text-align: center;\">\u30aa\u30d7\u30b7\u30e7\u30f3 B: \u81ea\u5206\u306b 12 MU\u3001\u4ed6\u306e\u53c2\u52a0\u8005\u306b 8 MU\u3002&nbsp;<\/div><div style=\"text-align: center;\"><br>\n\u30aa\u30d7\u30b7\u30e7\u30f3 A \u306f\u30016 \u3064\u306e\u6c7a\u5b9a\u3067\u540c\u3058\u3067\u3059\u3002\u81ea\u5206\u306b 10 MU\u3001\u4ed6\u306e\u53c2\u52a0\u8005\u306b 10 MU\u3002\u305f\u3060\u3057\u3001\u30aa\u30d7\u30b7\u30e7\u30f3 B \u306e\u5272\u308a\u5f53\u3066\u306f\u6bce\u56de\u5909\u308f\u308a\u307e\u3059\u3002<\/div><div style=\"text-align: center;\"><br><\/div><div style=\"text-align: center;\">\u5404\u6c7a\u5b9a\u3067\u3001\u90e8\u5c4b\u5185\u306e\u7570\u306a\u308b\u53c2\u52a0\u8005\u3068\u30da\u30a2\u306b\u306a\u308a\u307e\u3059\u3002<br>\n<br>\n\u4ed6\u306e\u53c2\u52a0\u8005\u306b\u3042\u306a\u305f\u306e\u500b\u4eba\u60c5\u5831\u304c\u901a\u77e5\u3055\u308c\u308b\u3053\u3068\u306f\u306a\u304f\u3001\u3042\u306a\u305f\u306b\u3082\u4ed6\u306e\u53c2\u52a0\u8005\u306e\u500b\u4eba\u60c5\u5831\u304c\u901a\u77e5\u3055\u308c\u306a\u3044\u3053\u3068\u306b\u6ce8\u610f\u3057\u3066\u304f\u3060\u3055\u3044\u3002<br>\n<br>\n\u958b\u59cb\u3059\u308b\u6e96\u5099\u304c\u3067\u304d\u305f\u3089\u3001\u6b21\u306e\u30da\u30fc\u30b8\u306b\u9032\u3093\u3067\u304f\u3060\u3055\u3044\u3002<\/div>"},"DE":{"QuestionText":"<div style=\"text-align: center;\">Jede Entscheidung besteht aus der Auswahl zwischen zwei Zuteilungen von Geldpunkteinheiten zwischen Ihnen und einem anderen Teilnehmer im Raum: \u201eOption A\u201c und \u201eOption B\u201c.<\/div><div style=\"text-align: center;\"><br><\/div><div style=\"text-align: center;\">Beispiel:<\/div><div style=\"text-align: center;\">Option A: 10 MUs f\u00fcr Sie und 10 MUs f\u00fcr den anderen Teilnehmer.&nbsp;<\/div><div style=\"text-align: center;\">Option B: 12 MUs f\u00fcr Sie und 8 MUs f\u00fcr den anderen Teilnehmer.&nbsp;<\/div><div style=\"text-align: center;\"><br>\nOption A bleibt bei allen sechs Entscheidungen gleich: 10 MUs f\u00fcr Sie und 10 MUs f\u00fcr den anderen Teilnehmer. Die Zuordnung bei Option B \u00e4ndert sich jedoch jedes Mal.<\/div><div style=\"text-align: center;\"><br><\/div><div style=\"text-align: center;\">Bei jeder Entscheidung werden Sie mit einem anderen Teilnehmer im Raum gepaart.<br>\n<br>\nBeachten Sie, dass der andere Teilnehmer niemals \u00fcber Ihre pers\u00f6nliche Identit\u00e4t informiert wird und Sie nicht \u00fcber die pers\u00f6nliche Identit\u00e4t des anderen Teilnehmers informiert werden.<br>\n<br>\nWenn Sie bereit sind zu beginnen, gehen Sie zur n\u00e4chsten Seite<\/div>"},"ZH-T":{"QuestionText":"<div style=\"text-align: center;\">\u5404\u9805\u6c7a\u7b56\u7684\u5167\u5bb9\u5982\u4e0b\uff1a\u8acb\u60a8\u6c7a\u5b9a\u8981\u5982\u4f55\u5728\u81ea\u5df1\u8207\u6559\u5ba4\u5167\u53e6\u4e00\u4f4d\u53d7\u8a66\u8005\u4e4b\u9593\u5206\u914d\u6cd5\u5e63\uff0c\u300c\u9078\u9805 A\u300d\u9084\u662f\u300c\u9078\u9805 B\u300d \u3002<br \/>\n<br \/>\n\u4f8b\u5982\uff1a<br \/>\n\u9078\u9805A\uff1a10 \u6cd5\u5e63\u7d66\u60a8\uff0c10 \u6cd5\u5e63\u7d66\u53e6\u4e00\u4f4d\u53d7\u8a66\u8005\u3002<\/div>\n\n<div style=\"text-align: center;\">\u9078\u9805B\uff1a12 \u6cd5\u5e63\u7d66\u60a8\uff0c8 \u6cd5\u5e63\u7d66\u53e6\u4e00\u4f4d\u53d7\u8a66\u8005\u3002<br \/>\n<br \/>\n\u9078\u9805 A \u5728\u516d\u9805\u6c7a\u7b56\u7576\u4e2d\u90fd\u662f\u76f8\u540c\u7684\uff1a 10 \u6cd5\u5e63\u7d66\u60a8\uff0c10 \u6cd5\u5e63\u7d66\u53e6\u4e00\u4f4d\u53d7\u8a66\u8005\u3002\u4f46\u9078\u9805 B \u7684\u5206\u914d\u6bcf\u6b21\u90fd\u6703\u6539\u8b8a\u3002<br \/>\n<br \/>\n\u60a8\u5728\u6bcf\u9805\u6c7a\u7b56\u90fd\u6703\u914d\u5c0d\u5230\u6559\u5ba4\u5167\u7684\u4e0d\u540c\u4e00\u4f4d\u53d7\u8a66\u8005\u3002<br \/>\n\u8acb\u6ce8\u610f\uff0c\u5176\u4ed6\u53d7\u8a66\u8005\u6c38\u9060\u4e0d\u6703\u5f97\u77e5\u60a8\u7684\u500b\u4eba\u8eab\u4efd\uff0c\u60a8\u4e5f\u4e0d\u6703\u5f97\u77e5\u5176\u4ed6\u53d7\u8a66\u8005\u7684\u500b\u4eba\u8eab\u4efd\u3002<br \/>\n<br \/>\n\u5982\u679c\u60a8\u6e96\u5099\u597d\u4e86\uff0c\u8acb\u7e7c\u7e8c\u95b1\u8b80\u4e0b\u4e00\u9801\u3002<\/div>\n"},"KO":{"QuestionText":"<div style=\"text-align: center;\">\uac01 \uc758\uc0ac\uacb0\uc815\uc740 \uc774 \uc138\uc158\uc5d0 \uc788\ub294 \ubcf8\uc778\uacfc \ub2e4\ub978 \ucc38\uac00\uc790 \uc0ac\uc774\uc5d0 MU\ub97c \ud560\ub2f9\ud558\ub294 \ub450 \uac00\uc9c0 \uc120\ud0dd\uc9c0(\uc635\uc158 A\uc640 \uc635\uc158 B)\uc911\uc5d0\uc11c \ud558\ub098\ub97c \uc120\ud0dd\ud558\ub294 \uac83\uc73c\ub85c \uad6c\uc131\ub429\ub2c8\ub2e4.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">\uc608\ub97c \ub4e4\uc5b4:<\/div>\n\n<div style=\"text-align: center;\">\uc635\uc158 A: \ubcf8\uc778\uc5d0\uac8c 10MU, \ub2e4\ub978 \ucc38\uac00\uc790\uc5d0\uac8c 10MU.\u00a0<\/div>\n\n<div style=\"text-align: center;\">\uc635\uc158 B: \ubcf8\uc778\uc5d0\uac8c 12MU, \ub2e4\ub978 \ucc38\uac00\uc790\uc5d0\uac8c 8MU.\u00a0<\/div>\n\n<div style=\"text-align: center;\"><br \/>\n\uc635\uc158 A\ub294 \uc5ec\uc12f \uac00\uc9c0 \uacb0\uc815\uc5d0\uc11c \ubcf8\uc778\uc5d0\uac8c 10MU, \ub2e4\ub978 \ucc38\uac00\uc790\uc5d0\uac8c 10MU\ub97c \uc8fc\ub294 \uac83\uc73c\ub85c \ub3d9\uc77c\ud569\ub2c8\ub2e4. \uadf8\ub7ec\ub098 \uc635\uc158 B\uc758 \ud560\ub2f9\uc740 \ub9e4\ubc88 \ubcc0\uacbd\ub429\ub2c8\ub2e4.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">\uac01 \uc758\uc0ac\uacb0\uc815\uc744 \ud560 \ub54c\ub9c8\ub2e4, \uac19\uc740 \uc138\uc158\uc5d0 \uc788\ub294 \uc784\uc758\ub85c \uc120\ud0dd\ub41c \ub2e4\ub978 \ucc38\uac00\uc790\uc640 \uc9dd\uc744 \uc774\ub8e8\uac8c \ub429\ub2c8\ub2e4.<br \/>\n<br \/>\n\uc9dd\uc740 \uc775\uba85\uc73c\ub85c \uc774\ub904\uc9d1\ub2c8\ub2e4: \uc9dd\uc774 \ub41c \ucc38\uac00\uc790\uc640 \uadc0\ud558\ub294 \uc11c\ub85c\uc758 \uc2e0\uc6d0\uc744 \uc54c\uc9c0 \ubabb\ud569\ub2c8\ub2e4.<br \/>\n<br \/>\n\uc2dc\uc791\ud560 \uc900\ube44\uac00 \ub418\uc5c8\ub2e4\uba74 \ub2e4\uc74c \ud398\uc774\uc9c0\ub85c \uc774\ub3d9\ud558\uc138\uc694.<\/div>\n"},"DE-AT":{"QuestionText":"<div style=\"text-align: center;\">Jede Entscheidung besteht aus der Auswahl zwischen zwei Zuteilungen von Geldeinheiten zwischen Ihnen und einem\/einer anderen TeilnehmerIn im Raum: \u201eOption A\u201c und \u201eOption B\u201c.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">Zum Beispiel:<\/div>\n\n<div style=\"text-align: center;\">Option A: 10 GE f\u00fcr Sie und 10 GE f\u00fcr den\/die andere\/n TeilnehmerIn.<\/div>\n\n<div style=\"text-align: center;\">Option B: 12 GE f\u00fcr Sie und 8 GE f\u00fcr den\/die andere\/n TeilnehmerIn.<\/div>\n\n<div style=\"text-align: center;\"><br \/>\nOption A bleibt bei allen sechs Entscheidungen gleich: 10 GE f\u00fcr Sie und 10 GE f\u00fcr den\/die andere\/n TeilnehmerIn. Die Zuteilung bei Option B \u00e4ndert sich jedoch jedes Mal.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">Bei jeder Entscheidung werden Sie mit einem\/einer anderen TeilnehmerIn im Raum gepaart.<br \/>\n<br \/>\nBeachten Sie, dass der\/die andere TeilnehmerIn niemals \u00fcber Ihre pers\u00f6nliche Identit\u00e4t informiert wird und Sie nicht \u00fcber die pers\u00f6nliche Identit\u00e4t des\/der anderen Teilnehmers\/Teilnehmerin informiert werden.<br \/>\n<br \/>\nWenn Sie bereit sind zu beginnen, fahren Sie bitte fort.<\/div>\n"},"TR":{"QuestionText":"<div style=\"text-align: center;\">Bu b\u00f6l\u00fcmde yer alan 6 durumun <u>her birinde<\/u>, oturumda yer alan <u>ba\u015fka bir kat\u0131l\u0131mc\u0131<\/u> ile rastgele e\u015fle\u015ftirileceksiniz. 6 durumun her birinde, siz e\u015fle\u015ftirildi\u011finiz kat\u0131l\u0131mc\u0131 aras\u0131nda iki farkl\u0131 DPB da\u011f\u0131l\u0131m\u0131ndan birini se\u00e7meniz istenecektir.\u00a0<br \/>\n\u00a0<\/div>\n\n<div style=\"text-align: center;\">\u00d6rne\u011fin:<\/div>\n\n<div style=\"text-align: center;\">A Se\u00e7ene\u011fi: Sizin i\u00e7in 10 DPB ve di\u011fer kat\u0131l\u0131mc\u0131 i\u00e7in 10 DPB.<\/div>\n\n<div style=\"text-align: center;\">B Se\u00e7ene\u011fi: Sizin i\u00e7in 12 DPB ve di\u011fer kat\u0131l\u0131mc\u0131 i\u00e7in 8 DPB.<\/div>\n\n<div style=\"text-align: center;\"><br \/>\nA Se\u00e7ene\u011fi 6 durumda da ayn\u0131 olacakt\u0131r: Sizin i\u00e7in 10 DPB ve di\u011fer kat\u0131l\u0131mc\u0131 i\u00e7in 10 DPB. Ancak, B Se\u00e7ene\u011fi'ndeki da\u011f\u0131l\u0131m her seferinde de\u011fi\u015fecektir.<\/div>\n\n<div style=\"text-align: center;\"><br \/>\nE\u015fle\u015ftirilece\u011finiz kat\u0131l\u0131mc\u0131lar\u0131n kimlikleri size, ya da sizin kimli\u011finiz e\u015fle\u015ftirildi\u011finiz kat\u0131l\u0131mc\u0131lara hi\u00e7bir zaman a\u00e7\u0131klanmayacakt\u0131r.<br \/>\n<br \/>\nBa\u015flamaya haz\u0131rsan\u0131z l\u00fctfen bir sonraki sayfaya ge\u00e7in.<\/div>\n"},"EN-UK":{"QuestionText":"<div style=\"text-align: center;\">Each decision consists of choosing between two allocations of monetary units between yourself and another participant in the room: \u201cOption A\u201d and \u201cOption B\u201d.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">For example:<\/div>\n\n<div style=\"text-align: center;\">Option A: 10 MUs for you and 10 MUs for the other participant.\u00a0<\/div>\n\n<div style=\"text-align: center;\">Option B: 12 MUs for you and 8 MUs for the other participant.\u00a0<\/div>\n\n<div style=\"text-align: center;\"><br \/>\nOption A will be the same across the six decisions: 10 MUs for you and 10 MUs for the other participant. However, the allocation in Option B will change each time.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">In each decision, you will be paired with a different participant in the room.<br \/>\n<br \/>\nNote that the other participant will never be informed of your personal identity and you will not be informed of the other participant\u2019s personal identity.<br \/>\n<br \/>\nIf you are ready to begin, go to the next page<\/div>\n"},"ZH-HK":{"QuestionText":"<div style=\"text-align: center;\">\n<p>\u5404\u9805\u6c7a\u7b56\u7684\u5167\u5bb9\u5982\u4e0b\uff1a\u8acb\u60a8\u6c7a\u5b9a\u8981\u5982\u4f55\u5728\u81ea\u5df1\u8207\u6559\u5ba4\u5167\u53e6\u4e00\u4f4d\u53c3\u8207\u8005\u4e4b\u9593\u5206\u914dMU\uff0c \u300c\u9078\u9805 A\u300d\u9084\u662f\u300c\u9078\u9805 B\u300d \u3002<\/p>\n<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">\u4f8b\u5982\uff1a<\/div>\n\n<div style=\"text-align: center;\">\u9078\u9805 A\uff1a\u60a8\u7372\u5f97 10 MU\uff0c\u53e6\u4e00\u4f4d\u53c3\u8207\u8005\u7372\u5f97 10\u00a0 MU\u3002<\/div>\n\n<div style=\"text-align: center;\">\u9078\u9805 B\uff1a\u60a8\u7372\u5f97 12 MU\uff0c\u53e6\u4e00\u4f4d\u53c3\u8207\u8005\u7372\u5f97 8\u00a0 MU\u3002<\/div>\n\n<div style=\"text-align: center;\"><br \/>\n\u9078\u9805 A \u5728\u516d\u500b\u6c7a\u7b56\u4e2d\u90fd\u662f\u76f8\u540c\u7684\uff1a\u60a8\u7372\u5f97 10 MU\uff0c\u53e6\u4e00\u4f4d\u53c3\u8207\u8005\u7372\u5f97 10\u00a0 MU\u3002\u4f46\u9078\u9805 B \u7684\u5206\u914d\u6bcf\u6b21\u90fd\u6703\u6539\u8b8a\u3002<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">\n<p>\u60a8\u5728\u6bcf\u9805\u6c7a\u7b56\u90fd\u6703\u914d\u5c0d\u5230\u6559\u5ba4\u5167\u7684\u4e0d\u540c\u4e00\u4f4d\u53c3\u8207\u8005\u3002<\/p>\n\n<p>\u8acb\u6ce8\u610f\uff0c\u5176\u4ed6\u53d7\u8a66\u8005\u6c38\u9060\u4e0d\u6703\u5f97\u77e5\u60a8\u7684\u500b\u4eba\u8eab\u4efd\uff0c\u60a8\u4e5f\u4e0d\u6703\u5f97\u77e5\u5176\u4ed6\u53d7\u8a66\u8005\u7684\u500b\u4eba\u8eab\u4efd\u3002<\/p>\n\n<p><br \/>\n\u5982\u679c\u60a8\u6e96\u5099\u597d\u4e86\uff0c\u8acb\u7e7c\u7e8c\u95b1\u8b80\u4e0b\u4e00\u9801\u3002<\/p>\n<\/div>\n"},"KZ-RU":[],"AR":{"QuestionText":"<div style=\"text-align: center;;text-align:right;direction:rtl\">\u064a\u062a\u0623\u0644\u0641 \u0643\u0644 \u0642\u0631\u0627\u0631 \u0645\u0646 \u0627\u0644\u0627\u062e\u062a\u064a\u0627\u0631 \u0628\u064a\u0646 \u062a\u062e\u0635\u064a\u0635\u064a\u0646 \u0645\u0646 \u0648\u062d\u062f\u0627\u062a \u0627\u0644\u0646\u0642\u0627\u0637 \u0627\u0644\u0646\u0642\u062f\u064a\u0629 \u0628\u064a\u0646\u0643 \u0648\u0628\u064a\u0646 \u0645\u0634\u0627\u0631\u0643 \u0622\u062e\u0631 \u0641\u064a \u0627\u0644\u063a\u0631\u0641\u0629: \"\u0627\u0644\u062e\u064a\u0627\u0631 \u0623\" \u0648\"\u0627\u0644\u062e\u064a\u0627\u0631 \u0628\".<\/div>\n\n<div style=\"text-align: center;;text-align:right;direction:rtl\">\u00a0<\/div>\n\n<div style=\"text-align: center;;text-align:right;direction:rtl\">\u0639\u0644\u0649 \u0633\u0628\u064a\u0644 \u0627\u0644\u0645\u062b\u0627\u0644:<\/div>\n\n<div style=\"text-align: center;;text-align:right;direction:rtl\">\u0627\u0644\u062e\u064a\u0627\u0631 \u0623: 10 \u0648\u062d\u062f\u0627\u062a \u0646\u0642\u062f\u064a\u0629 \u0644\u0643 \u064810 \u0648\u062d\u062f\u0627\u062a \u0646\u0642\u062f\u064a\u0629 \u0644\u0644\u0645\u0634\u0627\u0631\u0643 \u0627\u0644\u0622\u062e\u0631.<\/div>\n\n<div style=\"text-align: center;;text-align:right;direction:rtl\">\u0627\u0644\u062e\u064a\u0627\u0631 \u0628: 12 \u0648\u062d\u062f\u0629 \u0646\u0642\u062f\u064a\u0629 \u0644\u0643 \u06488 \u0648\u062d\u062f\u0627\u062a \u0646\u0642\u062f\u064a\u0629 \u0644\u0644\u0645\u0634\u0627\u0631\u0643 \u0627\u0644\u0622\u062e\u0631.<\/div>\n\n<div style=\"text-align: center;;text-align:right;direction:rtl\"><br \/>\n\u0633\u064a\u0643\u0648\u0646 \u0627\u0644\u062e\u064a\u0627\u0631 (\u0623) \u0647\u0648 \u0646\u0641\u0633\u0647 \u0641\u064a \u0627\u0644\u0642\u0631\u0627\u0631\u0627\u062a \u0627\u0644\u0633\u062a\u0629: 10 \u0648\u062d\u062f\u0627\u062a \u0646\u0642\u062f\u064a\u0629 \u0644\u0643 \u064810 \u0648\u062d\u062f\u0627\u062a \u0646\u0642\u062f\u064a\u0629 \u0644\u0644\u0645\u0634\u0627\u0631\u0643 \u0627\u0644\u0622\u062e\u0631. \u0648\u0644\u0643\u0646\u060c \u0633\u064a\u062a\u063a\u064a\u0631 \u0627\u0644\u062a\u062e\u0635\u064a\u0635 \u0641\u064a \u0627\u0644\u062e\u064a\u0627\u0631 (\u0628) \u0641\u064a \u0643\u0644 \u0645\u0631\u0629.<\/div>\n\n<div style=\"text-align: center;;text-align:right;direction:rtl\">\u00a0<\/div>\n\n<div style=\"text-align: center;;text-align:right;direction:rtl\">\u0641\u064a \u0643\u0644 \u0642\u0631\u0627\u0631\u060c \u0633\u064a\u062a\u0645 \u0625\u0642\u0631\u0627\u0646\u0643 \u0628\u0645\u0634\u0627\u0631\u0643 \u0645\u062e\u062a\u0644\u0641 \u0641\u064a \u0627\u0644\u063a\u0631\u0641\u0629.<br \/>\n<br \/>\n\u064a\u0631\u062c\u0649 \u0645\u0644\u0627\u062d\u0638\u0629 \u0623\u0646 \u0627\u0644\u0645\u0634\u0627\u0631\u0643 \u0627\u0644\u0622\u062e\u0631 \u0644\u0646 \u064a\u062a\u0645 \u0625\u0639\u0644\u0627\u0645\u0647 \u0628\u0647\u0648\u064a\u062a\u0643 \u0627\u0644\u0634\u062e\u0635\u064a\u0629 \u0648\u0644\u0646 \u064a\u062a\u0645 \u0625\u0639\u0644\u0627\u0645\u0643 \u0628\u0627\u0644\u0647\u0648\u064a\u0629 \u0627\u0644\u0634\u062e\u0635\u064a\u0629 \u0644\u0644\u0645\u0634\u0627\u0631\u0643 \u0627\u0644\u0622\u062e\u0631.<br \/>\n<br \/>\n\u0625\u0630\u0627 \u0643\u0646\u062a \u0645\u0633\u062a\u0639\u062f\u064b\u0627 \u0644\u0644\u0628\u062f\u0621\u060c \u0627\u0646\u062a\u0642\u0644 \u0625\u0644\u0649 \u0627\u0644\u0635\u0641\u062d\u0629 \u0627\u0644\u062a\u0627\u0644\u064a\u0629<\/div>\n"},"DE-DE":{"QuestionText":"Jede Entscheidung besteht aus der Auswahl zwischen zwei Zuteilungen von Geldeinheiten zwischen Ihnen und einem\/einer anderen TeilnehmerIn im Raum: \u201eOption A\u201c und \u201eOption B\u201c.<br \/>\n<br \/>\nZum Beispiel:<br \/>\nOption A: 10 GE f\u00fcr Sie und 10 GE f\u00fcr den\/die andere\/n TeilnehmerIn.<br \/>\nOption B: 12 GE f\u00fcr Sie und 8 GE f\u00fcr den\/die andere\/n TeilnehmerIn.<br \/>\nOption A bleibt bei allen sechs Entscheidungen gleich: 10 GE f\u00fcr Sie und 10 GE f\u00fcr den\/die andere\/n TeilnehmerIn. Die Zuteilung bei Option B \u00e4ndert sich jedoch jedes Mal.<br \/>\n<br \/>\nBei jeder Entscheidung werden Sie mit einem\/einer anderen TeilnehmerIn im Raum gepaart.<br \/>\n<br \/>\nBeachten Sie, dass der\/die andere TeilnehmerIn niemals \u00fcber Ihre pers\u00f6nliche Identit\u00e4t informiert wird und Sie nicht \u00fcber die pers\u00f6nliche Identit\u00e4t des\/der anderen Teilnehmers\/Teilnehmerin informiert werden.<br \/>\n<br \/>\nWenn Sie bereit sind zu beginnen, fahren Sie bitte fort."}},"NextChoiceId":4,"NextAnswerId":1,"DataVisibility":{"Private":false,"Hidden":false},"QuestionText_Unsafe":"<div style=\"text-align: center;\">Each decision consists of choosing between two allocations of monetary points units between yourself and another participant in the room: \u201cOption A\u201d and \u201cOption B\u201d.<\/div><div style=\"text-align: center;\"><br><\/div><div style=\"text-align: center;\">For example:<\/div><div style=\"text-align: center;\">Option A: 10 MUs for you and 10 MUs for the other participant.&nbsp;<\/div><div style=\"text-align: center;\">Option B: 12 MUs for you and 8 MUs for the other participant.&nbsp;<\/div><div style=\"text-align: center;\"><br>\nOption A will be the same across the six decisions: 10 MUs for you and 10 MUs for the other participant. However, the allocation in Option B will change each time.<\/div><div style=\"text-align: center;\"><br><\/div><div style=\"text-align: center;\">In each decision, you will be paired with a different participant in the room.<br>\n<br>\nNote that the other participant will never be informed of your personal identity and you will not be informed of the other participant\u2019s personal identity.<br>\n<br>\nIf you are ready to begin, go to the next page<\/div>"}},{"SurveyID":"SV_b3mHBVkuioRMhng","Element":"SQ","PrimaryAttribute":"QID24","SecondaryAttribute":"How much confidence do you have in each of the following:","TertiaryAttribute":null,"Payload":{"QuestionText":"<div style=\"text-align: center;\"><\/div>How much confidence do you have in each of the following:","DefaultChoices":false,"DataExportTag":"Turst_Q","QuestionID":"QID24","QuestionType":"Matrix","Selector":"Likert","SubSelector":"SingleAnswer","Configuration":{"QuestionDescriptionOption":"UseText","TextPosition":"inline","ChoiceColumnWidth":25,"RepeatHeaders":"none","WhiteSpace":"OFF","MobileFirst":true},"QuestionDescription":"How much confidence do you have in each of the following:","Choices":{"1":{"Display":"People that you meet for the first time"},"3":{"Display":"The government"},"4":{"Display":"The American Red Cross organisation"},"5":{"Display":"Your classmates"},"6":{"Display":"People from other countries"},"8":{"Display":"People from your own country"},"14":{"Display":"Your family"},"15":{"Display":"Your neighbours"},"16":{"Display":"People from your region"},"17":{"Display":"Political parties"}},"ChoiceOrder":[1,3,4,5,6,"8","14","15","16","17"],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"GradingData":[],"Language":{"AR":{"QuestionText":"<div style=\"text-align: center;;text-align:right;direction:rtl\"><\/div>\u0645\u0627 \u0645\u062f\u0649 \u062b\u0642\u062a\u0643 \u0641\u064a \u0643\u0644 \u0645\u0645\u0627 \u064a\u0644\u064a:","Choices":{"1":{"Display":"\u0627\u0644\u0623\u0634\u062e\u0627\u0635 \u0627\u0644\u0630\u064a\u0646 \u062a\u0642\u0627\u0628\u0644\u0647\u0645 \u0644\u0644\u0645\u0631\u0629 \u0627\u0644\u0623\u0648\u0644\u0649"},"3":{"Display":"\u0627\u0644\u062d\u0643\u0648\u0645\u0629"},"4":{"Display":"\u0645\u0633\u062a\u0634\u0641\u064a \u062d\u0631\u0648\u0642 \u0623\u0647\u0644 \u0645\u0635\u0631"},"5":{"Display":"\u0632\u0645\u0644\u0627\u0624\u0643 \u0641\u064a \u0627\u0644\u0641\u0635\u0644"},"6":{"Display":"\u0623\u0634\u062e\u0627\u0635 \u0645\u0646 \u0628\u0644\u062f\u0627\u0646 \u0623\u062e\u0631\u0649"},"8":{"Display":"\u0623\u0634\u062e\u0627\u0635 \u0645\u0646 \u0628\u0644\u062f\u0643"},"14":{"Display":"\u0639\u0627\u0626\u0644\u062a\u0643"},"15":{"Display":"\u062c\u064a\u0631\u0627\u0646\u0643"},"16":{"Display":"\u0623\u0634\u062e\u0627\u0635 \u0645\u0646 \u0645\u0646\u0637\u0642\u062a\u0643"},"17":{"Display":"\u0627\u0644\u0623\u062d\u0632\u0627\u0628 \u0627\u0644\u0633\u064a\u0627\u0633\u064a\u0629"}},"Ans