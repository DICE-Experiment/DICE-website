6chten wir Sie noch nach Ihren Ansichten zu bestimmten Themen fragen.<br>"},"ZH-T":{"QuestionText":"<div style=\"text-align: center;\"><strong>\u7b2c 7 \u90e8\u5206<\/strong><\/div>\n\n<div style=\"text-align: center;\"><strong>\uff08\u6700\u5f8c\u4e00\u90e8\u5206\uff09<\/strong><\/div>\n<br \/>\n\u6700\u5f8c\uff0c\u6211\u5011\u60f3\u8a62\u554f\u60a8\u5c0d\u67d0\u4e9b\u8b70\u984c\u7684\u770b\u6cd5\u3002"},"KO":{"QuestionText":"<div style=\"text-align: center;\"><strong>7\ubd80<\/strong><\/div>\n\n<div style=\"text-align: center;\"><strong>(\ub9c8\uc9c0\ub9c9 \ubd80\ubd84)<\/strong><\/div>\n<br \/>\n\ub9c8\uc9c0\ub9c9 7\ubd80\uc5d0\uc11c\ub294, \ud2b9\uc815 \uc774\uc288\ub4e4\uc5d0 \ub300\ud55c \uadc0\ud558\uc758 \uacac\ud574\ub97c \uc5ec\ucb59\uace0\uc790 \ud569\ub2c8\ub2e4."},"DE-AT":{"QuestionText":"<div style=\"text-align: center;\"><strong>TEIL 7<\/strong><\/div>\n\n<div style=\"text-align: center;\"><strong>(letzter Teil)<\/strong><\/div>\n<br \/>\nZum Schluss m\u00f6chten wir Sie noch nach Ihrer Meinung zu ausgew\u00e4hlten Themen fragen."},"TR":{"QuestionText":"<div style=\"text-align: center;\"><strong>B\u00d6L\u00dcM 7<\/strong><\/div>\n\n<div style=\"text-align: center;\"><strong>(son k\u0131s\u0131m)<\/strong><\/div>\n<br \/>\nSon olarak size\u00a0baz\u0131 konular hakk\u0131ndaki g\u00f6r\u00fc\u015flerinizi sormak istiyoruz."},"ZH-HK":{"QuestionText":"<div style=\"text-align: center;\"><strong>\u7b2c 7 \u90e8\u5206<\/strong><\/div>\n\n<div style=\"text-align: center;\"><strong>\uff08\u6700\u5f8c\u4e00\u90e8\u5206\uff09<\/strong><\/div>\n\u00a0\n\n<p>\u6700\u5f8c\uff0c\u6211\u5011\u60f3\u8a62\u554f\u60a8\u5c0d\u67d0\u4e9b\u8b70\u984c\u7684\u770b\u6cd5\u3002<\/p>\n"},"KZ-RU":[],"AR":{"QuestionText":"<div style=\"text-align: center;;text-align:right;direction:rtl\"><strong>\u0627\u0644\u062c\u0632\u0621 \u0627\u0644\u0633\u0627\u0628\u0639<\/strong><\/div>\n\n<div style=\"text-align: center;;text-align:right;direction:rtl\"><strong>(\u0627\u0644\u062c\u0632\u0621 \u0627\u0644\u0623\u062e\u064a\u0631)<\/strong><\/div>\n<br \/>\n\u0648\u0623\u062e\u064a\u0631\u0627\u060c \u0646\u0648\u062f \u0623\u0646 \u0646\u0633\u0623\u0644 \u0639\u0646 \u0631\u0623\u064a\u0643 \u0628\u0634\u0623\u0646 \u0628\u0639\u0636 \u0627\u0644\u0642\u0636\u0627\u064a\u0627."},"DE-DE":{"QuestionText":"<div style=\"text-align: center;\"><strong>TEIL 7<\/strong><\/div><div style=\"text-align: center;\"> <strong>(letzter Teil)<\/strong><\/div><br> Abschlie\u00dfend m\u00f6chten wir Sie noch zu Ihren Ansichten zu bestimmten Themen befragen.<br>"}},"NextChoiceId":4,"NextAnswerId":1,"QuestionText_Unsafe":"<div style=\"text-align: center;\"><strong>PART 7<\/strong><\/div><div style=\"text-align: center;\"><strong>(last part)<\/strong><\/div>\n<br>\nFinally, we\u2019d like to ask about your views on certain issues.<br>","DataVisibility":{"Private":false,"Hidden":false}}},{"SurveyID":"SV_b3mHBVkuioRMhng","Element":"SQ","PrimaryAttribute":"QID56","SecondaryAttribute":"Situation 1 \u00a0 What do you choose?","TertiaryAttribute":null,"Payload":{"QuestionText":"<div style=\"text-align: center;\"><strong>Situation 1<\/strong><br \/>\n&nbsp;<\/div>\n\n<div style=\"text-align: center;\">What do you choose?<\/div>","DataExportTag":"mini DG 1","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Situation 1 \u00a0 What do you choose?","Choices":{"1":{"Display":"10 MUs for you and 10 MUs for the other participant"},"2":{"Display":"10 MUs for you and 0 MUs for the other participant"}},"ChoiceOrder":["1","2"],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"Language":{"ES":{"QuestionText":"<div style=\"text-align: center;\"><strong>Situaci\u00f3n 1<\/strong><\/div>\n\n<div style=\"text-align: center;\">\u00bfQu\u00e9 elige?<\/div>\n","Choices":{"1":{"Display":"10 UM para usted y 10 UM para el otro participante"},"2":{"Display":"10 UM para used y 0 UM para el otro participante"}}}},"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID56","DataVisibility":{"Private":false,"Hidden":false},"QuestionText_Unsafe":"<div style=\"text-align: center;\"><strong>Situation 1<\/strong><br \/>\n&nbsp;<\/div>\n\n<div style=\"text-align: center;\">What do you choose?<\/div>"}},{"SurveyID":"SV_b3mHBVkuioRMhng","Element":"SQ","PrimaryAttribute":"QID57","SecondaryAttribute":"Situation 2 \u00a0 What do you choose?","TertiaryAttribute":null,"Payload":{"QuestionText":"<div style=\"text-align: center;\"><strong>Situation 2<\/strong><br>\n&nbsp;<\/div>\n\n<div style=\"text-align: center;\">What do you choose?<\/div>","DataExportTag":"mini DG2","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Situation 2 \u00a0 What do you choose?","Choices":{"1":{"Display":"10 MUs for you and 10 MUs for the other participant"},"2":{"Display":"10 MUs for you and 20 MUs for the other participant"}},"ChoiceOrder":["1","2"],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"Language":{"ES":{"QuestionText":"<div style=\"text-align: center;\"><strong>Situaci\u00f3n 2<\/strong><\/div>\n\n<div style=\"text-align: center;\">\u00bfQu\u00e9 elige?<\/div>\n","Choices":{"1":{"Display":"10 UM para usted y 10 UM para el otro participante"},"2":{"Display":"10 UM para usted y 20 UM para el otro participante"}}}},"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID57","QuestionText_Unsafe":"<div style=\"text-align: center;\"><strong>Situation 2<\/strong><br>\n&nbsp;<\/div>\n\n<div style=\"text-align: center;\">What do you choose?<\/div>"}},{"SurveyID":"SV_b3mHBVkuioRMhng","Element":"SQ","PrimaryAttribute":"QID58","SecondaryAttribute":"Situation 3 \u00a0 What do you choose?","TertiaryAttribute":null,"Payload":{"QuestionText":"<div style=\"text-align: center;\"><strong>Situation 3<\/strong><br>\n&nbsp;<\/div>\n\n<div style=\"text-align: center;\">What do you choose?<\/div>","DataExportTag":"mini DG3","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Situation 3 \u00a0 What do you choose?","Choices":{"1":{"Display":"10 MUs for you and 10 MUs for the other participant"},"2":{"Display":"20 MUs for you and 0 MUs for the other participant"}},"ChoiceOrder":["1","2"],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"Language":{"ES":{"QuestionText":"<div style=\"text-align: center;\"><strong>Situaci\u00f3n 3<\/strong><\/div>\n\n<div style=\"text-align: center;\">\u00bfQu\u00e9 elige?<\/div>\n","Choices":{"1":{"Display":"10 UM para ti y 10 UM para el otro participante"},"2":{"Display":"20 UMs para ti y 0 UMs para el otro participante"}}}},"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID58","QuestionText_Unsafe":"<div style=\"text-align: center;\"><strong>Situation 3<\/strong><br>\n&nbsp;<\/div>\n\n<div style=\"text-align: center;\">What do you choose?<\/div>"}},{"SurveyID":"SV_b3mHBVkuioRMhng","Element":"SQ","PrimaryAttribute":"QID59","SecondaryAttribute":"Captura la pantalla. Este es el c\u00f3digo que necesitas para cobrar. ID:\u00a0${e:\/\/Field\/ID}","TertiaryAttribute":null,"Payload":{"QuestionText":"Captura la pantalla.<br>Este es el c\u00f3digo que necesitas para cobrar.<br>ID:&nbsp;${e:\/\/Field\/ID}<br><br>","DefaultChoices":false,"DataExportTag":"Q52","QuestionType":"DB","Selector":"TB","Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Captura la pantalla. Este es el c\u00f3digo que necesitas para cobrar. ID:\u00a0${e:\/\/Field\/ID}","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID59","DataVisibility":{"Private":false,"Hidden":false}}},{"SurveyID":"SV_b3mHBVkuioRMhng","Element":"SQ","PrimaryAttribute":"QID6","SecondaryAttribute":"You will have to throw a dice twice. Your first throw decides how much you receive, and the secon...","TertiaryAttribute":null,"Payload":{"QuestionText":"<div style=\"text-align: center;\">You will have to throw a dice twice. Your first throw decides how much you receive, and the second throw only serves to make sure that the dice is working properly. In fact, you may throw the dice more than twice. However, only the first throw counts.<\/div>\n\n<div style=\"text-align: center;\">&nbsp;<\/div>\n\n<div style=\"text-align: center;\">The maximum payoff you can receive is 50 Monetary Units (MUs) and the minimum 0. You can see the exact payoff from the following table.<\/div>\n\n<div style=\"text-align: center;\">&nbsp;<\/div>\n\n<div style=\"text-align: center;\">The table will remain on the screen until you entered your throw. If you have any questions, please raise your hand. If you are ready, please continue to the next page.<\/div>\n\n<table style=\"width:200px;\" cellspacing=\"1\" cellpadding=\"1\" border=\"1\" align=\"center\">\n\t<thead>\n\t\t<tr>\n\t\t\t<th scope=\"row\">Number thrown<\/th>\n\t\t\t<th scope=\"col\">MUs for you<\/th>\n\t\t<\/tr>\n\t<\/thead>\n\t<tbody>\n\t\t<tr>\n\t\t\t<th scope=\"row\">1<\/th>\n\t\t\t<td style=\"text-align: center;\">10<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">2<\/th>\n\t\t\t<td style=\"text-align: center;\">20<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">3<\/th>\n\t\t\t<td style=\"text-align: center;\">30<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">4<\/th>\n\t\t\t<td style=\"text-align: center;\">40<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">5<\/th>\n\t\t\t<td style=\"text-align: center;\">50<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">6<\/th>\n\t\t\t<td style=\"text-align: center;\">0<\/td>\n\t\t<\/tr>\n\t<\/tbody>\n<\/table>\n\n<div style=\"text-align: center;\">&nbsp;<\/div>","DefaultChoices":false,"DataExportTag":"T1: BASE_1","QuestionID":"QID6","QuestionType":"DB","Selector":"TB","Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"You will have to throw a dice twice. Your first throw decides how much you receive, and the secon...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":{"ES":{"QuestionText":"<div style=\"text-align: center;\">Tendr\u00e1 que lanzar el dado dos veces. Su primer lanzamiento decide cu\u00e1nto recibe, y el segundo lanzamiento solo sirve para asegurarse de que los dados funcionan correctamente. De hecho, puede tirar el dado m\u00e1s de dos veces. Sin embargo, solo cuenta el primer lanzamiento.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">El pago m\u00e1ximo que puede recibir es de 50 Unidades Monetarias (UM) y el m\u00ednimo de 0. Puede ver el pago exacto en la siguiente tabla.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">La tabla permanecer\u00e1 en la pantalla hasta que ingrese su lanzamiento. Si tiene alguna pregunta, por favor levante su mano. Si est\u00e1 listo, siga adelante.<\/div>\n\n<table align=\"center\" border=\"1\" cellpadding=\"1\" cellspacing=\"1\" style=\"width:200px;\">\n\t<thead>\n\t\t<tr>\n\t\t\t<th scope=\"row\">N\u00famero lanzado<\/th>\n\t\t\t<th scope=\"col\">UM para usted<\/th>\n\t\t<\/tr>\n\t<\/thead>\n\t<tbody>\n\t\t<tr>\n\t\t\t<th scope=\"row\">1<\/th>\n\t\t\t<td style=\"text-align: center;\">10<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">2<\/th>\n\t\t\t<td style=\"text-align: center;\">20<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">3<\/th>\n\t\t\t<td style=\"text-align: center;\">30<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">4<\/th>\n\t\t\t<td style=\"text-align: center;\">40<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">5<\/th>\n\t\t\t<td style=\"text-align: center;\">50<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">6<\/th>\n\t\t\t<td style=\"text-align: center;\">0<\/td>\n\t\t<\/tr>\n\t<\/tbody>\n<\/table>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n"},"EL":{"QuestionText":"<div style=\"text-align: center;\">\u0398\u03b1 \u03c0\u03c1\u03ad\u03c0\u03b5\u03b9 \u03bd\u03b1 \u03c1\u03af\u03be\u03b5\u03c4\u03b5 \u03c4\u03bf \u03b6\u03ac\u03c1\u03b9 \u03b4\u03cd\u03bf \u03c6\u03bf\u03c1\u03ad\u03c2. \u0397 \u03c0\u03c1\u03ce\u03c4\u03b7 \u03c6\u03bf\u03c1\u03ac \u03b8\u03b1 \u03ba\u03b1\u03b8\u03bf\u03c1\u03af\u03c3\u03b5\u03b9 \u03c0\u03cc\u03c3\u03b1 \u03c7\u03c1\u03ae\u03bc\u03b1\u03c4\u03b1 \u03b8\u03b1 \u03bb\u03ac\u03b2\u03b5\u03c4\u03b5 \u03ba\u03b1\u03b9 \u03b7 \u03b4\u03b5\u03cd\u03c4\u03b5\u03c1\u03b7 \u03c6\u03bf\u03c1\u03ac \u03c7\u03c1\u03b7\u03c3\u03b9\u03bc\u03b5\u03cd\u03b5\u03b9 \u03bc\u03cc\u03bd\u03bf \u03b3\u03b9\u03b1 \u03bd\u03b1 \u03b2\u03b5\u03b2\u03b1\u03b9\u03c9\u03b8\u03b5\u03af\u03c4\u03b5 \u03cc\u03c4\u03b9 \u03c4\u03bf \u03b6\u03ac\u03c1\u03b9 \u03bb\u03b5\u03b9\u03c4\u03bf\u03c5\u03c1\u03b3\u03b5\u03af \u03c3\u03c9\u03c3\u03c4\u03ac. \u03a3\u03c4\u03b7\u03bd \u03c0\u03c1\u03b1\u03b3\u03bc\u03b1\u03c4\u03b9\u03ba\u03cc\u03c4\u03b7\u03c4\u03b1, \u03bc\u03c0\u03bf\u03c1\u03b5\u03af\u03c4\u03b5 \u03bd\u03b1 \u03c1\u03af\u03be\u03b5\u03c4\u03b5 \u03c4\u03bf \u03b6\u03ac\u03c1\u03b9 \u03c0\u03b5\u03c1\u03b9\u03c3\u03c3\u03cc\u03c4\u03b5\u03c1\u03b5\u03c2 \u03b1\u03c0\u03cc \u03b4\u03cd\u03bf \u03c6\u03bf\u03c1\u03ad\u03c2. \u03a9\u03c3\u03c4\u03cc\u03c3\u03bf, \u03bc\u03cc\u03bd\u03bf \u03b7 \u03c0\u03c1\u03ce\u03c4\u03b7 \u03c6\u03bf\u03c1\u03ac \u03bc\u03b5\u03c4\u03c1\u03ac\u03b5\u03b9.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">\u0397 \u03bc\u03ad\u03b3\u03b9\u03c3\u03c4\u03b7 \u03c0\u03bb\u03b7\u03c1\u03c9\u03bc\u03ae \u03c0\u03bf\u03c5 \u03bc\u03c0\u03bf\u03c1\u03b5\u03af\u03c4\u03b5 \u03bd\u03b1 \u03bb\u03ac\u03b2\u03b5\u03c4\u03b5 \u03b5\u03af\u03bd\u03b1\u03b9 50 \u039d\u03bf\u03bc\u03b9\u03c3\u03bc\u03b1\u03c4\u03b9\u03ba\u03ad\u03c2 \u039c\u03bf\u03bd\u03ac\u03b4\u03b5\u03c2 (\u039d\u039c) \u03ba\u03b1\u03b9 \u03b7 \u03b5\u03bb\u03ac\u03c7\u03b9\u03c3\u03c4\u03b7 0. \u039c\u03c0\u03bf\u03c1\u03b5\u03af\u03c4\u03b5 \u03bd\u03b1 \u03b4\u03b5\u03af\u03c4\u03b5 \u03c4\u03b7\u03bd \u03b1\u03ba\u03c1\u03b9\u03b2\u03ae \u03c0\u03bb\u03b7\u03c1\u03c9\u03bc\u03ae \u03b1\u03c0\u03cc \u03c4\u03bf\u03bd \u03c0\u03b1\u03c1\u03b1\u03ba\u03ac\u03c4\u03c9 \u03c0\u03af\u03bd\u03b1\u03ba\u03b1.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">\u039f \u03c0\u03af\u03bd\u03b1\u03ba\u03b1\u03c2 \u03b8\u03b1 \u03c0\u03b1\u03c1\u03b1\u03bc\u03b5\u03af\u03bd\u03b5\u03b9 \u03c3\u03c4\u03b7\u03bd \u03bf\u03b8\u03cc\u03bd\u03b7 \u03bc\u03ad\u03c7\u03c1\u03b9 \u03bd\u03b1 \u03c3\u03b1\u03c2 \u03b6\u03b7\u03c4\u03b7\u03b8\u03b5\u03af \u03bd\u03b1 \u03b3\u03c1\u03ac\u03c8\u03c4\u03b5 \u03c4\u03bf \u03bd\u03bf\u03cd\u03bc\u03b5\u03c1\u03bf \u03c0\u03bf\u03c5 \u03c3\u03b1\u03c2 \u03ad\u03c4\u03c5\u03c7\u03b5. \u0391\u03bd \u03ad\u03c7\u03b5\u03c4\u03b5 \u03b5\u03c1\u03c9\u03c4\u03ae\u03c3\u03b5\u03b9\u03c2, \u03c3\u03b7\u03ba\u03ce\u03c3\u03c4\u03b5 \u03c4\u03bf \u03c7\u03ad\u03c1\u03b9 \u03c3\u03b1\u03c2. \u0395\u03ac\u03bd \u03c0\u03ac\u03bb\u03b9 \u03b5\u03af\u03c3\u03c4\u03b5 \u03ad\u03c4\u03bf\u03b9\u03bc\u03bf\u03b9, \u03c3\u03c5\u03bd\u03b5\u03c7\u03af\u03c3\u03c4\u03b5 \u03c3\u03c4\u03b7\u03bd \u03b5\u03c0\u03cc\u03bc\u03b5\u03bd\u03b7 \u03c3\u03b5\u03bb\u03af\u03b4\u03b1.<br \/>\n\u00a0<\/div>\n\n<table align=\"center\" border=\"1\" cellpadding=\"1\" cellspacing=\"1\" style=\"width:200px;\">\n\t<thead>\n\t\t<tr>\n\t\t\t<th scope=\"row\">\u0391\u03c1\u03b9\u03b8\u03bc\u03cc\u03c2 \u03c4\u03bf\u03c5 \u03b6\u03b1\u03c1\u03b9\u03bf\u03cd<\/th>\n\t\t\t<th scope=\"col\">\u039d\u039c \u03b3\u03b9\u03b1 \u03b5\u03c3\u03ac\u03c2<\/th>\n\t\t<\/tr>\n\t<\/thead>\n\t<tbody>\n\t\t<tr>\n\t\t\t<th scope=\"row\">1<\/th>\n\t\t\t<td style=\"text-align: center;\">10<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">2<\/th>\n\t\t\t<td style=\"text-align: center;\">20<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">3<\/th>\n\t\t\t<td style=\"text-align: center;\">30<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">4<\/th>\n\t\t\t<td style=\"text-align: center;\">40<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">5<\/th>\n\t\t\t<td style=\"text-align: center;\">50<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">6<\/th>\n\t\t\t<td style=\"text-align: center;\">0<\/td>\n\t\t<\/tr>\n\t<\/tbody>\n<\/table>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n"},"FR":{"QuestionText":"<div><span style=\"line-height:130%\"><span style=\"font-family:Arial\"><span lang=\"FR\" style=\"color:#525252\">Vous devez lancer un d\u00e9 deux fois. Votre premier lancer va d\u00e9cider du montant que vous recevez, et le deuxi\u00e8me lancer sert uniquement \u00e0 vous assurer que les d\u00e9s fonctionnent correctement. Vous pouvez lancer les d\u00e9s plus de deux fois.\u00a0<\/span><\/span><\/span><span style=\"font-family:Arial\"><span lang=\"FR\" style=\"color:#525252\">Cependant, seul le premier lancer compte.<\/span><\/span><\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div><span style=\"line-height:130%\"><span style=\"font-family:Arial\"><span lang=\"FR\" style=\"color:#525252\">Le gain maximum que vous pouvez recevoir est de 50 unit\u00e9s mon\u00e9taires (UM) et le minimum de 0. Vous pouvez voir le montant des gains exact dans le tableau suivant.<\/span><\/span><\/span><br \/>\n\u00a0<\/div>\n\n<div><span style=\"line-height:130%\"><span style=\"font-family:Arial\"><span lang=\"FR\" style=\"color:#525252\">Le tableau restera \u00e0 l'\u00e9cran jusqu'\u00e0 ce que vous saisissiez votre lancer. Si vous avez des questions, veuillez lever la main. Si vous \u00eates pr\u00eat, veuillez passer \u00e0 la page suivante.<\/span><\/span><\/span><\/div>\n\n<table align=\"center\" border=\"1\" cellpadding=\"1\" cellspacing=\"1\" style=\"width:200px;\">\n\t<thead>\n\t\t<tr>\n\t\t\t<th scope=\"row\">Num\u00e9ro lanc\u00e9<\/th>\n\t\t\t<th scope=\"col\">UM\u00a0pour vous<\/th>\n\t\t<\/tr>\n\t<\/thead>\n\t<tbody>\n\t\t<tr>\n\t\t\t<th scope=\"row\">1<\/th>\n\t\t\t<td style=\"text-align: center;\">10<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">2<\/th>\n\t\t\t<td style=\"text-align: center;\">20<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">3<\/th>\n\t\t\t<td style=\"text-align: center;\">30<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">4<\/th>\n\t\t\t<td style=\"text-align: center;\">40<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">5<\/th>\n\t\t\t<td style=\"text-align: center;\">50<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">6<\/th>\n\t\t\t<td style=\"text-align: center;\">0<\/td>\n\t\t<\/tr>\n\t<\/tbody>\n<\/table>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n"},"CS":{"QuestionText":"<div style=\"text-align: center;\">Po\u017e\u00e1d\u00e1me V\u00e1s, abyste dvakr\u00e1t hodil(a) kostkou. V\u00e1\u0161 prvn\u00ed hod rozhodne o tom, kolik dostanete. Druh\u00fd hod slou\u017e\u00ed pouze k tomu, abyste se ujistil(a), \u017ee kostky funguj\u00ed spr\u00e1vn\u011b. Ve skute\u010dnosti m\u016f\u017eete hodit kostkou, kolikr\u00e1t chcete, ale po\u010d\u00edt\u00e1 se pouze V\u00e1\u0161 prvn\u00ed hod.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">Maxim\u00e1ln\u00ed \u010d\u00e1stka, kterou m\u016f\u017eete v t\u00e9to \u010d\u00e1sti obdr\u017eet, je 50 experiment\u00e1ln\u00edch m\u011bnov\u00fdch jednotek (EMJ) a minim\u00e1ln\u00ed je 0 EMJ. N\u00e1sleduj\u00edc\u00ed tabulka popisuje, kolik p\u0159esn\u011b m\u016f\u017eete vyhr\u00e1t.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">Tato tabulka z\u016fstane zobrazena na Va\u0161\u00ed obrazovce, dokud nebudete cht\u00edt napsat, kolik jste hodil(a). Pokud m\u00e1te n\u011bjak\u00e9 ot\u00e1zky, zvedn\u011bte, pros\u00edm, ruku. Pokud jste p\u0159ipraven(a), pokra\u010dujte na dal\u0161\u00ed str\u00e1nku.<\/div>\n\n<table align=\"center\" border=\"1\" cellpadding=\"1\" cellspacing=\"1\" style=\"width:200px;\">\n\t<thead>\n\t\t<tr>\n\t\t\t<th scope=\"row\">\u010c\u00edslo vr\u017eeno<\/th>\n\t\t\t<th scope=\"col\">EMJ pro V\u00e1s<\/th>\n\t\t<\/tr>\n\t<\/thead>\n\t<tbody>\n\t\t<tr>\n\t\t\t<th scope=\"row\">1<\/th>\n\t\t\t<td style=\"text-align: center;\">10<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">2<\/th>\n\t\t\t<td style=\"text-align: center;\">20<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">3<\/th>\n\t\t\t<td style=\"text-align: center;\">30<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">4<\/th>\n\t\t\t<td style=\"text-align: center;\">40<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">5<\/th>\n\t\t\t<td style=\"text-align: center;\">50<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">6<\/th>\n\t\t\t<td style=\"text-align: center;\">0<\/td>\n\t\t<\/tr>\n\t<\/tbody>\n<\/table>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n"},"RU":{"QuestionText":"\u00a0\n<div style=\"text-align: center;\">\u0412\u0430\u043c \u043d\u0430\u0434\u043e \u0431\u0443\u0434\u0435\u0442 \u0431\u0440\u043e\u0441\u0438\u0442\u044c \u0438\u0433\u0440\u0430\u043b\u044c\u043d\u0443\u044e \u043a\u043e\u0441\u0442\u044c \u0434\u0432\u0430\u0436\u0434\u044b. \u0412\u0430\u0448 \u043f\u0435\u0440\u0432\u044b\u0439 \u0431\u0440\u043e\u0441\u043e\u043a \u043e\u043f\u0440\u0435\u0434\u0435\u043b\u044f\u0435\u0442, \u0441\u043a\u043e\u043b\u044c\u043a\u043e \u0412\u044b \u043f\u043e\u043b\u0443\u0447\u0438\u0442\u0435, \u0430 \u0432\u0442\u043e\u0440\u043e\u0439 \u0431\u0440\u043e\u0441\u043e\u043a \u0441\u043b\u0443\u0436\u0438\u0442 \u0442\u043e\u043b\u044c\u043a\u043e \u0434\u043b\u044f \u0442\u043e\u0433\u043e, \u0447\u0442\u043e\u0431\u044b \u0443\u0431\u0435\u0434\u0438\u0442\u044c\u0441\u044f, \u0447\u0442\u043e \u043a\u043e\u0441\u0442\u044c \u0440\u0430\u0431\u043e\u0442\u0430\u0435\u0442 \u043f\u0440\u0430\u0432\u0438\u043b\u044c\u043d\u043e. \u0424\u0430\u043a\u0442\u0438\u0447\u0435\u0441\u043a\u0438, \u0412\u044b \u043c\u043e\u0436\u0435\u0442\u0435 \u0431\u0440\u043e\u0441\u0438\u0442\u044c \u043a\u043e\u0441\u0442\u044c \u0438 \u0431\u043e\u043b\u0435\u0435 \u0434\u0432\u0443\u0445 \u0440\u0430\u0437. \u041e\u0434\u043d\u0430\u043a\u043e \u0437\u0430\u0441\u0447\u0438\u0442\u044b\u0432\u0430\u0435\u0442\u0441\u044f \u0442\u043e\u043b\u044c\u043a\u043e \u043f\u0435\u0440\u0432\u044b\u0439 \u0431\u0440\u043e\u0441\u043e\u043a.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">\u041c\u0430\u043a\u0441\u0438\u043c\u0430\u043b\u044c\u043d\u044b\u0439 \u0432\u044b\u0438\u0433\u0440\u044b\u0448, \u043a\u043e\u0442\u043e\u0440\u044b\u0439 \u0412\u044b \u043c\u043e\u0436\u0435\u0442\u0435 \u043f\u043e\u043b\u0443\u0447\u0438\u0442\u044c, \u0441\u043e\u0441\u0442\u0430\u0432\u043b\u044f\u0435\u0442 50 \u0434\u0435\u043d\u0435\u0436\u043d\u044b\u0445 \u0435\u0434\u0438\u043d\u0438\u0446 (\u0414\u0415), \u0430 \u043c\u0438\u043d\u0438\u043c\u0430\u043b\u044c\u043d\u044b\u0439 \u2014 0. \u0422\u043e\u0447\u043d\u044b\u0439 \u0432\u044b\u0438\u0433\u0440\u044b\u0448 \u0412\u044b \u043c\u043e\u0436\u0435\u0442\u0435 \u0443\u0432\u0438\u0434\u0435\u0442\u044c \u0438\u0437 \u0441\u043b\u0435\u0434\u0443\u044e\u0449\u0435\u0439 \u0442\u0430\u0431\u043b\u0438\u0446\u044b.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">\u0422\u0430\u0431\u043b\u0438\u0446\u0430 \u0431\u0443\u0434\u0435\u0442 \u043e\u0441\u0442\u0430\u0432\u0430\u0442\u044c\u0441\u044f \u043d\u0430 \u044d\u043a\u0440\u0430\u043d\u0435 \u0434\u043e \u0442\u0435\u0445 \u043f\u043e\u0440, \u043f\u043e\u043a\u0430 \u0412\u044b \u043d\u0435 \u0432\u0432\u0435\u0434\u0435\u0442\u0435 \u0440\u0435\u0437\u0443\u043b\u044c\u0442\u0430\u0442 \u0412\u0430\u0448\u0435\u0433\u043e \u0431\u0440\u043e\u0441\u043a\u0430. \u0415\u0441\u043b\u0438 \u0443 \u0412\u0430\u0441 \u0435\u0441\u0442\u044c \u0432\u043e\u043f\u0440\u043e\u0441\u044b, \u043f\u043e\u0436\u0430\u043b\u0443\u0439\u0441\u0442\u0430, \u043f\u043e\u0434\u043d\u0438\u043c\u0438\u0442\u0435 \u0440\u0443\u043a\u0443. \u0415\u0441\u043b\u0438 \u0412\u044b \u0433\u043e\u0442\u043e\u0432\u044b, \u043f\u0435\u0440\u0435\u0439\u0434\u0438\u0442\u0435 \u043d\u0430 \u0441\u043b\u0435\u0434\u0443\u044e\u0449\u0443\u044e \u0441\u0442\u0440\u0430\u043d\u0438\u0446\u0443.<\/div>\n\n<table align=\"center\" border=\"1\" cellpadding=\"1\" cellspacing=\"1\" style=\"width:200px;\">\n\t<thead>\n\t\t<tr>\n\t\t\t<th scope=\"row\">\u0427\u0438\u0441\u043b\u043e \u0432\u044b\u043f\u0430\u0432\u0448\u0438\u0445 \u043e\u0447\u043a\u043e\u0432<\/th>\n\t\t\t<th scope=\"col\">\u0414\u0415 \u0434\u043b\u044f \u0412\u0430\u0441<\/th>\n\t\t<\/tr>\n\t<\/thead>\n\t<tbody>\n\t\t<tr>\n\t\t\t<th scope=\"row\">1<\/th>\n\t\t\t<td style=\"text-align: center;\">10<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">2<\/th>\n\t\t\t<td style=\"text-align: center;\">20<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">3<\/th>\n\t\t\t<td style=\"text-align: center;\">30<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">4<\/th>\n\t\t\t<td style=\"text-align: center;\">40<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">5<\/th>\n\t\t\t<td style=\"text-align: center;\">50<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">6<\/th>\n\t\t\t<td style=\"text-align: center;\">0<\/td>\n\t\t<\/tr>\n\t<\/tbody>\n<\/table>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n"},"HU":{"QuestionText":"<div style=\"text-align: center;\">K\u00e9tszer kell dobni egy kock\u00e1val. Az els\u0151 dob\u00e1s hat\u00e1rozza meg, hogy mennyit kap, a m\u00e1sodik pedig csak arra szolg\u00e1l, hogy megbizonyosodjon arr\u00f3l, hogy a kocka megfelel\u0151en m\u0171k\u00f6dik. Val\u00f3j\u00e1ban t\u00f6bbsz\u00f6r is dobhat a kock\u00e1val. Azonban csak az els\u0151 dob\u00e1s sz\u00e1m\u00edt.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">A maxim\u00e1lisan megkaphat\u00f3 kifizet\u00e9s 50 p\u00e9nzegys\u00e9g (PE), a legkisebb pedig 0. A pontos kifizet\u00e9st a k\u00f6vetkez\u0151 t\u00e1bl\u00e1zat mutatja.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">A t\u00e1bl\u00e1zat addig lesz majd l\u00e1that\u00f3 a k\u00e9perny\u0151n, am\u00edg meg nem adja a dobott sz\u00e1mot. Ha k\u00e9rd\u00e9se van, k\u00e9rj\u00fck, emelje fel a kez\u00e9t. Ha k\u00e9szen \u00e1ll, akkor l\u00e9pjen a k\u00f6vetkez\u0151 oldalra.<\/div>\n\n<table align=\"center\" border=\"1\" cellpadding=\"1\" cellspacing=\"1\" style=\"width:200px;\">\n\t<thead>\n\t\t<tr>\n\t\t\t<th scope=\"row\">Dobott sz\u00e1m\u00a0<\/th>\n\t\t\t<th scope=\"col\">Nyert PE<\/th>\n\t\t<\/tr>\n\t<\/thead>\n\t<tbody>\n\t\t<tr>\n\t\t\t<th scope=\"row\">1<\/th>\n\t\t\t<td style=\"text-align: center;\">10<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">2<\/th>\n\t\t\t<td style=\"text-align: center;\">20<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">3<\/th>\n\t\t\t<td style=\"text-align: center;\">30<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">4<\/th>\n\t\t\t<td style=\"text-align: center;\">40<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">5<\/th>\n\t\t\t<td style=\"text-align: center;\">50<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">6<\/th>\n\t\t\t<td style=\"text-align: center;\">0<\/td>\n\t\t<\/tr>\n\t<\/tbody>\n<\/table>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n"},"IT":{"QuestionText":"<div style=\"text-align: center;\">Dovrai lanciare un dado due volte. Il tuo primo lancio decide quanto ricevi, mentre il secondo serve solo per assicurarti che i dadi funzionino correttamente. In sostanza, puoi lanciare i dadi pi\u00f9 di due volte. Tuttavia conta solo il primo tiro.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">Il guadagno massimo che puoi ricevere \u00e8 50 unit\u00e0 monetarie (MU) e il minimo \u00e8 0. Puoi vedere il guadagno esatto dalla tabella seguente.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">La tabella rimarr\u00e0 sullo schermo finch\u00e9 non inserirai il numero uscito. Se hai domande, per favore alza la mano. Se sei pronto, continua alla pagina successiva.<\/div>\n\n<table align=\"center\" border=\"1\" cellpadding=\"1\" cellspacing=\"1\" style=\"width:200px;\">\n\t<thead>\n\t\t<tr>\n\t\t\t<th scope=\"row\">Numero uscito<\/th>\n\t\t\t<th scope=\"col\">MU per te<\/th>\n\t\t<\/tr>\n\t<\/thead>\n\t<tbody>\n\t\t<tr>\n\t\t\t<th scope=\"row\">1<\/th>\n\t\t\t<td style=\"text-align: center;\">10<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">2<\/th>\n\t\t\t<td style=\"text-align: center;\">20<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">3<\/th>\n\t\t\t<td style=\"text-align: center;\">30<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">4<\/th>\n\t\t\t<td style=\"text-align: center;\">40<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">5<\/th>\n\t\t\t<td style=\"text-align: center;\">50<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">6<\/th>\n\t\t\t<td style=\"text-align: center;\">0<\/td>\n\t\t<\/tr>\n\t<\/tbody>\n<\/table>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n"},"PL":{"QuestionText":"<div style=\"text-align: center;\">B\u0119dziesz musia\u0142 rzuci\u0107 kostk\u0105 dwa razy. Tw\u00f3j pierwszy rzut decyduje o tym, ile otrzymasz, a drugi rzut s\u0142u\u017cy jedynie upewnieniu si\u0119, \u017ce kostka dzia\u0142a prawid\u0142owo. Mo\u017cesz rzuci\u0107 kostk\u0105 wi\u0119cej ni\u017c dwa razy. Jednak liczy si\u0119 tylko pierwszy rzut.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">Maksymalna wyp\u0142ata, jak\u0105 mo\u017cesz otrzyma\u0107, to 50 jednostek monetarnych (MU), a minimalna 0. Dok\u0142adn\u0105 wyp\u0142at\u0119 mo\u017cesz zobaczy\u0107 w poni\u017cszej tabeli.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">Tabela pozostanie na ekranie, dop\u00f3ki nie wykonasz rzutu. Je\u015bli masz jakie\u015b pytania, podnie\u015b r\u0119k\u0119. Je\u015bli jeste\u015b gotowy, przejd\u017a do nast\u0119pnej strony.<\/div>\n\n<table align=\"center\" border=\"1\" cellpadding=\"1\" cellspacing=\"1\" style=\"width:200px;\">\n\t<thead>\n\t\t<tr>\n\t\t\t<th scope=\"row\">Wyrzucony numer<\/th>\n\t\t\t<th scope=\"col\">MU dla Ciebie<\/th>\n\t\t<\/tr>\n\t<\/thead>\n\t<tbody>\n\t\t<tr>\n\t\t\t<th scope=\"row\">1<\/th>\n\t\t\t<td style=\"text-align: center;\">10<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">2<\/th>\n\t\t\t<td style=\"text-align: center;\">20<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">3<\/th>\n\t\t\t<td style=\"text-align: center;\">30<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">4<\/th>\n\t\t\t<td style=\"text-align: center;\">40<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">5<\/th>\n\t\t\t<td style=\"text-align: center;\">50<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">6<\/th>\n\t\t\t<td style=\"text-align: center;\">0<\/td>\n\t\t<\/tr>\n\t<\/tbody>\n<\/table>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n"},"PT":{"QuestionText":"<div style=\"text-align: center;\">Ter\u00e1 que lan\u00e7ar um dado duas vezes. O seu primeiro lan\u00e7amento determina quanto recebe, e o segundo lan\u00e7amento serve apenas para garantir que o dado est\u00e1 a funcionar corretamente. Na verdade, pode lan\u00e7ar o dado mais do que duas vezes. No entanto, apenas o primeiro lan\u00e7amento conta.<\/div>\n\n<div>\u00a0<\/div>\n\n<div style=\"text-align: center;\">O pagamento m\u00e1ximo que pode receber \u00e9 50 Unidades Monet\u00e1rias (UMs) e o m\u00ednimo \u00e9 0. Pode ver o pagamento exato na tabela seguinte.<br \/>\n<br \/>\nA tabela permanecer\u00e1 no ecr\u00e3 at\u00e9 que insira o seu lan\u00e7amento. Se tiver alguma d\u00favida, por favor levante a m\u00e3o. Se est\u00e1 preparado, continue para a p\u00e1gina seguinte.<\/div>\n\n<table align=\"center\" border=\"1\" cellpadding=\"1\" style=\"largura:200px;\">\n\t<thead>\n\t\t<tr>\n\t\t\t<th scope=\"row\">N\u00famero lan\u00e7ado<\/th>\n\t\t\t<th scope=\"col\">UMs para si<\/th>\n\t\t<\/tr>\n\t<\/thead>\n\t<tbody>\n\t\t<tr>\n\t\t\t<th>1<\/th>\n\t\t\t<td style=\"text-align: center;\">10<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th>2<\/th>\n\t\t\t<td style=\"text-align: center;\">20<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th>3<\/th>\n\t\t\t<td style=\"text-align: center;\">30<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th>4<\/th>\n\t\t\t<td style=\"text-align: center;\">40<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th>5<\/th>\n\t\t\t<td style=\"text-align: center;\">50<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th>6<\/th>\n\t\t\t<td style=\"text-align: center;\">0<\/td>\n\t\t<\/tr>\n\t<\/tbody>\n<\/table>\n<br \/>\n\u00a0"},"KZ-RU":{"QuestionText":"<div style=\"text-align: center;\">\n<p align=\"center\" style=\"line-height: 100%; margin-bottom: 0cm\">\u0412\u0430\u043c \u043d\u0430\u0434\u043e \u0431\u0443\u0434\u0435\u0442 \u0431\u0440\u043e\u0441\u0438\u0442\u044c \u0438\u0433\u0440\u0430\u043b\u044c\u043d\u0443\u044e \u043a\u043e\u0441\u0442\u044c \u0434\u0432\u0430\u0436\u0434\u044b. \u0412\u0430\u0448 \u043f\u0435\u0440\u0432\u044b\u0439 \u0431\u0440\u043e\u0441\u043e\u043a \u043e\u043f\u0440\u0435\u0434\u0435\u043b\u044f\u0435\u0442, \u0441\u043a\u043e\u043b\u044c\u043a\u043e \u0412\u044b \u043f\u043e\u043b\u0443\u0447\u0438\u0442\u0435, \u0430 \u0432\u0442\u043e\u0440\u043e\u0439 \u0431\u0440\u043e\u0441\u043e\u043a \u0441\u043b\u0443\u0436\u0438\u0442 \u0442\u043e\u043b\u044c\u043a\u043e \u0434\u043b\u044f \u0442\u043e\u0433\u043e, \u0447\u0442\u043e\u0431\u044b \u0443\u0431\u0435\u0434\u0438\u0442\u044c\u0441\u044f, \u0447\u0442\u043e \u043a\u043e\u0441\u0442\u044c \u0440\u0430\u0431\u043e\u0442\u0430\u0435\u0442 \u043f\u0440\u0430\u0432\u0438\u043b\u044c\u043d\u043e. \u0424\u0430\u043a\u0442\u0438\u0447\u0435\u0441\u043a\u0438, \u0412\u044b \u043c\u043e\u0436\u0435\u0442\u0435 \u0431\u0440\u043e\u0441\u0438\u0442\u044c \u043a\u043e\u0441\u0442\u044c \u0438 \u0431\u043e\u043b\u0435\u0435 \u0434\u0432\u0443\u0445 \u0440\u0430\u0437. \u041e\u0434\u043d\u0430\u043a\u043e \u0437\u0430\u0441\u0447\u0438\u0442\u044b\u0432\u0430\u0435\u0442\u0441\u044f \u0442\u043e\u043b\u044c\u043a\u043e \u043f\u0435\u0440\u0432\u044b\u0439 \u0431\u0440\u043e\u0441\u043e\u043a.<\/p>\n\n<p align=\"center\" style=\"line-height: 100%; margin-bottom: 0cm\">\u00a0<\/p>\n\n<p align=\"center\" style=\"line-height: 100%; margin-bottom: 0cm\">\u041c\u0430\u043a\u0441\u0438\u043c\u0430\u043b\u044c\u043d\u044b\u0439 \u0432\u044b\u0438\u0433\u0440\u044b\u0448, \u043a\u043e\u0442\u043e\u0440\u044b\u0439 \u0412\u044b \u043c\u043e\u0436\u0435\u0442\u0435 \u043f\u043e\u043b\u0443\u0447\u0438\u0442\u044c, \u0441\u043e\u0441\u0442\u0430\u0432\u043b\u044f\u0435\u0442 50 \u0434\u0435\u043d\u0435\u0436\u043d\u044b\u0445 \u0435\u0434\u0438\u043d\u0438\u0446 (\u0414\u0415), \u0430 \u043c\u0438\u043d\u0438\u043c\u0430\u043b\u044c\u043d\u044b\u0439 \u2014 0. \u0422\u043e\u0447\u043d\u044b\u0439 \u0432\u044b\u0438\u0433\u0440\u044b\u0448 \u0412\u044b \u043c\u043e\u0436\u0435\u0442\u0435 \u0443\u0432\u0438\u0434\u0435\u0442\u044c \u0438\u0437 \u0441\u043b\u0435\u0434\u0443\u044e\u0449\u0435\u0439 \u0442\u0430\u0431\u043b\u0438\u0446\u044b.<\/p>\n\n<p align=\"center\" style=\"line-height: 100%; margin-bottom: 0cm\">\u00a0<\/p>\n\n<p align=\"center\" style=\"line-height: 100%; margin-bottom: 0cm\">\u0422\u0430\u0431\u043b\u0438\u0446\u0430 \u0431\u0443\u0434\u0435\u0442 \u043e\u0441\u0442\u0430\u0432\u0430\u0442\u044c\u0441\u044f \u043d\u0430 \u044d\u043a\u0440\u0430\u043d\u0435 \u0434\u043e \u0442\u0435\u0445 \u043f\u043e\u0440, \u043f\u043e\u043a\u0430 \u0412\u044b \u043d\u0435 \u0432\u0432\u0435\u0434\u0435\u0442\u0435 \u0440\u0435\u0437\u0443\u043b\u044c\u0442\u0430\u0442 \u0412\u0430\u0448\u0435\u0433\u043e \u0431\u0440\u043e\u0441\u043a\u0430. \u0415\u0441\u043b\u0438 \u0443 \u0412\u0430\u0441 \u0435\u0441\u0442\u044c \u0432\u043e\u043f\u0440\u043e\u0441\u044b, \u043f\u043e\u0436\u0430\u043b\u0443\u0439\u0441\u0442\u0430, \u043f\u043e\u0434\u043d\u0438\u043c\u0438\u0442\u0435 \u0440\u0443\u043a\u0443. \u0415\u0441\u043b\u0438 \u0412\u044b \u0433\u043e\u0442\u043e\u0432\u044b, \u043f\u0435\u0440\u0435\u0439\u0434\u0438\u0442\u0435 \u043d\u0430 \u0441\u043b\u0435\u0434\u0443\u044e\u0449\u0443\u044e \u0441\u0442\u0440\u0430\u043d\u0438\u0446\u0443.<\/p>\n<\/div>\n\n<table align=\"center\" border=\"1\" cellpadding=\"1\" cellspacing=\"1\" style=\"width:200px;\">\n\t<thead>\n\t\t<tr>\n\t\t\t<th style=\"border-top: 1px double #808080; border-bottom: 1px double #808080; border-left: 1px double #808080; border-right: 1px double #808080; padding: 0.05cm\" width=\"174\">\n\t\t\t<p>\u0427\u0438\u0441\u043b\u043e \u0432\u044b\u043f\u0430\u0432\u0448\u0438\u0445 \u043e\u0447\u043a\u043e\u0432<\/p>\n\t\t\t<\/th>\n\t\t\t<th style=\"border-top: 1px double #808080; border-bottom: 1px double #808080; border-left: 1px double #808080; border-right: 1px double #808080; padding: 0.05cm\" width=\"83\">\n\t\t\t<p>\u0414\u0415 \u0434\u043b\u044f \u0412\u0430\u0441<\/p>\n\t\t\t<\/th>\n\t\t<\/tr>\n\t<\/thead>\n\t<tbody>\n\t\t<tr>\n\t\t\t<th scope=\"row\">1<\/th>\n\t\t\t<td style=\"text-align: center;\">10<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">2<\/th>\n\t\t\t<td style=\"text-align: center;\">20<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">3<\/th>\n\t\t\t<td style=\"text-align: center;\">30<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">4<\/th>\n\t\t\t<td style=\"text-align: center;\">40<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">5<\/th>\n\t\t\t<td style=\"text-align: center;\">50<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">6<\/th>\n\t\t\t<td style=\"text-align: center;\">0<\/td>\n\t\t<\/tr>\n\t<\/tbody>\n<\/table>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n"},"ZH-S":{"QuestionText":"<div style=\"text-align: center;\">\u60a8\u9700\u8981\u63b7\u4e24\u6b21\u9ab0\u5b50\u3002\u7b2c\u4e00\u6b21\u63b7\u9ab0\u5b50\u51b3\u5b9a\u60a8\u80fd\u5f97\u5230\u591a\u5c11\u4e2a MU\uff0c\u7b2c\u4e8c\u6b21\u63b7\u9ab0\u5b50\u53ea\u662f\u4e3a\u4e86\u786e\u4fdd\u9ab0\u5b50\u662f\u6ca1\u95ee\u9898\u7684\u3002\u4e8b\u5b9e\u4e0a\uff0c\u60a8\u53ef\u4ee5\u63b7\u9ab0\u5b50\u4e24\u6b21\u4ee5\u4e0a\u3002\u4f46\u662f\uff0c\u53ea\u6709\u7b2c\u4e00\u6b21\u63b7\u9ab0\u5b50\u7684\u7ed3\u679c\u624d\u7b97\u6570\u3002<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">\u60a8\u80fd\u5f97\u5230\u7684\u6700\u5927\u6536\u76ca\u662f 50\u00a0\u4e2a\u8d27\u5e01\u5355\u4f4d (MU)\uff0c\u6700\u5c0f\u6536\u76ca\u662f 0 \u4e2a\u3002\u60a8\u53ef\u4ee5\u4ece\u4e0b\u8868\u4e2d\u770b\u5230\u786e\u5207\u7684\u6536\u76ca\u3002<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">\u8868\u683c\u5c06\u4e00\u76f4\u663e\u793a\u5728\u5c4f\u5e55\u4e0a\uff0c\u76f4\u5230\u60a8\u8f93\u5165\u60a8\u7684\u63b7\u9ab0\u5b50\u7ed3\u679c\u3002\u5982\u679c\u60a8\u6709\u4efb\u4f55\u7591\u95ee\uff0c\u8bf7\u4e3e\u624b\u3002\u5982\u679c\u60a8\u51c6\u5907\u597d\u4e86\uff0c\u8bf7\u7ee7\u7eed\u9605\u8bfb\u4e0b\u4e00\u9875\u3002<\/div>\n\n<table align=\"center\" border=\"1\" cellpadding=\"1\" cellspacing=\"1\" style=\"width:200px;\">\n\t<thead>\n\t\t<tr>\n\t\t\t<th scope=\"row\">\u63b7\u51fa\u7684\u6570\u5b57<\/th>\n\t\t\t<th scope=\"col\">\u60a8\u5c06\u5f97\u5230\u7684 MU<\/th>\n\t\t<\/tr>\n\t<\/thead>\n\t<tbody>\n\t\t<tr>\n\t\t\t<th scope=\"row\">1<\/th>\n\t\t\t<td style=\"text-align: center;\">10<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">2<\/th>\n\t\t\t<td style=\"text-align: center;\">20<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">3<\/th>\n\t\t\t<td style=\"text-align: center;\">30<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">4<\/th>\n\t\t\t<td style=\"text-align: center;\">40<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">5<\/th>\n\t\t\t<td style=\"text-align: center;\">50<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">6<\/th>\n\t\t\t<td style=\"text-align: center;\">0<\/td>\n\t\t<\/tr>\n\t<\/tbody>\n<\/table>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n"},"FR-FR":{"QuestionText":"<div style=\"text-align: center;\">Vous allez \u00eatre invit\u00e9 \u00e0 lancer votre d\u00e9 deux fois. Le r\u00e9sultat du premier lancer d\u00e9termine le montant que vous allez obtenir. Le deuxi\u00e8me lancer sert uniquement \u00e0 vous assurer que le d\u00e9 n'est pas truqu\u00e9. Vous pouvez m\u00eame lancer les d\u00e9s plus de deux fois. Cependant, seul le premier lancer compte.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">Le gain maximum que vous pouvez obtenir est de 50 unit\u00e9s mon\u00e9taires (UM), et le minimum est de 0 UM. Le tableau ci-dessous d\u00e9crit les gains exacts en fonction du r\u00e9sultat du d\u00e9.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">Si vous avez une question, veuillez lever la main. Si vous \u00eates pr\u00eat, vous pouvez passer \u00e0 la page suivante.<\/div>\n<t\u00eate> <\/t\u00eate><corps> <\/corps>\n\n<table align=\"center\" border=\"1\" cellpacing=\"1\" cellpadding=\"2\">\n\t<tbody>\n\t\t<tr>\n\t\t\t<th scope=\"row\">R\u00e9sultat du d\u00e9<\/th>\n\t\t\t<th scope=\"col\">UM pour vous<\/th>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">1<\/th>\n\t\t\t<td style=\"text-align: center;\">10<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">2<\/th>\n\t\t\t<td style=\"text-align: center;\">20<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">3<\/th>\n\t\t\t<td style=\"text-align: center;\">30<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">4<\/th>\n\t\t\t<td style=\"text-align: center;\">40<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">5<\/th>\n\t\t\t<td style=\"text-align: center;\">50<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">6<\/th>\n\t\t\t<td style=\"text-align: center;\">0<\/td>\n\t\t<\/tr>\n\t<\/tbody>\n<\/table>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n"},"ES-ES":{"QuestionText":"<div style=\"text-align: center;\">Tendr\u00e1 que lanzar el dado dos veces. Su primer lanzamiento decide cu\u00e1nto recibe, y el segundo lanzamiento solo sirve para asegurarse de que los dados funcionan correctamente. De hecho, puede tirar el dado m\u00e1s de dos veces. Sin embargo, solo cuenta el primer lanzamiento.<br \/>\n\u00a0<br \/>\nEl pago m\u00e1ximo que puede recibir es de 50 Unidades Monetarias (UM) y el m\u00ednimo de 0. Puede ver el pago exacto en la siguiente tabla.<br \/>\n\u00a0<br \/>\nLa tabla permanecer\u00e1 en la pantalla hasta que ingrese su lanzamiento. Si tiene alguna pregunta, por favor levante su mano. Si est\u00e1 listo, presione OK.\n<table align=\"center\" border=\"1\" cellpadding=\"1\" cellspacing=\"1\">\n\t<thead>\n\t\t<tr>\n\t\t\t<th scope=\"row\">N\u00famero lanzado<\/th>\n\t\t\t<th scope=\"col\">UM para usted<\/th>\n\t\t<\/tr>\n\t<\/thead>\n\t<tbody>\n\t\t<tr>\n\t\t\t<th scope=\"row\">1<\/th>\n\t\t\t<td>10<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">2<\/th>\n\t\t\t<td>20<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">3<\/th>\n\t\t\t<td>30<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">4<\/th>\n\t\t\t<td>40<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">5<\/th>\n\t\t\t<td>50<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">6<\/th>\n\t\t\t<td>0<\/td>\n\t\t<\/tr>\n\t<\/tbody>\n<\/table>\n<\/div>\n"},"ES-AR":{"QuestionText":"<div style=\"text-align: center;\">Tendr\u00e1 que lanzar el dado dos veces. Su primer lanzamiento decide cu\u00e1nto recibe, y el segundo lanzamiento solo sirve para asegurarse de que el dado funciona correctamente. De hecho, puede tirar el dado m\u00e1s de dos veces. Sin embargo, solo cuenta el primer lanzamiento.<br \/>\n\u00a0<br \/>\nEl pago m\u00e1ximo que puede recibir es de 50 Unidades Monetarias (UM) y el m\u00ednimo de 0. Puede ver el pago exacto en la siguiente tabla.<br \/>\n\u00a0<br \/>\nLa tabla permanecer\u00e1 en la pantalla hasta que ingrese su lanzamiento. Si tiene alguna pregunta, por favor levante su mano. Si est\u00e1 listo, presione OK.<br \/>\n\u00a0<\/div>\n\n<table align=\"center\" border=\"1\" cellpadding=\"1\" cellspacing=\"1\">\n\t<thead>\n\t\t<tr>\n\t\t\t<th scope=\"row\">\u00a0N\u00famero lanzado\u00a0<\/th>\n\t\t\t<th scope=\"col\">\u00a0UM para usted\u00a0<\/th>\n\t\t<\/tr>\n\t<\/thead>\n\t<tbody>\n\t\t<tr>\n\t\t\t<th scope=\"row\">1<\/th>\n\t\t\t<td style=\"text-align: center;\">10<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">2<\/th>\n\t\t\t<td style=\"text-align: center;\">20<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">3<\/th>\n\t\t\t<td style=\"text-align: center;\">30<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">4<\/th>\n\t\t\t<td style=\"text-align: center;\">40<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">5<\/th>\n\t\t\t<td style=\"text-align: center;\">50<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">6<\/th>\n\t\t\t<td style=\"text-align: center;\">0<\/td>\n\t\t<\/tr>\n\t<\/tbody>\n<\/table>\n"},"JA":{"QuestionText":"<div style=\"text-align: center;\">\u30b5\u30a4\u30b3\u30ed\u3092 2 \u56de\u6295\u3052\u308b\u5fc5\u8981\u304c\u3042\u308a\u307e\u3059\u30021 \u56de\u76ee\u306e\u6295\u3052\u3067\u53d7\u3051\u53d6\u308b\u91d1\u984d\u304c\u6c7a\u307e\u308a\u30012 \u56de\u76ee\u306e\u6295\u3052\u306f\u30b5\u30a4\u30b3\u30ed\u304c\u6b63\u3057\u304f\u6a5f\u80fd\u3057\u3066\u3044\u308b\u304b\u3069\u3046\u304b\u3092\u78ba\u8a8d\u3059\u308b\u305f\u3081\u3060\u3051\u306b\u884c\u308f\u308c\u307e\u3059\u3002\u5b9f\u969b\u3001\u30b5\u30a4\u30b3\u30ed\u3092 2 \u56de\u4ee5\u4e0a\u6295\u3052\u308b\u3053\u3068\u3082\u3067\u304d\u307e\u3059\u3002\u305f\u3060\u3057\u3001\u30ab\u30a6\u30f3\u30c8\u3055\u308c\u308b\u306e\u306f 1 \u56de\u76ee\u306e\u6295\u3052\u3060\u3051\u3067\u3059\u3002<\/div>\n\n<div style=\"text-align: center;\">&nbsp;<\/div>\n\n<div style=\"text-align: center;\">\u53d7\u3051\u53d6\u308b\u3053\u3068\u304c\u3067\u304d\u308b\u6700\u5927\u306e\u5831\u916c\u306f 50 \u901a\u8ca8\u5358\u4f4d (MU)\u3001\u6700\u5c0f\u306f 0 \u3067\u3059\u3002\u6b63\u78ba\u306a\u5831\u916c\u306f\u6b21\u306e\u8868\u3067\u78ba\u8a8d\u3067\u304d\u307e\u3059\u3002<\/div>\n\n<div style=\"text-align: center;\">&nbsp;<\/div>\n\n<div style=\"text-align: center;\">\u6295\u3052\u305f\u91d1\u984d\u3092\u5165\u529b\u3059\u308b\u307e\u3067\u3001\u8868\u306f\u753b\u9762\u306b\u8868\u793a\u3055\u308c\u305f\u307e\u307e\u306b\u306a\u308a\u307e\u3059\u3002\u8cea\u554f\u304c\u3042\u308b\u5834\u5408\u306f\u3001\u624b\u3092\u6319\u3052\u3066\u304f\u3060\u3055\u3044\u3002\u6e96\u5099\u304c\u3067\u304d\u305f\u3089\u3001\u6b21\u306e\u30da\u30fc\u30b8\u306b\u9032\u3093\u3067\u304f\u3060\u3055\u3044\u3002<\/div>\n\n<table style=\"width:200px;\" cellspacing=\"1\" cellpadding=\"1\" border=\"1\" align=\"center\">\n<thead>\n<tr>\n<th scope=\"row\">\u6295\u3052\u305f\u6570<\/th>\n<th scope=\"col\">\u3042\u306a\u305f\u306eMU\u6570<\/th>\n<\/tr>\n<\/thead>\n<tbody>\n<tr>\n<th scope=\"row\">1<\/th>\n<td style=\"text-align: center;\">10<\/td>\n<\/tr>\n<tr>\n<th scope=\"row\">2<\/th>\n<td style=\"text-align: center;\">20<\/td>\n<\/tr>\n<tr>\n<th scope=\"row\">3<\/th>\n<td style=\"text-align: center;\">30<\/td>\n<\/tr>\n<tr>\n<th scope=\"row\">4<\/th>\n<td style=\"text-align: center;\">40<\/td>\n<\/tr>\n<tr>\n<th scope=\"row\">5<\/th>\n<td style=\"text-align: center;\">50<\/td>\n<\/tr>\n<tr>\n<th scope=\"row\">6<\/th>\n<td style=\"text-align: center;\">0<\/td>\n<\/tr>\n<\/tbody>\n<\/table>\n\n<div style=\"text-align: center;\">&nbsp;<\/div>"},"DE":{"QuestionText":"<div style=\"text-align: center;\">Sie m\u00fcssen zweimal w\u00fcrfeln. Ihr erster Wurf entscheidet, wie viel Sie erhalten, und der zweite Wurf dient nur dazu, sicherzustellen, dass der W\u00fcrfel richtig funktioniert. Tats\u00e4chlich k\u00f6nnen Sie die W\u00fcrfel mehr als zweimal werfen. Allerdings z\u00e4hlt nur der erste Wurf.<\/div>\n\n<div style=\"text-align: center;\">&nbsp;<\/div>\n\n<div style=\"text-align: center;\">Die maximale Auszahlung, die Sie erhalten k\u00f6nnen, betr\u00e4gt 50 W\u00e4hrungseinheiten (MUs) und die minimale 0. Die genaue Auszahlung k\u00f6nnen Sie der folgenden Tabelle entnehmen.<\/div>\n\n<div style=\"text-align: center;\">&nbsp;<\/div>\n\n<div style=\"text-align: center;\">Die Tabelle bleibt auf dem Bildschirm, bis Sie Ihren Wurf eingegeben haben. Wenn Sie Fragen haben, heben Sie bitte Ihre Hand. Wenn Sie bereit sind, fahren Sie bitte mit der n\u00e4chsten Seite fort.<\/div>\n\n<table style=\"width:200px;\" cellspacing=\"1\" cellpadding=\"1\" border=\"1\" align=\"center\">\n<thead>\n<tr>\n<th scope=\"row\">Gew\u00fcrfelte Zahl<\/th>\n<th scope=\"col\">MUs f\u00fcr dich<\/th>\n<\/tr>\n<\/thead>\n<tbody>\n<tr>\n<th scope=\"row\">1<\/th>\n<td style=\"text-align: center;\">10<\/td>\n<\/tr>\n<tr>\n<th scope=\"row\">2<\/th>\n<td style=\"text-align: center;\">20<\/td>\n<\/tr>\n<tr>\n<th scope=\"row\">3<\/th>\n<td style=\"text-align: center;\">30<\/td>\n<\/tr>\n<tr>\n<th scope=\"row\">4<\/th>\n<td style=\"text-align: center;\">40<\/td>\n<\/tr>\n<tr>\n<th Umfang=\"Zeile\">5<\/th>\n<td style=\"text-align: center;\">50<\/td>\n<\/tr>\n<tr>\n<th Umfang=\"Zeile\">6<\/th>\n<td style=\"text-align: center;\">0<\/td>\n<\/tr>\n<\/tbody>\n<\/table>\n\n<div style=\"text-align: center;\">&nbsp;<\/div>"},"ZH-T":{"QuestionText":"<div style=\"text-align: center;\">\u60a8\u5fc5\u9808\u64f2\u5169\u6b21\u9ab0\u5b50\u3002\u7b2c\u4e00\u6b21\u64f2\u9ab0\u5b50\u6703\u6c7a\u5b9a\u60a8\u7372\u5f97\u7684\u6cd5\u5e63\u6578\u91cf\uff0c\u7b2c\u4e8c\u6b21\u64f2\u9ab0\u5b50\u53ea\u662f\u70ba\u4e86\u78ba\u8a8d\u9ab0\u5b50\u7684\u516c\u6b63\u6027\u3002\u4e8b\u5be6\u4e0a\uff0c\u60a8\u53ef\u4ee5\u64f2\u9ab0\u5b50\u5169\u6b21\u4ee5\u4e0a\u3002\u4f46\u662f\uff0c\u53ea\u6709\u7b2c\u4e00\u6b21\u64f2\u9ab0\u5b50\u7b97\u6578\u3002\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">\u60a8\u53ef\u4ee5\u7372\u5f97\u7684\u6cd5\u5e63\u6578\u91cf\u6700\u591a\u70ba 50\uff0c\u6700\u5c11\u70ba 0 \u3002\u4e0b\u65b9\u7684\u8868\u683c\u986f\u793a\u8457\u78ba\u5207\u7684\u6cd5\u5e63\u6578\u91cf\u5c0d\u61c9\u3002\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">\u8868\u683c\u6703\u505c\u7559\u5728\u87a2\u5e55\u4e0a\uff0c\u76f4\u5230\u60a8\u8f38\u5165\u64f2\u51fa\u7684\u6578\u5b50\u3002\u5982\u679c\u60a8\u6709\u4efb\u4f55\u7591\u554f\uff0c\u8acb\u8209\u624b\u3002\u5982\u679c\u60a8\u6e96\u5099\u597d\u4e86\uff0c\u8acb\u7e7c\u7e8c\u95b1\u8b80\u4e0b\u4e00\u9801\u3002\n<table align=\"center\" border=\"1\" cellpadding=\"1\" cellspacing=\"1\">\n\t<thead>\n\t\t<tr>\n\t\t\t<th scope=\"row\">\u00a0\u64f2\u51fa\u7684\u6578\u5b57\u00a0<\/th>\n\t\t\t<th scope=\"col\">\u00a0\u60a8\u7372\u5f97\u7684\u6cd5\u5e63\u00a0<\/th>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">1<\/th>\n\t\t\t<td>10<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">2<\/th>\n\t\t\t<td>20<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">3<\/th>\n\t\t\t<td>30<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">4<\/th>\n\t\t\t<td>40<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">5<\/th>\n\t\t\t<td>50<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">6<\/th>\n\t\t\t<td>0<\/td>\n\t\t<\/tr>\n\t<\/thead>\n<\/table>\n<\/div>\n<\/div>\n<\/div>\n"},"KO":{"QuestionText":"<div style=\"text-align: center;\">\uadc0\ud558\ub294 \uc8fc\uc0ac\uc704\ub97c \ucd5c\uc18c\ud55c \ub450 \ubc88 \uad74\ub824\uc57c \ud569\ub2c8\ub2e4. \uc8fc\uc0ac\uc704\ub97c \ucc98\uc74c \uad74\ub824 \uc5bb\uc740 \uacb0\uacfc\ub97c \uc785\ub825\ud558\uc5ec \ubcf4\uc0c1\uc744 \ubc1b\uc2b5\ub2c8\ub2e4. \uc8fc\uc0ac\uc704\uac00 \uc81c\ub300\ub85c \uc791\ub3d9\ud558\ub294 \uc9c0\ub97c \ud655\uc778\ud558\uae30 \uc704\ud574 \uc8fc\uc0ac\uc704\ub97c \ucd5c\uc18c\ud55c \ud55c \ubc88 \uc774\uc0c1 \ucd94\uac00\ub85c \uad74\ub824\uc57c \ud569\ub2c8\ub2e4. \uadf8\ub7ec\ub098 \uccab \ubc88\uc9f8 \uad74\ub9ac\uae30\ub9cc \ubcf4\uc0c1\uc5d0 \ubc18\uc601\ub429\ub2c8\ub2e4.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">\ubc1b\uc744 \uc218 \uc788\ub294 \ucd5c\ub300 \ubcf4\uc0c1\uc740 50 MU\uc774\uace0 \ucd5c\uc18c \ubcf4\uc0c1\uc740 0\uc785\ub2c8\ub2e4. \ub2e4\uc74c \ud45c\uc5d0\uc11c \uc815\ud655\ud55c \ubcf4\uc0c1\uc744 \ud655\uc778\ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">\uc8fc\uc0ac\uc704\ub97c \uad74\ub9b0 \uacb0\uacfc\ub97c \uc785\ub825\ud560 \ub54c\uae4c\uc9c0 \uc544\ub798\uc758 \ud45c\uac00 \ud654\uba74\uc5d0 \ud45c\uc2dc\ub429\ub2c8\ub2e4. \uc9c8\ubb38\uc774 \uc788\uc73c\uba74 \uc190\uc744 \ub4e4\uc5b4\uc8fc\uc138\uc694. \uc900\ube44\uac00 \ub418\uc5c8\ub2e4\uba74 \ub2e4\uc74c \ud398\uc774\uc9c0\ub85c \ub118\uc5b4\uac00\uc138\uc694.<\/div>\n\n<table align=\"center\" border=\"1\" cellpadding=\"1\" cellspacing=\"1\" style=\"width:200px;\">\n\t<thead>\n\t\t<tr>\n\t\t\t<th scope=\"row\">\uc8fc\uc0ac\uc704 \uacb0\uacfc<\/th>\n\t\t\t<th scope=\"col\">\uc5bb\uac8c \ub418\ub294\u00a0MU<\/th>\n\t\t<\/tr>\n\t<\/thead>\n\t<tbody>\n\t\t<tr>\n\t\t\t<th scope=\"row\">1<\/th>\n\t\t\t<td style=\"text-align: center;\">10<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">2<\/th>\n\t\t\t<td style=\"text-align: center;\">20<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">3<\/th>\n\t\t\t<td style=\"text-align: center;\">30<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">4<\/th>\n\t\t\t<td style=\"text-align: center;\">40<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th>5<\/th>\n\t\t\t<td style=\"text-align: center;\">50<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th>6<\/th>\n\t\t\t<td style=\"text-align: center;\">0<\/td>\n\t\t<\/tr>\n\t<\/tbody>\n<\/table>\n\n<div>\u00a0<\/div>\n"},"DE-AT":{"QuestionText":"<div style=\"text-align: center;\">Nachfolgend werden Sie aufgefordert, zweimal zu w\u00fcrfeln. Ihr erster Wurf entscheidet, wie viel Sie erhalten; der zweite Wurf dient nur dazu, sicherzustellen, dass der W\u00fcrfel richtig funktioniert. Tats\u00e4chlich k\u00f6nnen Sie die W\u00fcrfel mehr als zweimal werfen. Allerdings z\u00e4hlt nur der erste Wurf.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">Die maximale Auszahlung, die Sie erhalten k\u00f6nnen, betr\u00e4gt 50 Geldeinheiten (GE) und die minimale Auszahlung betr\u00e4gt 0. Die genaue Auszahlung k\u00f6nnen Sie der folgenden Tabelle entnehmen.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">Die Tabelle wird auf dem Bildschirm angezeigt , bis Sie Ihren Wurf eingegeben haben. Wenn Sie Fragen haben, heben Sie bitte Ihre Hand. Wenn Sie bereit sind, fahren Sie bitte mit der n\u00e4chsten Seite fort.<br \/>\n\u00a0<\/div>\n\n<table align=\"center\" border=\"1\" cellpadding=\"1\" cellspacing=\"1\" style=\"width:200px;\">\n\t<thead>\n\t\t<tr>\n\t\t\t<th scope=\"row\">Gew\u00fcrfelte Zahl<\/th>\n\t\t\t<th scope=\"col\">GE f\u00fcr Sie<\/th>\n\t\t<\/tr>\n\t<\/thead>\n\t<tbody>\n\t\t<tr>\n\t\t\t<th scope=\"row\">1<\/th>\n\t\t\t<td style=\"text-align: center;\">10<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">2<\/th>\n\t\t\t<td style=\"text-align: center;\">20<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">3<\/th>\n\t\t\t<td style=\"text-align: center;\">30<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">4<\/th>\n\t\t\t<td style=\"text-align: center;\">40<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">5<\/th>\n\t\t\t<td style=\"text-align: center;\">50<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">6<\/th>\n\t\t\t<td style=\"text-align: center;\">0<\/td>\n\t\t<\/tr>\n\t<\/tbody>\n<\/table>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n"},"TR":{"QuestionText":"<div style=\"text-align: center;\">Bu b\u00f6l\u00fcmde, size verilen zar\u0131 iki kez atman\u0131z istenmektedir. Elde edece\u011finiz kazanc\u0131 zar\u0131 ilk at\u0131\u015f\u0131n\u0131z\u0131n sonucu belirleyecektir. \u0130kinci at\u0131\u015f ise sadece zar\u0131n d\u00fczg\u00fcn \u00e7al\u0131\u015ft\u0131\u011f\u0131ndan emin olman\u0131z i\u00e7indir. Dilerseniz zar\u0131 iki kereden fazla da atabilirsiniz. Ancak, kazanc\u0131n\u0131z\u0131 sadece ilk at\u0131\u015f\u0131n\u0131z\u0131n sonucu belirleyecektir.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">Bu b\u00f6l\u00fcmde elde edebilece\u011finiz en y\u00fcksek kazan\u00e7 50 Deney Para Birimi (DPB), en d\u00fc\u015f\u00fck kazan\u00e7 0 DPB'dir. A\u015fa\u011f\u0131daki tabloda ataca\u011f\u0131n\u0131z ilk zar\u0131n sonucuna g\u00f6re kazanaca\u011f\u0131n\u0131z DPB'ler yer almaktad\u0131r.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">Att\u0131\u011f\u0131n\u0131z ilk zar\u0131n sonucunu girene kadar tablo ekranda kalacakt\u0131r. Herhangi bir sorunuz varsa l\u00fctfen elinizi kald\u0131r\u0131n. Haz\u0131r oldu\u011funuzda l\u00fctfen bir sonraki sayfaya ge\u00e7in.<br \/>\n\u00a0<\/div>\n\n<table align=\"center\" border=\"1\" cellpadding=\"1\" cellspacing=\"1\" style=\"width:200px;\">\n\t<thead>\n\t\t<tr>\n\t\t\t<th scope=\"row\">Zar\u0131n sonucu<\/th>\n\t\t\t<th scope=\"col\">DPB kazanc\u0131n\u0131z<\/th>\n\t\t<\/tr>\n\t<\/thead>\n\t<tbody>\n\t\t<tr>\n\t\t\t<th scope=\"row\">1<\/th>\n\t\t\t<td style=\"text-align: center;\">10<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">2<\/th>\n\t\t\t<td style=\"text-align: center;\">20<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">3<\/th>\n\t\t\t<td style=\"text-align: center;\">30<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">4<\/th>\n\t\t\t<td style=\"text-align: center;\">40<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">5<\/th>\n\t\t\t<td style=\"text-align: center;\">50<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">6<\/th>\n\t\t\t<td style=\"text-align: center;\">0<\/td>\n\t\t<\/tr>\n\t<\/tbody>\n<\/table>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n"},"EN-UK":{"QuestionText":"<div style=\"text-align: center;\">You will have to throw a die twice. Your first throw decides how much you receive, and the second throw only serves to make sure that the die is working properly. In fact, you may throw the die more than twice. However, only the first throw counts.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">The maximum payoff you can receive is 50 Monetary Units (MUs) and the minimum 0. You can see the exact payoff in the table below.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">The table will remain on the screen until you entered your throw. If you have any questions, please raise your hand. If you are ready, please continue to the next page.<br \/>\n\u00a0<\/div>\n\n<table align=\"center\" border=\"1\" cellpadding=\"1\" cellspacing=\"1\" style=\"width:200px;\">\n\t<thead>\n\t\t<tr>\n\t\t\t<th scope=\"row\">Number thrown<\/th>\n\t\t\t<th scope=\"col\">MUs for you<\/th>\n\t\t<\/tr>\n\t<\/thead>\n\t<tbody>\n\t\t<tr>\n\t\t\t<th scope=\"row\">1<\/th>\n\t\t\t<td style=\"text-align: center;\">10<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">2<\/th>\n\t\t\t<td style=\"text-align: center;\">20<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">3<\/th>\n\t\t\t<td style=\"text-align: center;\">30<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">4<\/th>\n\t\t\t<td style=\"text-align: center;\">40<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">5<\/th>\n\t\t\t<td style=\"text-align: center;\">50<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">6<\/th>\n\t\t\t<td style=\"text-align: center;\">0<\/td>\n\t\t<\/tr>\n\t<\/tbody>\n<\/table>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n"},"ZH-HK":{"QuestionText":"<div style=\"text-align: center;\">\n<p>\u60a8\u5fc5\u9808\u64f2\u5169\u6b21\u9ab0\u5b50\u3002\u7b2c\u4e00\u6b21\u64f2\u9ab0\u5b50\u6703\u6c7a\u5b9a\u4f60\u7372\u5f97\u7684MU\u6578\u91cf\uff0c\u7b2c\u4e8c\u6b21\u64f2\u9ab0\u5b50\u53ea\u662f\u70ba\u4e86\u78ba\u8a8d\u9ab0\u5b50\u6b63\u5e38\u904b\u4f5c\u3002\u4e8b\u5be6\u4e0a\uff0c\u60a8\u53ef\u4ee5\u64f2\u9ab0\u5b50\u5169\u6b21\u4ee5\u4e0a\u3002\u4f46\u662f\uff0c\u53ea\u6709\u7b2c\u4e00\u6b21\u64f2\u9ab0\u5b50\u7b97\u6578\u3002<\/p>\n<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">\n<p>\u60a8\u53ef\u4ee5\u7372\u5f97\u7684MU\u6578\u91cf\u6700\u591a\u70ba 50\uff0c\u6700\u5c11\u70ba 0 \u3002\u4e0b\u65b9\u7684\u8868\u683c\u986f\u793a\u8457\u78ba\u5207\u5c0d\u61c9\u7684MU\u6578\u91cf\u3002<\/p>\n<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">\n<p>\u8868\u683c\u6703\u505c\u7559\u5728\u87a2\u5e55\u4e0a\uff0c\u76f4\u5230\u60a8\u8f38\u5165\u64f2\u51fa\u7684\u6570\u5b57\u3002\u5982\u679c\u60a8\u6709\u4efb\u4f55\u7591\u554f\uff0c\u8acb\u8209\u624b\u3002\u5982\u679c\u60a8\u6e96\u5099\u597d\u4e86\uff0c\u8acb\u7e7c\u7e8c\u95b1\u8b80\u4e0b\u4e00\u9801\u3002<\/p>\n<\/div>\n\n<table align=\"center\" border=\"1\" cellpadding=\"1\" cellspacing=\"1\" style=\"width:200px;\">\n\t<thead>\n\t\t<tr>\n\t\t\t<th scope=\"row\">\n\t\t\t<p><strong>\u64f2\u51fa\u7684\u6578\u5b57<\/strong><\/p>\n\t\t\t<\/th>\n\t\t\t<th scope=\"col\">\n\t\t\t<p><b>\u60a8\u7372\u5f97\u7684MU<\/b><\/p>\n\t\t\t<\/th>\n\t\t<\/tr>\n\t<\/thead>\n\t<tbody>\n\t\t<tr>\n\t\t\t<th scope=\"row\">1<\/th>\n\t\t\t<td style=\"text-align: center;\">10<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">2<\/th>\n\t\t\t<td style=\"text-align: center;\">20<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">3<\/th>\n\t\t\t<td style=\"text-align: center;\">30<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">4<\/th>\n\t\t\t<td style=\"text-align: center;\">40<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">5<\/th>\n\t\t\t<td style=\"text-align: center;\">50<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">6<\/th>\n\t\t\t<td style=\"text-align: center;\">0<\/td>\n\t\t<\/tr>\n\t<\/tbody>\n<\/table>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n"},"AR":{"QuestionText":"<div style=\"text-align: center;;text-align:right;direction:rtl\">\u0633\u064a\u062a\u0639\u064a\u0646 \u0639\u0644\u064a\u0643 \u0631\u0645\u064a \u0627\u0644\u0632\u0647\u0631 \u0645\u0631\u062a\u064a\u0646. \u062a\u062d\u062f\u062f \u0631\u0645\u064a\u062a\u0643 \u0627\u0644\u0623\u0648\u0644\u0649 \u0645\u0642\u062f\u0627\u0631 \u0645\u0627 \u0633\u062a\u062d\u0635\u0644 \u0639\u0644\u064a\u0647\u060c \u0623\u0645\u0627 \u0627\u0644\u0631\u0645\u064a\u0629 \u0627\u0644\u062b\u0627\u0646\u064a\u0629 \u0641\u062a\u0639\u0645\u0644 \u0641\u0642\u0637 \u0639\u0644\u0649 \u0627\u0644\u062a\u0623\u0643\u062f \u0645\u0646 \u0623\u0646 \u0627\u0644\u0632\u0647\u0631 \u064a\u0639\u0645\u0644 \u0628\u0634\u0643\u0644 \u0635\u062d\u064a\u062d. \u0641\u064a \u0627\u0644\u0648\u0627\u0642\u0639\u060c \u064a\u0645\u0643\u0646\u0643 \u0631\u0645\u064a \u0627\u0644\u0632\u0647\u0631 \u0623\u0643\u062b\u0631 \u0645\u0646 \u0645\u0631\u062a\u064a\u0646. \u0648\u0645\u0639 \u0630\u0644\u0643\u060c \u0641\u0625\u0646 \u0627\u0644\u0631\u0645\u064a\u0629 \u0627\u0644\u0623\u0648\u0644\u0649 \u0641\u0642\u0637 \u0647\u064a \u0627\u0644\u062a\u064a \u062a\u064f\u062d\u0633\u0628.<\/div>\n\n<div style=\"text-align: center;;text-align:right;direction:rtl\">\u00a0<\/div>\n\n<div style=\"text-align: center;;text-align:right;direction:rtl\">\u0627\u0644\u062d\u062f \u0627\u0644\u0623\u0642\u0635\u0649 \u0644\u0644\u0645\u0643\u0627\u0641\u0623\u0629 \u0627\u0644\u062a\u064a \u064a\u0645\u0643\u0646\u0643 \u0627\u0644\u062d\u0635\u0648\u0644 \u0639\u0644\u064a\u0647\u0627 \u0647\u0648 50 \u0648\u062d\u062f\u0629 \u0646\u0642\u062f\u064a\u0629 (\u0648.\u0646.) \u0648\u0627\u0644\u062d\u062f \u0627\u0644\u0623\u062f\u0646\u0649 \u0647\u0648 \u0635\u0641\u0631. \u064a\u0645\u0643\u0646\u0643 \u0631\u0624\u064a\u0629 \u0627\u0644\u0645\u0643\u0627\u0641\u0623\u0629 \u062a\u062d\u062f\u064a\u062f\u0627 \u0645\u0646 \u0627\u0644\u062c\u062f\u0648\u0644 \u0627\u0644\u062a\u0627\u0644\u064a.<\/div>\n\n<div style=\"text-align: center;;text-align:right;direction:rtl\">\u00a0<\/div>\n\n<div style=\"text-align: center;;text-align:right;direction:rtl\">\u0633\u064a\u0638\u0644 \u0627\u0644\u062c\u062f\u0648\u0644 \u0639\u0644\u0649 \u0627\u0644\u0634\u0627\u0634\u0629 \u062d\u062a\u0649 \u062a\u0642\u0648\u0645 \u0628\u0625\u062f\u062e\u0627\u0644 \u0631\u0645\u064a\u062a\u0643. \u0625\u0630\u0627 \u0643\u0627\u0646\u062a \u0644\u062f\u064a\u0643 \u0623\u064a \u0623\u0633\u0626\u0644\u0629\u060c \u064a\u0631\u062c\u0649 \u0631\u0641\u0639 \u064a\u062f\u0643. \u0625\u0630\u0627 \u0643\u0646\u062a \u0645\u0633\u062a\u0639\u062f\u064b\u0627\u060c \u064a\u0631\u062c\u0649 \u0627\u0644\u0627\u0646\u062a\u0642\u0627\u0644 \u0625\u0644\u0649 \u0627\u0644\u0635\u0641\u062d\u0629 \u0627\u0644\u062a\u0627\u0644\u064a\u0629.<\/div>\n\n<table align=\"center\" border=\"1\" cellpadding=\"1\" cellspacing=\"1\" style=\"width:200px;;text-align:right;direction:rtl\">\n\t<thead>\n\t\t<tr>\n\t\t\t<th scope=\"row\">\u0627\u0644\u0631\u0642\u0645 \u0627\u0644\u0630\u064a \u062a\u0645 \u0625\u0644\u0642\u0627\u0624\u0647<\/th>\n\t\t\t<th scope=\"col\">\u0648\u062d\u062f\u0627\u062a \u0646\u0642\u062f\u064a\u0629 (\u0648.\u0646.) \u0645\u0646 \u0623\u062c\u0644\u0643<\/th>\n\t\t<\/tr>\n\t<\/thead>\n\t<tbody>\n\t\t<tr>\n\t\t\t<th scope=\"row\" style=\"text-align: center;\">1<\/th>\n\t\t\t<td style=\"text-align: center;\">10<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\" style=\"text-align: center;\">2<\/th>\n\t\t\t<td style=\"text-align: center;\">20<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\" style=\"text-align: center;\">3<\/th>\n\t\t\t<td style=\"text-align: center;\">30<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\" style=\"text-align: center;\">4<\/th>\n\t\t\t<td style=\"text-align: center;\">40<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\" style=\"text-align: center;\">5<\/th>\n\t\t\t<td style=\"text-align: center;\">50<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\" style=\"text-align: center;\">6<\/th>\n\t\t\t<td style=\"text-align: center;\">0<\/td>\n\t\t<\/tr>\n\t<\/tbody>\n<\/table>\n\n<div style=\"text-align: center;;text-align:right;direction:rtl\">\u00a0<\/div>\n"},"DE-DE":{"QuestionText":"<div style=\"text-align: center;\">\n<div style=\"text-align: center;\">Sie m\u00fcssen zweimal w\u00fcrfeln. Der erste Wurf entscheidet, wie viel Sie erhalten, und der zweite Wurf dient nur dazu, zu pr\u00fcfen, ob der W\u00fcrfel richtig funktioniert. Sie d\u00fcrfen sogar \u00f6fter w\u00fcrfeln. Allerdings z\u00e4hlt nur der erste Wurf.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">Die maximale Auszahlung, die Sie erhalten k\u00f6nnen, betr\u00e4gt 50 Geldeinheint (GE), die minimale 0. Die genaue Auszahlung k\u00f6nnen Sie der folgenden Tabelle entnehmen.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">\n<div style=\"text-align: center;\">Die Tabelle bleibt auf dem Bildschirm, bis Sie Ihren Wurf eingegeben haben. Wenn Sie Fragen haben, heben Sie bitte Ihre Hand. Wenn Sie bereit sind, fahren Sie bitte mit der n\u00e4chsten Seite fort.<\/div>\n<\/div>\n<\/div>\n\n<table align=\"center\" border=\"1\" cellpadding=\"1\" cellspacing=\"1\" style=\"width:200px;\">\n\t<thead>\n\t\t<tr>\n\t\t\t<th scope=\"row\">Geworfene Zahl<\/th>\n\t\t\t<th scope=\"col\">GE\u00a0f\u00fcr Sie<\/th>\n\t\t<\/tr>\n\t<\/thead>\n\t<tbody>\n\t\t<tr>\n\t\t\t<th scope=\"row\">1<\/th>\n\t\t\t<td style=\"text-align: center;\">10<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">2<\/th>\n\t\t\t<td style=\"text-align: center;\">20<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">3<\/th>\n\t\t\t<td style=\"text-align: center;\">30<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">4<\/th>\n\t\t\t<td style=\"text-align: center;\">40<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">5<\/th>\n\t\t\t<td style=\"text-align: center;\">50<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">6<\/th>\n\t\t\t<td style=\"text-align: center;\">0<\/td>\n\t\t<\/tr>\n\t<\/tbody>\n<\/table>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n"}},"NextChoiceId":4,"NextAnswerId":1,"DataVisibility":{"Private":false,"Hidden":false},"QuestionText_Unsafe":"<div style=\"text-align: center;\">You will have to throw a dice twice. Your first throw decides how much you receive, and the second throw only serves to make sure that the dice is working properly. In fact, you may throw the dice more than twice. However, only the first throw counts.<\/div>\n\n<div style=\"text-align: center;\">&nbsp;<\/div>\n\n<div style=\"text-align: center;\">The maximum payoff you can receive is 50 Monetary Units (MUs) and the minimum 0. You can see the exact payoff from the following table.<\/div>\n\n<div style=\"text-align: center;\">&nbsp;<\/div>\n\n<div style=\"text-align: center;\">The table will remain on the screen until you entered your throw. If you have any questions, please raise your hand. If you are ready, please continue to the next page.<\/div>\n\n<table style=\"width:200px;\" cellspacing=\"1\" cellpadding=\"1\" border=\"1\" align=\"center\">\n\t<thead>\n\t\t<tr>\n\t\t\t<th scope=\"row\">Number thrown<\/th>\n\t\t\t<th scope=\"col\">MUs for you<\/th>\n\t\t<\/tr>\n\t<\/thead>\n\t<tbody>\n\t\t<tr>\n\t\t\t<th scope=\"row\">1<\/th>\n\t\t\t<td style=\"text-align: center;\">10<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">2<\/th>\n\t\t\t<td style=\"text-align: center;\">20<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">3<\/th>\n\t\t\t<td style=\"text-align: center;\">30<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">4<\/th>\n\t\t\t<td style=\"text-align: center;\">40<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">5<\/th>\n\t\t\t<td style=\"text-align: center;\">50<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">6<\/th>\n\t\t\t<td style=\"text-align: center;\">0<\/td>\n\t\t<\/tr>\n\t<\/tbody>\n<\/table>\n\n<div style=\"text-align: center;\">&nbsp;<\/div>"}},{"SurveyID":"SV_b3mHBVkuioRMhng","Element":"SQ","PrimaryAttribute":"QID60","SecondaryAttribute":"Please enter the number, i.e., the first number you have thrown.","TertiaryAttribute":null,"Payload":{"QuestionText":"<div style=\"text-align: center;\">Please enter the number, i.e., the first number you have thrown.<\/div>","DefaultChoices":false,"DataExportTag":"T2: Dice_throw_2","QuestionType":"TE","Selector":"SL","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Please enter the number, i.e., the first number you have thrown.","Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"ContentType","MinChars":"1","ContentType":"ValidNumber","ValidDateType":"DateWithFormat","ValidPhoneType":"ValidUSPhone","ValidZipType":"ValidUSZip","ValidNumber":{"Min":"1","Max":"6","NumDecimals":""}}},"GradingData":[],"Language":{"CS":{"QuestionText":"<div style=\"text-align: center;\">Zadejte \u010d\u00edslo, tj. prvn\u00ed \u010d\u00edslo, kter\u00e9 jste hodil.<\/div>"},"DA":{"QuestionText":"<div style=\"text-align: center;\">Indtast venligst nummeret, dvs. det f\u00f8rste tal du har kastet.<\/div>"},"DE":{"QuestionText":"<div style=\"text-align: center;\">Bitte geben Sie die Zahl ein, dh die erste Zahl, die Sie gew\u00fcrfelt haben.<\/div>"},"EL":{"QuestionText":"<div style=\"text-align: center;\">\u0395\u03b9\u03c3\u03b1\u03b3\u03ac\u03b3\u03b5\u03c4\u03b5 \u03c4\u03bf\u03bd \u03b1\u03c1\u03b9\u03b8\u03bc\u03cc, \u03b4\u03b7\u03bb\u03b1\u03b4\u03ae \u03c4\u03bf\u03bd \u03c0\u03c1\u03ce\u03c4\u03bf \u03b1\u03c1\u03b9\u03b8\u03bc\u03cc \u03c0\u03bf\u03c5 \u03ad\u03c7\u03b5\u03c4\u03b5 \u03c0\u03b5\u03c4\u03ac\u03be\u03b5\u03b9.<\/div>"},"ES":{"QuestionText":"<div style=\"text-align: center;\">Por favor ingrese el n\u00famero, es decir, el primer n\u00famero que ha lanzado.<\/div>"},"ES-ES":{"QuestionText":"<div style=\"text-align: center;\">Por favor ingrese el n\u00famero, es decir, el primer n\u00famero que ha lanzado.<\/div>"},"FR":{"QuestionText":"<div style=\"text-align: center;\">Veuillez entrer le num\u00e9ro, c&#39;est-\u00e0-dire le premier num\u00e9ro que vous avez lanc\u00e9.<\/div>"},"IT":{"QuestionText":"<div style=\"text-align: center;\">Per favore inserisci il numero, cio\u00e8 il primo numero che hai lanciato.<\/div>"},"NL":{"QuestionText":"<div style=\"text-align: center;\">Voer het nummer in, dwz het eerste nummer dat u hebt gegooid.<\/div>"},"RU":{"QuestionText":"<div style=\"text-align: center;\">\u041f\u043e\u0436\u0430\u043b\u0443\u0439\u0441\u0442\u0430, \u0432\u0432\u0435\u0434\u0438\u0442\u0435 \u043d\u043e\u043c\u0435\u0440, \u0442.\u0435. \u043f\u0435\u0440\u0432\u044b\u0439 \u043d\u043e\u043c\u0435\u0440, \u043a\u043e\u0442\u043e\u0440\u044b\u0439 \u0432\u044b \u0431\u0440\u043e\u0441\u0438\u043b\u0438.<\/div>"},"ZH-S":{"QuestionText":"<div style=\"text-align: center;\">\u8bf7\u8f93\u5165\u6570\u5b57\uff0c\u5373\u60a8\u629b\u51fa\u7684\u7b2c\u4e00\u4e2a\u6570\u5b57\u3002<\/div>"},"ZH-T":{"QuestionText":"<div style=\"text-align: center;\">\u8acb\u8f38\u5165\u6578\u5b57\uff0c\u5373\u60a8\u62cb\u51fa\u7684\u7b2c\u4e00\u500b\u6578\u5b57\u3002<\/div>"}},"NextChoiceId":4,"NextAnswerId":1,"SearchSource":{"AllowFreeResponse":"false"},"QuestionID":"QID60"}},{"SurveyID":"SV_b3mHBVkuioRMhng","Element":"SQ","PrimaryAttribute":"QID61","SecondaryAttribute":"Please enter the number, i.e., the first number you have thrown.","TertiaryAttribute":null,"Payload":{"QuestionText":"<div style=\"text-align: center;\">Please enter the number, i.e., the first number you have thrown.<\/div>","DefaultChoices":false,"DataExportTag":"T3: Dice_throw_3","QuestionType":"TE","Selector":"SL","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Please enter the number, i.e., the first number you have thrown.","Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"ContentType","MinChars":"1","ContentType":"ValidNumber","ValidDateType":"DateWithFormat","ValidPhoneType":"ValidUSPhone","ValidZipType":"ValidUSZip","ValidNumber":{"Min":"1","Max":"6","NumDecimals":""}}},"GradingData":[],"Language":{"CS":{"QuestionText":"<div style=\"text-align: center;\">Zadejte \u010d\u00edslo, tj. prvn\u00ed \u010d\u00edslo, kter\u00e9 jste hodil.<\/div>"},"DA":{"QuestionText":"<div style=\"text-align: center;\">Indtast venligst nummeret, dvs. det f\u00f8rste tal du har kastet.<\/div>"},"DE":{"QuestionText":"<div style=\"text-align: center;\">Bitte geben Sie die Zahl ein, dh die erste Zahl, die Sie gew\u00fcrfelt haben.<\/div>"},"EL":{"QuestionText":"<div style=\"text-align: center;\">\u0395\u03b9\u03c3\u03b1\u03b3\u03ac\u03b3\u03b5\u03c4\u03b5 \u03c4\u03bf\u03bd \u03b1\u03c1\u03b9\u03b8\u03bc\u03cc, \u03b4\u03b7\u03bb\u03b1\u03b4\u03ae \u03c4\u03bf\u03bd \u03c0\u03c1\u03ce\u03c4\u03bf \u03b1\u03c1\u03b9\u03b8\u03bc\u03cc \u03c0\u03bf\u03c5 \u03ad\u03c7\u03b5\u03c4\u03b5 \u03c0\u03b5\u03c4\u03ac\u03be\u03b5\u03b9.<\/div>"},"ES":{"QuestionText":"<div style=\"text-align: center;\">Por favor ingrese el n\u00famero, es decir, el primer n\u00famero que ha lanzado.<\/div>"},"ES-ES":{"QuestionText":"<div style=\"text-align: center;\">Por favor ingrese el n\u00famero, es decir, el primer n\u00famero que ha lanzado.<\/div>"},"FR":{"QuestionText":"<div style=\"text-align: center;\">Veuillez entrer le num\u00e9ro, c&#39;est-\u00e0-dire le premier num\u00e9ro que vous avez lanc\u00e9.<\/div>"},"IT":{"QuestionText":"<div style=\"text-align: center;\">Per favore inserisci il numero, cio\u00e8 il primo numero che hai lanciato.<\/div>"},"NL":{"QuestionText":"<div style=\"text-align: center;\">Voer het nummer in, dwz het eerste nummer dat u hebt gegooid.<\/div>"},"RU":{"QuestionText":"<div style=\"text-align: center;\">\u041f\u043e\u0436\u0430\u043b\u0443\u0439\u0441\u0442\u0430, \u0432\u0432\u0435\u0434\u0438\u0442\u0435 \u043d\u043e\u043c\u0435\u0440, \u0442.\u0435. \u043f\u0435\u0440\u0432\u044b\u0439 \u043d\u043e\u043c\u0435\u0440, \u043a\u043e\u0442\u043e\u0440\u044b\u0439 \u0432\u044b \u0431\u0440\u043e\u0441\u0438\u043b\u0438.<\/div>"},"ZH-S":{"QuestionText":"<div style=\"text-align: center;\">\u8bf7\u8f93\u5165\u6570\u5b57\uff0c\u5373\u60a8\u629b\u51fa\u7684\u7b2c\u4e00\u4e2a\u6570\u5b57\u3002<\/div>"},"ZH-T":{"QuestionText":"<div style=\"text-align: center;\">\u8acb\u8f38\u5165\u6578\u5b57\uff0c\u5373\u60a8\u62cb\u51fa\u7684\u7b2c\u4e00\u500b\u6578\u5b57\u3002<\/div>"}},"NextChoiceId":4,"NextAnswerId":1,"SearchSource":{"AllowFreeResponse":"false"},"QuestionID":"QID61"}},{"SurveyID":"SV_b3mHBVkuioRMhng","Element":"SQ","PrimaryAttribute":"QID62","SecondaryAttribute":"Please enter the number, i.e., the first number you have thrown.","TertiaryAttribute":null,"Payload":{"QuestionText":"<div style=\"text-align: center;\">Please enter the number, i.e., the first number you have thrown.<\/div>","DefaultChoices":false,"DataExportTag":"T4: Dice_throw_4","QuestionType":"TE","Selector":"SL","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Please enter the number, i.e., the first number you have thrown.","Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"ContentType","MinChars":"1","ContentType":"ValidNumber","ValidDateType":"DateWithFormat","ValidPhoneType":"ValidUSPhone","ValidZipType":"ValidUSZip","ValidNumber":{"Min":"1","Max":"6","NumDecimals":""}}},"GradingData":[],"Language":{"CS":{"QuestionText":"<div style=\"text-align: center;\">Zadejte \u010d\u00edslo, tj. prvn\u00ed \u010d\u00edslo, kter\u00e9 jste hodil.<\/div>"},"DA":{"QuestionText":"<div style=\"text-align: center;\">Indtast venligst nummeret, dvs. det f\u00f8rste tal du har kastet.<\/div>"},"DE":{"QuestionText":"<div style=\"text-align: center;\">Bitte geben Sie die Zahl ein, dh die erste Zahl, die Sie gew\u00fcrfelt haben.<\/div>"},"EL":{"QuestionText":"<div style=\"text-align: center;\">\u0395\u03b9\u03c3\u03b1\u03b3\u03ac\u03b3\u03b5\u03c4\u03b5 \u03c4\u03bf\u03bd \u03b1\u03c1\u03b9\u03b8\u03bc\u03cc, \u03b4\u03b7\u03bb\u03b1\u03b4\u03ae \u03c4\u03bf\u03bd \u03c0\u03c1\u03ce\u03c4\u03bf \u03b1\u03c1\u03b9\u03b8\u03bc\u03cc \u03c0\u03bf\u03c5 \u03ad\u03c7\u03b5\u03c4\u03b5 \u03c0\u03b5\u03c4\u03ac\u03be\u03b5\u03b9.<\/div>"},"ES":{"QuestionText":"<div style=\"text-align: center;\">Por favor ingrese el n\u00famero, es decir, el primer n\u00famero que ha lanzado.<\/div>"},"ES-ES":{"QuestionText":"<div style=\"text-align: center;\">Por favor ingrese el n\u00famero, es decir, el primer n\u00famero que ha lanzado.<\/div>"},"FR":{"QuestionText":"<div style=\"text-align: center;\">Veuillez entrer le num\u00e9ro, c&#39;est-\u00e0-dire le premier num\u00e9ro que vous avez lanc\u00e9.<\/div>"},"IT":{"QuestionText":"<div style=\"text-align: center;\">Per favore inserisci il numero, cio\u00e8 il primo numero che hai lanciato.<\/div>"},"NL":{"QuestionText":"<div style=\"text-align: center;\">Voer het nummer in, dwz het eerste nummer dat u hebt gegooid.<\/div>"},"RU":{"QuestionText":"<div style=\"text-align: center;\">\u041f\u043e\u0436\u0430\u043b\u0443\u0439\u0441\u0442\u0430, \u0432\u0432\u0435\u0434\u0438\u0442\u0435 \u043d\u043e\u043c\u0435\u0440, \u0442.\u0435. \u043f\u0435\u0440\u0432\u044b\u0439 \u043d\u043e\u043c\u0435\u0440, \u043a\u043e\u0442\u043e\u0440\u044b\u0439 \u0432\u044b \u0431\u0440\u043e\u0441\u0438\u043b\u0438.<\/div>"},"ZH-S":{"QuestionText":"<div style=\"text-align: center;\">\u8bf7\u8f93\u5165\u6570\u5b57\uff0c\u5373\u60a8\u629b\u51fa\u7684\u7b2c\u4e00\u4e2a\u6570\u5b57\u3002<\/div>"},"ZH-T":{"QuestionText":"<div style=\"text-align: center;\">\u8acb\u8f38\u5165\u6578\u5b57\uff0c\u5373\u60a8\u62cb\u51fa\u7684\u7b2c\u4e00\u500b\u6578\u5b57\u3002<\/div>"}},"NextChoiceId":4,"NextAnswerId":1,"SearchSource":{"AllowFreeResponse":"false"},"QuestionID":"QID62"}},{"SurveyID":"SV_b3mHBVkuioRMhng","Element":"SQ","PrimaryAttribute":"QID63","SecondaryAttribute":"Timing","TertiaryAttribute":null,"Payload":{"QuestionText":"Timing","DefaultChoices":false,"DataExportTag":"Q56","QuestionID":"QID63","QuestionType":"Timing","Selector":"PageTimer","Configuration":{"QuestionDescriptionOption":"UseText","MinSeconds":"0","MaxSeconds":"0"},"QuestionDescription":"Timing","Choices":{"1":{"Display":"First Click"},"2":{"Display":"Last Click"},"3":{"Display":"Page Submit"},"4":{"Display":"Click Count"}},"Validation":"None","GradingData":[],"Language":{"ES":{"QuestionText":"Momento","Choices":{"1":{"Display":"Primer clic"},"2":{"Display":"\u00daltimo clic"},"3":{"Display":"P\u00e1gina Enviar"},"4":{"Display":"Haga clic en Contar"}}}},"NextChoiceId":16,"NextAnswerId":1,"QuestionText_Unsafe":"Timing"}},{"SurveyID":"SV_b3mHBVkuioRMhng","Element":"SQ","PrimaryAttribute":"QID64","SecondaryAttribute":"Please answer the following two blocks of mathematical questions. Each block is composed of 10 su...","TertiaryAttribute":null,"Payload":{"ChoiceOrder":[],"Configuration":{"QuestionDescriptionOption":"UseText"},"DataExportTag":"Mathpay1","DataVisibility":{"Hidden":false,"Private":false},"DefaultChoices":false,"GradingData":[],"Language":{"CS":{"QuestionText":"<div style=\"text-align: center;\">Odpov\u011bzte, pros\u00edm, na n\u00e1sleduj\u00edc\u00ed dva bloky matematick\u00fdch ot\u00e1zek.<\/div>\n\n<div style=\"text-align: center;\"><br \/>\nKa\u017ed\u00fd blok se skl\u00e1d\u00e1 z 10 sou\u010dt\u016f.<\/div>\n\n<div style=\"text-align: center;\"><br \/>\nKa\u017ed\u00fd blok trv\u00e1 20 sekund.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">Va\u0161\u00edm \u00fakolem je spr\u00e1vn\u011b odpov\u011bd\u011bt na co nejv\u00edce ot\u00e1zek.<\/div>\n"},"DE":{"QuestionText":"<div style=\"text-align: center;\">Bitte beantworten Sie die folgenden beiden Bl\u00f6cke mit mathematischen Fragen.<\/div><div style=\"text-align: center;\"><br>\nJeder Block besteht aus 10 Summationsfragen.<\/div><div style=\"text-align: center;\"><br>\nJeder Block dauert 20 Sekunden.<\/div><div style=\"text-align: center;\"><br><\/div><div style=\"text-align: center;\">Ihre Aufgabe ist es, so viele Fragen wie m\u00f6glich richtig zu beantworten.<br><\/div>"},"DE-AT":{"QuestionText":"<div style=\"text-align: center;\">Bitte beantworten Sie die folgenden beiden Mathematik-Fragenbl\u00f6cke.<\/div>\n\n<div style=\"text-align: center;\"><br \/>\nJeder Block besteht aus 10 Additionsfragen.<\/div>\n\n<div style=\"text-align: center;\"><br \/>\nJeder Block dauert 20 Sekunden.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">Ihre Aufgabe besteht darin, m\u00f6glichst viele Fragen richtig zu beantworten.<\/div>\n"},"EL":{"QuestionText":"<div style=\"text-align: center;\">\u0391\u03c0\u03b1\u03bd\u03c4\u03ae\u03c3\u03c4\u03b5 \u03c3\u03c4\u03b1 \u03b1\u03ba\u03cc\u03bb\u03bf\u03c5\u03b8\u03b1 \u03b4\u03cd\u03bf \u03bc\u03c0\u03bb\u03bf\u03ba \u03bc\u03b1\u03b8\u03b7\u03bc\u03b1\u03c4\u03b9\u03ba\u03ce\u03bd \u03b5\u03c1\u03c9\u03c4\u03ae\u03c3\u03b5\u03c9\u03bd.<\/div>\n\n<div style=\"text-align: center;\"><br \/>\n\u039a\u03ac\u03b8\u03b5 \u03bc\u03c0\u03bb\u03bf\u03ba \u03b1\u03c0\u03bf\u03c4\u03b5\u03bb\u03b5\u03af\u03c4\u03b1\u03b9 \u03b1\u03c0\u03cc 10 \u03b5\u03c1\u03c9\u03c4\u03ae\u03c3\u03b5\u03b9\u03c2 \u03ac\u03b8\u03c1\u03bf\u03b9\u03c3\u03b7\u03c2.<\/div>\n\n<div style=\"text-align: center;\"><br \/>\n\u039a\u03ac\u03b8\u03b5 \u03bc\u03c0\u03bb\u03bf\u03ba \u03b4\u03b9\u03b1\u03c1\u03ba\u03b5\u03af 20 \u03b4\u03b5\u03c5\u03c4\u03b5\u03c1\u03cc\u03bb\u03b5\u03c0\u03c4\u03b1.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">\u0398\u03b1 \u03c0\u03c1\u03ad\u03c0\u03b5\u03b9 \u03bd\u03b1 \u03b1\u03c0\u03b1\u03bd\u03c4\u03ae\u03c3\u03b5\u03c4\u03b5 \u03c3\u03c9\u03c3\u03c4\u03ac \u03c3\u03b5 \u03cc\u03c3\u03bf \u03c4\u03bf \u03b4\u03c5\u03bd\u03b1\u03c4\u03cc\u03bd \u03c0\u03b5\u03c1\u03b9\u03c3\u03c3\u03cc\u03c4\u03b5\u03c1\u03b5\u03c2 \u03b5\u03c1\u03c9\u03c4\u03ae\u03c3\u03b5\u03b9\u03c2.<\/div>\n"},"ES":{"QuestionText":"<div style=\"text-align: center;\">Por favor conteste los siguientes dos bloques de preguntas matem\u00e1ticas.<br \/>\n<br \/>\nCada bloque est\u00e1 compuesto por 10 preguntas de sumatoria.<br \/>\n<br \/>\nCada bloque dura 20 segundos.<br \/>\n<br \/>\nSu tarea es responder correctamente tantas preguntas como sea posible.<\/div>\n"},"ES-AR":{"QuestionText":"<div style=\"text-align: center;\">Responda los siguientes dos bloques de preguntas matem\u00e1ticas.<br \/>\n<br \/>\nCada bloque se compone de 10 preguntas de resumen.<br \/>\n<br \/>\nCada bloque dura 20 segundos.<br \/>\n<br \/>\nSu tarea es responder correctamente tantas preguntas como sea posible.<\/div>\n"},"ES-ES":{"QuestionText":"<div style=\"text-align: center;\">Responda los siguientes dos bloques de preguntas matem\u00e1ticas.<\/div><div style=\"text-align: center;\"><br>\nCada bloque se compone de 10 preguntas de resumen.<\/div><div style=\"text-align: center;\"><br>\nCada bloque dura 20 segundos.<\/div><div style=\"text-align: center;\"><br><\/div><div style=\"text-align: center;\">Tu tarea es responder correctamente como tantas preguntas como sea posible.<br><\/div>"},"FR":{"QuestionText":"<div style=\"text-align: center;\">Veuillez r\u00e9pondre aux deux blocs de questions math\u00e9matiques suivants.<\/div><div style=\"text-align: center;\"><br> Chaque bloc est compos\u00e9 de 10 questions r\u00e9capitulatives.<\/div><div style=\"text-align: center;\"><br> Chaque bloc dure 20 secondes.<\/div><div style=\"text-align: center;\"><br><\/div><div style=\"text-align: center;\"> Votre t\u00e2che est de r\u00e9pondre correctement \u00e0 autant de questions que possible.<br><\/div>"},"FR-FR":{"QuestionText":"<div style=\"text-align: center;\">Vous allez maintenant r\u00e9pondre \u00e0 deux blocs de questions de calcul mental.<\/div>\n\n<div style=\"text-align: center;\"><br \/>\nChaque bloc est compos\u00e9 de 10 additions.<\/div>\n\n<div style=\"text-align: center;\"><br \/>\nChaque bloc dure 20 secondes.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">Votre t\u00e2che consiste \u00e0 r\u00e9pondre correctement \u00e0 autant de questions que possible.<\/div>\n"},"HU":{"QuestionText":"<div style=\"text-align: center;\">K\u00e9rj\u00fck, v\u00e1laszoljon a k\u00f6vetkez\u0151 k\u00e9t matematikai k\u00e9rd\u00e9sblokkra!<\/div>\n\n<div style=\"text-align: center;\"><br \/>\nMinden blokk 10 \u00f6sszead\u00e1sos feladatb\u00f3l \u00e1ll.<\/div>\n\n<div style=\"text-align: center;\"><br \/>\nMinden blokk 20 m\u00e1sodpercig tart.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">Az \u00d6n feladata, hogy min\u00e9l t\u00f6bb k\u00e9rd\u00e9sre helyesen v\u00e1laszoljon.<\/div>\n"},"IT":{"QuestionText":"<div style=\"text-align: center;\">Rispondi ai seguenti due blocchi di domande matematiche.<\/div><div style=\"text-align: center;\"><br> Ogni blocco \u00e8 composto da 10 domande di sommatoria.<\/div><div style=\"text-align: center;\"><br> Ogni blocco dura 20 secondi.<\/div><div style=\"text-align: center;\"><br><\/div><div style=\"text-align: center;\"> Il tuo compito \u00e8 rispondere correttamente a quante pi\u00f9 domande possibile.<br><\/div>"},"JA":{"QuestionText":"<div style=\"text-align: center;\">\u6b21\u306e 2 \u3064\u306e\u6570\u5b66\u306e\u554f\u984c\u30d6\u30ed\u30c3\u30af\u306b\u7b54\u3048\u3066\u304f\u3060\u3055\u3044\u3002<\/div><div style=\"text-align: center;\"><br>\n\u5404\u30d6\u30ed\u30c3\u30af\u306f 10 \u500b\u306e\u5408\u8a08\u554f\u984c\u3067\u69cb\u6210\u3055\u308c\u3066\u3044\u307e\u3059\u3002<\/div><div style=\"text-align: center;\"><br>\n\u5404\u30d6\u30ed\u30c3\u30af\u306f 20 \u79d2\u9593\u7d9a\u304d\u307e\u3059\u3002<\/div><div style=\"text-align: center;\"><br><\/div><div style=\"text-align: center;\">\u3042\u306a\u305f\u306e\u8ab2\u984c\u306f\u3001\u3067\u304d\u308b\u3060\u3051\u591a\u304f\u306e\u554f\u984c\u306b\u6b63\u3057\u304f\u7b54\u3048\u308b\u3053\u3068\u3067\u3059\u3002<br><\/div>"},"KO":{"QuestionText":"<div style=\"text-align: center;\">\ub2e4\uc74c \ub450 \ubb36\uc74c\uc758 \uc218\ud559 \ubb38\uc81c\uc5d0 \ub2f5\ud558\uc138\uc694.<\/div>\n\n<div style=\"text-align: center;\"><br \/>\n\uac01 \ubb36\uc74c\uc740 10\uac1c\uc758 \ub367\uc148 \ubb38\uc81c\ub85c \uad6c\uc131\ub418\uc5b4 \uc788\uc2b5\ub2c8\ub2e4.<\/div>\n\n<div style=\"text-align: center;\"><br \/>\n\uac01 \ubb36\uc74c\uc740 20\ucd08 \ub3d9\uc548 \uc9c4\ud589\ub429\ub2c8\ub2e4.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">\uadc0\ud558\uc758 \uc784\ubb34\ub294 \uac00\ub2a5\ud55c \ud55c \ub9ce\uc740 \uc9c8\ubb38\uc5d0 \uc62c\ubc14\ub974\uac8c \ub2f5\ud558\ub294 \uac83\uc785\ub2c8\ub2e4.<\/div>\n"},"PL":{"QuestionText":"<div style=\"text-align: center;\">Prosz\u0119 odpowiedzie\u0107 na dwa poni\u017csze bloki pyta\u0144 matematycznych.<\/div><div style=\"text-align: center;\"><br> Ka\u017cdy blok sk\u0142ada si\u0119 z 10 pyta\u0144 podsumowuj\u0105cych.<\/div><div style=\"text-align: center;\"><br> Ka\u017cdy blok trwa 20 sekund.<\/div><div style=\"text-align: center;\"><br><\/div><div style=\"text-align: center;\"> Twoim zadaniem jest udzielenie poprawnej odpowiedzi na jak najwi\u0119ksz\u0105 liczb\u0119 pyta\u0144.<br><\/div>"},"PT":{"QuestionText":"<div style=\"text-align: center;\">Por favor, responda aos dois blocos de quest\u00f5es matem\u00e1ticas seguintes.<\/div>\n\n<div style=\"text-align: center;\"><br \/>\nCada bloco \u00e9 composto por 10 quest\u00f5es de somat\u00f3rio.<\/div>\n\n<div style=\"text-align: center;\"><br \/>\nCada bloco tem a dura\u00e7\u00e3o de 20 segundos.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">A sua tarefa \u00e9 responder corretamente ao m\u00e1ximo de perguntas poss\u00edvel.<\/div>\n"},"RU":{"QuestionText":"<div style=\"text-align: center;\">\u041f\u043e\u0436\u0430\u043b\u0443\u0439\u0441\u0442\u0430, \u043e\u0442\u0432\u0435\u0442\u044c\u0442\u0435 \u043d\u0430 \u0441\u043b\u0435\u0434\u0443\u044e\u0449\u0438\u0435 \u0434\u0432\u0430 \u0431\u043b\u043e\u043a\u0430 \u043c\u0430\u0442\u0435\u043c\u0430\u0442\u0438\u0447\u0435\u0441\u043a\u0438\u0445 \u0432\u043e\u043f\u0440\u043e\u0441\u043e\u0432.<\/div>\n\n<div style=\"text-align: center;\"><br \/>\n\u041a\u0430\u0436\u0434\u044b\u0439 \u0431\u043b\u043e\u043a \u0441\u043e\u0441\u0442\u043e\u0438\u0442 \u0438\u0437 10 \u0437\u0430\u0434\u0430\u043d\u0438\u0439 \u043d\u0430 \u0441\u043b\u043e\u0436\u0435\u043d\u0438\u0435.<\/div>\n\n<div style=\"text-align: center;\"><br \/>\n\u041a\u0430\u0436\u0434\u044b\u0439 \u0431\u043b\u043e\u043a \u0434\u043b\u0438\u0442\u0441\u044f 20 \u0441\u0435\u043a\u0443\u043d\u0434.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">\u0412\u0430\u0448\u0430 \u0437\u0430\u0434\u0430\u0447\u0430 \u2014 \u043f\u0440\u0430\u0432\u0438\u043b\u044c\u043d\u043e \u043e\u0442\u0432\u0435\u0442\u0438\u0442\u044c \u043d\u0430 \u043a\u0430\u043a \u043c\u043e\u0436\u043d\u043e \u0431\u043e\u043b\u044c\u0448\u0435\u0435 \u043a\u043e\u043b\u0438\u0447\u0435\u0441\u0442\u0432\u043e \u0432\u043e\u043f\u0440\u043e\u0441\u043e\u0432.<\/div>\n"},"TR":{"QuestionText":"<div style=\"text-align: center;\">Bu b\u00f6l\u00fcmde, her biri 10 adet toplama i\u015flemi sorusu i\u00e7eren 2 blok yer almaktad\u0131r.<\/div>\n\n<div style=\"text-align: center;\"><br \/>\nHer blo\u011fu tamamlamak i\u00e7in size 20 saniye verilmektedir.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">Kazanc\u0131n\u0131z, her blokta 20 saniye i\u00e7inde verece\u011finiz do\u011fru cevap say\u0131s\u0131na g\u00f6re belirlenecektir.<\/div>\n"},"ZH-HK":{"QuestionText":"<div style=\"text-align: center;\">\u8acb\u56de\u7b54\u4ee5\u4e0b\u5169\u7d44\u6578\u5b78\u984c\u76ee\u3002<\/div>\n\n<div style=\"text-align: center;\"><br \/>\n\u6bcf\u7d44\u7531 10 \u9053\u6c42\u548c\u984c\u76ee\u7d44\u6210\u3002<\/div>\n\n<div style=\"text-align: center;\"><br \/>\n\u6bcf\u7d44\u984c\u76ee\u9650\u6642 20 \u79d2\u3002<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">\u60a8\u7684\u4efb\u52d9\u662f\u7b54\u5c0d\u8d8a\u591a\u984c\u8d8a\u597d\u3002<\/div>\n"},"ZH-S":{"QuestionText":"<div style=\"text-align: center;\">\u8bf7\u56de\u7b54\u4ee5\u4e0b\u4e24\u7ec4\u6570\u5b66\u95ee\u9898\u3002<\/div><div style=\"text-align: center;\"><br>\n\u6bcf\u7ec4\u7531 10 \u9053\u6c42\u548c\u9898\u7ec4\u6210\u3002<\/div><div style=\"text-align: center;\"><br>\n\u6bcf\u7ec4\u6301\u7eed 20 \u79d2\u3002<\/div><div style=\"text-align: center;\"><br><\/div><div style=\"text-align: center;\">\u60a8\u7684\u4efb\u52a1\u662f\u5c3d\u53ef\u80fd\u6b63\u786e\u56de\u7b54\u5c3d\u53ef\u80fd\u591a\u7684\u95ee\u9898\u3002<br><\/div>"},"ZH-T":{"QuestionText":"<div style=\"text-align: center;\">\u00a0\n<div style=\"text-align: center;\">\u8acb\u56de\u7b54\u4ee5\u4e0b\u5169\u7d44\u6578\u5b78\u984c\u76ee\u3002<br \/>\n<br \/>\n\u6bcf\u7d44\u7531 10 \u9053\u6c42\u548c\u984c\u76ee\u7d44\u6210\u3002<br \/>\n<br \/>\n\u6bcf\u7d44\u984c\u76ee\u9650\u6642 20 \u79d2\u3002<br \/>\n<br \/>\n\u60a8\u7684\u4efb\u52d9\u662f\u7b54\u5c0d\u8d8a\u591a\u984c\u8d8a\u597d\u3002<\/div>\n<\/div>\n"},"KZ-RU":[],"AR":{"QuestionText":"<div style=\"text-align: center;;text-align:right;direction:rtl\">\u0627\u0644\u0631\u062c\u0627\u0621 \u0627\u0644\u0625\u062c\u0627\u0628\u0629 \u0639\u0644\u0649 \u0627\u0644\u062c\u0632\u0626\u064a\u0646 \u0627\u0644\u062a\u0627\u0644\u064a\u064a\u0646 \u0645\u0646 \u0627\u0644\u0623\u0633\u0626\u0644\u0629 \u0627\u0644\u0631\u064a\u0627\u0636\u064a\u0629.<\/div>\n\n<div style=\"text-align: center;;text-align:right;direction:rtl\"><br \/>\n\u064a\u062a\u0643\u0648\u0646 \u0643\u0644 \u062c\u0632\u0621 \u0645\u0646 10 \u0623\u0633\u0626\u0644\u0629 \u062a\u0644\u062e\u064a\u0635\u064a\u0629.<\/div>\n\n<div style=\"text-align: center;;text-align:right;direction:rtl\"><br \/>\n\u0643\u0644 \u062c\u0632\u0621 \u064a\u0633\u062a\u0645\u0631 \u0644\u0645\u062f\u0629 20 \u062b\u0627\u0646\u064a\u0629.<\/div>\n\n<div style=\"text-align: center;;text-align:right;direction:rtl\">\u00a0<\/div>\n\n<div style=\"text-align: center;;text-align:right;direction:rtl\">\u0645\u0647\u0645\u062a\u0643 \u0647\u064a \u0627\u0644\u0625\u062c\u0627\u0628\u0629 \u0628\u0634\u0643\u0644 \u0635\u062d\u064a\u062d \u0639\u0644\u0649 \u0623\u0643\u0628\u0631 \u0639\u062f\u062f \u0645\u0645\u0643\u0646 \u0645\u0646 \u0627\u0644\u0623\u0633\u0626\u0644\u0629.<\/div>\n"},"DE-DE":{"QuestionText":"<div style=\"text-align: center;\">Bitte beantworten Sie die folgenden beiden Mathematik-Fragenbl\u00f6cke.<\/div>\n\n<div style=\"text-align: center;\"><br \/>\nJeder Block besteht aus 10 Additionsaufgaben.<\/div>\n\n<div style=\"text-align: center;\"><br \/>\nJeder Block dauert 20 Sekunden.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">Ihre Aufgabe besteht darin, m\u00f6glichst viele Fragen richtig zu beantworten.<\/div>\n"}},"NextAnswerId":1,"NextChoiceId":4,"QuestionDescription":"Please answer the following two blocks of mathematical questions. Each block is composed of 10 su...","QuestionID":"QID64","QuestionText":"<div style=\"text-align: center;\">Please answer the following two blocks of mathematical questions.<\/div><div style=\"text-align: center;\"><br>\nEach block is composed of 10 summation questions.<\/div><div style=\"text-align: center;\"><br>\nEach block lasts 20 seconds.<\/div><div style=\"text-align: center;\"><br><\/div><div style=\"text-align: center;\">Your task is to answer correctly as many questions as possible.<br><\/div>","QuestionText_Unsafe":"<div style=\"text-align: center;\">Please answer the following two blocks of mathematical questions.<\/div><div style=\"text-align: center;\"><br>\nEach block is composed of 10 summation questions.<\/div><div style=\"text-align: center;\"><br>\nEach block lasts 20 seconds.<\/div><div style=\"text-align: center;\"><br><\/div><div style=\"text-align: center;\">Your task is to answer correctly as many questions as possible.<br><\/div>","QuestionType":"DB","Selector":"TB","Validation":{"Settings":{"Type":"None"}}}},{"SurveyID":"SV_b3mHBVkuioRMhng","Element":"SQ","PrimaryAttribute":"QID65","SecondaryAttribute":"Please answer the following two blocks of mathematical questions. Each block is composed of 10 su...","TertiaryAttribute":null,"Payload":{"ChoiceOrder":[],"Configuration":{"QuestionDescriptionOption":"UseText"},"DataExportTag":"sum1.2","DataVisibility":{"Hidden":false,"Private":false},"DefaultChoices":false,"GradingData":[],"Language":{"ES":{"QuestionText":"<div style=\"text-align: center;\">Por favor conteste los siguientes dos bloques de preguntas matem\u00e1ticas.<br \/>\n<br \/>\nCada bloque est\u00e1 compuesto por 10 preguntas de sumatoria.<br \/>\n<br \/>\nCada bloque dura 20 segundos.<br \/>\n<br \/>\nSu tarea es responder correctamente tantas preguntas como sea posible.<\/div>\n"},"EL":{"QuestionText":"<div style=\"text-align: center;\">\u0391\u03c0\u03b1\u03bd\u03c4\u03ae\u03c3\u03c4\u03b5 \u03c3\u03c4\u03b1 \u03b1\u03ba\u03cc\u03bb\u03bf\u03c5\u03b8\u03b5\u03c2 \u03b4\u03cd\u03bf \u03bc\u03c0\u03bb\u03bf\u03ba \u03bc\u03b1\u03b8\u03b7\u03bc\u03b1\u03c4\u03b9\u03ba\u03ce\u03bd \u03b5\u03c1\u03c9\u03c4\u03ae\u03c3\u03b5\u03c9\u03bd.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">\u039a\u03ac\u03b8\u03b5 \u03bc\u03c0\u03bb\u03bf\u03ba \u03b1\u03c0\u03bf\u03c4\u03b5\u03bb\u03b5\u03af\u03c4\u03b1\u03b9 \u03b1\u03c0\u03cc 10 \u03b5\u03c1\u03c9\u03c4\u03ae\u03c3\u03b5\u03b9\u03c2 \u03ac\u03b8\u03c1\u03bf\u03b9\u03c3\u03b7\u03c2.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">\u039a\u03ac\u03b8\u03b5 \u03bc\u03c0\u03bb\u03bf\u03ba \u03b4\u03b9\u03b1\u03c1\u03ba\u03b5\u03af 20 \u03b4\u03b5\u03c5\u03c4\u03b5\u03c1\u03cc\u03bb\u03b5\u03c0\u03c4\u03b1.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">\u0398\u03b1 \u03c0\u03c1\u03ad\u03c0\u03b5\u03b9 \u03bd\u03b1 \u03b1\u03c0\u03b1\u03bd\u03c4\u03ae\u03c3\u03b5\u03c4\u03b5 \u03c3\u03c9\u03c3\u03c4\u03ac \u03c3\u03b5 \u03cc\u03c3\u03bf \u03c4\u03bf \u03b4\u03c5\u03bd\u03b1\u03c4\u03cc\u03bd \u03c0\u03b5\u03c1\u03b9\u03c3\u03c3\u03cc\u03c4\u03b5\u03c1\u03b5\u03c2 \u03b5\u03c1\u03c9\u03c4\u03ae\u03c3\u03b5\u03b9\u03c2.<\/div>\n"},"FR":{"QuestionText":"<div style=\"text-align: center;\">Veuillez r\u00e9pondre aux deux blocs de questions math\u00e9matiques suivants.<\/div><div style=\"text-align: center;\"><br><\/div><div style=\"text-align: center;\"> Chaque bloc est compos\u00e9 de 10 questions r\u00e9capitulatives.<\/div><div style=\"text-align: center;\"><br><\/div><div style=\"text-align: center;\"> Chaque bloc dure 20 secondes.<\/div><div style=\"text-align: center;\"><br><\/div><div style=\"text-align: center;\"> Votre t\u00e2che est de r\u00e9pondre correctement \u00e0 autant de questions que possible.<br><\/div>"},"CS":{"QuestionText":"<div style=\"text-align: center;\">Odpov\u011bzte, pros\u00edm, na n\u00e1sleduj\u00edc\u00ed dva bloky matematick\u00fdch ot\u00e1zek.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">Ka\u017ed\u00fd blok se skl\u00e1d\u00e1 z 10 <span style=\"color:#e74c3c;\">sou\u010dt\u016f<\/span>.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">Ka\u017ed\u00fd blok trv\u00e1 20 sekund.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">Va\u0161\u00edm \u00fakolem je spr\u00e1vn\u011b odpov\u011bd\u011bt na co nejv\u00edce ot\u00e1zek.<\/div>\n"},"RU":{"QuestionText":"<div style=\"text-align: center;\">\u041f\u043e\u0436\u0430\u043b\u0443\u0439\u0441\u0442\u0430, \u043e\u0442\u0432\u0435\u0442\u044c\u0442\u0435 \u043d\u0430 \u0441\u043b\u0435\u0434\u0443\u044e\u0449\u0438\u0435 \u0434\u0432\u0430 \u0431\u043b\u043e\u043a\u0430 \u043c\u0430\u0442\u0435\u043c\u0430\u0442\u0438\u0447\u0435\u0441\u043a\u0438\u0445 \u0432\u043e\u043f\u0440\u043e\u0441\u043e\u0432.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">\u041a\u0430\u0436\u0434\u044b\u0439 \u0431\u043b\u043e\u043a \u0441\u043e\u0441\u0442\u043e\u0438\u0442 \u0438\u0437 10 \u0437\u0430\u0434\u0430\u043d\u0438\u0439 \u043d\u0430 \u0441\u043b\u043e\u0436\u0435\u043d\u0438\u0435.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">\u041a\u0430\u0436\u0434\u044b\u0439 \u0431\u043b\u043e\u043a \u0434\u043b\u0438\u0442\u0441\u044f 20 \u0441\u0435\u043a\u0443\u043d\u0434.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">\u0412\u0430\u0448\u0430 \u0437\u0430\u0434\u0430\u0447\u0430 \u2013 \u043f\u0440\u0430\u0432\u0438\u043b\u044c\u043d\u043e \u043e\u0442\u0432\u0435\u0442\u0438\u0442\u044c \u043d\u0430 \u043a\u0430\u043a \u043c\u043e\u0436\u043d\u043e \u0431\u043e\u043b\u044c\u0448\u0435\u0435 \u043a\u043e\u043b\u0438\u0447\u0435\u0441\u0442\u0432\u043e \u0432\u043e\u043f\u0440\u043e\u0441\u043e\u0432.<\/div>\n"},"HU":{"QuestionText":"<div style=\"text-align: center;\">K\u00e9rj\u00fck, v\u00e1laszoljon a k\u00f6vetkez\u0151 k\u00e9t matematikai k\u00e9rd\u00e9sblokkra!<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">Minden blokk 10 \u00f6sszead\u00e1sos feladatokb\u00f3l \u00e1ll.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">Minden blokk 20 m\u00e1sodpercig tart.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">Az \u00d6n feladata, hogy min\u00e9l t\u00f6bb k\u00e9rd\u00e9sre helyesen v\u00e1laszoljon.<\/div>\n"},"IT":{"QuestionText":"<div style=\"text-align: center;\">Rispondi ai seguenti due blocchi di domande matematiche.<\/div><div style=\"text-align: center;\"><br><\/div><div style=\"text-align: center;\"> Ogni blocco \u00e8 composto da 10 domande di sommatoria.<\/div><div style=\"text-align: center;\"><br><\/div><div style=\"text-align: center;\"> Ogni blocco dura 20 secondi.<\/div><div style=\"text-align: center;\"><br><\/div><div style=\"text-align: center;\"> Il tuo compito \u00e8 rispondere correttamente al maggior numero possibile di domande.<br><\/div>"},"PL":{"QuestionText":"<div style=\"text-align: center;\">Prosz\u0119 odpowiedzie\u0107 na dwa poni\u017csze bloki pyta\u0144 matematycznych.<\/div><div style=\"text-align: center;\"><br><\/div><div style=\"text-align: center;\"> Ka\u017cdy blok sk\u0142ada si\u0119 z 10 pyta\u0144 podsumowuj\u0105cych.<\/div><div style=\"text-align: center;\"><br><\/div><div style=\"text-align: center;\"> Ka\u017cdy blok trwa 20 sekund.<\/div><div style=\"text-align: center;\"><br><\/div><div style=\"text-align: center;\"> Twoim zadaniem jest udzielenie poprawnej odpowiedzi na jak najwi\u0119ksz\u0105 liczb\u0119 pyta\u0144.<br><\/div>"},"PT":{"QuestionText":"<div style=\"text-align: center;\">Responda aos dois blocos de quest\u00f5es matem\u00e1ticas seguintes.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">Cada bloco \u00e9 composto por 10 quest\u00f5es de somat\u00f3rio.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">Cada bloco tem a dura\u00e7\u00e3o de 20 segundos.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">A sua tarefa \u00e9 responder corretamente ao maior n\u00famero de perguntas poss\u00edvel.<\/div>\n"},"ZH-S":{"QuestionText":"<div style=\"text-align: center;\">\u8bf7\u56de\u7b54\u4ee5\u4e0b\u4e24\u7ec4\u6570\u5b66\u95ee\u9898\u3002<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">\u6bcf\u7ec4\u7531 10 \u4e2a\u6c42\u548c\u95ee\u9898\u7ec4\u6210\u3002<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">\u6bcf\u7ec4\u6301\u7eed 20 \u79d2\u3002<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">\u60a8\u7684\u4efb\u52a1\u662f\u5c3d\u53ef\u80fd\u6b63\u786e\u56de\u7b54\u5c3d\u53ef\u80fd\u591a\u7684\u95ee\u9898\u3002<\/div>\n"},"FR-FR":{"QuestionText":"<div style=\"text-align: center;\">\n<div style=\"text-align: center;\">Vous allez maintenant r\u00e9pondre \u00e0 deux blocs de questions de calcul mental.<\/div>\n\n<div style=\"text-align: center;\"><br \/>\nChaque bloc est compos\u00e9 de 10 additions.<\/div>\n\n<div style=\"text-align: center;\"><br \/>\nChaque bloc dure 20 secondes.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">Votre t\u00e2che consiste \u00e0 r\u00e9pondre correctement \u00e0 autant de questions que possible.<\/div>\n.<\/div>\n"},"ES-ES":{"QuestionText":"<div style=\"text-align: center;\">Responda los siguientes dos bloques de preguntas matem\u00e1ticas.<\/div><div style=\"text-align: center;\"><br><\/div><div style =\"text-align: center;\">Cada bloque se compone de 10 preguntas de resumen.<\/div><div style=\"text-align: center;\"><br><\/div><div style=\"text- align: center;\">Cada bloque dura 20 segundos.<\/div><div style=\"text-align: center;\"><br><\/div><div style=\"text-align: center;\">Tu La tarea es responder correctamente tantas preguntas como sea posible.\n<br><\/div>"},"ES-AR":{"QuestionText":"<div style=\"text-align: center;\">Responda los siguientes dos bloques de preguntas matem\u00e1ticas.<br \/>\n<br \/>\nCada bloque se compone de 10 preguntas de resumen.<br \/>\n<br \/>\nCada bloque dura 20 segundos.<br \/>\n<br \/>\nSu tarea es responder correctamente tantas preguntas como sea posible.<\/div>\n"},"JA":{"QuestionText":"<div style=\"text-align: center;\">\u6b21\u306e 2 \u3064\u306e\u6570\u5b66\u306e\u554f\u984c\u30d6\u30ed\u30c3\u30af\u306b\u7b54\u3048\u3066\u304f\u3060\u3055\u3044\u3002<\/div><div style=\"text-align: center;\"><br><\/div><div style=\"text-align: center;\">\u5404\u30d6\u30ed\u30c3\u30af\u306f 10 \u500b\u306e\u5408\u8a08\u554f\u984c\u3067\u69cb\u6210\u3055\u308c\u3066\u3044\u307e\u3059\u3002<\/div><div style=\"text-align: center;\"><br><\/div><div style=\"text-align: center;\">\u5404\u30d6\u30ed\u30c3\u30af\u306e\u6240\u8981\u6642\u9593\u306f 20 \u79d2\u3067\u3059\u3002<\/div><div style=\"text-align: center;\"><br><\/div><div style=\"text-align: center;\">\u3042\u306a\u305f\u306e\u8ab2\u984c\u306f\u3001\u3067\u304d\u308b\u3060\u3051\u591a\u304f\u306e\u554f\u984c\u306b\u6b63\u3057\u304f\u7b54\u3048\u308b\u3053\u3068\u3067\u3059\u3002\n<br><\/div>"},"DE":{"QuestionText":"<div style=\"text-align: center;\">Bitte beantworten Sie die folgenden beiden Bl\u00f6cke mit mathematischen Fragen.<\/div><div style=\"text-align: center;\"><br><\/div><div style=\"text-align: center;\">Jeder Block besteht aus 10 Summationsfragen.<\/div><div style=\"text-align: center;\"><br><\/div><div style=\"text-align: center;\">Jeder Block dauert 20 Sekunden.<\/div><div style=\"text-align: center;\"><br><\/div><div style=\"text-align: center;\">Ihre Aufgabe ist es, so viele Fragen wie m\u00f6glich richtig zu beantworten.\n<br><\/div>"},"ZH-T":{"QuestionText":"<div style=\"text-align: center;\">\u8acb\u56de\u7b54\u4ee5\u4e0b\u5169\u7d44\u6578\u5b78\u984c\u76ee\u3002<br \/>\n<br \/>\n\u6bcf\u7d44\u7531 10 \u9053\u6c42\u548c\u984c\u76ee\u7d44\u6210\u3002<br \/>\n<br \/>\n\u6bcf\u7d44\u984c\u76ee\u9650\u6642 20 \u79d2\u3002<br \/>\n<br \/>\n\u60a8\u7684\u4efb\u52d9\u662f\u7b54\u5c0d\u8d8a\u591a\u984c\u8d8a\u597d\u3002<\/div>\n"},"KO":{"QuestionText":"<div style=\"text-align: center;\">\ub2e4\uc74c \ub450 \ubb36\uc74c\uc758 \uc218\ud559 \ubb38\uc81c\uc5d0 \ub2f5\ud558\uc138\uc694.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">\uac01 \ubb36\uc74c\uc740 10\uac1c\uc758 \ub367\uc148 \ubb38\uc81c\ub85c \uad6c\uc131\ub418\uc5b4 \uc788\uc2b5\ub2c8\ub2e4.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">\uac01 \ubb36\uc74c 20\ucd08 \ub3d9\uc548 \uc9c4\ud589\ub429\ub2c8\ub2e4.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">\uadc0\ud558\uc758 \uc784\ubb34\ub294 \uac00\ub2a5\ud55c \ud55c \ub9ce\uc740 \uc9c8\ubb38\uc5d0 \uc62c\ubc14\ub974\uac8c \ub2f5\ud558\ub294 \uac83\uc785\ub2c8\ub2e4.<\/div>\n"},"DE-AT":{"QuestionText":"<div style=\"text-align: center;\">Bitte beantworten Sie die folgenden beiden Mathematik-Fragenbl\u00f6cke.<\/div><div style=\"text-align: center;\"><br><\/div><div style=\"text-align: center;\"> Jeder Block besteht aus 10 Zusammenfassungsfragen.<\/div><div style=\"text-align: center;\"><br><\/div><div style=\"text-align: center;\"> Jeder Block dauert 20 Sekunden.<\/div><div style=\"text-align: center;\"><br><\/div><div style=\"text-align: center;\"> Ihre Aufgabe besteht darin, m\u00f6glichst viele Fragen richtig zu beantworten.<br><\/div>"},"TR":{"QuestionText":"<div style=\"text-align: center;\">Bu b\u00f6l\u00fcmde, her biri 10 adet toplama i\u015flemi sorusu i\u00e7eren 2 blok yer almaktad\u0131r.<\/div>\n\n<div style=\"text-align: center;\"><br \/>\nHer blo\u011fu tamamlamak i\u00e7in size 20 saniye verilmektedir.<\/div>\n"},"ZH-HK":{"QuestionText":"<div style=\"text-align: center;\">\u8acb\u56de\u7b54\u4ee5\u4e0b\u5169\u7d44\u6578\u5b78\u984c\u76ee\u3002<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">\u6bcf\u7d44\u7531 10 \u9053\u6c42\u548c\u984c\u76ee\u7d44\u6210\u3002<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">\u6bcf\u7d44\u984c\u76ee\u9650\u6642 20 \u79d2\u3002<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">\u60a8\u7684\u4efb\u52d9\u662f\u7b54\u5c0d\u8d8a\u591a\u984c\u8d8a\u597d\u3002<\/div>\n"},"KZ-RU":[],"AR":{"QuestionText":"<div style=\"text-align: center;;text-align:right;direction:rtl\">\u0627\u0644\u0631\u062c\u0627\u0621 \u0627\u0644\u0625\u062c\u0627\u0628\u0629 \u0639\u0644\u0649 \u0627\u0644\u062c\u0632\u0626\u064a\u0646 \u0627\u0644\u062a\u0627\u0644\u064a\u064a\u064a\u0646 \u0645\u0646 \u0627\u0644\u0623\u0633\u0626\u0644\u0629 \u0627\u0644\u0631\u064a\u0627\u0636\u064a\u0629.<\/div>\n\n<div style=\"text-align: center;;text-align:right;direction:rtl\">\u00a0<\/div>\n\n<div style=\"text-align: center;;text-align:right;direction:rtl\">\u064a\u062a\u0643\u0648\u0646 \u0643\u0644 \u062c\u0632\u0621\u0645\u0646 10 \u0623\u0633\u0626\u0644\u0629 \u062a\u0644\u062e\u064a\u0635\u064a\u0629.<\/div>\n\n<div style=\"text-align: center;;text-align:right;direction:rtl\">\u00a0<\/div>\n\n<div style=\"text-align: center;;text-align:right;direction:rtl\">\u0643\u0644 \u062c\u0632\u0621 \u064a\u0633\u062a\u0645\u0631 \u0644\u0645\u062f\u0629 20 \u062b\u0627\u0646\u064a\u0629.<\/div>\n\n<div style=\"text-align: center;;text-align:right;direction:rtl\">\u00a0<\/div>\n\n<div style=\"text-align: center;;text-align:right;direction:rtl\">\u0645\u0647\u0645\u062a\u0643 \u0647\u064a \u0627\u0644\u0625\u062c\u0627\u0628\u0629 \u0628\u0634\u0643\u0644 \u0635\u062d\u064a\u062d \u0639\u0644\u0649 \u0623\u0643\u0628\u0631 \u0639\u062f\u062f \u0645\u0645\u0643\u0646 \u0645\u0646 \u0627\u0644\u0623\u0633\u0626\u0644\u0629.<\/div>\n"},"DE-DE":{"QuestionText":"<div style=\"text-align: center;\">Bitte beantworten Sie die folgenden beiden Mathematik-Fragenbl\u00f6cke.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">Jeder Block besteht aus 10 Additionsaufgaben.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">Jeder Block dauert 20 Sekunden.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">Ihre Aufgabe besteht darin, m\u00f6glichst viele Fragen richtig zu beantworten.<\/div>\n"}},"NextAnswerId":1,"NextChoiceId":4,"QuestionDescription":"Please answer the following two blocks of mathematical questions. Each block is composed of 10 su...","QuestionID":"QID65","QuestionText":"<div style=\"text-align: center;\">Please answer the following two blocks of mathematical questions.<\/div><div style=\"text-align: center;\"><br><\/div><div style=\"text-align: center;\">Each block is composed of 10 summation questions.<\/div><div style=\"text-align: center;\"><br><\/div><div style=\"text-align: center;\">Each block lasts 20 seconds.<\/div><div style=\"text-align: center;\"><br><\/div><div style=\"text-align: center;\">Your task is to answer correctly as many as questions as possible.\n<br><\/div>","QuestionText_Unsafe":"<div style=\"text-align: center;\">Please answer the following two blocks of mathematical questions.<\/div><div style=\"text-align: center;\"><br><\/div><div style=\"text-align: center;\">Each blo