*10}"},"3":{"Display":"$e{7*10+9 + ${rand:\/\/int\/1:9}}"},"4":{"Display":"$e{7*10}"},"5":{"Display":"$e{9}"}},"Configuration":{"LabelPosition":"BELOW","QuestionDescriptionOption":"UseText"},"DataExportTag":"sum2.13","DataVisibility":{"Hidden":false,"Private":false},"DefaultChoices":false,"GradingData":[],"Language":{"ES":{"QuestionText":"$e{7*10} + $e{9} = ???","Choices":{"1":{"Display":"$e{7*10+9}"},"4":{"Display":"$e{7*10}"},"5":{"Display":"$e{9}"}}}},"NextAnswerId":1,"NextChoiceId":6,"QuestionDescription":"$e{7*10} + $e{9} = ???","QuestionID":"QID78","QuestionText":"$e{7*10} + $e{9} = ???","QuestionText_Unsafe":"$e{7*10} + $e{9} = ???","QuestionType":"MC","Randomization":{"Advanced":null,"TotalRandSubset":"","Type":"All"},"RecodeValues":{"1":"0","2":"-1","3":"1","4":"99","5":"9"},"Selector":"SAHR","SubSelector":"TX","Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}}}},{"SurveyID":"SV_b3mHBVkuioRMhng","Element":"SQ","PrimaryAttribute":"QID79","SecondaryAttribute":"$e{3*10} + $e{1} = ???","TertiaryAttribute":null,"Payload":{"ChoiceOrder":[1,2,3,4,5],"Choices":{"1":{"Display":"$e{3*10+1}"},"2":{"Display":"$e{3*10+1 - ${rand:\/\/int\/1:9}}"},"3":{"Display":"$e{3*10+1 + ${rand:\/\/int\/1:9}}"},"4":{"Display":"$e{3*10}"},"5":{"Display":"$e{1}"}},"Configuration":{"LabelPosition":"BELOW","QuestionDescriptionOption":"UseText"},"DataExportTag":"sum2.14","DataVisibility":{"Hidden":false,"Private":false},"DefaultChoices":false,"GradingData":[],"Language":{"ES":{"QuestionText":"$e{3*10} + $e{1} = ???","Choices":{"1":{"Display":"$e{3*10+1}"},"4":{"Display":"$e{3*10}"},"5":{"Display":"$e{1}"}}}},"NextAnswerId":1,"NextChoiceId":6,"QuestionDescription":"$e{3*10} + $e{1} = ???","QuestionID":"QID79","QuestionText":"$e{3*10} + $e{1} = ???","QuestionText_Unsafe":"$e{3*10} + $e{1} = ???","QuestionType":"MC","Randomization":{"Advanced":null,"TotalRandSubset":"","Type":"All"},"RecodeValues":{"1":"0","2":"-1","3":"1","4":"99","5":"9"},"Selector":"SAHR","SubSelector":"TX","Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}}}},{"SurveyID":"SV_b3mHBVkuioRMhng","Element":"SQ","PrimaryAttribute":"QID8","SecondaryAttribute":"Please enter the number of the dice i.e., the first number you have thrown. (please enter the num...","TertiaryAttribute":null,"Payload":{"QuestionText":"<div style=\"text-align: center;\">Please enter the <b>number of the dice<\/b> i.e., the first number you have thrown.<\/div><div style=\"text-align: center;\">(please enter the number of the dice, <u>not the MUs<\/u>)<\/div>","DefaultChoices":false,"DataExportTag":"Dice throw","QuestionType":"TE","Selector":"SL","Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Please enter the number of the dice i.e., the first number you have thrown. (please enter the num...","Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"ContentType","MinChars":"1","ContentType":"ValidNumber","ValidDateType":"DateWithFormat","ValidPhoneType":"ValidUSPhone","ValidZipType":"ValidUSZip","ValidNumber":{"Min":"1","Max":"6","NumDecimals":""}}},"GradingData":[],"Language":{"ES":{"QuestionText":"<div style=\"text-align: center;\">Introduzca el <strong>n\u00famero del dado<\/strong>, es decir, el n\u00famero que le ha tocado en el primer lanzamiento.<br \/>\n(introduzca el n\u00famero del dado, <u>no de las UMs<\/u>)<\/div>\n"},"EL":{"QuestionText":"<div style=\"text-align: center;\">\u03a0\u03b1\u03c1\u03b1\u03ba\u03b1\u03bb\u03ce \u03b5\u03b9\u03c3\u03ac\u03b3\u03b5\u03c4\u03b5 \u03c4\u03bf\u03bd <b>\u03b1\u03c1\u03b9\u03b8\u03bc\u03cc \u03c4\u03bf\u03c5 \u03b6\u03b1\u03c1\u03b9\u03bf\u03cd<\/b>\u00a0, \u03b4\u03b7\u03bb\u03b1\u03b4\u03ae \u03c4\u03bf\u03bd \u03c0\u03c1\u03ce\u03c4\u03bf \u03b1\u03c1\u03b9\u03b8\u03bc\u03cc \u03c0\u03bf\u03c5 \u03ad\u03c7\u03b5\u03c4\u03b5 \u03c1\u03af\u03be\u03b5\u03b9.<\/div>\n"},"FR":{"QuestionText":"<span style=\"line-height:130%\"><span style=\"font-family:Arial\"><span lang=\"FR\" style=\"color:#525252\">Veuillez entrer ci-dessous le <b>num\u00e9ro du d\u00e9 obtenu <\/b>lors du premier lancer. (Veuillez saisir le num\u00e9ro des d\u00e9s, p<u style=\"text-underline:#525252\">as les UM<\/u>)<\/span><\/span><\/span>"},"CS":{"QuestionText":"<div style=\"text-align: center;\">Zadejte zde, pros\u00edm, prvn\u00ed <b>\u010d\u00edslo, kter\u00e9 jste hodil(a)<\/b>.<\/div>\n\n<div style=\"text-align: center;\">(zadejte pros\u00edm \u010d\u00edslo na kostce, <u>ne EMJ<\/u> )<\/div>\n"},"RU":{"QuestionText":"<div style=\"text-align: center;\">\u041f\u043e\u0436\u0430\u043b\u0443\u0439\u0441\u0442\u0430, \u0432\u0432\u0435\u0434\u0438\u0442\u0435 <b>\u0447\u0438\u0441\u043b\u043e \u043e\u0447\u043a\u043e\u0432, \u0432\u044b\u043f\u0430\u0432\u0448\u0435\u0435 \u043d\u0430 \u0438\u0433\u0440\u0430\u043b\u044c\u043d\u043e\u0439 \u043a\u043e\u0441\u0442\u0438<\/b> , \u0442.\u0435. \u0438\u0441\u0445\u043e\u0434 \u043f\u0435\u0440\u0432\u043e\u0433\u043e \u0431\u0440\u043e\u0441\u043a\u0430.<\/div>\n\n<div style=\"text-align: center;\">(\u043f\u043e\u0436\u0430\u043b\u0443\u0439\u0441\u0442\u0430, \u0443\u043a\u0430\u0436\u0438\u0442\u0435 \u0447\u0438\u0441\u043b\u043e \u043e\u0447\u043a\u043e\u0432, <u>\u0430 \u043d\u0435 \u0414\u0415<\/u> )<\/div>\n"},"HU":{"QuestionText":"<div style=\"text-align: center;\">K\u00e9rj\u00fck, adja meg <b>a dobott sz\u00e1mot<\/b>\u00a0(az els\u0151k\u00e9nt dobott sz\u00e1mot)!<\/div>\n\n<div style=\"text-align: center;\">(K\u00e9rj\u00fck, hogy a dobott sz\u00e1mot adja meg, <u>ne a nyert \u00f6sszeget!<\/u>)<\/div>\n"},"IT":{"QuestionText":"<div style=\"text-align: center;\">Per favore inserisci il <b>numero del dado<\/b> , cio\u00e8 il primo numero che hai lanciato.<\/div>\n\n<div style=\"text-align: center;\">(inserisci il numero dei dado, <u>non le MU<\/u> )<\/div>\n"},"PL":{"QuestionText":"<div style=\"text-align: center;\">Prosz\u0119 wpisa\u0107 <b>numer z kostki<\/b> , czyli pierwsz\u0105 wyrzucon\u0105 liczb\u0119.<\/div>\n\n<div style=\"text-align: center;\">(prosz\u0119 wpisa\u0107 liczb\u0119 na kostce, <u>a nie liczb\u0119 MU<\/u> )<\/div>\n"},"PT":{"QuestionText":"<div style=\"text-align: center;\">Por favor, introduza o <b>n\u00famero do dado<\/b>, ou seja, o n\u00famero que obteve no primeiro lan\u00e7amento.<\/div>\n\n<div style=\"text-align: center ;\">(por favor introduza o n\u00famero do dado, <u>n\u00e3o as UMs<\/u>)<\/div>\n"},"ZH-S":{"QuestionText":"<div style=\"text-align: center;\">\u8bf7\u8f93\u5165<strong>\u63b7\u51fa<\/strong><b>\u9ab0\u5b50\u7684\u6570\u5b57<\/b>\uff0c\u5373\u60a8\u63b7\u51fa\u7684\u7b2c\u4e00\u4e2a\u6570\u5b57\u3002<\/div>\n\n<div style=\"text-align: center;\">\uff08\u8bf7\u8f93\u5165\u63b7\u51fa\u9ab0\u5b50\u7684\u6570\u5b57\uff0c<u>\u4e0d\u662f MU\u7684\u4e2a\u6570<\/u>\uff09<\/div>\n"},"FR-FR":{"QuestionText":"<div style=\"text-align: center;\">Veuillez entrer le <b>r\u00e9sultat du d\u00e9<\/b>, c'est-\u00e0-dire le premier chiffre que vous avez obtenu.<\/div>\n\n<div style=\"text-align: center ;\">(saisissez le r\u00e9sultat du d\u00e9, <u>et non les UM correspondantes<\/u>)<\/div>\n"},"ES-ES":{"QuestionText":"<div style=\"text-align: center;\">Ingrese el <b>n\u00famero de dados<\/b>, es decir, el primer n\u00famero que lanz\u00f3.<\/div><div style=\"text-align: center ;\">(ingrese el n\u00famero de dados, <u>no los MU<\/u>)<\/div>"},"ES-AR":{"QuestionText":"<div style=\"text-align: center;\">Ingrese el <b>n\u00famero que arroj\u00f3 el dado<\/b>, esto es, el n\u00famero que sali\u00f3 en la primera tirada que realiz\u00f3.<br \/>\n(ingrese el n\u00famero del dado, <u>no las UM<\/u>)<\/div>\n"},"JA":{"QuestionText":"<div style=\"text-align: center;\">\u6700\u521d\u306b\u6295\u3052\u305f\u30b5\u30a4\u30b3\u30ed\u306e\u6570\u5b57\u3092\u5165\u529b\u3057\u3066\u304f\u3060\u3055\u3044\u3002<b>\u30b5\u30a4\u30b3\u30ed\u306e\u6570\u5b57<\/b> <\/div><div style=\"text-align: center;\">(\u30b5\u30a4\u30b3\u30ed\u306e\u6570\u5b57\u3092\u5165\u529b\u3057\u3066\u304f\u3060\u3055\u3044\u3002<u>MU \u3067\u306f\u3042\u308a\u307e\u305b\u3093<\/u>)<\/div>"},"DE":{"QuestionText":"<div style=\"text-align: center;\">Bitte geben Sie die <b>Zahl des W\u00fcrfels<\/b> ein, also die erste Zahl, die Sie gew\u00fcrfelt haben.<\/div><div style=\"text-align: center;\">(bitte geben Sie die Zahl des W\u00fcrfels ein, <u>nicht die Zahl der MUs<\/u>)<\/div>"},"ZH-T":{"QuestionText":"<div style=\"text-align: center;\">\u8acb\u8f38\u5165<b>\u9ab0\u5b50\u7684\u9ede\u6578<\/b>\uff0c\u4e5f\u5c31\u662f\u60a8\u64f2\u51fa\u7684\u7b2c\u4e00\u500b\u6578\u5b57\u3002<br \/>\n\uff08\u8acb\u8f38\u5165\u9ab0\u5b50\u4e0a\u7684\u6578\u5b57\uff0c<u>\u4e0d\u662f\u6cd5\u5e63\u6578\u91cf<\/u>\uff09<\/div>\n"},"KO":{"QuestionText":"<div style=\"text-align: center;\">\uc8fc\uc0ac\uc704 \uacb0\uacfc\ub97c \uc785\ub825\ud558\uc138\uc694. \uc989, \ucc98\uc74c \uad74\ub824 \uc5bb\uc740 \uc8fc\uc0ac\uc704 \uc22b\uc790\ub97c \uc785\ub825\ud558\uc138\uc694.<\/div>\n\n<div style=\"text-align: center;\">(<u>MU\uac00 \uc544\ub2cc<\/u> \uc8fc\uc0ac\uc704\uc758 \uc22b\uc790\ub97c \uc785\ub825\ud558\uc138\uc694.)<\/div>\n"},"DE-AT":{"QuestionText":"<div style=\"text-align: center;\">Bitte geben Sie die <b>Zahl des W\u00fcrfels<\/b> ein, also die erste Zahl, die Sie gew\u00fcrfelt haben. (Bitte geben Sie die Zahl des W\u00fcrfels ein, <u>nicht die entsprechenden GE.<\/u>)<\/div>\n"},"TR":{"QuestionText":"<div style=\"text-align: center;\">L\u00fctfen ilk <b>zar at\u0131\u015f\u0131n\u0131z\u0131n sonucunda gelen say\u0131y\u0131\u00a0<\/b>giriniz.<\/div>\n\n<div style=\"text-align: center;\">(L\u00fctfen zar at\u0131\u015f\u0131nda gelen say\u0131y\u0131 girin, kar\u015f\u0131l\u0131k gelen\u00a0<u>DPB'leri de\u011fil<\/u> )<\/div>\n"},"EN-UK":{"QuestionText":"<div style=\"text-align: center;\">Please enter the <b>number of the die,<\/b> i.e., the first number you have thrown.<\/div>\n\n<div style=\"text-align: center;\">(please enter the number of the die, <u>not the MUs<\/u>)<\/div>\n"},"ZH-HK":{"QuestionText":"<div style=\"text-align: center;\">\u8acb\u8f38\u5165<b>\u9ab0\u5b50\u7684\u9ede\u6578<\/b>\uff0c\u4e5f\u5c31\u662f\u60a8\u64f2\u51fa\u7684\u7b2c\u4e00\u500b\u6578\u5b57\u3002<\/div>\n\n<div style=\"text-align: center;\">\uff08\u8acb\u8f38\u5165\u9ab0\u5b50\u4e0a\u7684\u6578\u5b57\uff0c<u>\u800c\u4e0d\u662fMU\u6578\u91cf<\/u>\uff09<\/div>\n"},"KZ-RU":[],"AR":{"QuestionText":"<div style=\"text-align: center;;text-align:right;direction:rtl\">\u0627\u0644\u0631\u062c\u0627\u0621 \u0625\u062f\u062e\u0627\u0644 \u0631\u0642\u0645\u00a0\u0627\u0644\u0632\u0647\u0631\u060c \u0623\u064a \u0627\u0644\u0631\u0642\u0645 \u0627\u0644\u0623\u0648\u0644 \u0627\u0644\u0630\u064a \u0642\u0645\u062a \u0628\u0631\u0645\u064a\u0647.<\/div>\n\n<div style=\"text-align: center;;text-align:right;direction:rtl\">(\u0627\u0644\u0631\u062c\u0627\u0621 \u0625\u062f\u062e\u0627\u0644 \u0631\u0642\u0645 \u0627\u0644\u0632\u0647\u0631 <u>\u0648\u0644\u064a\u0633 \u0627\u0644\u0648\u062d\u062f\u0627\u062a \u0627\u0644\u0646\u0642\u062f\u064a\u0629<\/u>)<\/div>\n"},"DE-DE":{"QuestionText":"<div style=\"text-align: center;\">Geben Sie bitte die <b>Zahl Ihres Wurfes<\/b>\u00a0ein, also die erste Zahl, die Sie gew\u00fcrfelt haben.<\/div>\n\n<div style=\"text-align: center;\">(bitte die Augenzahl auf dem W\u00fcrfel eingeben, <u>nicht die der GE<\/u>\u00a0)<\/div>\n"}},"NextChoiceId":4,"NextAnswerId":1,"SearchSource":{"AllowFreeResponse":"false"},"QuestionID":"QID8","DataVisibility":{"Private":false,"Hidden":false},"QuestionText_Unsafe":"<div style=\"text-align: center;\">Please enter the <b>number of the dice<\/b> i.e., the first number you have thrown.<\/div><div style=\"text-align: center;\">(please enter the number of the dice, <u>not the MUs<\/u>)<\/div>"}},{"SurveyID":"SV_b3mHBVkuioRMhng","Element":"SQ","PrimaryAttribute":"QID80","SecondaryAttribute":"$e{4*10} + $e{2} = ???","TertiaryAttribute":null,"Payload":{"ChoiceOrder":[1,2,3,4,5],"Choices":{"1":