ion Flash"},"6":{"Display":"Prise en charge Java"},"7":{"Display":"Agent utilisateur"}}},"ES-ES":{"QuestionText":"Haga clic para escribir el texto de la pregunta.","Choices":{"1":{"Display":"Navegador"},"2":{"Display":"Versi\u00f3n"},"3":{"Display":"Sistema operativo"},"4":{"Display":"Resoluci\u00f3n de la pantalla"},"5":{"Display":"Versi\u00f3n flash"},"6":{"Display":"Soporte Java"},"7":{"Display":"Agente de usuario"}}},"JA":{"QuestionText":"\u30af\u30ea\u30c3\u30af\u3057\u3066\u8cea\u554f\u6587\u3092\u5165\u529b\u3057\u3066\u304f\u3060\u3055\u3044","Choices":{"1":{"Display":"\u30d6\u30e9\u30a6\u30b6"},"2":{"Display":"\u30d0\u30fc\u30b8\u30e7\u30f3"},"3":{"Display":"\u30aa\u30da\u30ec\u30fc\u30c6\u30a3\u30f3\u30b0\u00b7\u30b7\u30b9\u30c6\u30e0"},"4":{"Display":"\u753b\u9762\u89e3\u50cf\u5ea6"},"5":{"Display":"\u30d5\u30e9\u30c3\u30b7\u30e5\u30d0\u30fc\u30b8\u30e7\u30f3"},"6":{"Display":"Java \u30b5\u30dd\u30fc\u30c8"},"7":{"Display":"\u30e6\u30fc\u30b6\u30fc\u30a8\u30fc\u30b8\u30a7\u30f3\u30c8"}}},"DE":{"QuestionText":"Klicken Sie hier, um den Fragentext zu schreiben","Choices":{"1":{"Display":"Browser"},"2":{"Display":"Version"},"3":{"Display":"Betriebssystem"},"4":{"Display":"Bildschirmaufl\u00f6sung"},"5":{"Display":"Flash-Version"},"6":{"Display":"Java-Unterst\u00fctzung"},"7":{"Display":"Benutzeragent"}}},"ZH-T":{"QuestionText":"\u9ede\u9078\u5beb\u5165\u554f\u984c\u6587\u5b57","Choices":{"1":{"Display":"\u700f\u89bd\u5668"},"2":{"Display":"\u7248\u672c"},"3":{"Display":"\u4f5c\u696d\u7cfb\u7d71"},"4":{"Display":"\u87a2\u5e55\u89e3\u6790\u5ea6"},"5":{"Display":"\u5feb\u9583\u8a18\u61b6\u9ad4\u7248"},"6":{"Display":"Java\u652f\u63f4"},"7":{"Display":"\u4f7f\u7528\u8005\u4ee3\u7406"}}},"KO":{"QuestionText":"\uc9c8\ubb38\uc758 \ub0b4\uc6a9\uc744 \uc791\uc131\ud558\ub824\uba74 \ud074\ub9ad\ud558\uc138\uc694","Choices":{"1":{"Display":"\ube0c\ub77c\uc6b0\uc800"},"2":{"Display":"\ubc84\uc804"},"3":{"Display":"\uc6b4\uc601 \uccb4\uc81c"},"4":{"Display":"\ud654\uba74 \ud574\uc0c1\ub3c4"},"5":{"Display":"\ud50c\ub798\uc2dc \ubc84\uc804"},"6":{"Display":"\uc790\ubc14 \uc9c0\uc6d0"},"7":{"Display":"\uc0ac\uc6a9\uc790 \uc5d0\uc774\uc804\ud2b8"}}},"DE-AT":{"QuestionText":"Klicken Sie hier, um den Fragentext zu schreiben","Choices":{"1":{"Display":"Browser"},"2":{"Display":"Version"},"3":{"Display":"Betriebssystem"},"4":{"Display":"Bildschirmaufl\u00f6sung"},"5":{"Display":"Flash-Version"},"6":{"Display":"Java-Unterst\u00fctzung"},"7":{"Display":"Benutzeragent"}}},"TR":{"QuestionText":"Soru metnini yazmak i\u00e7in t\u0131klay\u0131n","Choices":{"1":{"Display":"Taray\u0131c\u0131"},"2":{"Display":"S\u00fcr\u00fcm"},"3":{"Display":"\u0130\u015fletim Sistemi"},"4":{"Display":"Ekran \u00c7\u00f6z\u00fcn\u00fcrl\u00fc\u011f\u00fc"},"5":{"Display":"Flash S\u00fcr\u00fcm\u00fc"},"6":{"Display":"Java Deste\u011fi"},"7":{"Display":"Kullan\u0131c\u0131 Arac\u0131s\u0131"}}},"ZH-HK":[],"KZ-RU":[],"AR":[],"DE-DE":{"QuestionText":"Klicken Sie hier, um den Fragentext zu schreiben","Choices":{"1":{"Display":"Browser"},"2":{"Display":"Version"},"3":{"Display":"Betriebssystem"},"4":{"Display":"Bildschirmaufl\u00f6sung"},"5":{"Display":"Flash-Version"},"6":{"Display":"Java-Unterst\u00fctzung"},"7":{"Display":"Benutzeragent"}}}},"NextChoiceId":4,"NextAnswerId":1,"QuestionText_Unsafe":"Click to write the question text","DataVisibility":{"Private":false,"Hidden":false}}},{"SurveyID":"SV_b3mHBVkuioRMhng","Element":"SQ","PrimaryAttribute":"QID329","SecondaryAttribute":"Click to write the question text","TertiaryAttribute":null,"Payload":{"QuestionText":"Click to write the question text","DefaultChoices":false,"DataExportTag":"Q322","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Click to write the question text","Choices":{"1":{"Display":"Click to write Choice 1"},"2":{"Display":"Click to write Choice 2"},"3":{"Display":"Click to write Choice 3"}},"ChoiceOrder":["1","2","3"],"Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID329"}},{"SurveyID":"SV_b3mHBVkuioRMhng","Element":"SQ","PrimaryAttribute":"QID33","SecondaryAttribute":"You will have to throw a dice twice. Your first throw decides how much you receive, and the secon...","TertiaryAttribute":null,"Payload":{"QuestionText":"<div style=\"text-align: center;\">\n<div style=\"text-align: center;\">You will have to throw a dice twice. Your first throw decides how much you receive, and the second throw only serves to make sure that the dice is working properly. In fact, you may throw the dice more than twice. However, only the first throw counts.<\/div>\n\n<div style=\"text-align: center;\">&nbsp;<\/div>\n\n<div style=\"text-align: center;\">The maximum payoff you can receive is 50 Monetary Units (MUs) and the minimum 0. You can see the exact payoff from the following table.<\/div>\n\n<div style=\"text-align: center;\">&nbsp;<\/div>\n\n<div style=\"text-align: center;\">The table also describes that the money not earned by you (50 MUs minus MUs for you)  will be sent to the American Red Cross (ARC), as a donation in order to finance their projects in in the USA. At the end of the session, the sum of money gathered from all participants will be sent via a direct transfer.<\/div>\n\n<div style=\"text-align: center;\">&nbsp;<\/div>\n\n<div style=\"text-align: center;\">The table will remain on the screen until you entered your throw. If you have any questions, please raise your hand. If you are ready, please continue to the next page.<\/div>\n&nbsp;\n\n<table style=\"width: 250px;\" cellspacing=\"1\" cellpadding=\"1\" border=\"1\" align=\"center\">\n\t<thead>\n\t\t<tr>\n\t\t\t<th scope=\"row\">Number thrown<\/th>\n\t\t\t<th scope=\"col\">MUs for you<\/th>\n\t\t\t<th scope=\"col\">MUs for ARC <\/th>\n\t\t<\/tr>\n\t<\/thead>\n\t<tbody>\n\t\t<tr>\n\t\t\t<th scope=\"row\">1<\/th>\n\t\t\t<td>10<\/td>\n\t\t\t<td>40<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">2<\/th>\n\t\t\t<td>20<\/td>\n\t\t\t<td>30<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">3<\/th>\n\t\t\t<td>30<\/td>\n\t\t\t<td>20<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">4<\/th>\n\t\t\t<td>40<\/td>\n\t\t\t<td>10<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">5<\/th>\n\t\t\t<td>50<\/td>\n\t\t\t<td>0<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">6<\/th>\n\t\t\t<td>0<\/td>\n\t\t\t<td>50<\/td>\n\t\t<\/tr>\n\t<\/tbody>\n<\/table>\n<\/div>\n\n<div style=\"text-align: center;\">&nbsp;<\/div>","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"You will have to throw a dice twice. Your first throw decides how much you receive, and the secon...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":{"AR":{"QuestionText":"<div style=\"text-align: center;;text-align:right;direction:rtl\">\n<div style=\"text-align: center;;text-align:right;direction:rtl\">\u0633\u064a\u062a\u0639\u064a\u0646 \u0639\u0644\u064a\u0643 \u0631\u0645\u064a \u0627\u0644\u0632\u0647\u0631 \u0645\u0631\u062a\u064a\u0646. \u062a\u062d\u062f\u062f \u0631\u0645\u064a\u062a\u0643 \u0627\u0644\u0623\u0648\u0644\u0649 \u0645\u0642\u062f\u0627\u0631 \u0645\u0627 \u0633\u062a\u062d\u0635\u0644 \u0639\u0644\u064a\u0647\u060c \u0623\u0645\u0627 \u0627\u0644\u0631\u0645\u064a\u0629 \u0627\u0644\u062b\u0627\u0646\u064a\u0629 \u0641\u062a\u0639\u0645\u0644 \u0641\u0642\u0637 \u0639\u0644\u0649 \u0627\u0644\u062a\u0623\u0643\u062f \u0645\u0646 \u0623\u0646 \u0627\u0644\u0632\u0647\u0631 \u064a\u0639\u0645\u0644 \u0628\u0634\u0643\u0644 \u0635\u062d\u064a\u062d. \u0641\u064a \u0627\u0644\u0648\u0627\u0642\u0639\u060c \u064a\u0645\u0643\u0646\u0643 \u0631\u0645\u064a \u0627\u0644\u0632\u0647\u0631 \u0623\u0643\u062b\u0631 \u0645\u0646 \u0645\u0631\u062a\u064a\u0646. \u0648\u0645\u0639 \u0630\u0644\u0643\u060c \u0641\u0625\u0646 \u0627\u0644\u0631\u0645\u064a\u0629 \u0627\u0644\u0623\u0648\u0644\u0649 \u0641\u0642\u0637 \u0647\u064a \u0627\u0644\u062a\u064a \u062a\u064f\u062d\u0633\u0628.<\/div>\n\n<div style=\"text-align: center;;text-align:right;direction:rtl\">\u00a0<\/div>\n\n<div style=\"text-align: center;;text-align:right;direction:rtl\">\u0627\u0644\u062d\u062f \u0627\u0644\u0623\u0642\u0635\u0649 \u0644\u0644\u0645\u0643\u0627\u0641\u0623\u0629 \u0627\u0644\u062a\u064a \u064a\u0645\u0643\u0646\u0643 \u0627\u0644\u062d\u0635\u0648\u0644 \u0639\u0644\u064a\u0647\u0627 \u0647\u0648 50 \u0648\u062d\u062f\u0629 \u0646\u0642\u062f\u064a\u0629 (\u0648.\u0646.) \u0648\u0627\u0644\u062d\u062f \u0627\u0644\u0623\u062f\u0646\u0649 \u0635\u0641\u0631. \u064a\u0645\u0643\u0646\u0643 \u0631\u0624\u064a\u0629 \u0627\u0644\u0645\u0643\u0627\u0641\u0623\u0629 \u062a\u062d\u062f\u064a\u062f\u0627 \u0645\u0646 \u0627\u0644\u062c\u062f\u0648\u0644 \u0627\u0644\u062a\u0627\u0644\u064a.<\/div>\n\n<div style=\"text-align: center;;text-align:right;direction:rtl\">\u00a0<\/div>\n\n<div style=\"text-align: center;;text-align:right;direction:rtl\">\u064a\u0648\u0636\u062d \u0627\u0644\u062c\u062f\u0648\u0644 \u0623\u064a\u0636\u064b\u0627 \u0623\u0646 \u0627\u0644\u0623\u0645\u0648\u0627\u0644 \u0627\u0644\u062a\u064a \u0644\u0645 \u062a\u0643\u0633\u0628\u0647\u0627 (50 \u0648\u062d\u062f\u0629 \u0646\u0642\u062f\u064a\u0629 \u0646\u0627\u0642\u0635 \u0648\u062d\u062f\u0627\u062a \u0646\u0642\u062f\u064a\u0629 \u0644\u0643) \u0633\u064a\u062a\u0645 \u0625\u0631\u0633\u0627\u0644\u0647\u0627 \u0625\u0644\u0649 \u0645\u0633\u062a\u0634\u0641\u064a \u062d\u0631\u0648\u0642 \u0623\u0647\u0644 \u0645\u0635\u0631 (AMBH)\u060c \u0643\u062a\u0628\u0631\u0639 \u0644\u062a\u0645\u0648\u064a\u0644 \u0645\u0634\u0627\u0631\u064a\u0639\u0647\u0627 \u0644\u0645\u0639\u0627\u0644\u062c\u0629 \u0636\u062d\u0627\u064a\u0627 \u0627\u0644\u062d\u0631\u0648\u0642 \u0641\u064a \u0645\u0635\u0631. \u0641\u064a \u0646\u0647\u0627\u064a\u0629 \u0627\u0644\u062c\u0644\u0633\u0629\u060c \u0633\u064a\u062a\u0645 \u0625\u0631\u0633\u0627\u0644 \u0627\u0644\u0645\u0628\u0644\u063a \u0627\u0644\u0630\u064a \u062a\u0645 \u062c\u0645\u0639\u0647 \u0645\u0646 \u062c\u0645\u064a\u0639 \u0627\u0644\u0645\u0634\u0627\u0631\u0643\u064a\u0646 \u0639\u0646 \u0637\u0631\u064a\u0642 \u062a\u062d\u0648\u064a\u0644 \u0645\u0628\u0627\u0634\u0631.<\/div>\n\n<div style=\"text-align: center;;text-align:right;direction:rtl\">\u00a0<\/div>\n\n<div style=\"text-align: center;;text-align:right;direction:rtl\">\u0633\u064a\u0638\u0644 \u0627\u0644\u062c\u062f\u0648\u0644 \u0639\u0644\u0649 \u0627\u0644\u0634\u0627\u0634\u0629 \u062d\u062a\u0649 \u062a\u0642\u0648\u0645 \u0628\u0625\u062f\u062e\u0627\u0644 \u0631\u0645\u064a\u062a\u0643. \u0625\u0630\u0627 \u0643\u0627\u0646\u062a \u0644\u062f\u064a\u0643 \u0623\u064a \u0623\u0633\u0626\u0644\u0629\u060c \u064a\u0631\u062c\u0649 \u0631\u0641\u0639 \u064a\u062f\u0643. \u0625\u0630\u0627 \u0643\u0646\u062a \u0645\u0633\u062a\u0639\u062f\u064b\u0627\u060c \u064a\u0631\u062c\u0649 \u0627\u0644\u0627\u0646\u062a\u0642\u0627\u0644 \u0625\u0644\u0649 \u0627\u0644\u0635\u0641\u062d\u0629 \u0627\u0644\u062a\u0627\u0644\u064a\u0629.<\/div>\n\n<table align=\"center\" border=\"1\" cellpadding=\"1\" cellspacing=\"1\" style=\"width: 250px;;text-align:right;direction:rtl\">\n\t<thead>\n\t\t<tr>\n\t\t\t<th scope=\"row\">\u0627\u0644\u0631\u0642\u0645 \u0627\u0644\u0630\u064a \u062a\u0645 \u0625\u0644\u0642\u0627\u0624\u0647<\/th>\n\t\t\t<th scope=\"col\">\u0648.\u0646. \u0645\u0646 \u0623\u062c\u0644\u0643<\/th>\n\t\t\t<th scope=\"col\">\u0648.\u0646.\u00a0\u0645\u0646 \u0623\u062c\u0644 AMBH<\/th>\n\t\t<\/tr>\n\t<\/thead>\n\t<tbody>\n\t\t<tr>\n\t\t\t<th scope=\"row\" style=\"text-align: center;\">1<\/th>\n\t\t\t<td style=\"text-align: center;\">10<\/td>\n\t\t\t<td style=\"text-align: center;\">40<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\" style=\"text-align: center;\">2<\/th>\n\t\t\t<td style=\"text-align: center;\">20<\/td>\n\t\t\t<td style=\"text-align: center;\">30<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\" style=\"text-align: center;\">3<\/th>\n\t\t\t<td style=\"text-align: center;\">30<\/td>\n\t\t\t<td style=\"text-align: center;\">20<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\" style=\"text-align: center;\">4<\/th>\n\t\t\t<td style=\"text-align: center;\">40<\/td>\n\t\t\t<td style=\"text-align: center;\">10<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\" style=\"text-align: center;\">5<\/th>\n\t\t\t<td style=\"text-align: center;\">50<\/td>\n\t\t\t<td style=\"text-align: center;\">0<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\" style=\"text-align: center;\">6<\/th>\n\t\t\t<td style=\"text-align: center;\">0<\/td>\n\t\t\t<td style=\"text-align: center;\">50<\/td>\n\t\t<\/tr>\n\t<\/tbody>\n<\/table>\n<\/div>\n\n<div style=\"text-align: center;;text-align:right;direction:rtl\">\u00a0<\/div>\n"},"CS":{"QuestionText":"<div style=\"text-align: center;\">\n<div style=\"text-align: center;\">\n<div style=\"text-align: center;\">Po\u017e\u00e1d\u00e1me V\u00e1s, abyste dvakr\u00e1t hodil(a) kostkou. V\u00e1\u0161 prvn\u00ed hod rozhodne o tom, kolik dostanete. Druh\u00fd hod slou\u017e\u00ed pouze k tomu, abyste se ujistil(a), \u017ee kostky funguj\u00ed spr\u00e1vn\u011b. Ve skute\u010dnosti m\u016f\u017eete hodit kostkou, kolikr\u00e1t chcete, ale po\u010d\u00edt\u00e1 se pouze V\u00e1\u0161 prvn\u00ed hod.\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">Maxim\u00e1ln\u00ed \u010d\u00e1stka, kterou m\u016f\u017eete v t\u00e9to \u010d\u00e1sti obdr\u017eet, je 50 experiment\u00e1ln\u00edch m\u011bnov\u00fdch jednotek (EMJ) a minim\u00e1ln\u00ed je 0 EMJ. N\u00e1sleduj\u00edc\u00ed tabulka popisuje, kolik p\u0159esn\u011b m\u016f\u017eete vyhr\u00e1t.<\/div>\n<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">Tabulka tak\u00e9 ukazuje, \u017ee pen\u00edze, kter\u00e9 nevyhrajete Vy (50 EMJ m\u00ednus EMJ pro V\u00e1s) budou darov\u00e1ny organizaci L\u00e9ka\u0159i bez hranic na financov\u00e1n\u00ed jejich projekt\u016f v \u010cesk\u00e9 Republice. Po skon\u010den\u00ed tohoto experimentu po\u0161leme pen\u00edze takto z\u00edskan\u00e9 od v\u0161ech \u00fa\u010dastn\u00edk\u016f p\u0159evodem na \u00fa\u010det \u010d\u00edslo: 2101950100\/2700.<br \/>\n<br \/>\nTato tabulka bude zobrazena na Va\u0161\u00ed obrazovce, dokud nebudete cht\u00edt napsat, kolik jste hodil(a). Pokud m\u00e1te n\u011bjak\u00e9 ot\u00e1zky, zvedn\u011bte, pros\u00edm, ruku. Pokud jste p\u0159ipraven(a), pokra\u010dujte na dal\u0161\u00ed str\u00e1nku.<\/div>\n<\/div>\n\n<table align=\"center\" border=\"1\" cellpadding=\"1\" cellspacing=\"1\" style=\"width: 250px;\">\n\t<thead>\n\t\t<tr>\n\t\t\t<th scope=\"row\">\u010c\u00edslo vr\u017eeno<\/th>\n\t\t\t<th scope=\"col\">EMJ pro v\u00e1s<\/th>\n\t\t\t<th scope=\"col\">EMJ pro L\u00e9ka\u0159e bez hranic<\/th>\n\t\t<\/tr>\n\t<\/thead>\n\t<tbody>\n\t\t<tr>\n\t\t\t<th scope=\"row\">1<\/th>\n\t\t\t<td>10<\/td>\n\t\t\t<td>40<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">2<\/th>\n\t\t\t<td>20<\/td>\n\t\t\t<td>30<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">3<\/th>\n\t\t\t<td>30<\/td>\n\t\t\t<td>20<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">4<\/th>\n\t\t\t<td>40<\/td>\n\t\t\t<td>10<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">5<\/th>\n\t\t\t<td>50<\/td>\n\t\t\t<td>0<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">6<\/th>\n\t\t\t<td>0<\/td>\n\t\t\t<td>50<\/td>\n\t\t<\/tr>\n\t<\/tbody>\n<\/table>\n<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n"},"DE":{"QuestionText":"<div style=\"text-align: center;\">\n<div style=\"text-align: center;\">Du musst zweimal w\u00fcrfeln. Dein erster Wurf entscheidet, wie viel du erh\u00e4ltst, und der zweite Wurf dient nur dazu, sicherzustellen, dass der W\u00fcrfel richtig funktioniert. Tats\u00e4chlich kannst du mehr als zweimal w\u00fcrfeln. Allerdings z\u00e4hlt nur der erste Wurf.<\/div>\n\n<div style=\"text-align: center;\">&nbsp;<\/div>\n\n<div style=\"text-align: center;\">Die maximale Auszahlung, die Sie erhalten k\u00f6nnen, betr\u00e4gt 50 Geldeinheiten (MUs) und die minimale 0. Die genaue Auszahlung k\u00f6nnen Sie der folgenden Tabelle entnehmen.<\/div>\n\n<div style=\"text-align: center;\">&nbsp;<\/div>\n\n<div style=\"text-align: center;\">Die Tabelle beschreibt auch, dass das von Ihnen nicht verdiente Geld (50 MUs abz\u00fcglich MUs f\u00fcr Sie) als Spende an die Organisation Mercy Relief (https:\/\/www.mercyrelief.org\/) gesendet wird, um deren Projekte zur Bek\u00e4mpfung endemischer Krankheiten in Singapur zu finanzieren. Am Ende der Sitzung wird der von allen Teilnehmern gesammelte Geldbetrag per Direkt\u00fcberweisung \u00fcberwiesen (Kontonummer: 004-027421-7).<\/div>\n\n<div style=\"text-align: center;\">&nbsp;<\/div>\n\n<div style=\"text-align: center;\">Die Tabelle bleibt auf dem Bildschirm, bis Sie Ihren Wurf eingegeben haben. Wenn Sie Fragen haben, heben Sie bitte Ihre Hand. Wenn Sie bereit sind, fahren Sie bitte mit der n\u00e4chsten Seite fort.<\/div>\n&nbsp;\n\n<table align=\"center\" border=\"1\" cellpadding=\"1\" cellspacing=\"1\" style=\"width: 250px;\">\n<thead>\n<tr>\n<th scope=\"row\">Gew\u00fcrfelte Zahl<\/th>\n<th scope=\"col\">MUs f\u00fcr Sie<\/th>\n<th scope=\"col\">MUs f\u00fcr Mercy Relief<\/th>\n<\/tr>\n<\/thead>\n<tbody>\n<tr>\n<th scope=\"row\">1<\/th>\n<td>10<\/td>\n<td>40<\/td>\n<\/tr>\n<tr>\n<th scope=\"row\">2<\/th>\n<td>20<\/td>\n<td>30<\/td>\n<\/tr>\n<tr>\n<th scope=\"row\">3<\/th>\n<td>30<\/td>\n<td>20<\/td>\n<\/tr>\n<tr>\n<th scope=\"row\">4<\/th>\n<td>40<\/td>\n<td>10<\/td>\n<\/tr>\n<tr>\n<th scope=\"row\">5<\/th>\n<td>50<\/td>\n<td>0<\/td>\n<\/tr>\n<tr>\n<th scope=\"row\">6<\/th>\n<td>0<\/td>\n<td>50<\/td>\n<\/tr>\n<\/tbody>\n<\/table>\n<\/div>\n\n<div style=\"text-align: center;\">&nbsp;<\/div>"},"DE-AT":{"QuestionText":"<div style=\"text-align: center;\">\n<div style=\"text-align: center;\">\n<div style=\"text-align: center;\">\n<div style=\"text-align: center;\">\n<div style=\"text-align: center;\">Nachfolgend werden Sie aufgefordert, zweimal zu w\u00fcrfeln. Ihr erster Wurf entscheidet, wie viel Sie erhalten; der zweite Wurf dient nur dazu, sicherzustellen, dass der W\u00fcrfel richtig funktioniert. Tats\u00e4chlich k\u00f6nnen Sie die W\u00fcrfel mehr als zweimal werfen. Allerdings z\u00e4hlt nur der erste Wurf.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">Die maximale Auszahlung, die Sie erhalten k\u00f6nnen, betr\u00e4gt 50 Geldeinheiten (GE) und die minimale Auszahlung betr\u00e4gt 0. Die genaue Auszahlung k\u00f6nnen Sie der folgenden Tabelle entnehmen.<\/div>\n<\/div>\n<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">In der Tabelle ist au\u00dferdem beschrieben, dass der nicht von Ihnen verdiente Betrag (50 GE minus GE f\u00fcr Sie) als Spende an \u00c4rzte ohne Grenzen \u00d6sterreich gerichtet wird, um deren Projekte in \u00d6sterreich zu unterst\u00fctzen. Am Ende der Sitzung wird der von allen Teilnehmern gesammelte Geldbetrag per Direkt\u00fcberweisung gesendet.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">Die Tabelle wird auf dem Bildschirm angezeigt , bis Sie Ihren Wurf eingegeben haben. Wenn Sie Fragen haben, heben Sie bitte Ihre Hand. Wenn Sie bereit sind, fahren Sie bitte mit der n\u00e4chsten Seite fort.<\/div>\n<\/div>\n\u00a0\n\n<table align=\"center\" border=\"1\" cellpadding=\"1\" cellspacing=\"1\" style=\"width: 350px;\">\n\t<thead>\n\t\t<tr>\n\t\t\t<th scope=\"row\">Geworfene Zahl<\/th>\n\t\t\t<th scope=\"col\">GE f\u00fcr Sie<\/th>\n\t\t\t<th scope=\"col\">GE an \u00c4rzte ohne Grenzen<\/th>\n\t\t<\/tr>\n\t<\/thead>\n\t<tbody>\n\t\t<tr>\n\t\t\t<th scope=\"row\">1<\/th>\n\t\t\t<td>10<\/td>\n\t\t\t<td>40<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">2<\/th>\n\t\t\t<td>20<\/td>\n\t\t\t<td>30<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">3<\/th>\n\t\t\t<td>30<\/td>\n\t\t\t<td>20<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">4<\/th>\n\t\t\t<td>40<\/td>\n\t\t\t<td>10<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">5<\/th>\n\t\t\t<td>50<\/td>\n\t\t\t<td>0<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">6<\/th>\n\t\t\t<td>0<\/td>\n\t\t\t<td>50<\/td>\n\t\t<\/tr>\n\t<\/tbody>\n<\/table>\n<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n"},"DE-DE":{"QuestionText":"<div style=\"text-align: center;\">\n<div style=\"text-align: center;\">Sie m\u00fcssen zweimal w\u00fcrfeln. Der erste Wurf entscheidet, wie viel Sie erhalten, und der zweite Wurf dient nur dazu, zu pr\u00fcfen, ob der W\u00fcrfel richtig funktioniert. Sie d\u00fcrfen sogar \u00f6fter w\u00fcrfeln. Allerdings z\u00e4hlt nur der erste Wurf.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">Die maximale Auszahlung, die Sie erhalten k\u00f6nnen, betr\u00e4gt 50 Geldeinheiten (GE), die minimale 0. Die genaue Auszahlung k\u00f6nnen Sie der folgenden Tabelle entnehmen.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">In der Tabelle steht auch, dass das von Ihnen nicht verdiente Geld (50 GE minus GE f\u00fcr Sie) als Spende an die Nichregierungsorganisation \u00c4rzte ohne Grenzen (MSF) gesendet wird, um deren Projekte zur Bek\u00e4mpfung endemischer Krankheiten in Deutschland zu finanzieren. Am Ende der Sitzung wird der von allen TeilnehmerInnen gesammelte Geldbetrag per Direkt\u00fcberweisung gesendet.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">Die Tabelle bleibt auf dem Bildschirm, bis Sie Ihren Wurf eingegeben haben. Wenn Sie Fragen haben, heben Sie bitte Ihre Hand. Wenn Sie bereit sind, fahren Sie bitte mit der n\u00e4chsten Seite fort.<\/div>\n\n<table align=\"center\" border=\"1\" cellpadding=\"1\" cellspacing=\"1\" style=\"width: 250px;\">\n\t<thead>\n\t\t<tr>\n\t\t\t<th scope=\"row\">Geworfene Zahl<\/th>\n\t\t\t<th scope=\"col\">GE\u00a0f\u00fcr Sie<\/th>\n\t\t\t<th scope=\"col\">GE\u00a0f\u00fcr MSF<\/th>\n\t\t<\/tr>\n\t<\/thead>\n\t<tbody>\n\t\t<tr>\n\t\t\t<th scope=\"row\">1<\/th>\n\t\t\t<td>10<\/td>\n\t\t\t<td>40<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">2<\/th>\n\t\t\t<td>20<\/td>\n\t\t\t<td>30<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">3<\/th>\n\t\t\t<td>30<\/td>\n\t\t\t<td>20<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">4<\/th>\n\t\t\t<td>40<\/td>\n\t\t\t<td>10<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">5<\/th>\n\t\t\t<td>50<\/td>\n\t\t\t<td>0<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">6<\/th>\n\t\t\t<td>0<\/td>\n\t\t\t<td>50<\/td>\n\t\t<\/tr>\n\t<\/tbody>\n<\/table>\n<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n"},"EL":{"QuestionText":"<div style=\"text-align: center;\">\n<div style=\"text-align: center;\">\n<div style=\"text-align: center;\">\n<div style=\"text-align: center;\">\u0398\u03b1 \u03c0\u03c1\u03ad\u03c0\u03b5\u03b9 \u03bd\u03b1 \u03c1\u03af\u03be\u03b5\u03c4\u03b5 \u03c4\u03bf \u03b6\u03ac\u03c1\u03b9 \u03b4\u03cd\u03bf \u03c6\u03bf\u03c1\u03ad\u03c2. \u0397 \u03c0\u03c1\u03ce\u03c4\u03b7 \u03c6\u03bf\u03c1\u03ac \u03b8\u03b1 \u03ba\u03b1\u03b8\u03bf\u03c1\u03af\u03c3\u03b5\u03b9 \u03c0\u03cc\u03c3\u03b1 \u03c7\u03c1\u03ae\u03bc\u03b1\u03c4\u03b1 \u03b8\u03b1 \u03bb\u03ac\u03b2\u03b5\u03c4\u03b5 \u03ba\u03b1\u03b9 \u03b7 \u03b4\u03b5\u03cd\u03c4\u03b5\u03c1\u03b7 \u03c6\u03bf\u03c1\u03ac \u03c7\u03c1\u03b7\u03c3\u03b9\u03bc\u03b5\u03cd\u03b5\u03b9 \u03bc\u03cc\u03bd\u03bf \u03b3\u03b9\u03b1 \u03bd\u03b1 \u03b2\u03b5\u03b2\u03b1\u03b9\u03c9\u03b8\u03b5\u03af\u03c4\u03b5 \u03cc\u03c4\u03b9 \u03c4\u03bf \u03b6\u03ac\u03c1\u03b9 \u03bb\u03b5\u03b9\u03c4\u03bf\u03c5\u03c1\u03b3\u03b5\u03af \u03c3\u03c9\u03c3\u03c4\u03ac. \u03a3\u03c4\u03b7\u03bd \u03c0\u03c1\u03b1\u03b3\u03bc\u03b1\u03c4\u03b9\u03ba\u03cc\u03c4\u03b7\u03c4\u03b1, \u03bc\u03c0\u03bf\u03c1\u03b5\u03af\u03c4\u03b5 \u03bd\u03b1 \u03c1\u03af\u03be\u03b5\u03c4\u03b5 \u03c4\u03bf \u03b6\u03ac\u03c1\u03b9 \u03c0\u03b5\u03c1\u03b9\u03c3\u03c3\u03cc\u03c4\u03b5\u03c1\u03b5\u03c2 \u03b1\u03c0\u03cc \u03b4\u03cd\u03bf \u03c6\u03bf\u03c1\u03ad\u03c2. \u03a9\u03c3\u03c4\u03cc\u03c3\u03bf, \u03bc\u03cc\u03bd\u03bf \u03b7 \u03c0\u03c1\u03ce\u03c4\u03b7 \u03c6\u03bf\u03c1\u03ac \u03bc\u03b5\u03c4\u03c1\u03ac\u03b5\u03b9.<\/div>\n\n<div style=\"text-align: center;\">\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">\u0397 \u03bc\u03ad\u03b3\u03b9\u03c3\u03c4\u03b7 \u03c0\u03bb\u03b7\u03c1\u03c9\u03bc\u03ae \u03c0\u03bf\u03c5 \u03bc\u03c0\u03bf\u03c1\u03b5\u03af\u03c4\u03b5 \u03bd\u03b1 \u03bb\u03ac\u03b2\u03b5\u03c4\u03b5 \u03b5\u03af\u03bd\u03b1\u03b9 50 \u039d\u03bf\u03bc\u03b9\u03c3\u03bc\u03b1\u03c4\u03b9\u03ba\u03ad\u03c2 \u039c\u03bf\u03bd\u03ac\u03b4\u03b5\u03c2 (\u039d\u039c) \u03ba\u03b1\u03b9 \u03b7 \u03b5\u03bb\u03ac\u03c7\u03b9\u03c3\u03c4\u03b7 0. \u039c\u03c0\u03bf\u03c1\u03b5\u03af\u03c4\u03b5 \u03bd\u03b1 \u03b4\u03b5\u03af\u03c4\u03b5 \u03c4\u03b7\u03bd \u03b1\u03ba\u03c1\u03b9\u03b2\u03ae \u03c0\u03bb\u03b7\u03c1\u03c9\u03bc\u03ae \u03b1\u03c0\u03cc \u03c4\u03bf\u03bd \u03c0\u03b1\u03c1\u03b1\u03ba\u03ac\u03c4\u03c9 \u03c0\u03af\u03bd\u03b1\u03ba\u03b1.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n<\/div>\n<\/div>\n\n<div style=\"text-align: center;\">\u039f \u03c0\u03af\u03bd\u03b1\u03ba\u03b1\u03c2 \u03c0\u03b5\u03c1\u03b9\u03b3\u03c1\u03ac\u03c6\u03b5\u03b9 \u03b5\u03c0\u03af\u03c3\u03b7\u03c2 \u03cc\u03c4\u03b9 \u03c4\u03b1 \u03c7\u03c1\u03ae\u03bc\u03b1\u03c4\u03b1 \u03c0\u03bf\u03c5 \u03b4\u03b5\u03bd \u03b8\u03b1 \u03ba\u03b5\u03c1\u03b4\u03af\u03c3\u03b5\u03c4\u03b5 \u03b5\u03c3\u03b5\u03af\u03c2 (50 \u039d\u039c \u03bc\u03b5\u03af\u03bf\u03bd \u03c4\u03b9\u03c2 \u039d\u039c \u03c0\u03bf\u03c5 \u03b8\u03b1 \u03bb\u03ac\u03b2\u03b5\u03c4\u03b5 \u03b5\u03c3\u03b5\u03af\u03c2) \u03b8\u03b1 \u03c3\u03c4\u03b1\u03bb\u03bf\u03cd\u03bd \u03c3\u03c4\u03b7 \u03bc\u03b7 \u03ba\u03c5\u03b2\u03b5\u03c1\u03bd\u03b7\u03c4\u03b9\u03ba\u03ae \u03bf\u03c1\u03b3\u03ac\u03bd\u03c9\u03c3\u03b7\u00a0\u0393\u03b9\u03b1\u03c4\u03c1\u03bf\u03af \u03a7\u03c9\u03c1\u03af\u03c2 \u03a3\u03cd\u03bd\u03bf\u03c1\u03b1, \u03c9\u03c2 \u03b4\u03c9\u03c1\u03b5\u03ac \u03c0\u03c1\u03bf\u03ba\u03b5\u03b9\u03bc\u03ad\u03bd\u03bf\u03c5 \u03bd\u03b1 \u03c7\u03c1\u03b7\u03bc\u03b1\u03c4\u03bf\u03b4\u03bf\u03c4\u03ae\u03c3\u03bf\u03c5\u03bd \u03c4\u03b1 \u03c0\u03c1\u03cc\u03c4\u03b6\u03b5\u03ba\u03c4 \u03c4\u03b7\u03c2 \u03c3\u03c4\u03b7\u03bd \u0395\u03bb\u03bb\u03ac\u03b4\u03b1. \u03a3\u03c4\u03bf \u03c4\u03ad\u03bb\u03bf\u03c2 \u03c4\u03b7\u03c2 \u03ad\u03c1\u03b5\u03c5\u03bd\u03b1\u03c2, \u03c4\u03bf \u03c7\u03c1\u03b7\u03bc\u03b1\u03c4\u03b9\u03ba\u03cc \u03c0\u03bf\u03c3\u03cc \u03c0\u03bf\u03c5 \u03b8\u03b1 \u03c3\u03c5\u03b3\u03ba\u03b5\u03bd\u03c4\u03c1\u03c9\u03b8\u03b5\u03af \u03b1\u03c0\u03cc \u03cc\u03bb\u03bf\u03c5\u03c2 \u03c4\u03bf\u03c5\u03c2 \u03c3\u03c5\u03bc\u03bc\u03b5\u03c4\u03ad\u03c7\u03bf\u03bd\u03c4\u03b5\u03c2 \u03b8\u03b1 \u03b1\u03c0\u03bf\u03c3\u03c4\u03b1\u03bb\u03b5\u03af \u03bc\u03b5 \u03c4\u03c1\u03b1\u03c0\u03b5\u03b6\u03b9\u03ba\u03ae \u03bc\u03b5\u03c4\u03b1\u03c6\u03bf\u03c1\u03ac (\u03b1\u03c1\u03b9\u03b8\u03bc\u03cc\u03c2 IBAN: GR 3601 1008 0000 0008 0480 84795).<br \/>\n<br \/>\n\u039f \u03c0\u03af\u03bd\u03b1\u03ba\u03b1\u03c2 \u03b8\u03b1 \u03c0\u03b1\u03c1\u03b1\u03bc\u03b5\u03af\u03bd\u03b5\u03b9 \u03c3\u03c4\u03b7\u03bd \u03bf\u03b8\u03cc\u03bd\u03b7 \u03bc\u03ad\u03c7\u03c1\u03b9 \u03bd\u03b1 \u03c3\u03b1\u03c2 \u03b6\u03b7\u03c4\u03b7\u03b8\u03b5\u03af \u03bd\u03b1 \u03b3\u03c1\u03ac\u03c8\u03c4\u03b5 \u03c4\u03bf \u03bd\u03bf\u03cd\u03bc\u03b5\u03c1\u03bf \u03c0\u03bf\u03c5 \u03c3\u03b1\u03c2 \u03ad\u03c4\u03c5\u03c7\u03b5. \u0391\u03bd \u03ad\u03c7\u03b5\u03c4\u03b5 \u03b5\u03c1\u03c9\u03c4\u03ae\u03c3\u03b5\u03b9\u03c2, \u03c3\u03b7\u03ba\u03ce\u03c3\u03c4\u03b5 \u03c4\u03bf \u03c7\u03ad\u03c1\u03b9 \u03c3\u03b1\u03c2. \u0395\u03ac\u03bd \u03c0\u03ac\u03bb\u03b9 \u03b5\u03af\u03c3\u03c4\u03b5 \u03ad\u03c4\u03bf\u03b9\u03bc\u03bf\u03b9, \u03c3\u03c5\u03bd\u03b5\u03c7\u03af\u03c3\u03c4\u03b5 \u03c3\u03c4\u03b7\u03bd \u03b5\u03c0\u03cc\u03bc\u03b5\u03bd\u03b7 \u03c3\u03b5\u03bb\u03af\u03b4\u03b1.<\/div>\n<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<table align=\"center\" border=\"1\" cellpadding=\"1\" cellspacing=\"1\" style=\"width: 250px;\">\n\t<thead>\n\t\t<tr>\n\t\t\t<th scope=\"row\">\u0391\u03c1\u03b9\u03b8\u03bc\u03cc\u03c2 \u03c4\u03bf\u03c5 \u03b6\u03b1\u03c1\u03b9\u03bf\u03cd<\/th>\n\t\t\t<th scope=\"col\">\u039d\u039c \u03b3\u03b9\u03b1 \u03b5\u03c3\u03ac\u03c2<\/th>\n\t\t\t<th scope=\"col\">\u039d\u039c \u03b3\u03b9\u03b1 \u03c4\u03bf\u03c5\u03c2 \u0393\u03b9\u03b1\u03c4\u03c1\u03bf\u03cd\u03c2 \u03a7\u03c9\u03c1\u03af\u03c2 \u03a3\u03cd\u03bd\u03bf\u03c1\u03b1<\/th>\n\t\t<\/tr>\n\t<\/thead>\n\t<tbody>\n\t\t<tr>\n\t\t\t<th scope=\"row\">1<\/th>\n\t\t\t<td>10<\/td>\n\t\t\t<td>40<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">2<\/th>\n\t\t\t<td>20<\/td>\n\t\t\t<td>30<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">3<\/th>\n\t\t\t<td>30<\/td>\n\t\t\t<td>20<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">4<\/th>\n\t\t\t<td>40<\/td>\n\t\t\t<td>10<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">5<\/th>\n\t\t\t<td>50<\/td>\n\t\t\t<td>0<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">6<\/th>\n\t\t\t<td>0<\/td>\n\t\t\t<td>50<\/td>\n\t\t<\/tr>\n\t<\/tbody>\n<\/table>\n<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n"},"EN-PAK":{"QuestionText":"<div style=\"text-align: center;\">\n<div style=\"text-align: center;\">You will have to throw a dice twice. Your first throw decides how much you receive, and the second throw only serves to make sure that the dice is working properly. In fact, you may throw the dice more than twice. However, only the first throw counts.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">The maximum payoff you can receive is 50 Monetary Units (MUs) and the minimum 0. You can see the exact payoff from the following table.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">The table also describes that the money not earned by you (50 MUs minus MUs for you) will be sent to the Doctors Without Boarders (DWB), as a donation in order to finance their projects in fighting endemic diseases in Pakistan. At the end of the session, the sum of money gathered from all participants will be sent via a direct transfer.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">The table will remain on the screen until you entered your throw. If you have any questions, please raise your hand. If you are ready, please continue to the next page.<\/div>\n\u00a0\n\n<table align=\"center\" border=\"1\" cellpadding=\"1\" cellspacing=\"1\" style=\"width: 250px;\">\n\t<thead>\n\t\t<tr>\n\t\t\t<th scope=\"row\">Number thrown<\/th>\n\t\t\t<th scope=\"col\">MUs for you<\/th>\n\t\t\t<th scope=\"col\">MUs for DWB<\/th>\n\t\t<\/tr>\n\t<\/thead>\n\t<tbody>\n\t\t<tr>\n\t\t\t<th scope=\"row\">1<\/th>\n\t\t\t<td>10<\/td>\n\t\t\t<td>40<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">2<\/th>\n\t\t\t<td>20<\/td>\n\t\t\t<td>30<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">3<\/th>\n\t\t\t<td>30<\/td>\n\t\t\t<td>20<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">4<\/th>\n\t\t\t<td>40<\/td>\n\t\t\t<td>10<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">5<\/th>\n\t\t\t<td>50<\/td>\n\t\t\t<td>0<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">6<\/th>\n\t\t\t<td>0<\/td>\n\t\t\t<td>50<\/td>\n\t\t<\/tr>\n\t<\/tbody>\n<\/table>\n<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n"},"EN-TW":{"QuestionText":"<div style=\"text-align: center;\">\n<div style=\"text-align: center;\">You will have to throw a dice twice. Your first throw decides how much you receive, and the second throw only serves to make sure that the dice is working properly. In fact, you may throw the dice more than twice. However, only the first throw counts.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">The maximum payoff you can receive is 50 Monetary Units (MUs) and the minimum 0. You can see the exact payoff from the following table.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">The table also describes that the money not earned by you (50 MUs minus MUs for you) will be sent to the Doctors Without Boarders in Taiwan (MSF Taiwan) , as a donation in order to finance their projects in providing humanitarian medical aid. The sum of money gathered from all participants will be sent to the \"Medecins Sans Frontieres Foundation\" after the experiment ends.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">The table will remain on the screen until you entered your throw. If you have any questions, please raise your hand. If you are ready, please continue to the next page.<\/div>\n\u00a0\n\n<table align=\"center\" border=\"1\" cellpadding=\"1\" cellspacing=\"1\" style=\"width: 250px;\">\n\t<thead>\n\t\t<tr>\n\t\t\t<th scope=\"row\">Number thrown<\/th>\n\t\t\t<th scope=\"col\">MUs for you<\/th>\n\t\t\t<th scope=\"col\">MUs for MSF Taiwan<\/th>\n\t\t<\/tr>\n\t<\/thead>\n\t<tbody>\n\t\t<tr>\n\t\t\t<th scope=\"row\">1<\/th>\n\t\t\t<td>10<\/td>\n\t\t\t<td>40<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">2<\/th>\n\t\t\t<td>20<\/td>\n\t\t\t<td>30<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">3<\/th>\n\t\t\t<td>30<\/td>\n\t\t\t<td>20<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">4<\/th>\n\t\t\t<td>40<\/td>\n\t\t\t<td>10<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">5<\/th>\n\t\t\t<td>50<\/td>\n\t\t\t<td>0<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">6<\/th>\n\t\t\t<td>0<\/td>\n\t\t\t<td>50<\/td>\n\t\t<\/tr>\n\t<\/tbody>\n<\/table>\n<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n"},"EN-UK":{"QuestionText":"<div style=\"text-align: center;\">\n<div style=\"text-align: center;\">You will have to throw a die twice. Your first throw decides how much you receive, and the second throw only serves to make sure that the die is working properly. In fact, you may throw the die more than twice. However, only the first throw counts.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">The maximum payoff you can receive is 50 Monetary Units (MUs) and the minimum 0. You can see the exact payoff in the table below.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">The table also describes that the money not earned by you (50 MUs minus MUs for you) will be sent to Centrepoint, a UK charity, as a donation in order to finance their projects in fighting youth homelessness in the UK. At the end of the session, the sum of money gathered from all participants will be sent via a direct transfer.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">The table will remain on the screen until you entered your throw. If you have any questions, please raise your hand. If you are ready, please continue to the next page.<\/div>\n\u00a0\n\n<table align=\"center\" border=\"1\" cellpadding=\"1\" cellspacing=\"1\" style=\"width: 250px;\">\n\t<thead>\n\t\t<tr>\n\t\t\t<th scope=\"row\">Number thrown<\/th>\n\t\t\t<th scope=\"col\">MUs for you<\/th>\n\t\t\t<th scope=\"col\">MUs for Centrepoint<\/th>\n\t\t<\/tr>\n\t<\/thead>\n\t<tbody>\n\t\t<tr>\n\t\t\t<th scope=\"row\">1<\/th>\n\t\t\t<td>10<\/td>\n\t\t\t<td>40<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">2<\/th>\n\t\t\t<td>20<\/td>\n\t\t\t<td>30<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">3<\/th>\n\t\t\t<td>30<\/td>\n\t\t\t<td>20<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">4<\/th>\n\t\t\t<td>40<\/td>\n\t\t\t<td>10<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">5<\/th>\n\t\t\t<td>50<\/td>\n\t\t\t<td>0<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">6<\/th>\n\t\t\t<td>0<\/td>\n\t\t\t<td>50<\/td>\n\t\t<\/tr>\n\t<\/tbody>\n<\/table>\n<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n"},"ES":{"QuestionText":"<div style=\"text-align: center;\">\n<div style=\"text-align: center;\">Tendr\u00e1 que lanzar el dado dos veces. Su primer lanzamiento decide cu\u00e1nto recibe, y el segundo lanzamiento solo sirve para asegurarse de que el dado funciona correctamente. De hecho, puede tirar el dado m\u00e1s de dos veces. Sin embargo, solo cuenta el primer lanzamiento.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">El pago m\u00e1ximo que puede recibir usted es de 50 Unidades Monetarias (UM) y el m\u00ednimo de 0. Puede ver el pago exacto en la siguiente tabla.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">La tabla tambi\u00e9n describe que el dinero que no gane (50 UM menos las UM para usted) se enviar\u00e1 a la organizaci\u00f3n <strong>M\u00e9dicos Sin Fronteras<\/strong>, como donaci\u00f3n para financiar su labor humanitaria brindando atenci\u00f3n m\u00e9dica a poblaciones afectadas por cat\u00e1strofes naturales, epidemias y pandemias en Uruguay. Al finalizar la sesi\u00f3n, la suma de dinero recaudada entre todos los participantes se enviar\u00e1 mediante transferencia directa. M\u00e1s informaci\u00f3n en https:\/\/www.msf.org.uy\/hace-una-donacion-unica-vez\/<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">La tabla permanecer\u00e1 en la pantalla hasta que ingrese su lanzamiento. Si tiene alguna pregunta, por favor levante su mano. Si est\u00e1 listo\/a, presione OK.<br \/>\n\u00a0<\/div>\n\n<table align=\"center\" border=\"1\" cellpadding=\"1\" cellspacing=\"1\" style=\"width: 250px;\">\n\t<thead>\n\t\t<tr>\n\t\t\t<th scope=\"row\">N\u00famero lanzado<\/th>\n\t\t\t<th scope=\"col\">UM para usted<\/th>\n\t\t\t<th scope=\"col\">UM para M\u00e9dicos Sin Fronteras<\/th>\n\t\t<\/tr>\n\t<\/thead>\n\t<tbody>\n\t\t<tr>\n\t\t\t<th scope=\"row\">1<\/th>\n\t\t\t<td>10<\/td>\n\t\t\t<td>40<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">2<\/th>\n\t\t\t<td>20<\/td>\n\t\t\t<td>30<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">3<\/th>\n\t\t\t<td>30<\/td>\n\t\t\t<td>20<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">4<\/th>\n\t\t\t<td>40<\/td>\n\t\t\t<td>10<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">5<\/th>\n\t\t\t<td>50<\/td>\n\t\t\t<td>0<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">6<\/th>\n\t\t\t<td>0<\/td>\n\t\t\t<td>50<\/td>\n\t\t<\/tr>\n\t<\/tbody>\n<\/table>\n<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n"},"ES-AR":{"QuestionText":"<div style=\"text-align: center;\">\n<div style=\"text-align: center;\">Tendr\u00e1 que lanzar el dado dos veces. Su primer lanzamiento decide cu\u00e1nto recibe, y el segundo lanzamiento solo sirve para asegurarse de que los dados funcionan correctamente. De hecho, puede tirar el dado m\u00e1s de dos veces. Sin embargo, solo cuenta el primer lanzamiento.<br \/>\n\u00a0<br \/>\nEl pago m\u00e1ximo que puede recibir es de 50 Unidades Monetarias (UM) y el m\u00ednimo de 0. Puede ver el pago exacto en la siguiente tabla.<br \/>\n<br \/>\nLa tabla tambi\u00e9n describe que el dinero que no reciba (50 UM menos las UM para usted) se donar\u00e1 a la organizaci\u00f3n Cruz Roja Peruana para financiar sus proyectos en el Per\u00fa. Al finalizar la sesi\u00f3n, la suma de dinero recaudada entre todos los participantes ser\u00e1 enviada mediante transferencia directa a la Cruz Roja Peruana, en el siguiente enlace https:\/\/secure.micuentaweb.pe\/vads-site\/IZI_Sociedad_Peruana_De_La_Cru<br \/>\n<br \/>\nLa tabla permanecer\u00e1 en la pantalla hasta que ingrese su lanzamiento. Si tiene alguna pregunta, por favor levante su mano. Si est\u00e1 listo, presione OK.<\/div>\n\u00a0\n\n<table align=\"center\" border=\"1\" cellpadding=\"1\" cellspacing=\"1\" style=\"width: 250px;\">\n\t<thead>\n\t\t<tr>\n\t\t\t<th scope=\"row\">N\u00famero tirado<\/th>\n\t\t\t<th scope=\"col\">UM para usted<\/th>\n\t\t\t<th scope=\"col\">UM para Cruz Roja Peruana<\/th>\n\t\t<\/tr>\n\t<\/thead>\n\t<tbody>\n\t\t<tr>\n\t\t\t<th scope=\"row\">1<\/th>\n\t\t\t<td>10<\/td>\n\t\t\t<td>40<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">2<\/th>\n\t\t\t<td>20<\/td>\n\t\t\t<td>30<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">3<\/th>\n\t\t\t<td>30<\/td>\n\t\t\t<td>20<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">4<\/th>\n\t\t\t<td>40<\/td>\n\t\t\t<td>10<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">5<\/th>\n\t\t\t<td>50<\/td>\n\t\t\t<td>0<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">6<\/th>\n\t\t\t<td>0<\/td>\n\t\t\t<td>50<\/td>\n\t\t<\/tr>\n\t<\/tbody>\n<\/table>\n<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n"},"ES-ES":{"QuestionText":"Tendr\u00e1 que lanzar el dado dos veces. Su primer lanzamiento decide cu\u00e1nto recibe, y el segundo lanzamiento solo sirve para asegurarse de que el dado funciona correctamente. De hecho, puede tirar el dado m\u00e1s de dos veces. Sin embargo, solo cuenta el primer lanzamiento.<br \/>\n<br \/>\nEl pago m\u00e1ximo que puede recibir usted es de 50 Unidades Monetarias (UM) y el m\u00ednimo de 0. Puede ver el pago exacto en la siguiente tabla.<br \/>\n<br \/>\nLa tabla tambi\u00e9n describe que el dinero que no gane (50 UM menos las UM para usted) se enviar\u00e1 a la organizaci\u00f3n TECHO-Chile, como donaci\u00f3n para financiar sus proyectos\u00a0al servicio de las familias que viven en situaci\u00f3n de precariedad habitacional. Al finalizar la sesi\u00f3n, la suma de dinero recaudada entre todos los participantes se enviar\u00e1 mediante transferencia directa a\u00a0Emergencia - TECHO Chile<br \/>\n\u00a0Cta Cte:062020 Banco Santander<br \/>\n<br \/>\nLa tabla permanecer\u00e1 en la pantalla hasta que ingrese su lanzamiento. Si tiene alguna pregunta, por favor levante su mano. Si est\u00e1 listo, presione OK.<br \/>\n\u00a0\n<table align=\"center\" border=\"1\" cellpadding=\"1\" cellspacing=\"1\">\n\t<thead>\n\t\t<tr>\n\t\t\t<th scope=\"row\">N\u00famero<br \/>\n\t\t\tlanzado<\/th>\n\t\t\t<th scope=\"col\">UM<br \/>\n\t\t\tpara usted<\/th>\n\t\t\t<th scope=\"col\">UM para<br \/>\n\t\t\tTECHO-Chile<\/th>\n\t\t<\/tr>\n\t<\/thead>\n\t<tbody>\n\t\t<tr>\n\t\t\t<th scope=\"row\">1<\/th>\n\t\t\t<td style=\"text-align: center;\">10<\/td>\n\t\t\t<td style=\"text-align: center;\">40<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">2<\/th>\n\t\t\t<td style=\"text-align: center;\">20<\/td>\n\t\t\t<td style=\"text-align: center;\">30<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">3<\/th>\n\t\t\t<td style=\"text-align: center;\">30<\/td>\n\t\t\t<td style=\"text-align: center;\">20<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">4<\/th>\n\t\t\t<td style=\"text-align: center;\">40<\/td>\n\t\t\t<td style=\"text-align: center;\">10<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">5<\/th>\n\t\t\t<td style=\"text-align: center;\">50<\/td>\n\t\t\t<td style=\"text-align: center;\">0<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">6<\/th>\n\t\t\t<td style=\"text-align: center;\">0<\/td>\n\t\t\t<td style=\"text-align: center;\">50<\/td>\n\t\t<\/tr>\n\t<\/tbody>\n<\/table>\n"},"FR":{"QuestionText":"<div style=\"text-align: center;\">\n<div style=\"text-align: center;\">Vous devrez lancer un d\u00e9 deux fois. Votre premier lancer d\u00e9cide du montant que vous recevez, et le deuxi\u00e8me lancer sert uniquement \u00e0 vous assurer que les d\u00e9s fonctionnent correctement. En fait, vous pouvez lancer les d\u00e9s plus de deux fois. Cependant, seul le premier lancer compte.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">Le gain maximum que vous pouvez recevoir est de 50 unit\u00e9s mon\u00e9taires (UM) et le minimum de 0. Vous pouvez voir le gain exact dans le tableau suivant.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">Le tableau indique \u00e9galement que l'argent que vous n'aurez pas gagn\u00e9 (50 UM moins les UM pour vous) sera envoy\u00e9 \u00e0 l'organisation M\u00e9decins Sans Fronti\u00e8res, sous forme de don afin de financer leurs projets de lutte contre les maladies end\u00e9miques \u00e0 Madagascar. A la fin de la s\u00e9ance, la somme d'argent r\u00e9colt\u00e9e aupr\u00e8s de tous les participants sera envoy\u00e9e par virement direct (num\u00e9ro de compte : 652146021???).<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">Le tableau restera \u00e0 l'\u00e9cran jusqu'\u00e0 ce que vous saisissiez votre lancer. Si vous avez des questions, veuillez lever la main. Si vous \u00eates pr\u00eat, veuillez passer \u00e0 la page suivante.<br \/>\n\u00a0<\/div>\n\n<table align=\"center\" border=\"1\" cellpadding=\"1\" cellspacing=\"1\" style=\"width: 250px;\">\n\t<thead>\n\t\t<tr>\n\t\t\t<th scope=\"row\">Num\u00e9ro lanc\u00e9<\/th>\n\t\t\t<th scope=\"col\">Des UM pour vous<\/th>\n\t\t\t<th scope=\"col\">Des UM pour M\u00e9decins Sans Fronti\u00e8res<\/th>\n\t\t<\/tr>\n\t<\/thead>\n\t<tbody>\n\t\t<tr>\n\t\t\t<th scope=\"row\">1<\/th>\n\t\t\t<td>10<\/td>\n\t\t\t<td>40<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">2<\/th>\n\t\t\t<td>20<\/td>\n\t\t\t<td>30<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">3<\/th>\n\t\t\t<td>30<\/td>\n\t\t\t<td>20<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">4<\/th>\n\t\t\t<td>40<\/td>\n\t\t\t<td>10<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">5<\/th>\n\t\t\t<td>50<\/td>\n\t\t\t<td>0<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">6<\/th>\n\t\t\t<td>0<\/td>\n\t\t\t<td>50<\/td>\n\t\t<\/tr>\n\t<\/tbody>\n<\/table>\n<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n"},"FR-FR":{"QuestionText":"<div style=\"text-align: center;\">\n<div style=\"text-align: center;\">\n<div style=\"text-align: center;\">Vous allez \u00eatre invit\u00e9 \u00e0 lancer votre d\u00e9 deux fois. Le r\u00e9sultat du premier lancer d\u00e9termine le montant que vous allez obtenir. Le deuxi\u00e8me lancer sert uniquement \u00e0 vous assurer que le d\u00e9 n'est pas truqu\u00e9. Vous pouvez m\u00eame lancer les d\u00e9s plus de deux fois. Cependant, seul le premier lancer compte.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">Le gain maximum que vous pouvez obtenir est de 50 unit\u00e9s mon\u00e9taires (UM), et le minimum est de 0 UM. Le tableau ci-dessous d\u00e9crit les gains exacts en fonction du r\u00e9sultat du d\u00e9.<\/div>\n\n<div style=\"text-align: center;\"><br \/>\nLe tableau d\u00e9crit \u00e9galement que l'argent que vous n'aurez pas gagn\u00e9 (50 MU moins les MU pour vous) sera envoy\u00e9 \u00e0 l'organisation M\u00e9decins Sans Fronti\u00e8res, sous forme de don afin de financer leur projets en France. A la fin de la session, la somme d'argent cumul\u00e9e par tous les participants sera envoy\u00e9e via un virement.\n<div style=\"text-align: center;\">\u00a0<\/div>\n<\/div>\n\n<div style=\"text-align: center;\">Si vous avez une question, veuillez lever la main. Si vous \u00eates pr\u00eat, vous pouvez passer \u00e0 la page suivante.<br \/>\n\u00a0<\/div>\n<\/div>\n<t\u00eate> <\/t\u00eate><corps> <\/corps>\n\n<table align=\"center\" border=\"1\" cellpacing=\"1\" cellpadding=\"1\" style=\"width: 250px;\">\n\t<tbody>\n\t\t<tr>\n\t\t\t<th scope=\"row\">R\u00e9sultat du d\u00e9<\/th>\n\t\t\t<th scope=\"col\">UM pour vous<\/th>\n\t\t\t<th scope=\"col\">UM pour M\u00e9decins Sans Fronti\u00e8res<\/th>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">1<\/th>\n\t\t\t<td>10<\/td>\n\t\t\t<td>40<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">2<\/th>\n\t\t\t<td>20<\/td>\n\t\t\t<td>30<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">3<\/th>\n\t\t\t<td>30<\/td>\n\t\t\t<td>20<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">4<\/th>\n\t\t\t<td>40<\/td>\n\t\t\t<td>10<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">5<\/th>\n\t\t\t<td>50<\/td>\n\t\t\t<td>0<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">6<\/th>\n\t\t\t<td>0<\/td>\n\t\t\t<td>50<\/td>\n\t\t<\/tr>\n\t<\/tbody>\n<\/table>\n<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n"},"HU":{"QuestionText":"<div style=\"text-align: center;\">\n<div style=\"text-align: center;\">\n<div style=\"text-align: center;\">K\u00e9tszer kell dobnia egy kock\u00e1val. Az els\u0151 dob\u00e1s hat\u00e1rozza meg, hogy mennyit kap, a m\u00e1sodik pedig csak arra szolg\u00e1l, hogy megbizonyosodjon arr\u00f3l, hogy a kocka megfelel\u0151en m\u0171k\u00f6dik. Ak\u00e1r t\u00f6bbsz\u00f6r is dobhat a kock\u00e1val, azonban csak az els\u0151 dob\u00e1s sz\u00e1m\u00edt.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">A legnagyobb kifizet\u00e9s 50 p\u00e9nzegys\u00e9g (PE), a legkisebb pedig 0. A pontos kifizet\u00e9st a k\u00f6vetkez\u0151 t\u00e1bl\u00e1zat mutatja.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">A t\u00e1bl\u00e1zat azt is mutatja, hogy az \u00d6n \u00e1ltal nem megnyert p\u00e9nzt (50 PE m\u00ednusz az \u00d6n \u00e1ltal nyert PE)<\/div>\nadom\u00e1nyk\u00e9nt a Magyar V\u00f6r\u00f6skeresztnek k\u00fcldj\u00fck el, hogy \u00edgy t\u00e1mogassuk tev\u00e9kenys\u00e9g\u00fcket (p\u00e9ld\u00e1ul v\u00e9rad\u00e1sszervez\u00e9s, szoci\u00e1lis seg\u00edts\u00e9gny\u00fajt\u00e1s) Magyarorsz\u00e1gon. A lek\u00e9rdez\u00e9s v\u00e9g\u00e9n az \u00f6sszes r\u00e9sztvev\u0151t\u0151l beszedett p\u00e9nz\u00f6sszeget k\u00f6zvetlen \u00e1tutaljuk\u00a0a Magyar V\u00f6r\u00f6skeresztnek (sz\u00e1mlasz\u00e1m: 10405004-00026542-00000005).<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">A t\u00e1bl\u00e1zat addig lesz majd l\u00e1that\u00f3, am\u00edg meg nem adja a dobott sz\u00e1mot. Ha k\u00e9rd\u00e9se van, k\u00e9rj\u00fck, emelje fel a kez\u00e9t. Ha k\u00e9szen \u00e1ll, l\u00e9pjen a k\u00f6vetkez\u0151 oldalra.<\/div>\n\n<table align=\"center\" border=\"1\" cellpadding=\"1\" cellspacing=\"1\" style=\"width: 250px;\">\n\t<thead>\n\t\t<tr>\n\t\t\t<th scope=\"row\">Dobott sz\u00e1m<\/th>\n\t\t\t<th scope=\"col\">Nyert PE<\/th>\n\t\t\t<th scope=\"col\">PE a\u00a0Magyar V\u00f6r\u00f6skereszt sz\u00e1m\u00e1ra<\/th>\n\t\t<\/tr>\n\t<\/thead>\n\t<tbody>\n\t\t<tr>\n\t\t\t<th scope=\"row\">1<\/th>\n\t\t\t<td>10<\/td>\n\t\t\t<td>40<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">2<\/th>\n\t\t\t<td>20<\/td>\n\t\t\t<td>30<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">3<\/th>\n\t\t\t<td>30<\/td>\n\t\t\t<td>20<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">4<\/th>\n\t\t\t<td>40<\/td>\n\t\t\t<td>10<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">5<\/th>\n\t\t\t<td>50<\/td>\n\t\t\t<td>0<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">6<\/th>\n\t\t\t<td>0<\/td>\n\t\t\t<td>50<\/td>\n\t\t<\/tr>\n\t<\/tbody>\n<\/table>\n<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n"},"IT":{"QuestionText":"<div style=\"text-align: center;\">\n<div style=\"text-align: center;\">Dovrai lanciare un dado due volte. Il tuo primo lancio decide quanto ricevi, mentre il secondo serve solo per assicurarti che i dadi funzionino correttamente. In sostanza, puoi lanciare i dadi pi\u00f9 di due volte. Tuttavia conta solo il primo tiro.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">Il guadagno massimo che puoi ricevere \u00e8 50 unit\u00e0 monetarie (MU) e il minimo \u00e8 0. Puoi vedere il guadagno esatto dalla tabella seguente.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">La tabella descrive anche il denaro non guadagnato da te (50 MU meno le MU da te guadagnate) che verr\u00e0 inviato all'organizzazione Medici Senza Frontiere, come donazione per finanziare i loro progetti nella lotta alle malattie endemiche in Italia. Al termine della sessione, la somma di denaro raccolta da tutti i partecipanti verr\u00e0 inviata tramite bonifico diretto (numero di conto: 025-328-24-28203-3).<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">La tabella rimarr\u00e0 sullo schermo finch\u00e9 non inserirai il tuo tiro. Se hai domande, per favore alzate la mano. Se sei pronto, continua alla pagina successiva.<\/div>\n\n<table align=\"center\" border=\"1\" cellpadding=\"1\" cellspacing=\"1\" style=\"width: 250px;\">\n\t<thead>\n\t\t<tr>\n\t\t\t<th scope=\"row\">Numero uscito<\/th>\n\t\t\t<th scope=\"col\">MU per te<\/th>\n\t\t\t<th scope=\"col\">MU per Medici Senza Frontiere<\/th>\n\t\t<\/tr>\n\t<\/thead>\n\t<tbody>\n\t\t<tr>\n\t\t\t<th scope=\"row\">1<\/th>\n\t\t\t<td>10<\/td>\n\t\t\t<td>40<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">2<\/th>\n\t\t\t<td>20<\/td>\n\t\t\t<td>30<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">3<\/th>\n\t\t\t<td>30<\/td>\n\t\t\t<td>20<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">4<\/th>\n\t\t\t<td>40<\/td>\n\t\t\t<td>10<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">5<\/th>\n\t\t\t<td>50<\/td>\n\t\t\t<td>0<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">6<\/th>\n\t\t\t<td>0<\/td>\n\t\t\t<td>50<\/td>\n\t\t<\/tr>\n\t<\/tbody>\n<\/table>\n<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n"},"JA":{"QuestionText":"<div style=\"text-align: center;\">\n<div style=\"text-align: center;\">\u30b5\u30a4\u30b3\u30ed\u3092 2 \u56de\u6295\u3052\u308b\u5fc5\u8981\u304c\u3042\u308a\u307e\u3059\u30021 \u56de\u76ee\u306e\u6295\u3052\u3067\u7372\u5f97\u3067\u304d\u308b\u91d1\u984d\u304c\u6c7a\u307e\u308a\u30012 \u56de\u76ee\u306e\u6295\u3052\u306f\u30b5\u30a4\u30b3\u30ed\u304c\u6b63\u3057\u304f\u6a5f\u80fd\u3057\u3066\u3044\u308b\u304b\u3069\u3046\u304b\u3092\u78ba\u8a8d\u3059\u308b\u305f\u3081\u3060\u3051\u306b\u884c\u308f\u308c\u307e\u3059\u3002\u5b9f\u969b\u3001\u30b5\u30a4\u30b3\u30ed\u3092 2 \u56de\u4ee5\u4e0a\u6295\u3052\u308b\u3053\u3068\u3082\u3067\u304d\u307e\u3059\u3002\u305f\u3060\u3057\u3001\u30ab\u30a6\u30f3\u30c8\u3055\u308c\u308b\u306e\u306f\u6700\u521d\u306e\u6295\u3052\u3060\u3051\u3067\u3059\u3002<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">\u3042\u306a\u305f\u304c\u53d7\u3051\u53d6\u308c\u308b\u6700\u5927\u306e\u5831\u916c\u306f50\u901a\u8ca8\u5358\u4f4d\uff08MU\uff09\u3067\u3001\u6700\u5c0f\u306f0\u3067\u3059\u3002\u6b63\u78ba\u306a\u5831\u916c\u306f\u6b21\u306e\u8868\u3067\u78ba\u8a8d\u3067\u304d\u307e\u3059\u3002<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">\u3053\u306e\u8868\u306b\u306f\u3001\u3042\u306a\u305f\u304c\u7372\u5f97\u3057\u306a\u304b\u3063\u305f\u304a\u91d1\uff0850 MU\u304b\u3089\u3042\u306a\u305f\u306eMU\u3092\u5dee\u3057\u5f15\u3044\u305f\u3082\u306e\uff09\u304c\u3001NPO\u6cd5\u4eba\u300c\u56fd\u5883\u306a\u304d\u533b\u5e2b\u56e3\u65e5\u672c\u300d\u3078\u306e\u5bc4\u4ed8\u91d1\u3068\u3057\u3066\u306b\u9001\u3089\u308c\u308b\u3053\u3068\u3082\u8a18\u8f09\u3055\u308c\u3066\u3044\u307e\u3059\u3002\u30bb\u30c3\u30b7\u30e7\u30f3\u7d42\u4e86\u6642\u306b\u3001\u53c2\u52a0\u8005\u5168\u54e1\u304b\u3089\u96c6\u3081\u305f\u91d1\u984d\u306f\u3001\u76f4\u63a5\u632f\u8fbc\u3067\u9001\u91d1\u3055\u308c\u307e\u3059 (\u3086\u3046\u3061\u3087\u9280\u884c\u3001\u53e3\u5ea7\u756a\u53f7: 00190-6-566468\u3001\u53e3\u5ea7\u540d\u7fa9\uff1a\u7279\u5b9a\u975e\u55b6\u5229\u6d3b\u52d5\u6cd5\u4eba\u56fd\u5883\u306a\u304d\u533b\u5e2b\u56e3\u65e5\u672c)\u3002<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">\u30c6\u30fc\u30d6\u30eb\u306f\u3001\u3042\u306a\u305f\u304c\u6295\u3052\u308b\u306e\u3092\u5165\u529b\u3059\u308b\u307e\u3067\u753b\u9762\u306b\u8868\u793a\u3055\u308c\u305f\u307e\u307e\u3067\u3059\u3002\u8cea\u554f\u304c\u3042\u308b\u5834\u5408\u306f\u3001\u624b\u3092\u6319\u3052\u3066\u304f\u3060\u3055\u3044\u3002\u6e96\u5099\u304c\u3067\u304d\u305f\u3089\u3001\u6b21\u306e\u30da\u30fc\u30b8\u306b\u9032\u3093\u3067\u304f\u3060\u3055\u3044\u3002<\/div>\n\u00a0\n\n<table align=\"center\" border=\"1\" cellpadding=\"1\" cellspacing=\"1\" style=\"width: 250px;\">\n\t<thead>\n\t\t<tr>\n\t\t\t<th scope=\"row\">\u6295\u3052\u3089\u308c\u305f\u6570<\/th>\n\t\t\t<th scope=\"col\">\u3042\u306a\u305f\u306e\u305f\u3081\u306eMU<\/th>\n\t\t\t<th scope=\"col\">\u56fd\u5883\u306a\u304d\u533b\u5e2b\u56e3\u65e5\u672c\u306e\u305f\u3081\u306eMU<\/th>\n\t\t<\/tr>\n\t<\/thead>\n\t<tbody>\n\t\t<tr>\n\t\t\t<th scope=\"row\">1<\/th>\n\t\t\t<td>10<\/td>\n\t\t\t<td>40<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">2<\/th>\n\t\t\t<td>20<\/td>\n\t\t\t<td>30<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">3<\/th>\n\t\t\t<td>30<\/td>\n\t\t\t<td>20<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">4<\/th>\n\t\t\t<td>40<\/td>\n\t\t\t<td>10<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">5<\/th>\n\t\t\t<td>50<\/td>\n\t\t\t<td>0<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">6<\/th>\n\t\t\t<td>0<\/td>\n\t\t\t<td>50<\/td>\n\t\t<\/tr>\n\t<\/tbody>\n<\/table>\n<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n"},"KO":{"QuestionText":"<div style=\"text-align: center;\">\n<div style=\"text-align: center;\">\uadc0\ud558\ub294 \uc8fc\uc0ac\uc704\ub97c \ucd5c\uc18c\ud55c \ub450 \ubc88 \uad74\ub824\uc57c \ud569\ub2c8\ub2e4. \uc8fc\uc0ac\uc704\ub97c \ucc98\uc74c \uad74\ub824 \uc5bb\uc740 \uacb0\uacfc\ub97c \uc785\ub825\ud558\uc5ec \ubcf4\uc0c1\uc744 \ubc1b\uc2b5\ub2c8\ub2e4. \uc8fc\uc0ac\uc704\uac00 \uc81c\ub300\ub85c \uc791\ub3d9\ud558\ub294 \uc9c0 \ud655\uc778\ud558\uae30 \uc704\ud574 \uc8fc\uc0ac\uc704\ub97c \ucd5c\uc18c\ud55c \ud55c \ubc88 \uc774\uc0c1 \ucd94\uac00\ub85c \uad74\ub824\uc57c \ud569\ub2c8\ub2e4. \uadf8\ub7ec\ub098 \uccab \ubc88\uc9f8 \uad74\ub9ac\uae30\ub9cc \ubcf4\uc0c1\uc5d0 \ubc18\uc601\ub429\ub2c8\ub2e4.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">\ubc1b\uc744 \uc218 \uc788\ub294 \ucd5c\ub300 \ubcf4\uc0c1\uc740 50\ud654\ud3d0 \ub2e8\uc704(MU)\uc774\uace0 \ucd5c\uc18c \ubcf4\uc0c1\uc740 0\uc785\ub2c8\ub2e4. \ub2e4\uc74c \ud45c\uc5d0\uc11c \uc815\ud655\ud55c \ubcf4\uc0c1\uc744 \ud655\uc778\ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">\ub610\ud55c \uc544\ub798 \ud45c\uc5d0\uc11c \ud655\uc778\ud560 \uc218 \uc788\ub4ef, \uadc0\ud558\uac00 \uc5bb\uc9c0 \ubabb\ud55c \ub3c8(50MU\uc5d0\uc11c \uadc0\ud558\uc758 MU\ub97c \ube80 \uae08\uc561)\uc740 [\uad6d\uacbd \uc5c6\ub294 \uc758\uc0ac\ud68c]\ub77c\ub294 \ube44\uc601\ub9ac\uc7ac\ub2e8\uc5d0 \ubcf4\ub0b4\uc838, \uc800\uac1c\ubc1c\uad6d\uac00\uc758 \ud48d\ud1a0\ubcd1\uc744 \uce58\ub8cc\ud558\ub294 \ub370 \uc0ac\uc6a9\ub418\ub294 \uac83\uc744 \ubcf4\uc5ec\uc90d\ub2c8\ub2e4. \uc138\uc158\uc774 \ub05d\ub098\uba74 \ubaa8\ub4e0 \ucc38\uac00\uc790\ub85c\ubd80\ud130 \ubaa8\uc740 \uae08\uc561\uc774 \uc9c1\uc811 \uc774\uccb4\ub97c \ud1b5\ud574 \uc804\uc1a1\ub429\ub2c8\ub2e4.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">\uc8fc\uc0ac\uc704\ub97c \uad74\ub9b0 \uacb0\uacfc\ub97c \uc785\ub825\ud560 \ub54c\uae4c\uc9c0 \uc544\ub798\uc758 \ud45c\uac00 \ud654\uba74\uc5d0 \ud45c\uc2dc\ub429\ub2c8\ub2e4. \uc9c8\ubb38\uc774 \uc788\uc73c\uba74 \uc190\uc744 \ub4e4\uc5b4\uc8fc\uc138\uc694. \uc900\ube44\uac00 \ub418\uc5c8\ub2e4\uba74 \ub2e4\uc74c \ud398\uc774\uc9c0\ub85c \ub118\uc5b4\uac00\uc138\uc694.<\/div>\n\u00a0\n\n<table align=\"center\" border=\"1\" cellpadding=\"1\" cellspacing=\"1\" style=\"width: 250px;\">\n\t<thead>\n\t\t<tr>\n\t\t\t<th scope=\"row\">\uc8fc\uc0ac\uc704 \uacb0\uacfc<\/th>\n\t\t\t<th scope=\"col\">\uadc0\ud558\uac00 \uc5bb\uac8c \ub418\ub294 MU<\/th>\n\t\t\t<th scope=\"col\">\uad6d\uacbd\uc5c6\ub294\uc758\uc0ac\ud68c\uac00 \uc5bb\uac8c \ub418\ub294 MU<\/th>\n\t\t<\/tr>\n\t<\/thead>\n\t<tbody>\n\t\t<tr>\n\t\t\t<th scope=\"row\">1<\/th>\n\t\t\t<td>10<\/td>\n\t\t\t<td>40<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">2<\/th>\n\t\t\t<td>20<\/td>\n\t\t\t<td>30<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">3<\/th>\n\t\t\t<td>30<\/td>\n\t\t\t<td>20<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th>4<\/th>\n\t\t\t<td>40<\/td>\n\t\t\t<td>10<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th>5<\/th>\n\t\t\t<td>50<\/td>\n\t\t\t<td>0<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th>6<\/th>\n\t\t\t<td>0<\/td>\n\t\t\t<td>50<\/td>\n\t\t<\/tr>\n\t<\/tbody>\n<\/table>\n<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n"},"KZ-RU":{"QuestionText":"<div style=\"text-align: center;\">\n<div style=\"text-align: center;\">\n<div style=\"text-align: center;\">\n<div style=\"text-align: center;\">\u00a0\n<div style=\"text-align: center;\">\n<div style=\"text-align: center;\">\u00a0\n<div style=\"text-align: center;\">\n<div style=\"text-align: center;\">\n<div style=\"text-align: center;\">\u0412\u0430\u043c \u043d\u0430\u0434\u043e \u0431\u0443\u0434\u0435\u0442 \u0431\u0440\u043e\u0441\u0438\u0442\u044c \u0438\u0433\u0440\u0430\u043b\u044c\u043d\u0443\u044e \u043a\u043e\u0441\u0442\u044c \u0434\u0432\u0430\u0436\u0434\u044b. \u0412\u0430\u0448 \u043f\u0435\u0440\u0432\u044b\u0439 \u0431\u0440\u043e\u0441\u043e\u043a \u043e\u043f\u0440\u0435\u0434\u0435\u043b\u044f\u0435\u0442, \u0441\u043a\u043e\u043b\u044c\u043a\u043e \u0412\u044b \u043f\u043e\u043b\u0443\u0447\u0438\u0442\u0435, \u0430 \u0432\u0442\u043e\u0440\u043e\u0439 \u0431\u0440\u043e\u0441\u043e\u043a \u0441\u043b\u0443\u0436\u0438\u0442 \u0442\u043e\u043b\u044c\u043a\u043e \u0434\u043b\u044f \u0442\u043e\u0433\u043e, \u0447\u0442\u043e\u0431\u044b \u0443\u0431\u0435\u0434\u0438\u0442\u044c\u0441\u044f, \u0447\u0442\u043e \u043a\u043e\u0441\u0442\u044c \u0440\u0430\u0431\u043e\u0442\u0430\u0435\u0442 \u043f\u0440\u0430\u0432\u0438\u043b\u044c\u043d\u043e. \u0424\u0430\u043a\u0442\u0438\u0447\u0435\u0441\u043a\u0438, \u0412\u044b \u043c\u043e\u0436\u0435\u0442\u0435 \u0431\u0440\u043e\u0441\u0438\u0442\u044c \u043a\u043e\u0441\u0442\u044c \u0438 \u0431\u043e\u043b\u0435\u0435 \u0434\u0432\u0443\u0445 \u0440\u0430\u0437. \u041e\u0434\u043d\u0430\u043a\u043e \u0437\u0430\u0441\u0447\u0438\u0442\u044b\u0432\u0430\u0435\u0442\u0441\u044f \u0442\u043e\u043b\u044c\u043a\u043e \u043f\u0435\u0440\u0432\u044b\u0439 \u0431\u0440\u043e\u0441\u043e\u043a.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">\u041c\u0430\u043a\u0441\u0438\u043c\u0430\u043b\u044c\u043d\u044b\u0439 \u0432\u044b\u0438\u0433\u0440\u044b\u0448, \u043a\u043e\u0442\u043e\u0440\u044b\u0439 \u0412\u044b \u043c\u043e\u0436\u0435\u0442\u0435 \u043f\u043e\u043b\u0443\u0447\u0438\u0442\u044c, \u0441\u043e\u0441\u0442\u0430\u0432\u043b\u044f\u0435\u0442 50 \u0434\u0435\u043d\u0435\u0436\u043d\u044b\u0445 \u0435\u0434\u0438\u043d\u0438\u0446 (\u0414\u0415), \u0430 \u043c\u0438\u043d\u0438\u043c\u0430\u043b\u044c\u043d\u044b\u0439 \u2014 0. \u0422\u043e\u0447\u043d\u044b\u0439 \u0432\u044b\u0438\u0433\u0440\u044b\u0448 \u0412\u044b \u043c\u043e\u0436\u0435\u0442\u0435 \u0443\u0432\u0438\u0434\u0435\u0442\u044c \u0438\u0437 \u0441\u043b\u0435\u0434\u0443\u044e\u0449\u0435\u0439 \u0442\u0430\u0431\u043b\u0438\u0446\u044b.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n<\/div>\n\u0412 \u0442\u0430\u0431\u043b\u0438\u0446\u0435 \u0442\u0430\u043a\u0436\u0435 \u0443\u043a\u0430\u0437\u0430\u043d\u043e, \u0447\u0442\u043e \u0442\u043e \u0447\u0442\u043e \u0412\u044b \u043d\u0435 \u0437\u0430\u0440\u0430\u0431\u043e\u0442\u0430\u0435\u0442\u0435 (50 \u0414\u0415 \u043c\u0438\u043d\u0443\u0441 \u0414\u0415 \u0434\u043b\u044f \u0412\u0430\u0441) \u0431\u0443\u0434\u0443\u0442 \u043e\u0442\u043f\u0440\u0430\u0432\u043b\u0435\u043d\u044b \u0432 \u0447\u0430\u0441\u0442\u043d\u044b\u0439 \u0431\u043b\u0430\u0433\u043e\u0442\u0432\u043e\u0440\u0438\u0442\u0435\u043b\u044c\u043d\u044b\u0439 \u0444\u043e\u043d\u0434 Azarume (ttps:\/\/www.instagram.com\/asarume_kz\/)\u00a0 \u0434\u043b\u044f \u0444\u0438\u043d\u0430\u043d\u0441\u0438\u0440\u043e\u0432\u0430\u043d\u0438\u044f \u0438\u0445 \u0431\u043b\u0430\u0433\u043e\u0442\u0432\u043e\u0440\u0438\u0442\u0435\u043b\u044c\u043d\u044b\u0445 \u043f\u0440\u043e\u0435\u043a\u0442\u043e\u0432. \u041f\u043e \u043e\u043a\u043e\u043d\u0447\u0430\u043d\u0438\u0438 \u0441\u0435\u0441\u0441\u0438\u0438 \u0441\u0443\u043c\u043c\u0430 \u0434\u0435\u043d\u0435\u0433, \u0441\u043e\u0431\u0440\u0430\u043d\u043d\u0430\u044f \u043e\u0442 \u0432\u0441\u0435\u0445 \u0443\u0447\u0430\u0441\u0442\u043d\u0438\u043a\u043e\u0432, \u0431\u0443\u0434\u0435\u0442 \u043e\u0442\u043f\u0440\u0430\u0432\u043b\u0435\u043d\u0430 \u200b\u200b\u043f\u0440\u044f\u043c\u044b\u043c \u043f\u0435\u0440\u0435\u0432\u043e\u0434\u043e\u043c \u0447\u0435\u0440\u0435\u0437 \u041a\u0430\u0441\u043f\u0438\u00a0https:\/\/qtap.kz\/ASARUME\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">\u0422\u0430\u0431\u043b\u0438\u0446\u0430 \u0431\u0443\u0434\u0435\u0442 \u043e\u0441\u0442\u0430\u0432\u0430\u0442\u044c\u0441\u044f \u043d\u0430 \u044d\u043a\u0440\u0430\u043d\u0435 \u0434\u043e \u0442\u0435\u0445 \u043f\u043e\u0440, \u043f\u043e\u043a\u0430 \u0412\u044b \u043d\u0435 \u0432\u0432\u0435\u0434\u0435\u0442\u0435 \u0440\u0435\u0437\u0443\u043b\u044c\u0442\u0430\u0442 \u0412\u0430\u0448\u0435\u0433\u043e \u0431\u0440\u043e\u0441\u043a\u0430. \u0415\u0441\u043b\u0438 \u0443 \u0412\u0430\u0441 \u0435\u0441\u0442\u044c \u0432\u043e\u043f\u0440\u043e\u0441\u044b, \u043f\u043e\u0436\u0430\u043b\u0443\u0439\u0441\u0442\u0430, \u043f\u043e\u0434\u043d\u0438\u043c\u0438\u0442\u0435 \u0440\u0443\u043a\u0443. \u0415\u0441\u043b\u0438 \u0412\u044b \u0433\u043e\u0442\u043e\u0432\u044b, \u043f\u0435\u0440\u0435\u0439\u0434\u0438\u0442\u0435 \u043d\u0430 \u0441\u043b\u0435\u0434\u0443\u044e\u0449\u0443\u044e \u0441\u0442\u0440\u0430\u043d\u0438\u0446\u0443.<\/div>\n<\/div>\n\u00a0\n\n<table align=\"center\" border=\"1\" cellpadding=\"1\" cellspacing=\"1\" style=\"width: 250px;\">\n\t<thead>\n\t\t<tr>\n\t\t\t<th scope=\"row\">\u0427\u0438\u0441\u043b\u043e \u0432\u044b\u043f\u0430\u0432\u0448\u0438\u0445 \u043e\u0447\u043a\u043e\u0432<\/th>\n\t\t\t<th scope=\"col\">\u0414\u0415 \u0434\u043b\u044f \u0412\u0430\u0441<\/th>\n\t\t\t<th scope=\"col\">\u0414\u0415 \u0434\u043b\u044f \u0431\u043b\u0430\u0433\u043e\u0442\u0432\u043e\u0440\u0438\u0442\u0435\u043b\u044c\u043d\u043e\u0433\u043e \u0444\u043e\u043d\u0434\u0430 Azarume<\/th>\n\t\t<\/tr>\n\t<\/thead>\n\t<tbody>\n\t\t<tr>\n\t\t\t<th scope=\"row\">1<\/th>\n\t\t\t<td>10<\/td>\n\t\t\t<td>40<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">2<\/th>\n\t\t\t<td>20<\/td>\n\t\t\t<td>30<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">3<\/th>\n\t\t\t<td>30<\/td>\n\t\t\t<td>20<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">4<\/th>\n\t\t\t<td>40<\/td>\n\t\t\t<td>10<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">5<\/th>\n\t\t\t<td>50<\/td>\n\t\t\t<td>0<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">6<\/th>\n\t\t\t<td>0<\/td>\n\t\t\t<td>50<\/td>\n\t\t<\/tr>\n\t<\/tbody>\n<\/table>\n<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n<\/div>\n<\/div>\n<\/div>\n<\/div>\n<\/div>\n"},"PL":{"QuestionText":"<div style=\"text-align: center;\">\n<div style=\"text-align: center;\">B\u0119dziesz musia\u0142 rzuci\u0107 kostk\u0105 dwa razy. Tw\u00f3j pierwszy rzut decyduje o tym, ile otrzymasz, a drugi rzut s\u0142u\u017cy jedynie upewnieniu si\u0119, \u017ce kostka dzia\u0142a prawid\u0142owo. Mo\u017cesz rzuci\u0107 kostk\u0105 wi\u0119cej ni\u017c dwa razy. Jednak liczy si\u0119 tylko pierwszy rzut.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">Maksymalna wyp\u0142ata, jak\u0105 mo\u017cesz otrzyma\u0107, to 50 jednostek monetarnych (MU), a minimalna 0. Dok\u0142adn\u0105 wyp\u0142at\u0119 mo\u017cesz zobaczy\u0107 w poni\u017cszej tabeli.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">W tabeli widnieje r\u00f3wnie\u017c informacja, \u017ce \u200b\u200bniezarobione przez Ciebie pieni\u0105dze (50 MU minus MU dla Ciebie) zostan\u0105 przes\u0142ane do organizacji Lekarze bez Granic jako darowizna na finansowanie ich projekt\u00f3w maj\u0105cych na celu walk\u0119 z chorobami endemicznymi w Polsce. Na koniec sesji suma zebrana od wszystkich uczestnik\u00f3w zostanie przes\u0142ana przelewem.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">Tabela pozostanie na ekranie, dop\u00f3ki nie wpiszesz wyniku rzutu. Je\u015bli masz jakie\u015b pytania, podnie\u015b r\u0119k\u0119. Je\u015bli jeste\u015b gotowy, przejd\u017a do nast\u0119pnej strony.<\/div>\n\n<table align=\"center\" border=\"1\" cellpadding=\"1\" cellspacing=\"1\" style=\"width: 250px;\">\n\t<thead>\n\t\t<tr>\n\t\t\t<th scope=\"row\">Wyrzucony numer<\/th>\n\t\t\t<th scope=\"col\">MU dla Ciebie<\/th>\n\t\t\t<th scope=\"col\">MU dla Lekarzy bez Granic<\/th>\n\t\t<\/tr>\n\t<\/thead>\n\t<tbody>\n\t\t<tr>\n\t\t\t<th scope=\"row\">1<\/th>\n\t\t\t<td>10<\/td>\n\t\t\t<td>40<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">2<\/th>\n\t\t\t<td>20<\/td>\n\t\t\t<td>30<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">3<\/th>\n\t\t\t<td>30<\/td>\n\t\t\t<td>20<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">4<\/th>\n\t\t\t<td>40<\/td>\n\t\t\t<td>10<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">5<\/th>\n\t\t\t<td>50<\/td>\n\t\t\t<td>0<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">6<\/th>\n\t\t\t<td>0<\/td>\n\t\t\t<td>50<\/td>\n\t\t<\/tr>\n\t<\/tbody>\n<\/table>\n<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n"},"PT":{"QuestionText":"<div style=\"text-align: center;\">\n<div style=\"text-align: center;\">Ter\u00e1 que lan\u00e7ar um dado duas vezes. O seu primeiro lan\u00e7amento determina quanto recebe, e o segundo lan\u00e7amento serve apenas para garantir que o dado est\u00e1 a funcionar corretamente. Na verdade, pode lan\u00e7ar o dado mais do que duas vezes. No entanto, apenas o primeiro lan\u00e7amento conta.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">O pagamento m\u00e1ximo que pode receber \u00e9 50 Unidades Monet\u00e1rias (UMs) e o m\u00ednimo 0. Pode ver o pagamento exato na tabela seguinte.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">A tabela tamb\u00e9m descreve que o dinheiro n\u00e3o ganho por si (50 UMs menos as UMs para si) ser\u00e1 enviado para a organiza\u00e7\u00e3o M\u00e9dicos Sem Fronteiras, como uma doa\u00e7\u00e3o para financiar projetos no combate a doen\u00e7as end\u00eamicas em Portugal. No final da sess\u00e3o, a soma do valor arrecadado por todos os participantes ser\u00e1 enviado por transfer\u00eancia banc\u00e1ria.<\/div>\n\n<div style=\"text-align: center;\">\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">A tabela permanecer\u00e1 no ecr\u00e3 at\u00e9 que insira o seu lan\u00e7amento. Se tiver alguma d\u00favida, por favor levante a m\u00e3o. Se est\u00e1 preparado, continue para a p\u00e1gina seguinte.\u00a0<\/div>\n<\/div>\n\u00a0\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<table align=\"center\" border=\"1\" cellpacing=\"1\" cellpadding=\"1\" style=\"width: 250px;\">\n\t<thead>\n\t\t<tr>\n\t\t\t<th scope=\"row\">N\u00famero lan\u00e7ado<\/th>\n\t\t\t<th scope=\"col\">UMs para si<\/th>\n\t\t\t<th scope=\"col\">UMs para os M\u00e9dicos Sem Fronteiras<\/th>\n\t\t<\/tr>\n\t<\/thead>\n\t<tbody>\n\t\t<tr>\n\t\t\t<th escopo=\"linha\">1<\/th>\n\t\t\t<td>10<\/td>\n\t\t\t<td>40<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th escopo=\"linha\">2<\/th>\n\t\t\t<td>20<\/td>\n\t\t\t<td>30<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th escopo=\"linha\">3<\/th>\n\t\t\t<td>30<\/td>\n\t\t\t<td>20<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th escopo=\"linha\">4<\/th>\n\t\t\t<td>40<\/td>\n\t\t\t<td>10<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th escopo=\"linha\">5<\/th>\n\t\t\t<td>50<\/td>\n\t\t\t<td>0<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th escopo=\"linha\">6<\/th>\n\t\t\t<td>0<\/td>\n\t\t\t<td>50<\/td>\n\t\t<\/tr>\n\t<\/tbody>\n<\/table>\n<\/div>\n"},"RU":{"QuestionText":"<div style=\"text-align: center;\">\n<div style=\"text-align: center;\">\u00a0\n<div style=\"text-align: center;\">\n<div style=\"text-align: center;\">\u00a0\n<div style=\"text-align: center;\">\n<div style=\"text-align: center;\">\n<div style=\"text-align: center;\">\u0412\u0430\u043c \u043d\u0430\u0434\u043e \u0431\u0443\u0434\u0435\u0442 \u0431\u0440\u043e\u0441\u0438\u0442\u044c \u0438\u0433\u0440\u0430\u043b\u044c\u043d\u0443\u044e \u043a\u043e\u0441\u0442\u044c \u0434\u0432\u0430\u0436\u0434\u044b. \u0412\u0430\u0448 \u043f\u0435\u0440\u0432\u044b\u0439 \u0431\u0440\u043e\u0441\u043e\u043a \u043e\u043f\u0440\u0435\u0434\u0435\u043b\u044f\u0435\u0442, \u0441\u043a\u043e\u043b\u044c\u043a\u043e \u0412\u044b \u043f\u043e\u043b\u0443\u0447\u0438\u0442\u0435, \u0430 \u0432\u0442\u043e\u0440\u043e\u0439 \u0431\u0440\u043e\u0441\u043e\u043a \u0441\u043b\u0443\u0436\u0438\u0442 \u0442\u043e\u043b\u044c\u043a\u043e \u0434\u043b\u044f \u0442\u043e\u0433\u043e, \u0447\u0442\u043e\u0431\u044b \u0443\u0431\u0435\u0434\u0438\u0442\u044c\u0441\u044f, \u0447\u0442\u043e \u043a\u043e\u0441\u0442\u044c \u0440\u0430\u0431\u043e\u0442\u0430\u0435\u0442 \u043f\u0440\u0430\u0432\u0438\u043b\u044c\u043d\u043e. \u0424\u0430\u043a\u0442\u0438\u0447\u0435\u0441\u043a\u0438, \u0412\u044b \u043c\u043e\u0436\u0435\u0442\u0435 \u0431\u0440\u043e\u0441\u0438\u0442\u044c \u043a\u043e\u0441\u0442\u044c \u0438 \u0431\u043e\u043b\u0435\u0435 \u0434\u0432\u0443\u0445 \u0440\u0430\u0437. \u041e\u0434\u043d\u0430\u043a\u043e \u0437\u0430\u0441\u0447\u0438\u0442\u044b\u0432\u0430\u0435\u0442\u0441\u044f \u0442\u043e\u043b\u044c\u043a\u043e \u043f\u0435\u0440\u0432\u044b\u0439 \u0431\u0440\u043e\u0441\u043e\u043a.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">\u041c\u0430\u043a\u0441\u0438\u043c\u0430\u043b\u044c\u043d\u044b\u0439 \u0432\u044b\u0438\u0433\u0440\u044b\u0448, \u043a\u043e\u0442\u043e\u0440\u044b\u0439 \u0412\u044b \u043c\u043e\u0436\u0435\u0442\u0435 \u043f\u043e\u043b\u0443\u0447\u0438\u0442\u044c, \u0441\u043e\u0441\u0442\u0430\u0432\u043b\u044f\u0435\u0442 50 \u0434\u0435\u043d\u0435\u0436\u043d\u044b\u0445 \u0435\u0434\u0438\u043d\u0438\u0446 (\u0414\u0415), \u0430 \u043c\u0438\u043d\u0438\u043c\u0430\u043b\u044c\u043d\u044b\u0439 \u2014 0. \u0422\u043e\u0447\u043d\u044b\u0439 \u0432\u044b\u0438\u0433\u0440\u044b\u0448 \u0412\u044b \u043c\u043e\u0436\u0435\u0442\u0435 \u0443\u0432\u0438\u0434\u0435\u0442\u044c \u0438\u0437 \u0441\u043b\u0435\u0434\u0443\u044e\u0449\u0435\u0439 \u0442\u0430\u0431\u043b\u0438\u0446\u044b.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n<\/div>\n\u0412 \u0442\u0430\u0431\u043b\u0438\u0446\u0435 \u0442\u0430\u043a\u0436\u0435 \u0443\u043a\u0430\u0437\u0430\u043d\u043e, \u0447\u0442\u043e \u0442\u043e \u0447\u0442\u043e \u0412\u044b \u043d\u0435 \u0437\u0430\u0440\u0430\u0431\u043e\u0442\u0430\u0435\u0442\u0435 (50 \u0414\u0415 \u043c\u0438\u043d\u0443\u0441 \u0414\u0415 \u0434\u043b\u044f \u0412\u0430\u0441) \u0431\u0443\u0434\u0443\u0442 \u043e\u0442\u043f\u0440\u0430\u0432\u043b\u0435\u043d\u044b \u0432 \u043c\u0435\u0434\u0443\u043d\u0430\u0440\u043e\u0434\u043d\u0443\u044e \u0431\u043b\u0430\u0433\u043e\u0442\u0432\u043e\u0440\u0438\u0442\u0435\u043b\u044c\u043d\u0443\u044e \u043e\u0440\u0433\u0430\u043d\u0438\u0437\u0430\u0446\u0438\u044e \"\u0412\u0440\u0430\u0447\u0438 \u0431\u0435\u0437 \u0433\u0440\u0430\u043d\u0438\u0446\" (https:\/\/www.msf.org) \u0434\u043b\u044f \u0444\u0438\u043d\u0430\u043d\u0441\u0438\u0440\u043e\u0432\u0430\u043d\u0438\u044f \u0438\u0445 \u0433\u043b\u043e\u0431\u0430\u043b\u044c\u043d\u044b\u0445 \u043f\u0440\u043e\u0435\u043a\u0442\u043e\u0432. \u041f\u043e \u043e\u043a\u043e\u043d\u0447\u0430\u043d\u0438\u0438 \u0441\u0435\u0441\u0441\u0438\u0438 \u0441\u0443\u043c\u043c\u0430 \u0434\u0435\u043d\u0435\u0433, \u0441\u043e\u0431\u0440\u0430\u043d\u043d\u0430\u044f \u043e\u0442 \u0432\u0441\u0435\u0445 \u0443\u0447\u0430\u0441\u0442\u043d\u0438\u043a\u043e\u0432, \u0431\u0443\u0434\u0435\u0442 \u043e\u0442\u043f\u0440\u0430\u0432\u043b\u0435\u043d\u0430 \u200b\u200b\u043f\u0440\u044f\u043c\u044b\u043c \u043f\u0435\u0440\u0435\u0432\u043e\u0434\u043e\u043c \u0447\u0435\u0440\u0435\u0437 \u0441\u0430\u0439\u0442 <a data-saferedirecturl=\"https:\/\/www.google.com\/url?q=https:\/\/www.msf.org\/donate&source=gmail&ust=1710950721769000&usg=AOvVaw32NNbyVX1tuEHsWq90y0Cq\" href=\"https:\/\/www.msf.org\/donate\" target=\"_blank\">https:\/\/www.msf.org\/donate<\/a>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">\u0422\u0430\u0431\u043b\u0438\u0446\u0430 \u0431\u0443\u0434\u0435\u0442 \u043e\u0441\u0442\u0430\u0432\u0430\u0442\u044c\u0441\u044f \u043d\u0430 \u044d\u043a\u0440\u0430\u043d\u0435 \u0434\u043e \u0442\u0435\u0445 \u043f\u043e\u0440, \u043f\u043e\u043a\u0430 \u0412\u044b \u043d\u0435 \u0432\u0432\u0435\u0434\u0435\u0442\u0435 \u0440\u0435\u0437\u0443\u043b\u044c\u0442\u0430\u0442 \u0412\u0430\u0448\u0435\u0433\u043e \u0431\u0440\u043e\u0441\u043a\u0430. \u0415\u0441\u043b\u0438 \u0443 \u0412\u0430\u0441 \u0435\u0441\u0442\u044c \u0432\u043e\u043f\u0440\u043e\u0441\u044b, \u043f\u043e\u0436\u0430\u043b\u0443\u0439\u0441\u0442\u0430, \u043f\u043e\u0434\u043d\u0438\u043c\u0438\u0442\u0435 \u0440\u0443\u043a\u0443. \u0415\u0441\u043b\u0438 \u0412\u044b \u0433\u043e\u0442\u043e\u0432\u044b, \u043f\u0435\u0440\u0435\u0439\u0434\u0438\u0442\u0435 \u043d\u0430 \u0441\u043b\u0435\u0434\u0443\u044e\u0449\u0443\u044e \u0441\u0442\u0440\u0430\u043d\u0438\u0446\u0443.<\/div>\n\n<table align=\"center\" border=\"1\" cellpadding=\"1\" cellspacing=\"1\" style=\"width:250px;\">\n\t<thead>\n\t\t<tr>\n\t\t\t<th scope=\"row\">\u0427\u0438\u0441\u043b\u043e \u0432\u044b\u043f\u0430\u0432\u0448\u0438\u0445 \u043e\u0447\u043a\u043e\u0432<\/th>\n\t\t\t<th scope=\"col\">\u0414\u0415 \u0434\u043b\u044f \u0412\u0430\u0441<\/th>\n\t\t\t<th scope=\"col\">\u0414\u0415 \u0434\u043b\u044f \u0431\u043b\u0430\u0433\u043e\u0442\u0432\u043e\u0440\u0438\u0442\u0435\u043b\u044c\u043d\u043e\u0439 \u043e\u0440\u0433\u0430\u043d\u0438\u0437\u0430\u0446\u0438\u0438 \"\u0412\u0440\u0430\u0447\u0438 \u0431\u0435\u0437 \u0433\u0440\u0430\u043d\u0438\u0446\"<\/th>\n\t\t<\/tr>\n\t<\/thead>\n\t<tbody>\n\t\t<tr>\n\t\t\t<th scope=\"row\">1<\/th>\n\t\t\t<td>10<\/td>\n\t\t\t<td>40<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">2<\/th>\n\t\t\t<td>20<\/td>\n\t\t\t<td>30<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">3<\/th>\n\t\t\t<td>30<\/td>\n\t\t\t<td>20<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">4<\/th>\n\t\t\t<td>40<\/td>\n\t\t\t<td>10<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">5<\/th>\n\t\t\t<td>50<\/td>\n\t\t\t<td>0<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">6<\/th>\n\t\t\t<td>0<\/td>\n\t\t\t<td>50<\/td>\n\t\t<\/tr>\n\t<\/tbody>\n<\/table>\n<\/div>\n<\/div>\n<\/div>\n<\/div>\n<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n"},"TR":{"QuestionText":"<div style=\"text-align: center;\">\n<div style=\"text-align: center;\">\n<div style=\"text-align: center;\">\n<div style=\"text-align: center;\">\n<div style=\"text-align: center;\">\n<div style=\"text-align: center;\">\n<div style=\"text-align: center;\">\n<div style=\"text-align: center;\">\n<div style=\"text-align: center;\">Bu b\u00f6l\u00fcmde, size verilen zar\u0131 iki kez atman\u0131z istenmektedir. Elde edece\u011finiz kazanc\u0131 zar\u0131 ilk at\u0131\u015f\u0131n\u0131z\u0131n sonucu belirleyecektir. \u0130kinci at\u0131\u015f ise sadece zar\u0131n d\u00fczg\u00fcn \u00e7al\u0131\u015ft\u0131\u011f\u0131ndan emin olman\u0131z i\u00e7indir. Dilerseniz zar\u0131 iki kereden fazla da atabilirsiniz. Ancak, kazanc\u0131n\u0131z\u0131 sadece ilk at\u0131\u015f\u0131n\u0131z\u0131n sonucu belirleyecektir.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">Bu b\u00f6l\u00fcmde elde edebilece\u011finiz en y\u00fcksek kazan\u00e7 50 Deney Para Birimi (DPB), en d\u00fc\u015f\u00fck kazan\u00e7 0 DPB'dir. A\u015fa\u011f\u0131daki tabloda ataca\u011f\u0131n\u0131z ilk zar\u0131n sonucuna g\u00f6re kazanaca\u011f\u0131n\u0131z DPB'ler yer almaktad\u0131r.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n<\/div>\n\n<div style=\"text-align: center;\">Olas\u0131 en y\u00fcksek kazan\u00e7 olan 50 DPB'den ataca\u011f\u0131n\u0131z ilk zar\u0131n sonucuna g\u00f6re kazanaca\u011f\u0131n\u0131z DPB tutar\u0131 \u00e7\u0131kar\u0131lacak, bu tutar L\u00d6SEV'e, insanlara yard\u0131m ettikleri T\u00fcrkiye'deki \u00e7e\u015fitli \u00e7al\u0131\u015fmalar\u0131na destek olmak amac\u0131yla ba\u011f\u0131\u015flanacakt\u0131r.<br \/>\n\u00a0<\/div>\n<\/div>\n<\/div>\n<\/div>\n\n<div style=\"text-align: center;\">Tabloda sizin DPB kazanc\u0131n\u0131z\u0131n yan\u0131 s\u0131ra L\u00d6SEV'e g\u00f6nderilecek tutarlar (50 DPB'den sizin kazanc\u0131n\u0131z \u00e7\u0131kar\u0131ld\u0131\u011f\u0131nda kalan tutarlar) yer almaktad\u0131r. Oturumun sonunda, L\u00d6SEV'e ba\u011f\u0131\u015flanmas\u0131 i\u00e7in t\u00fcm kat\u0131l\u0131mc\u0131lardan toplanan paran\u0131n tamam\u0131 banka transferi yoluyla g\u00f6nderilecektir.<br \/>\n(IBAN:\u00a0IBAN TR 7900 0100 2211 0345 8518 5047)<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">Att\u0131\u011f\u0131n\u0131z ilk zar\u0131n sonucunu girene kadar tablo ekranda kalacakt\u0131r. Herhangi bir sorunuz varsa l\u00fctfen elinizi kald\u0131r\u0131n. Haz\u0131r oldu\u011funuzda l\u00fctfen bir sonraki sayfaya ge\u00e7in.<\/div>\n<\/div>\n<\/div>\n<\/div>\n\n<div style=\"text-align: center;\"><br \/>\n\u00a0<\/div>\n\n<table align=\"center\" border=\"1\" cellpadding=\"1\" cellspacing=\"1\" style=\"width:250px;\">\n\t<thead>\n\t\t<tr>\n\t\t\t<th scope=\"row\">Zar\u0131n Sonucu<\/th>\n\t\t\t<th scope=\"col\">DPB kazanc\u0131n\u0131z<\/th>\n\t\t\t<th scope=\"col\">L\u00d6SEV'in DPB kazanc\u0131<\/th>\n\t\t<\/tr>\n\t<\/thead>\n\t<tbody>\n\t\t<tr>\n\t\t\t<th scope=\"row\">1<\/th>\n\t\t\t<td>10<\/td>\n\t\t\t<td>40<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">2<\/th>\n\t\t\t<td>20<\/td>\n\t\t\t<td>30<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">3<\/th>\n\t\t\t<td>30<\/td>\n\t\t\t<td>20<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">4<\/th>\n\t\t\t<td>40<\/td>\n\t\t\t<td>10<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">5<\/th>\n\t\t\t<td>50<\/td>\n\t\t\t<td>0<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">6<\/th>\n\t\t\t<td>0<\/td>\n\t\t\t<td>50<\/td>\n\t\t<\/tr>\n\t<\/tbody>\n<\/table>\n<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n"},"ZH-HK":{"QuestionText":"<div style=\"text-align: center;\">\n<div style=\"text-align: center;\">\n<div style=\"text-align: center;\">\n<p>\u60a8\u5fc5\u9808\u64f2\u5169\u6b21\u9ab0\u5b50\u3002\u7b2c\u4e00\u6b21\u64f2\u9ab0\u5b50\u6703\u6c7a\u5b9a\u4f60\u7372\u5f97\u7684MU\u6578\u91cf\uff0c\u7b2c\u4e8c\u6b21\u64f2\u9ab0\u5b50\u53ea\u662f\u70ba\u4e86\u78ba\u8a8d\u9ab0\u5b50\u6b63\u5e38\u904b\u4f5c\u3002\u4e8b\u5be6\u4e0a\uff0c\u60a8\u53ef\u4ee5\u64f2\u9ab0\u5b50\u5169\u6b21\u4ee5\u4e0a\u3002\u4f46\u662f\uff0c\u53ea\u6709\u7b2c\u4e00\u6b21\u64f2\u9ab0\u5b50\u7b97\u6578\u3002<\/p>\n<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">\n<p>\u60a8\u53ef\u4ee5\u7372\u5f97\u7684MU\u6578\u91cf\u6700\u591a\u70ba 50\uff0c\u6700\u5c11\u70ba 0 \u3002\u4e0b\u65b9\u7684\u8868\u683c\u986f\u793a\u8457\u78ba\u5207\u5c0d\u61c9\u7684MU\u6578\u91cf\u3002<\/p>\n<\/div>\n<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">\u8868\u683c\u4e5f\u6307\u51fa\uff0c\u60a8\u5c11\u7372\u5f97\u7684MU\uff0850 MU\u6e1b\u53bb\u60a8\u7372\u5f97\u7684MU\uff09\n<p>\u6703\u6350\u8d08\u7d66\u7121\u570b\u754c\u91ab\u751f\u7d44\u7e54 (MSF)\uff0c\u4ee5\u8cc7\u52a9\u4ed6\u5011\u5728\u5361\u9054\u6297\u64ca\u6d41\u884c\u75c5\u7684\u8a08\u756b\u3002\u4ee5\u8cc7\u52a9\u5176\u5728\u9999\u6e2f\u63d0\u4f9b\u91ab\u7642\u63f4<\/p>\n\n<p>\u52a9\u3002\u5be6\u9a57\u7d50\u675f\u5f8c\uff0c\u4f86\u81ea\u6240\u6709\u53d7\u8a66\u8005\u5011\u7684\u6350\u8d08\u5c07\u5168\u984d\u76f4\u63a5\u8f49\u5e33\u7d66\u7121\u570b\u754c\u91ab\u751f\u7d44\u7e54\u3002<\/p>\n<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">\u8868\u683c\u5c07\u4fdd\u7559\u5728\u87a2\u5e55\u4e0a\uff0c\u76f4\u5230\u60a8\u8f38\u5165\u64f2\u51fa\u7684\u6570\u5b57\u3002\u5982\u679c\u60a8\u6709\u4efb\u4f55\u7591\u554f\uff0c\u8acb\u8209\u624b\u3002\u5982\u679c\u60a8\u6e96\u5099\u597d\u4e86\uff0c\u8acb\u7e7c\u7e8c\u95b1\u8b80\u4e0b\u4e00\u9801\u3002<\/div>\n\n<table align=\"center\" border=\"1\" cellpadding=\"1\" cellspacing=\"1\" style=\"width: 250px;\">\n\t<thead>\n\t\t<tr>\n\t\t\t<th scope=\"row\">\n\t\t\t<p><b>\u64f2\u51fa\u7684\u6578\u5b57<\/b><\/p>\n\t\t\t<\/th>\n\t\t\t<th scope=\"col\">\n\t\t\t<p><strong>\u60a8\u7372\u5f97\u7684<\/strong><\/p>\n\t\t\t<strong>MU<\/strong><\/th>\n\t\t\t<th scope=\"col\">\n\t\t\t<p><b>MSF<\/b><\/p>\n\n\t\t\t<p><strong>\u7372\u5f97\u7684<\/strong><\/p>\n\t\t\t<strong>MU<\/strong><\/th>\n\t\t<\/tr>\n\t<\/thead>\n\t<tbody>\n\t\t<tr>\n\t\t\t<th scope=\"row\">1<\/th>\n\t\t\t<td>10<\/td>\n\t\t\t<td>40<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">2<\/th>\n\t\t\t<td>20<\/td>\n\t\t\t<td>30<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">3<\/th>\n\t\t\t<td>30<\/td>\n\t\t\t<td>20<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">4<\/th>\n\t\t\t<td>40<\/td>\n\t\t\t<td>10<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">5<\/th>\n\t\t\t<td>50<\/td>\n\t\t\t<td>0<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">6<\/th>\n\t\t\t<td>0<\/td>\n\t\t\t<td>50<\/td>\n\t\t<\/tr>\n\t<\/tbody>\n<\/table>\n<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n"},"ZH-S":{"QuestionText":"<div style=\"text-align: center;\">\n<div style=\"text-align: center;\">\u60a8\u9700\u8981\u63b7\u4e24\u6b21\u9ab0\u5b50\u3002\u7b2c\u4e00\u6b21\u63b7\u9ab0\u5b50\u51b3\u5b9a\u60a8\u80fd\u5f97\u5230\u591a\u5c11\u4e2a MU\uff0c\u7b2c\u4e8c\u6b21\u63b7\u9ab0\u5b50\u53ea\u662f\u4e3a\u4e86\u786e\u4fdd\u9ab0\u5b50\u662f\u6ca1\u95ee\u9898\u7684\u3002\u4e8b\u5b9e\u4e0a\uff0c\u60a8\u53ef\u4ee5\u63b7\u9ab0\u5b50\u4e24\u6b21\u4ee5\u4e0a\u3002\u4f46\u662f\uff0c\u53ea\u6709\u7b2c\u4e00\u6b21\u63b7\u9ab0\u5b50\u7684\u7ed3\u679c\u624d\u7b97\u6570\u3002<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">\u60a8\u80fd\u5f97\u5230\u7684\u6700\u5927\u6536\u76ca\u662f 50\u00a0\u4e2a\u8d27\u5e01\u5355\u4f4d (MU)\uff0c\u6700\u5c0f\u6536\u76ca\u662f 0 \u4e2a\u3002\u60a8\u53ef\u4ee5\u4ece\u4e0b\u8868\u4e2d\u770b\u5230\u786e\u5207\u7684\u6536\u76ca\u3002<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">\u8be5\u8868\u8fd8\u8bf4\u660e\uff0c\u60a8\u672a\u8d5a\u5230\u7684\u8d27\u5e01\u5355\u4f4d\uff0850 MU \u51cf\u53bb\u60a8\u7684 MU\uff09\u5c06\u4f5c\u4e3a\u6350\u6b3e\u6350\u8d60\u7ed9\u65e0\u56fd\u754c\u533b\u751f\u7ec4\u7ec7\uff0c\u4ee5\u8d44\u52a9\u4ed6\u4eec\u5728\u4e2d\u56fd\u6297\u51fb\u5730\u65b9\u75c5\u7684\u9879\u76ee\u3002\u4f1a\u8bdd\u7ed3\u675f\u65f6\uff0c\u6240\u6709\u53c2\u4e0e\u8005\u7b79\u96c6\u7684\u8d44\u91d1\u5c06\u901a\u8fc7\u76f4\u63a5\u8f6c\u8d26\u7684\u65b9\u5f0f\u6350\u8d60\uff08\u5e10\u53f7\uff1a025-328-24-28203-3\uff09\u3002<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">\u8868\u683c\u5c06\u4fdd\u7559\u5728\u5c4f\u5e55\u4e0a\uff0c\u76f4\u5230\u60a8\u8f93\u5165\u60a8\u7684\u63b7\u9ab0\u5b50\u7ed3\u679c\u3002\u5982\u679c\u60a8\u6709\u4efb\u4f55\u7591\u95ee\uff0c\u8bf7\u4e3e\u624b\u3002\u5982\u679c\u60a8\u51c6\u5907\u597d\u4e86\uff0c\u8bf7\u7ee7\u7eed\u4e0b\u4e00\u9875\u3002<\/div>\n\u00a0\n\n<table align=\"center\" border=\"1\" cellpadding=\"1\" cellspacing=\"1\" style=\"width: 250px;\">\n\t<thead>\n\t\t<tr>\n\t\t\t<th scope=\"row\">\u629b\u51fa\u7684\u6570\u5b57<\/th>\n\t\t\t<th scope=\"col\">\u60a8\u5c06\u83b7\u5f97\u7684MU<\/th>\n\t\t\t<th scope=\"col\">\u65e0\u56fd\u754c\u533b\u751f\u5c06<br \/>\n\t\t\t\u83b7\u5f97\u7684 MU<\/th>\n\t\t<\/tr>\n\t<\/thead>\n\t<tbody>\n\t\t<tr>\n\t\t\t<th scope=\"row\">1<\/th>\n\t\t\t<td>10<\/td>\n\t\t\t<td>40<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">2<\/th>\n\t\t\t<td>20<\/td>\n\t\t\t<td>30<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">3<\/th>\n\t\t\t<td>30<\/td>\n\t\t\t<td>20<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">4<\/th>\n\t\t\t<td>40<\/td>\n\t\t\t<td>10<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">5<\/th>\n\t\t\t<td>50<\/td>\n\t\t\t<td>0<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">6<\/th>\n\t\t\t<td>0<\/td>\n\t\t\t<td>50<\/td>\n\t\t<\/tr>\n\t<\/tbody>\n<\/table>\n<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n"},"ZH-T":{"QuestionText":"<div style=\"text-align: center;\">\n<div style=\"text-align: center;\">\u60a8\u5fc5\u9808\u64f2\u5169\u6b21\u9ab0\u5b50\u3002\u7b2c\u4e00\u6b21\u64f2\u9ab0\u5b50\u6703\u6c7a\u5b9a\u60a8\u7372\u5f97\u7684\u6cd5\u5e63\u6578\u91cf\uff0c\u7b2c\u4e8c\u6b21\u64f2\u9ab0\u5b50\u53ea\u662f\u70ba\u4e86\u78ba\u8a8d\u9ab0\u5b50\u7684\u516c\u6b63\u6027\u3002\u4e8b\u5be6\u4e0a\uff0c\u60a8\u53ef\u4ee5\u64f2\u9ab0\u5b50\u5169\u6b21\u4ee5\u4e0a\u3002\u4f46\u662f\uff0c\u53ea\u6709\u7b2c\u4e00\u6b21\u64f2\u9ab0\u5b50\u7b97\u6578\u3002\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">\u60a8\u53ef\u4ee5\u7372\u5f97\u7684\u6cd5\u5e63\u6578\u91cf\u6700\u591a\u70ba 50\uff0c\u6700\u5c11\u70ba 0 \u3002\u4e0b\u65b9\u7684\u8868\u683c\u986f\u793a\u8457\u78ba\u5207\u7684\u6cd5\u5e63\u6578\u91cf\u5c0d\u61c9\u3002\n<div style=\"text-align: center;\">\u8868\u683c\u4e5f\u6307\u51fa\uff0c\u60a8\u5c11\u7372\u5f97\u7684\u91d1\u984d\uff0850 \u6cd5\u5e63\u6e1b\u53bb\u60a8\u7372\u5f97\u7684\u6cd5\u5e63\uff09\u6703\u5168\u6578\u6350\u7d66\u7121\u570b\u754c\u91ab\u751f (MSF) \u5728\u53f0\u7063\uff0c\u4ee5\u8cc7\u52a9\u5176\u63d0\u4f9b\u4eba\u9053\u91ab\u7642\u63f4\u52a9\u3002\u9019\u4e9b\u4f86\u81ea\u53d7\u8a66\u8005\u5011\u7684\u7e3d\u91d1\u984d\u5c07\u65bc\u5be6\u9a57\u7d50\u675f \u5f8c\u532f\u6b3e\u81f3\u300c\u8ca1\u5718\u6cd5\u4eba\u7121\u570b\u754c\u91ab\u751f\u57fa\u91d1\u6703\u300d\u3002<\/div>\n<\/div>\n\n<div style=\"text-align: center;\">\n<div style=\"text-align: center;\">\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">\n<div style=\"text-align: center;\">\u8868\u683c\u6703\u505c\u7559\u5728\u87a2\u5e55\u4e0a\uff0c\u76f4\u5230\u60a8\u8f38\u5165\u64f2\u51fa\u7684\u6578\u5b50\u3002\u5982\u679c\u60a8\u6709\u4efb\u4f55\u7591\u554f\uff0c\u8acb\u8209\u624b\u3002\u5982\u679c\u60a8\u6e96\u5099\u597d\u4e86\uff0c\u8acb\u7e7c\u7e8c\u95b1\u8b80\u4e0b\u4e00\u9801\u3002<\/div>\n<\/div>\n<\/div>\n<\/div>\n\n<div style=\"text-align: center;\">\n<div style=\"text-align: center;\">\n<div style=\"text-align: center;\">\n<table align=\"center\" border=\"1\" cellpadding=\"1\" cellspacing=\"1\">\n\t<thead>\n\t\t<tr>\n\t\t\t<th scope=\"row\">\u00a0\u64f2\u51fa\u7684\u6578\u5b57\u00a0<\/th>\n\t\t\t<th scope=\"col\">\u00a0\u60a8\u7372\u5f97\u7684\u6cd5\u5e63\u00a0<\/th>\n\t\t\t<th scope=\"col\">\u00a0\u7121\u570b\u754c\u91ab\u751f\u6536\u5230\u7684\u6cd5\u5e63\u00a0<\/th>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">1<\/th>\n\t\t\t<td>10<\/td>\n\t\t\t<td>40<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">2<\/th>\n\t\t\t<td>20<\/td>\n\t\t\t<td>30<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">3<\/th>\n\t\t\t<td>30<\/td>\n\t\t\t<td>20<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">4<\/th>\n\t\t\t<td>40<\/td>\n\t\t\t<td>10<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">5<\/th>\n\t\t\t<td>50<\/td>\n\t\t\t<td>0<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">6<\/th>\n\t\t\t<td>0<\/td>\n\t\t\t<td>50<\/td>\n\t\t<\/tr>\n\t<\/thead>\n<\/table>\n<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n<\/div>\n<\/div>\n<\/div>\n<\/div>\n"}},"NextChoiceId":4,"NextAnswerId":1,"QuestionText_Unsafe":"<div style=\"text-align: center;\">\n<div style=\"text-align: center;\">You will have to throw a dice twice. Your first throw decides how much you receive, and the second throw only serves to make sure that the dice is working properly. In fact, you may throw the dice more than twice. However, only the first throw counts.<\/div>\n\n<div style=\"text-align: center;\">&nbsp;<\/div>\n\n<div style=\"text-align: center;\">The maximum payoff you can receive is 50 Monetary Units (MUs) and the minimum 0. You can see the exact payoff from the following table.<\/div>\n\n<div style=\"text-align: center;\">&nbsp;<\/div>\n\n<div style=\"text-align: center;\">The table also describes that the money not earned by you (50 MUs minus MUs for you)  will be sent to the Doctors Without Boarders (MWB), as a donation in order to finance their projects in fighting endemic diseases in Qatar. At the end of the session, the sum of money gathered from all participants will be sent via a direct transfer.<\/div>\n\n<div style=\"text-align: center;\">&nbsp;<\/div>\n\n<div style=\"text-align: center;\">The table will remain on the screen until you entered your throw. If you have any questions, please raise your hand. If you are ready, please continue to the next page.<\/div>\n&nbsp;\n\n<table align=\"center\" border=\"1\" cellpadding=\"1\" cellspacing=\"1\" style=\"width: 250px;\">\n\t<thead>\n\t\t<tr>\n\t\t\t<th scope=\"row\">Number thrown<\/th>\n\t\t\t<th scope=\"col\">MUs for you<\/th>\n\t\t\t<th scope=\"col\">MUs for MWB<\/th>\n\t\t<\/tr>\n\t<\/thead>\n\t<tbody>\n\t\t<tr>\n\t\t\t<th scope=\"row\">1<\/th>\n\t\t\t<td>10<\/td>\n\t\t\t<td>40<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">2<\/th>\n\t\t\t<td>20<\/td>\n\t\t\t<td>30<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">3<\/th>\n\t\t\t<td>30<\/td>\n\t\t\t<td>20<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">4<\/th>\n\t\t\t<td>40<\/td>\n\t\t\t<td>10<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">5<\/th>\n\t\t\t<td>50<\/td>\n\t\t\t<td>0<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">6<\/th>\n\t\t\t<td>0<\/td>\n\t\t\t<td>50<\/td>\n\t\t<\/tr>\n\t<\/tbody>\n<\/table>\n<\/div>\n\n<div style=\"text-align: center;\">&nbsp;<\/div>","DataExportTag":"T4: NGO_1","QuestionID":"QID33"}},{"SurveyID":"SV_b3mHBVkuioRMhng","Element":"SQ","PrimaryAttribute":"QID330","SecondaryAttribute":"Please select your language from the drop-down menu on the top right.","TertiaryAttribute":null,"Payload":{"QuestionText":"Please select your language from the drop-down menu on the top right.<br>","DefaultChoices":false,"DataExportTag":"language","QuestionID":"QID330","QuestionType":"DB","Selector":"TB","Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Please select your language from the drop-down menu on the top right.","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":{"AR":{"QuestionText":"\u0627\u0644\u0631\u062c\u0627\u0621\u00a0\u062a\u062d\u062f\u064a\u062f \u0627\u0644\u0644\u063a\u0629 \u0627\u0644\u062e\u0627\u0635\u0629 \u0628\u0643 \u0645\u0646 \u0627\u0644\u0642\u0627\u0626\u0645\u0629 \u0641\u064a \u0623\u0639\u0644\u0649 \u0627\u0644\u064a\u0645\u064a\u0646."},"CS":{"QuestionText":"Vyberte si, pros\u00edm, sv\u016fj jazyk z nab\u00eddky nad t\u00edmto textem.<br \/>\n\u00a0"},"DE":{"QuestionText":"Bitte w\u00e4hlen Sie Ihre Sprache aus dem Drop-down-Men\u00fc oben rechts aus."},"DE-AT":{"QuestionText":"Bitte w\u00e4hlen Sie Ihre Sprache aus dem Drop-down-Men\u00fc oben rechts aus.<br>"},"EL":{"QuestionText":"\u0395\u03c0\u03b9\u03bb\u03ad\u03be\u03c4\u03b5 \u03c4\u03b7 \u03c7\u03ce\u03c1\u03b1 \u03c3\u03b1\u03c2 \u03b1\u03c0\u03cc \u03c4\u03bf \u03c0\u03c4\u03c5\u03c3\u03c3\u03cc\u03bc\u03b5\u03bd\u03bf \u03bc\u03b5\u03bd\u03bf\u03cd \u03b5\u03c0\u03ac\u03bd\u03c9 \u03b4\u03b5\u03be\u03b9\u03ac.<br \/>\n\u00a0"},"EN-UK":{"QuestionText":"Please select your language from the drop-down menu on the top right."},"ES":{"QuestionText":"Seleccione su pa\u00eds en el men\u00fa desplegable en la parte superior derecha.<br \/>\n\u00a0"},"ES-AR":{"QuestionText":"Por favor, seleccione su idioma en el men\u00fa desplegable en la parte superior derecha."},"ES-ES":{"QuestionText":"Seleccione su idioma en el men\u00fa desplegable en la parte superior derecha.<br>"},"FR":{"QuestionText":"<span style=\"font-size:16px;\"><span style=\"font-family:Arial\"><span lang=\"FR\" style=\"color:#525252\">Veuillez s\u00e9lectionner votre pays dans le menu d\u00e9roulant en haut \u00e0 droite.<\/span><\/span><\/span>"},"FR-FR":{"QuestionText":"Veuillez s\u00e9lectionner votre langue dans le menu d\u00e9roulant en haut \u00e0 droite.<br>"},"HU":{"QuestionText":"K\u00e9rj\u00fck, v\u00e1lassza ki orsz\u00e1g\u00e1t a jobb fels\u0151 sarokban tal\u00e1lhat\u00f3 leg\u00f6rd\u00fcl\u0151 men\u00fcb\u0151l.<br>"},"IT":{"QuestionText":"Seleziona la tua lingua dal menu a discesa in alto a destra."},"JA":{"QuestionText":"\u53f3\u4e0a\u306e\u30c9\u30ed\u30c3\u30d7\u30c0\u30a6\u30f3\u30e1\u30cb\u30e5\u30fc\u304b\u3089\u8a00\u8a9e\u3092\u9078\u629e\u3057\u307e\u3059\u3002<br>"},"KO":{"QuestionText":"\uc624\ub978\ucabd \uc0c1\ub2e8\uc758 \ub4dc\ub86d\ub2e4\uc6b4 \uba54\ub274\uc5d0\uc11c \uc5b8\uc5b4\ub97c \uc120\ud0dd\ud558\uc138\uc694.<br>"},"KZ-RU":{"QuestionText":"\u041f\u043e\u0436\u0430\u043b\u0443\u0439\u0441\u0442\u0430, \u0432\u044b\u0431\u0435\u0440\u0438\u0442\u0435 \u0441\u0432\u043e\u044e \u0441\u0442\u0440\u0430\u043d\u0443 \u0432 \u0440\u0430\u0441\u043a\u0440\u044b\u0432\u0430\u044e\u0449\u0435\u043c\u0441\u044f \u043c\u0435\u043d\u044e \u0432 \u043f\u0440\u0430\u0432\u043e\u043c \u0432\u0435\u0440\u0445\u043d\u0435\u043c \u0443\u0433\u043b\u0443."},"PL":{"QuestionText":"Wybierz j\u0119zyk z menu rozwijanego w prawym g\u00f3rnym rogu.<br>"},"PT":{"QuestionText":"Por favor, selecione o seu idioma no menu suspenso no canto superior direito."},"RU":{"QuestionText":"\u041f\u043e\u0436\u0430\u043b\u0443\u0439\u0441\u0442\u0430, \u0432\u044b\u0431\u0435\u0440\u0438\u0442\u0435 \u0441\u0432\u043e\u044e \u0441\u0442\u0440\u0430\u043d\u0443 \u0432 \u0440\u0430\u0441\u043a\u0440\u044b\u0432\u0430\u044e\u0449\u0435\u043c\u0441\u044f \u043c\u0435\u043d\u044e \u0432 \u043f\u0440\u0430\u0432\u043e\u043c \u0432\u0435\u0440\u0445\u043d\u0435\u043c \u0443\u0433\u043b\u0443.<br>"},"TR":{"QuestionText":"L\u00fctfen sa\u011f \u00fcst taraftaki a\u00e7\u0131l\u0131r men\u00fcden kulland\u0131\u011f\u0131n\u0131z dili se\u00e7iniz."},"ZH-HK":{"QuestionText":"\u8acb\u5f9e\u53f3\u4e0a\u89d2\u7684\u4e0b\u62c9\u5f0f\u9078\u55ae\u9078\u64c7\u60a8\u7684\u8a9e\u8a00\u3002"},"ZH-S":{"QuestionText":"\u8bf7\u4ece\u53f3\u4e0a\u89d2\u7684\u4e0b\u62c9\u83dc\u5355\u4e2d\u9009\u62e9\u60a8\u7684\u8bed\u8a00\u3002<br>"},"ZH-T":{"QuestionText":"\u8acb\u5f9e\u53f3\u4e0a\u89d2\u7684\u4e0b\u62c9\u5f0f\u9078\u55ae\u9078\u64c7\u60a8\u7684\u8a9e\u8a00\u3002"},"DE-DE":{"QuestionText":"Bitte w\u00e4hlen Sie Ihre Sprache aus dem Drop-Down-Men\u00fc oben rechts aus.<br>"}},"NextChoiceId":4,"NextAnswerId":1,"DataVisibility":{"Private":false,"Hidden":false},"QuestionText_Unsafe":"Please select your language from the drop-down menu on the top right.<br>"}},{"SurveyID":"SV_b3mHBVkuioRMhng","Element":"SQ","PrimaryAttribute":"QID331","SecondaryAttribute":"Please add the code given to you","TertiaryAttribute":null,"Payload":{"QuestionText":"Please add the code given to you","DefaultChoices":false,"DataExportTag":"Q324","QuestionID":"QID331","QuestionType":"TE","Selector":"SL","Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Please add the code given to you","Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"SearchSource":{"AllowFreeResponse":"false"}}},{"SurveyID":"SV_b3mHBVkuioRMhng","Element":"SQ","PrimaryAttribute":"QID332","SecondaryAttribute":"Important: For each correct answer you earn 1 MU. Ready?","TertiaryAttribute":null,"Payload":{"QuestionText":"<div style=\"text-align: center;\"><strong>Important: For each correct answer you earn 1 MU.<\/strong><\/div><div style=\"text-align: center;\"><br><\/div><div style=\"text-align: center;\">Ready?<\/div>","DefaultChoices":false,"DataExportTag":"Mathpay2","QuestionID":"QID332","QuestionType":"DB","Selector":"TB","Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Important: For each correct answer you earn 1 MU. Ready?","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":{"ES":{"QuestionText":"<div style=\"text-align: center;\"><strong>Importante: Por cada respuesta correcta ganar\u00e1 1 UM.<\/strong><\/div>\n"}},"NextChoiceId":4,"NextAnswerId":1,"QuestionText_Unsafe":"Important: For each correct answer you earn 0.1 UM.","DataVisibility":{"Private":false,"Hidden":false}}},{"SurveyID":"SV_b3mHBVkuioRMhng","Element":"SQ","PrimaryAttribute":"QID333","SecondaryAttribute":"Ready?","TertiaryAttribute":null,"Payload":{"QuestionText":"<div style=\"text-align: center;\">Ready?<\/div>","DefaultChoices":false,"DataExportTag":"Q326","QuestionID":"QID333","QuestionType":"DB","Selector":"TB","Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Ready?","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":{"CS":{"QuestionText":"<div style=\"text-align: center;\">P\u0159ipraven(a)?<\/div>\n"},"DE":{"QuestionText":"<div style=\"text-align: center;\">Bereit?<\/div>"},"DE-AT":{"QuestionText":"<div style=\"text-align: center;\">Bereit?<\/div>"},"EL":{"QuestionText":"<div style=\"text-align: center;\">'\u0395\u03c4\u03bf\u03b9\u03bc\u03bf\u03b9?<\/div>\n"},"ES":{"QuestionText":"<div style=\"text-align: center;\">\u00bfPreparado?<\/div>\n"},"ES-AR":{"QuestionText":"<div style=\"text-align: center;\">\u00bfListo?<\/div>\n"},"ES-ES":{"QuestionText":"<div style=\"text-align: center;\">\u00bfListo?<\/div>"},"FR":{"QuestionText":"<div style=\"text-align: center;\">Pr\u00eat?<\/div>"},"FR-FR":{"QuestionText":"<div style=\"text-align: center;\">Pr\u00eat\u00a0?<\/div>"},"HU":{"QuestionText":"<div style=\"text-align: center;\">K\u00e9szen \u00e1ll?<\/div>\n"},"IT":{"QuestionText":"<div style=\"text-align: center;\">Pronto?<\/div>"},"JA":{"QuestionText":"<div style=\"text-align: center;\">\u6e96\u5099\u306f\u3044\u3044\u3067\u3059\u304b?<\/div>"},"KO":{"QuestionText":"<div style=\"text-align: center;\">\uc900\ube44\ub418\uc168\ub098\uc694?<\/div>"},"PL":{"QuestionText":"<div style=\"text-align: center;\">Gotowy?<\/div>"},"PT":{"QuestionText":"<div style=\"text-align: center;\">Preparado?<\/div>\n"},"RU":{"QuestionText":"<div style=\"text-align: center;\">\u0413\u043e\u0442\u043e\u0432\u044b?<\/div>\n"},"TR":{"QuestionText":"<div style=\"text-align: center;\">Haz\u0131r oldu\u011funuzda ba\u015flayabilirsiniz.<\/div>\n"},"ZH-HK":{"QuestionText":"<p style=\"text-align: center;\">\u6e96\u5099\u597d\u4e86\u55ce\uff1f<\/p>\n"},"ZH-S":{"QuestionText":"<div style=\"text-align: center;\">\u51c6\u5907\u597d\u4e86\u5417\uff1f<\/div>"},"ZH-T":{"QuestionText":"<div style=\"text-align: center;\">\u6e96\u5099\u597d\u4e86\u55ce\uff1f"},"KZ-RU":[],"AR":{"QuestionText":"<div style=\"text-align: center;;text-align:right;direction:rtl\">\u0645\u0633\u062a\u0639\u062f\u061f<\/div>"},"DE-DE":{"QuestionText":"<div style=\"text-align: center;\">Bereit?<\/div>"}},"NextChoiceId":4,"NextAnswerId":1,"QuestionText_Unsafe":"<div style=\"text-align: center;\">Ready?<\/div>","DataVisibility":{"Private":false,"Hidden":false}}},{"SurveyID":"SV_b3mHBVkuioRMhng","Element":"SQ","PrimaryAttribute":"QID334","SecondaryAttribute":"The first block is now over. When you are ready, continue to begin the second one. It has 10 more...","TertiaryAttribute":null,"Payload":{"ChoiceOrder":[],"Configuration":{"QuestionDescriptionOption":"UseText"},"DataVisibility":{"Hidden":false,"Private":false},"DefaultChoices":false,"GradingData":[],"Language":{"CS":{"QuestionText":"<div style=\"text-align: center;\">Prvn\u00ed blok je nyn\u00ed u konce. A\u017e budete p\u0159ipraveni, za\u010dn\u011bte blok druh\u00fd.<br \/>\nSkl\u00e1d\u00e1 se z 10 dal\u0161\u00edch ot\u00e1zek a trv\u00e1 20 sekund.<br \/>\n<br \/>\n<strong>Pamatujte si, \u017ee za ka\u017edou spr\u00e1vnou odpov\u011b\u010f z\u00edsk\u00e1te 1 EMJ.<\/strong><\/div>\n\n<div style=\"text-align: center;\"><strong>Celkem tedy m\u016f\u017eete vyhr\u00e1t a\u017e 10 dal\u0161\u00edch EMJ.<\/strong><\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">P\u0159ipraven(a)?<\/div>\n"},"DE":{"QuestionText":"<div style=\"text-align: center;\">Der erste Block ist nun vorbei. Wenn Sie bereit sind, beginnen Sie mit dem zweiten.<br>\nEr enth\u00e4lt 10 weitere Fragen und dauert 20 Sekunden.<br>\n<br>\n<strong>Denken Sie daran, dass Sie f\u00fcr jede richtige Antwort 1 MU erhalten.<\/strong><\/div><div style=\"text-align: center;\"><strong>Insgesamt k\u00f6nnen Sie also 10 zus\u00e4tzliche MUs gewinnen.<\/strong><\/div><div style=\"text-align: center;\"><strong><br><\/strong><\/div><div style=\"text-align: center;\">Bereit?<\/div>"},"DE-AT":{"QuestionText":"<div style=\"text-align: center;\">Der erste Block ist nun vorbei. Wenn Sie bereit sind, beginnen Sie mit dem zweiten.<br \/>\nEr enth\u00e4lt 10 weitere Fragen und dauert 20 Sekunden.<br \/>\n<br \/>\n<strong>Zur Erinnerung: f\u00fcr jede richtige Antwort erhalten Sie 1 GE.<\/strong><\/div>\n\n<div style=\"text-align: center;\"><strong>Insgesamt k\u00f6nnen Sie also 10 zus\u00e4tzliche GE gewinnen.<\/strong><\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">Bereit?<\/div>\n"},"EL":{"QuestionText":"<div style=\"text-align: center;\">\u03a4\u03bf \u03c0\u03c1\u03ce\u03c4\u03bf \u03bc\u03c0\u03bb\u03bf\u03ba \u03c4\u03ad\u03bb\u03b5\u03b9\u03c9\u03c3\u03b5. \u038c\u03c4\u03b1\u03bd \u03b5\u03af\u03c3\u03c4\u03b5 \u03ad\u03c4\u03bf\u03b9\u03bc\u03bf\u03b9, \u03be\u03b5\u03ba\u03b9\u03bd\u03ae\u03c3\u03c4\u03b5 \u03c4\u03bf \u03b4\u03b5\u03cd\u03c4\u03b5\u03c1\u03bf.<br \/>\n\u0388\u03c7\u03b5\u03b9 \u03b1\u03ba\u03cc\u03bc\u03b1 10 \u03b5\u03c1\u03c9\u03c4\u03ae\u03c3\u03b5\u03b9\u03c2 \u03ba\u03b1\u03b9 \u03b4\u03b9\u03b1\u03c1\u03ba\u03b5\u03af \u03be\u03b1\u03bd\u03ac 20 \u03b4\u03b5\u03c5\u03c4\u03b5\u03c1\u03cc\u03bb\u03b5\u03c0\u03c4\u03b1.<br \/>\n<br \/>\n<strong>\u03a3\u03b7\u03bc\u03b5\u03b9\u03ce\u03c3\u03c4\u03b5 \u03cc\u03c4\u03b9 \u03b3\u03b9\u03b1 \u03ba\u03ac\u03b8\u03b5 \u03c3\u03c9\u03c3\u03c4\u03ae \u03b1\u03c0\u03ac\u03bd\u03c4\u03b7\u03c3\u03b7 \u03b8\u03b1 \u03ba\u03b5\u03c1\u03b4\u03af\u03c3\u03b5\u03c4\u03b5 1 \u039d\u039c.<\/strong><\/div>\n\n<div style=\"text-align: center;\"><strong>\u0395\u03c0\u03bf\u03bc\u03ad\u03bd\u03c9\u03c2, \u03c3\u03c5\u03bd\u03bf\u03bb\u03b9\u03ba\u03ac \u03bc\u03c0\u03bf\u03c1\u03b5\u03af\u03c4\u03b5 \u03bd\u03b1 \u03ba\u03b5\u03c1\u03b4\u03af\u03c3\u03b5\u03c4\u03b5 \u03b1\u03ba\u03cc\u03bc\u03b1 10 \u039d\u039c.<\/strong><\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">'\u0395\u03c4\u03bf\u03b9\u03bc\u03bf\u03b9?<\/div>\n"},"ES":{"QuestionText":"<div style=\"text-align: center;\">El primer bloque ya ha terminado. Cuando est\u00e9 listo, contin\u00fae para comenzar el segundo.<br \/>\nTiene 10 preguntas m\u00e1s y dura 20 segundos.<br \/>\n<br \/>\n<strong>Recuerda, por cada respuesta correcta ganar\u00e1s 1 UM.<br \/>\nPor lo tanto, en total puedes ganar 10 UM adicionales.<\/strong><br \/>\n<br \/>\n\u00bfListo\/a?<\/div>\n"},"ES-AR":{"QuestionText":"<div style=\"text-align: center;\">El primer bloque ya termin\u00f3. Cuando est\u00e9 listo, contin\u00fae para comenzar el segundo.<br \/>\nTiene 10 preguntas m\u00e1s y dura 20 segundos.<br \/>\n<br \/>\n<strong>Recuerda, por cada respuesta correcta ganar\u00e1 1 UM.<\/strong><br \/>\n<strong>Por lo tanto, en total podr\u00e1 ganar 10 UM adicionales. <\/strong><br \/>\n<br \/>\n\u00bfListo?<\/div>\n"},"ES-ES":{"QuestionText":"<div style=\"text-align: center;\">El primer bloque ya termin\u00f3. Cuando est\u00e9s listo, contin\u00faa comenzando el segundo.<br>\nTiene 10 preguntas m\u00e1s y dura 20 segundos.<br>\n<br>\n<strong>Recuerda, por cada respuesta correcta ganar\u00e1s 1 MU.<\/strong><\/div><div style=\"text-align: center;\"><strong>Por lo tanto, en total podr\u00e1s ganar 10 MU adicionales. <\/strong><\/div><div style=\"text-align: center;\"><strong><br><\/strong><\/div><div style=\"text-align: center;\">\u00bfListo? <\/div>"},"FR":{"QuestionText":"<div style=\"text-align: center;\">Le premier bloc est d\u00e9sormais termin\u00e9. Lorsque vous \u00eates pr\u00eat, faites\u00a0 le deuxi\u00e8me bloc.<br \/>\nIl comporte 10 questions suppl\u00e9mentaires et dure 20 secondes.<br \/>\n<br \/>\n<strong>N'oubliez pas que pour chaque bonne r\u00e9ponse, vous gagnerez 1 MU.<\/strong><\/div>\n\n<div style=\"text-align: center;\"><strong>Au total, vous pouvez donc gagner 10 MU suppl\u00e9mentaires.<\/strong><\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">Pr\u00eat?<\/div>\n"},"FR-FR":{"QuestionText":"<div style=\"text-align: center;\">Le premier bloc est maintenant termin\u00e9. Lorsque vous \u00eates pr\u00eat, vous pourrez passez au second bloc.<br \/>\nIl contient 10\u00a0questions suppl\u00e9mentaires et dure 20\u00a0secondes.<br \/>\n<br \/>\n<strong>N'oubliez pas que pour chaque bonne r\u00e9ponse, vous gagnerez 1 UM.<\/strong><\/div>\n\n<div style=\"text-align: center;\"><strong>Par cons\u00e9quent, au total, vous pouvez gagner 10 UM suppl\u00e9mentaires. <\/strong><\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">Pr\u00eat\u00a0?<\/div>\n"},"HU":{"QuestionText":"<div style=\"text-align: center;\">Az els\u0151 blokk most v\u00e9get \u00e9rt. Ha k\u00e9szen \u00e1ll, folytassa a m\u00e1sodikkal.<br \/>\nM\u00e9g 10 k\u00e9rd\u00e9s k\u00f6vetkezik, \u00e9s 20 m\u00e1sodpercig tart.<br \/>\n<br \/>\n<strong>Ne feledje, minden helyes v\u00e1lasz\u00e9rt 1 PE-t kap.<\/strong><\/div>\n\n<div style=\"text-align: center;\"><strong>\u00cdgy \u00f6sszesen 10 tov\u00e1bbi PE-t nyerhet.<\/strong><\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">K\u00e9sz?<\/div>\n"},"IT":{"QuestionText":"<div style=\"text-align: center;\">Il primo blocco \u00e8 ormai terminato. Quando sei pronto, continua per iniziare il secondo.<br \/>\nHa altre 10 domande e dura 20 secondi.<br \/>\n<br \/>\n<strong>Ricorda, per ogni risposta corretta guadagnerai 1 MU.<\/strong><\/div>\n\n<div style=\"text-align: center;\"><strong>Pertanto, in totale puoi vincere 10 MU aggiuntive.<\/strong><\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">Pronto?<\/div>\n"},"JA":{"QuestionText":"<div style=\"text-align: center;\">\u6700\u521d\u306e\u30d6\u30ed\u30c3\u30af\u306f\u3053\u308c\u3067\u7d42\u4e86\u3067\u3059\u3002\u6e96\u5099\u304c\u3067\u304d\u305f\u3089\u30012 \u756a\u76ee\u306e\u30d6\u30ed\u30c3\u30af\u3092\u958b\u59cb\u3057\u3066\u304f\u3060\u3055\u3044\u3002<br>\n2 \u756a\u76ee\u306e\u30d6\u30ed\u30c3\u30af\u306b\u306f\u3042\u3068 10 \u554f\u3042\u308a\u300120 \u79d2\u9593\u7d9a\u304d\u307e\u3059\u3002<br>\n<br>\n<strong>\u6b63\u89e3\u3059\u308b\u3054\u3068\u306b 1 MU \u3092\u7372\u5f97\u3067\u304d\u308b\u3053\u3068\u3092\u899a\u3048\u3066\u304a\u3044\u3066\u304f\u3060\u3055\u3044\u3002<\/strong><\/div><div style=\"text-align: center;\"><strong>\u3057\u305f\u304c\u3063\u3066\u3001\u5408\u8a08\u3067\u3055\u3089\u306b 10 MU \u3092\u7372\u5f97\u3067\u304d\u307e\u3059\u3002<\/strong><\/div><div style=\"text-align: center;\"><strong><br><\/strong><\/div><div style=\"text-align: center;\">\u6e96\u5099\u306f\u3067\u304d\u307e\u3057\u305f\u304b?<\/div>"},"KO":{"QuestionText":"<div style=\"text-align: center;\">\uccab \ubc88\uc9f8 \ubb36\uc74c\uc774 \ub05d\ub0ac\uc2b5\ub2c8\ub2e4. \uc900\ube44\uac00 \ub418\uba74 \ub450 \ubc88\uc9f8 \ubb36\uc74c\uc744 \uacc4\uc18d \uc2dc\uc791\ud558\uc138\uc694.<br \/>\n10\uac1c\uc758 \ubb38\uc81c\uac00 \ub354 \uc788\uace0 20\ucd08 \ub3d9\uc548 \uc9c4\ud589\ub429\ub2c8\ub2e4.<br \/>\n<br \/>\n<strong>\uc815\ub2f5\uc744 \ub9de\ucd9c \ub54c\ub9c8\ub2e4 1MU\ub97c \ud68d\ub4dd\ud55c\ub2e4\ub294 \uac83\uc744 \ub2e4\uc2dc \ub9d0\uc500\ub4dc\ub9bd\ub2c8\ub2e4.<\/strong><\/div>\n\n<div style=\"text-align: center;\"><strong>\ub530\ub77c\uc11c \ucd5c\ub300 10MU\ub97c \ucd94\uac00\ub85c \ud68d\ub4dd\ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4.<\/strong><\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">\uc900\ube44\ub418\uc168\ub098\uc694?<\/div>\n"},"PL":{"QuestionText":"<div style=\"text-align: center;\">Pierwszy blok ju\u017c za nami. Kiedy b\u0119dziesz gotowy, kontynuuj rozpocz\u0119cie drugiego.<br> Zawiera 10 dodatkowych pyta\u0144 i trwa 20 sekund.<br><br> <strong>Pami\u0119taj, za ka\u017cd\u0105 poprawn\u0105 odpowied\u017a otrzymasz 1 MU.<\/strong><\/div><div style=\"text-align: center;\"> <strong>\u0141\u0105cznie mo\u017cna zatem wygra\u0107 10 dodatkowych MU.<\/strong><\/div><div style=\"text-align: center;\"><strong><br><\/strong><\/div><div style=\"text-align: center;\"> Gotowy?<\/div>"},"PT":{"QuestionText":"<div style=\"text-align: center;\">O primeiro bloco acabou. Quando estiver preparado, continue para come\u00e7ar o segundo bloco.<br \/>\nTem mais 10 perguntas com dura\u00e7\u00e3o de 20 segundos.<br \/>\n<br \/>\n<strong>Lembre-se, para cada resposta correta ganhar\u00e1 1 UM.<\/strong><\/div>\n\n<div style=\"text-align: center;\"><strong>Assim, no total poder\u00e1 ganhar 10 UMs adicionais. <\/strong><\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">Preparado?<\/div>\n"},"RU":{"QuestionText":"<div style=\"text-align: center;\">\u041f\u0435\u0440\u0432\u044b\u0439 \u0431\u043b\u043e\u043a \u0443\u0436\u0435 \u043f\u043e\u0437\u0430\u0434\u0438. \u041a\u043e\u0433\u0434\u0430 \u0432\u044b \u0431\u0443\u0434\u0435\u0442\u0435 \u0433\u043e\u0442\u043e\u0432\u044b, \u043d\u0430\u0447\u0438\u043d\u0430\u0439\u0442\u0435 \u0432\u0442\u043e\u0440\u043e\u0439.<br \/>\n\u0412 \u043d\u0435\u043c \u0435\u0449\u0435 10 \u0432\u043e\u043f\u0440\u043e\u0441\u043e\u0432 \u0438 \u043e\u043d \u0434\u043b\u0438\u0442\u0441\u044f 20 \u0441\u0435\u043a\u0443\u043d\u0434.<br \/>\n<br \/>\n<strong>\u041f\u043e\u043c\u043d\u0438\u0442\u0435, \u0437\u0430 \u043a\u0430\u0436\u0434\u044b\u0439 \u043f\u0440\u0430\u0432\u0438\u043b\u044c\u043d\u044b\u0439 \u043e\u0442\u0432\u0435\u0442 \u0412\u044b \u043f\u043e\u043b\u0443\u0447\u0438\u0442\u0435 1 \u0414\u0415.<\/strong><\/div>\n\n<div style=\"text-align: center;\"><strong>\u0422\u0430\u043a\u0438\u043c \u043e\u0431\u0440\u0430\u0437\u043e\u043c, \u0432\u0441\u0435\u0433\u043e \u0412\u044b \u043c\u043e\u0436\u0435\u0442\u0435 \u0432\u044b\u0438\u0433\u0440\u0430\u0442\u044c 10 \u0434\u043e\u043f\u043e\u043b\u043d\u0438\u0442\u0435\u043b\u044c\u043d\u044b\u0445 \u0414E.<\/strong><\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">\u0413\u043e\u0442\u043e\u0432\u044b?<\/div>\n"},"TR":{"QuestionText":"<div style=\"text-align: center;\">\u0130lk blok sona erdi. Haz\u0131r oldu\u011funuzda, ikinci blo\u011fa devam edebilirsiniz.<br \/>\n\u0130kinci bloktaki 10 soru i\u00e7in de toplam 20 saniyeniz oldu\u011funu unutmay\u0131n\u0131z.<br \/>\n<br \/>\n<strong>Her do\u011fru cevap i\u00e7in 1 DPB kazanacaks\u0131n\u0131z.<\/strong><\/div>\n\n<div style=\"text-align: center;\"><strong>Dolay\u0131s\u0131yla, bu blokta toplam 10 DPB kazanabilirsiniz.<\/strong><\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">Haz\u0131r oldu\u011funuzda ba\u015flayabilirsiniz.<\/div>\n"},"ZH-HK":{"QuestionText":"<div style=\"text-align: center;\">\n<p>\u7b2c\u4e00\u7d44\u984c\u76ee\u5df2\u7d50\u675f\u3002\u6e96\u5099\u597d\u7684\u8a71\uff0c\u8acb\u7e7c\u7e8c\u9032\u5165\u7b2c\u4e8c\u7d44\u3002<\/p>\n\n<p>\u7b2c\u4e8c\u7d44\u5171\u6709 10 \u9053\u984c\u76ee\uff0c\u9650\u6642 20 \u79d2\u3002<\/p>\n\u00a0\n\n<p><b>\u5225\u5fd8\u4e86\uff0c\u6bcf\u7b54\u5c0d\u4e00\u984c\uff0c\u60a8\u6703\u7372\u5f97\u00a0<\/b><strong 72=\"\" style=\"font-family: \">1 MU\u3002<\/strong><\/p>\n<\/div>\n\n<div style=\"text-align: center;\"><b>\u6b64\uff0c\u60a8\u6700\u591a\u53ef\u4ee5\u984d\u5916\u7372\u5f97<\/b><strong> 10 MU\u3002<\/strong><\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">\u6e96\u5099\u597d\u4e86\u55ce\uff1f<\/div>\n"},"ZH-S":{"QuestionText":"<div style=\"text-align: center;\">\u7b2c\u4e00\u7ec4\u95ee\u9898\u73b0\u5728\u7ed3\u675f\u4e86\u3002\u5f53\u60a8\u51c6\u5907\u597d\u65f6\uff0c\u7ee7\u7eed\u5f00\u59cb\u7b2c\u4e8c\u7ec4\u95ee\u9898\u3002<br \/>\n\u5b83\u8fd8\u6709 10 \u4e2a\u95ee\u9898\uff0c\u6301\u7eed 20 \u79d2\u3002<br \/>\n<br \/>\n<strong>\u8bf7\u8bb0\u4f4f\uff0c\u5bf9\u4e8e\u6bcf\u4e2a\u6b63\u786e\u56de\u7b54\u7684\u95ee\u9898\uff0c\u60a8\u5c06\u83b7\u5f97 1\u00a0\u4e2a MU\u3002<\/strong><\/div>\n\n<div style=\"text-align: center;\"><strong>\u56e0\u6b64\uff0c\u60a8\u603b\u5171\u53ef\u4ee5\u8d62\u5f97 10 \u4e2a\u989d\u5916\u7684 MU\u3002<\/strong><\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">\u51c6\u5907\u597d\u4e86\u5417\uff1f<\/div>\n"},"ZH-T":{"QuestionText":"<div style=\"text-align: center;\">\u7b2c\u4e00\u7d44\u984c\u76ee\u5df2\u7d50\u675f\u3002\u6e96\u5099\u597d\u7684\u8a71\uff0c\u8acb\u7e7c\u7e8c\u9032\u5165\u7b2c\u4e8c\u7d44\u3002<br \/>\n\u7b2c\u4e8c\u7d44\u5171\u6709 10 \u9053\u984c\u76ee\uff0c\u9650\u6642 20 \u79d2\u3002<br \/>\n<br \/>\n<strong>\u5225\u5fd8\u4e86\uff0c\u6bcf\u7b54\u5c0d\u4e00\u984c\uff0c\u60a8\u6703\u7372\u5f97 1 \u6cd5\u5e63\u3002<br \/>\n\u56e0\u6b64\uff0c\u60a8\u6700\u591a\u53ef\u4ee5\u984d\u5916\u7372\u5f97 10 \u6cd5\u5e63\u3002<\/strong><br \/>\n<br \/>\n\u6e96\u5099\u597d\u4e86\u55ce\uff1f<\/div>\n"},"KZ-RU":[],"AR":{"QuestionText":"<div style=\"text-align: center;;text-align:right;direction:rtl\">\u0644\u0642\u062f \u0627\u0646\u062a\u0647\u064a \u0627\u0644\u062c\u0632\u0621 \u0627\u0644\u0623\u0648\u0644 \u0627\u0644\u0622\u0646. \u0639\u0646\u062f\u0645\u0627 \u062a\u0643\u0648\u0646 \u0645\u0633\u062a\u0639\u062f\u064b\u0627\u060c \u0627\u0633\u062a\u0645\u0631 \u0641\u064a \u0627\u0644\u0628\u062f\u0621 \u0641\u064a \u0627\u0644\u062c\u0632\u0621 \u0627\u0644\u062b\u0627\u0646\u064a.<br \/>\n\u064a\u062d\u062a\u0648\u064a \u0639\u0644\u0649 10 \u0623\u0633\u0626\u0644\u0629 \u0625\u0636\u0627\u0641\u064a\u0629 \u0648\u064a\u0633\u062a\u0645\u0631 \u0644\u0645\u062f\u0629 20 \u062b\u0627\u0646\u064a\u0629.<br \/>\n<br \/>\n<strong>\u062a\u0630\u0643\u0631\u060c \u0645\u0642\u0627\u0628\u0644 \u0643\u0644 \u0625\u062c\u0627\u0628\u0629 \u0635\u062d\u064a\u062d\u0629 \u0633\u0648\u0641 \u062a\u062d\u0635\u0644 \u0639\u0644\u0649 1 \u0648\u062d\u062f\u0629 \u0646\u0642\u062f\u064a\u0629.<\/strong><\/div>\n\n<div style=\"text-align: center;;text-align:right;direction:rtl\"><strong>\u0644\u0630\u0644\u0643\u060c \u064a\u0645\u0643\u0646\u0643 \u0627\u0644\u0641\u0648\u0632 \u0628\u0625\u062c\u0645\u0627\u0644\u064a 10 \u0648\u062d\u062f\u0627\u062a \u0646\u0642\u062f\u064a\u0629 \u0625\u0636\u0627\u0641\u064a\u0629.<\/strong><\/div>\n\n<div style=\"text-align: center;;text-align:right;direction:rtl\">\u00a0<\/div>\n\n<div style=\"text-align: center;;text-align:right;direction:rtl\">\u0645\u0633\u062a\u0639\u062f\u061f<\/div>\n"},"DE-DE":{"QuestionText":"<div style=\"text-align: center;\">Der erste Block ist nun beendet. Wenn Sie bereit sind, k\u00f6nnen Sie mit dem zweiten Block beginnen.<br \/>\nDieser enth\u00e4lt 10 weitere Fragen und dauert 20 Sekunden.<br \/>\n<br \/>\n<strong>Denken Sie daran, dass Sie f\u00fcr jede richtige Antwort 1 GE erhalten.<\/strong><\/div>\n\n<div style=\"text-align: center;\"><strong>Insgesamt k\u00f6nnen Sie also 10 zus\u00e4tzliche GE gewinnen.<\/strong><\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">Bereit?<\/div>\n"}},"NextAnswerId":1,"NextChoiceId":4,"QuestionDescription":"The first block is now over. When you are ready, continue to begin the second one. It has 10 more...","QuestionText":"<div style=\"text-align: center;\">The first block is now over. When you are ready, continue to begin the second one.<br>\nIt has 10 more questions and it lasts 20 seconds.<br>\n<br>\n<strong>Remember, for each correct answer you will earn 1 MU.<\/strong><\/div><div style=\"text-align: center;\"><strong>Therefore, in total you can win 10 additional MUs.<\/strong><\/div><div style=\"text-align: center;\"><strong><br><\/strong><\/div><div style=\"text-align: center;\">Ready?<\/div>","QuestionText_Unsafe":"<div style=\"text-align: center;\">The first block is now over. When you are ready, continue to begin the second one.<br>\nIt has 10 more questions and it lasts 20 seconds.<br>\n<br>\n<strong>Remember, for each correct answer you will earn 1 MU.<\/strong><\/div><div style=\"text-align: center;\"><strong>Therefore, in total you can win 10 additional MUs.<\/strong><\/div><div style=\"text-align: center;\"><strong><br><\/strong><\/div><div style=\"text-align: center;\">Ready?<\/div>","QuestionType":"DB","Selector":"TB","Validation":{"Settings":{"Type":"None"}},"DataExportTag":"RestBetweenMaths pay","QuestionID":"QID334"}},{"SurveyID":"SV_b3mHBVkuioRMhng","Element":"SQ","PrimaryAttribute":"QID335","SecondaryAttribute":"Click to write the question text","TertiaryAttribute":null,"Payload":{"QuestionText":"Click to write the question text","DataExportTag":"Q328","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Click to write the question text","Choices":{"1":{"Display":"Click to write Choice 1"},"2":{"Display":"Click to write Choice 2"},"3":{"Display":"Click to write Choice 3"}},"ChoiceOrder":["1","2","3"],"Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID335"}},{"SurveyID":"SV_b3mHBVkuioRMhng","Element":"SQ","PrimaryAttribute":"QID336","SecondaryAttribute":"Click to write the question text","TertiaryAttribute":null,"Payload":{"QuestionText":"Click to write the question text","DataExportTag":"Q329","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Click to write the question text","Choices"