s.com\/CP\/Graphic.php?IM=IM_5jLpAayWC6pPlOu\" style=\"width: 498px; height: 141px;\" \/>","Choices":{"1":{"Display":"Evet"},"2":{"Display":"Hay\u0131r"}}},"ZH-HK":{"QuestionText":"\u4e00\u8f1b\u96fb\u8eca\u5931\u63a7\u5730\u6cbf\u8457\u8ecc\u9053\u884c\u99db\u3002\u5728\u5b83\u7684\u8def\u5f91\u4e0a\u6709 5 \u500b\u4eba\u88ab\u7d81\u5728\u8ecc\u9053\u4e0a\u3002\u5e78\u904b\u7684\u662f\uff0c\u60a8\u53ef\u4ee5\u6273\u52d5\u958b\u95dc\uff0c\u5c07\u96fb\u8eca\u5f15\u5411\u4e0d\u540c\u7684\u8ecc\u9053\uff0c\u5f9e\u800c\u633d\u6551\u4ed6\u5011\u7684\u751f\u547d\u3002\u4e0d\u5e78\u7684\u662f\uff0c\u6709\u4e00\u500b\u4eba\u7d81\u5728\u9019\u689d\u8ecc\u9053\u4e0a\uff0c\u5982\u679c\u4f60\u6309\u4e0b\u958b\u95dc\uff0c\u4ed6\u5c31\u6703\u6b7b\u3002\u6309\u4e0b\u958b\u95dc\u5728\u9053\u5fb7\u4e0a\u662f\u53ef\u4ee5\u63a5\u53d7\u7684\u55ce\uff1f<br \/>\n<img src=\"https:\/\/investigadoresloyola.eu.qualtrics.com\/CP\/Graphic.php?IM=IM_5jLpAayWC6pPlOu\" style=\"width: 498px; height: 141px;\" \/>","Choices":{"1":{"Display":"\u662f"},"2":{"Display":"\u5426"}}},"KZ-RU":[],"AR":{"QuestionText":"\u0647\u0646\u0627\u0644\u0643 \u0639\u0631\u0628\u0629 \u062a\u0631\u0627\u0645 \u062e\u0627\u0631\u062c\u0629 \u0639\u0646 \u0627\u0644\u0633\u064a\u0637\u0631\u0629 \u062a\u0633\u064a\u0631 \u0628\u0627\u062a\u062c\u0627\u0647 \u062e\u0645\u0633\u0629 \u0623\u0634\u062e\u0627\u0635 \u0645\u0642\u064a\u0651\u062f\u064a\u0646 \u0645\u064f\u0645\u064e\u062f\u0651\u062f\u064a\u0646 \u0639\u0644\u0649 \u0627\u0644\u0633\u0643\u0629 \u0627\u0644\u062d\u062f\u064a\u062f. \u0644\u062d\u0633\u0646 \u0627\u0644\u062d\u0638\u060c \u064a\u0645\u0643\u0646\u0643 \u0633\u062d\u0628 \u0645\u0641\u062a\u0627\u062d \u0627\u0644\u062a\u0634\u063a\u064a\u0644 \u0627\u0644\u0630\u064a \u0633\u064a\u0642\u0648\u062f \u0627\u0644\u0639\u0631\u0628\u0629 \u0625\u0644\u0649 \u0645\u0633\u0627\u0631 \u0645\u062e\u062a\u0644\u0641\u060c \u0641\u062a\u0646\u0642\u0630 \u062d\u064a\u0627\u062a\u0647\u0645. \u0644\u0633\u0648\u0621 \u0627\u0644\u062d\u0638\u060c \u064a\u0648\u062c\u062f \u0634\u062e\u0635 \u0648\u0627\u062d\u062f \u0645\u0631\u0628\u0648\u0637 \u0628\u0647\u0630\u0627 \u0627\u0644\u0645\u0633\u0627\u0631 \u0633\u064a\u0645\u0648\u062a \u0625\u0630\u0627 \u0642\u0645\u062a \u0628\u0633\u062d\u0628 \u0627\u0644\u0645\u0641\u062a\u0627\u062d.\u00a0\u0647\u0644 \u0645\u0646 \u0627\u0644\u0645\u0642\u0628\u0648\u0644 \u0623\u062e\u0644\u0627\u0642\u064a\u0627\u064b \u0633\u062d\u0628 \u0645\u0641\u062a\u0627\u062d \u0627\u0644\u062a\u0634\u063a\u064a\u0644\u061f<br \/>\n<img src=\"https:\/\/investigadoresloyola.eu.qualtrics.com\/CP\/Graphic.php?IM=IM_5jLpAayWC6pPlOu\" style=\"width: 498px; height: 141px;\" \/>","Choices":{"1":{"Display":"\u0646\u0639\u0645"},"2":{"Display":"\u0644\u0627"}}},"DE-DE":{"QuestionText":"\u200bEine Stra\u00dfenbahn f\u00e4hrt unkontrolliert eine Gleis entlang. Auf ihrem Weg befinden sich 5 Personen, die an das Gleis gefesselt sind. Gl\u00fccklicherweise k\u00f6nnen Sie einen Schalter umlegen, der die Stra\u00dfenbahn auf ein anderes Gleis f\u00fchrt und so deren Leben rettet. Ungl\u00fccklicherweise ist eine einzelne Person an das Gleis gefesselt und wird sterben, wenn Sie den Schalter umlegen.\u00a0Ist es moralisch vertretbar, den Schalter umzulegen?<br \/>\n<img src=\"https:\/\/investigadoresloyola.eu.qualtrics.com\/CP\/Graphic.php?IM=IM_5jLpAayWC6pPlOu\" style=\"width: 498px; height: 141px;\" \/>","Choices":{"1":{"Display":"Ja"},"2":{"Display":"Nein"}}}},"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID342","QuestionText_Unsafe":"\u200bA trolley is running out of control down a track. In its path are 5 people who have been tied to the track. Fortunately, you can flip a switch that will lead the trolley down a different track, and save their lives. Unfortunately, there is a\u200b \u200bsingle person tied to that track\u200b who will die if you flip the switch. Is it morally acceptable to flip the switch?<br>\n&nbsp;<img style=\"width: 498px; height: 141px;\" src=\"https:\/\/investigadoresloyola.eu.qualtrics.com\/CP\/Graphic.php?IM=IM_5jLpAayWC6pPlOu\">"}},{"SurveyID":"SV_b3mHBVkuioRMhng","Element":"SQ","PrimaryAttribute":"QID343","SecondaryAttribute":"What if this person was your cousin? Is it morally acceptable to flip the switch in this case?\u00a0","TertiaryAttribute":null,"Payload":{"QuestionText":"What if this person was <b>your cousin<\/b>? Is it morally acceptable to flip the switch in this case?&nbsp;","DataExportTag":"Trol_norm_cousin","QuestionType":"MC","Selector":"SAHR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","LabelPosition":"BELOW"},"QuestionDescription":"What if this person was your cousin? Is it morally acceptable to flip the switch in this case?\u00a0","Choices":{"1":{"Display":"Yes"},"2":{"Display":"No"}},"ChoiceOrder":["1","2"],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"None"}},"Language":{"CS":{"QuestionText":"Co kdy\u017e tato osoba byla <b>va\u0161\u00edm bratrancem<\/b>? Je mor\u00e1ln\u011b p\u0159ijateln\u00e9 p\u0159ehodit v\u00fdhybku v tomto p\u0159\u00edpad\u011b?","Choices":{"1":{"Display":"Ano"},"2":{"Display":"Ne"}}},"EL":{"QuestionText":"\u039a\u03b1\u03b9 \u03b1\u03bd \u03b1\u03c5\u03c4\u03cc \u03c4\u03bf \u03ac\u03c4\u03bf\u03bc\u03bf \u03ae\u03c4\u03b1\u03bd <strong>\u03bf<\/strong>\u00a0<strong>\u03be\u03ac\u03b4\u03b5\u03c1\u03c6\u03cc\u03c2 \u03c3\u03b1\u03c2<\/strong>;\u00a0\u0395\u03af\u03bd\u03b1\u03b9 \u03b7\u03b8\u03b9\u03ba\u03ac \u03b1\u03c0\u03bf\u03b4\u03b5\u03ba\u03c4\u03cc \u03bd\u03b1 \u03b3\u03c5\u03c1\u03af\u03c3\u03b5\u03c4\u03b5 \u03c4\u03bf\u03bd \u03b4\u03b9\u03b1\u03ba\u03cc\u03c0\u03c4\u03b7 \u03c3\u03b5 \u03b1\u03c5\u03c4\u03ae\u03bd \u03c4\u03b7\u03bd \u03c0\u03b5\u03c1\u03af\u03c0\u03c4\u03c9\u03c3\u03b7;<br \/>\n\u00a0","Choices":{"1":{"Display":"\u039d\u03b1\u03b9"},"2":{"Display":"'\u039f\u03c7\u03b9"}}},"ES":{"QuestionText":"Una carro de tren est\u00e1 corriendo fuera de control por una v\u00eda donde se encuentran 5 personas atadas. Usted puede activar un interruptor que conducir\u00e1 el carro por una v\u00eda alternativa y salvar\u00e1 sus vidas. Sin embargo, en la v\u00eda alternativa se encuentra <strong>un primo suyo<\/strong>\u00a0que morir\u00e1 si activa el interruptor. \u00bfEs moralmente aceptable activar el interruptor?<br \/>\n\u00a0<img src=\"https:\/\/investigadoresloyola.eu.qualtrics.com\/CP\/Graphic.php?IM=IM_5jLpAayWC6pPlOu\" style=\"width: 498px; height: 141px;\" \/>","Choices":{"1":{"Display":"S\u00ed"},"2":{"Display":"No"}}},"FR":{"QuestionText":"Et si cette personne \u00e9tait <b>votre cousin<\/b> ? Est-il moralement acceptable d\u2019appuyer sur l\u2019interrupteur dans ce cas\u00a0?","Choices":{"1":{"Display":"Oui"},"2":{"Display":"Non"}}},"RU":{"QuestionText":"\u0427\u0442\u043e, \u0435\u0441\u043b\u0438 \u044d\u0442\u043e\u0442 \u0447\u0435\u043b\u043e\u0432\u0435\u043a \u0431\u044b\u043b <b>\u0412\u0430\u0448\u0438\u043c \u0434\u0432\u043e\u044e\u0440\u043e\u0434\u043d\u044b\u043c \u0431\u0440\u0430\u0442\u043e\u043c<\/b> ? \u0414\u043e\u043f\u0443\u0441\u0442\u0438\u043c\u043e \u043b\u0438 \u0441 \u043c\u043e\u0440\u0430\u043b\u044c\u043d\u043e\u0439 \u0442\u043e\u0447\u043a\u0438 \u0437\u0440\u0435\u043d\u0438\u044f \u043f\u0435\u0440\u0435\u0432\u0435\u0441\u0442\u0438 \u0441\u0442\u0440\u0435\u043b\u043a\u0438 \u0432 \u044d\u0442\u043e\u043c \u0441\u043b\u0443\u0447\u0430\u0435?","Choices":{"1":{"Display":"\u0414\u0430"},"2":{"Display":"\u041d\u0435\u0442"}}},"HU":{"QuestionText":"Mi van, ha ez a szem\u00e9ly a v\u00e1g\u00e1nyon, ahov\u00e1 \u00e1tterelheti az elszabadult villamost,\u00a0<b>az unokatestv\u00e9re?<\/b> Mor\u00e1lisan elfogadhat\u00f3 ebben az esetben a v\u00e1lt\u00f3 \u00e1t\u00e1ll\u00edt\u00e1sa?","Choices":{"1":{"Display":"Igen"},"2":{"Display":"Nem"}}},"IT":{"QuestionText":"E se questa persona fosse <b>tua cugina<\/b> ? \u00c8 moralmente accettabile girare l\u2019interruttore in questo caso?","Choices":{"1":{"Display":"S\u00cc"},"2":{"Display":"NO"}}},"PL":{"QuestionText":"A co by by\u0142o, gdyby ta osoba by\u0142a <b>Twoim kuzynem<\/b> ? Czy w tym przypadku moralnie dopuszczalne jest prze\u0142\u0105czenie prze\u0142\u0105cznika?","Choices":{"1":{"Display":"Tak"},"2":{"Display":"Nie"}}},"PT":{"QuestionText":"E se essa pessoa fosse <b>seu primo<\/b>? \u00c9 moralmente aceit\u00e1vel puxar a alavanca neste caso?","Choices":{"1":{"Display":"Sim"},"2":{"Display":"N\u00e3o"}}},"ZH-S":{"QuestionText":"\u5982\u679c\u8fd9\u4e2a\u4eba\u662f<b>\u4f60\u7684\u8868\u4eb2<\/b>\u600e\u4e48\u529e\uff1f\u5728\u8fd9\u79cd\u60c5\u51b5\u4e0b\uff0c\u6273\u52a8\u5f00\u5173\u5728\u9053\u5fb7\u4e0a\u53ef\u4ee5\u63a5\u53d7\u5417\uff1f","Choices":{"1":{"Display":"\u662f"},"2":{"Display":"\u5426"}}},"FR-FR":{"QuestionText":"Et si cette personne est <b>votre cousin<\/b>\u00a0? Est-il moralement acceptable d'actionner le levier dans ce cas\u00a0?\u00a0","Choices":{"1":{"Display":"Oui"},"2":{"Display":"Non"}}},"ES-ES":{"QuestionText":"\u00bfY si esta persona fuera <b>tu prima<\/b>? \u00bfEs moralmente aceptable accionar el interruptor en este caso?","Choices":{"1":{"Display":"S\u00ed"},"2":{"Display":"No"}}},"ES-AR":{"QuestionText":"\u00bfY si esta persona fuera <strong>s<\/strong><b>u prima<\/b>? \u00bfEs moralmente aceptable accionar la palanca en este caso?","Choices":{"1":{"Display":"S\u00ed"},"2":{"Display":"No"}}},"JA":{"QuestionText":"\u3082\u3057\u3053\u306e\u4eba\u304c<b>\u3042\u306a\u305f\u306e\u3044\u3068\u3053<\/b>\u3060\u3063\u305f\u3089\u3069\u3046\u3057\u307e\u3059\u304b? \u3053\u306e\u5834\u5408\u3001\u30b9\u30a4\u30c3\u30c1\u3092\u5207\u308a\u66ff\u3048\u308b\u3053\u3068\u306f\u9053\u5fb3\u7684\u306b\u8a31\u5bb9\u3055\u308c\u308b\u3067\u3057\u3087\u3046\u304b?","Choices":{"1":{"Display":"\u306f\u3044"},"2":{"Display":"\u3044\u3044\u3048"}}},"DE":{"QuestionText":"Was w\u00e4re, wenn diese Person <