043e\u0431\u0449\u0435\u0441\u0442\u0432\u0435\u043d\u043d\u043e\u0433\u043e \u043c\u043d\u0435\u043d\u0438\u044f. \u041a\u0430\u043a\u0438\u0435 \u0438\u0437 \u043d\u0438\u0445, \u0441 \u0412\u0430\u0448\u0435\u0439 \u0442\u043e\u0447\u043a\u0438 \u0437\u0440\u0435\u043d\u0438\u044f, \u0441\u0432\u044f\u0437\u0430\u043d\u044b \u0441 <b>\u043f\u0440\u043e\u0431\u043b\u0435\u043c\u043e\u0439 \u0438\u0437\u043c\u0435\u043d\u0435\u043d\u0438\u044f \u043a\u043b\u0438\u043c\u0430\u0442\u0430<\/b>? \u041e\u0442\u043c\u0435\u0442\u044c\u0442\u0435 \u0432\u0441\u0435, \u043a\u043e\u0442\u043e\u0440\u044b\u0435, \u0441 \u0412\u0430\u0448\u0435\u0439 \u0442\u043e\u0447\u043a\u0438 \u0437\u0440\u0435\u043d\u0438\u044f, \u043a \u043d\u0435\u0439 \u043e\u0442\u043d\u043e\u0441\u044f\u0442\u0441\u044f.","Choices":{"1":{"Display":"\u0417\u0430\u0433\u0440\u044f\u0437\u043d\u0435\u043d\u0438\u0435 \u043e\u0442 \u043f\u0440\u043e\u043c\u044b\u0448\u043b\u0435\u043d\u043d\u044b\u0445 \u043e\u0431\u044a\u0435\u043a\u0442\u043e\u0432"},"4":{"Display":"\u0417\u0430\u0433\u0440\u044f\u0437\u043d\u0435\u043d\u0438\u0435 \u0441\u0432\u0438\u043d\u0446\u043e\u043c \u0432\u043e\u0434\u043e\u043f\u0440\u043e\u0432\u043e\u0434\u043d\u043e\u0439 \u0432\u043e\u0434\u044b"},"5":{"Display":"\u0418\u0437\u043c\u0435\u043d\u0435\u043d\u0438\u0435 \u043a\u043b\u0438\u043c\u0430\u0442\u0430"},"6":{"Display":"\u0417\u0430\u0441\u0443\u0445\u0430"},"7":{"Display":"\u041d\u0430\u0432\u043e\u0434\u043d\u0435\u043d\u0438\u0435"},"8":{"Display":"\u0420\u0430\u0441\u043f\u0440\u043e\u0441\u0442\u0440\u0430\u043d\u0435\u043d\u0438\u0435 \u043e\u043f\u0430\u0441\u043d\u044b\u0445 \u0432\u0438\u0434\u043e\u0432 \u0436\u0438\u0432\u043e\u0442\u043d\u044b\u0445\/\u0431\u0430\u043a\u0442\u0435\u0440\u0438\u0439"},"9":{"Display":"\u041f\u0440\u043e\u0431\u043a\u0438 \u043d\u0430 \u0434\u043e\u0440\u043e\u0433\u0430\u0445 \u0432 \u0433\u043e\u0440\u043e\u0434\u0430\u0445"},"10":{"Display":"\u041e\u0442\u0441\u0443\u