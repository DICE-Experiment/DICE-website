sum4.9","DataVisibility":{"Hidden":false,"Private":false},"DefaultChoices":false,"GradingData":[],"Language":{"ES":{"QuestionText":"$e{7*10} + $e{9} +$e{7*9}+$e{7*27} = ???","Choices":{"1":{"Display":"$e{7*10+9+ 7*9+7*27}"},"4":{"Display":"$e{7*10}"},"5":{"Display":"$e{9}"}}}},"NextAnswerId":1,"NextChoiceId":6,"QuestionDescription":"$e{7*10} + $e{9} +$e{7*9}+$e{7*27} = ???","QuestionID":"QID197","QuestionText":"$e{7*10} + $e{9} +$e{7*9}+$e{7*27} = ???","QuestionText_Unsafe":"$e{7*10} + $e{9} +$e{7*9}+$e{7*27} = ???","QuestionType":"MC","Randomization":{"Advanced":null,"TotalRandSubset":"","Type":"All"},"RecodeValues":{"1":"0","2":"-1","3":"1","4":"99","5":"9"},"Selector":"SAHR","SubSelector":"TX","Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}}}},{"SurveyID":"SV_b3mHBVkuioRMhng","Element":"SQ","PrimaryAttribute":"QID198","SecondaryAttribute":"$e{8*10} + $e{1} +$e{8*9}+$e{8*27} = ???","TertiaryAttribute":null,"Payload":{"ChoiceOrder":[1,2,3,4,5],"Choices":{"1":{"Display":"$e{8*10+1+ 8*9+8*27}"},"2":{"Display":"$e{8*10+1 - ${rand:\/\/int\/1:9}+ 8*9+8*27}"},"3":{"Display":"$e{8*10+1 + ${rand:\/\/int\/1:9}+ 8*9+8*27}"},"4":{"Display":"$e{8*10}"},"5":{"Display":"$e{1}"}},"Configuration":{"LabelPosition":"BELOW","QuestionDescriptionOption":"UseText"},"DataExportTag":"sum4.10","DataVisibility":{"Hidden":false,"Private":false},"DefaultChoices":false,"GradingData":[],"Language":{"ES":{"QuestionText":"$e{8*10} + $e{1} +$e{8*9}+$e{8*27} = ???","Choices":{"1":{"Display":"$e{8*10+1+ 8*9+8*27}"},"4":{"Display":"$e{8*10}"},"5":{"Display":"$e{1}"}}}},"NextAnswerId":1,"NextChoiceId":6,"QuestionDescription":"$e{8*10} + $e{1} +$e{8*9}+$e{8*27} = ???","QuestionID":"QID198","QuestionText":"$e{8*10} + $e{1} +$e{8*9}+$e{8*27} = ???","QuestionText_Unsafe":"$e{8*10} + $e{1} +$e{8*9}+$e{8*27} = ???","QuestionType":"MC","Randomization":{"Advanced":null,"TotalRandSubset":"","Type":"All"},"RecodeValues":{"1":"0","2":"-1","3":"1","4":"99","5":"9"},"Selector":"SAHR","SubSelector":"TX","Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}}}},{"SurveyID":"SV_b3mHBVkuioRMhng","Element":"SQ","PrimaryAttribute":"QID199","SecondaryAttribute":"$e{9*10} + $e{2} +$e{9*9}+$e{9*27} = ???","TertiaryAttribute":null,"Payload":{"ChoiceOrder":[1,2,3,4,5],"Choices":{"1":{"Display":"$e{9*10+2+ 9*9+9*27}"},"2":{"Display":"$e{9*10+2 - ${rand:\/\/int\/1:9}+ 9*9+9*27}"},"3":{"Display":"$e{9*10+2 + ${rand:\/\/int\/1:9}+ 9*9+9*27}"},"4":{"Display":"$e{9*10}"},"5":{"Display":"$e{2}"}},"Configuration":{"LabelPosition":"BELOW","QuestionDescriptionOption":"UseText"},"DataExportTag":"sum4.11","DataVisibility":{"Hidden":false,"Private":false},"DefaultChoices":false,"GradingData":[],"Language":{"ES":{"QuestionText":"$e{9*10} + $e{2} +$e{9*9}+$e{9*27} = ???","Choices":{"1":{"Display":"$e{9*10+2+ 9*9+9*27}"},"4":{"Display":"$e{9*10}"},"5":{"Display":"$e{2}"}}}},"NextAnswerId":1,"NextChoiceId":6,"QuestionDescription":"$e{9*10} + $e{2} +$e{9*9}+$e{9*27} = ???","QuestionID":"QID199","QuestionText":"$e{9*10} + $e{2} +$e{9*9}+$e{9*27} = ???","QuestionText_Unsafe":"$e{9*10} + $e{2} +$e{9*9}+$e{9*27} = ???","QuestionType":"MC","Randomization":{"Advanced":null,"TotalRandSubset":"","Type":"All"},"RecodeValues":{"1":"0","2":"-1","3":"1","4":"99","5":"9"},"Selector":"SAHR","SubSelector":"TX","Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}}}},{"SurveyID":"SV_b3mHBVkuioRMhng","Element":"SQ","PrimaryAttribute":"QID2","SecondaryAttribute":"General rules 1. In this study, you will win real money. In the study, we will use Monetary Units...","TertiaryAttribute":null,"Payload":{"QuestionText":"<div style=\"text-align: center;\"><span style=\"font-size:19px;\"><strong>General rules<\/strong><br>\n<br>\n<strong>1. <\/strong>In this study, you will win real money.<br>\nIn the study, we will use Monetary Units (MUs). The MUs will be converted into cash at the end of the study at the following rate:<\/span><\/div><div style=\"text-align: center;\"><span style=\"font-size:19px;\"><br>\n<strong>1 USD = 8.25 MUs<\/strong><br>\n<br>\n<strong>2.<\/strong> The amount of money will depend on your decisions on the study, and in some cases on the decisions of other participants as well.<br>\n<br>\n<strong>3. <\/strong>The study has seven parts. Decisions that you make in one part of the study will not affect decisions or earnings in another part of the study.<br>\n<br>\n<strong>4.<\/strong> The study is <u><em><strong>100% anonymous. <\/strong><\/em><\/u>Nobody will ever know your decisions: Neither the researchers nor the other participants. This is true even when you interact with other participants in the room. In order to pay you, please note down a code that will appear on your screen on the final page of the study.<br>\n<br>\n<strong>5.<\/strong> Communication between the participants is strictly forbidden. If you have any questions, raise your hand and we will respond privately.<\/span><\/div>","DefaultChoices":false,"DataExportTag":"General Intro","QuestionID":"QID2","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"General rules 1. In this study, you will win real money. In the study, we will use Monetary Units...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":{"AR":{"QuestionText":"<div style=\"text-align: center;;text-align:right;direction:rtl\"><span style=\"font-size:19px;\"><strong>\u0627\u0644\u0642\u0648\u0627\u0639\u062f \u0627\u0644\u0639\u0627\u0645\u0629<\/strong><br \/>\n<br \/>\n<strong>1.<\/strong> \u0641\u064a \u0647\u0630\u0647 \u0627\u0644\u062f\u0631\u0627\u0633\u0629 \u0633\u0648\u0641 \u062a\u0631\u0628\u062d \u0623\u0645\u0648\u0627\u0644\u0627\u064b \u062d\u0642\u064a\u0642\u064a\u0629.<br \/>\n\u0641\u064a \u0627\u0644\u062f\u0631\u0627\u0633\u0629 \u0633\u0646\u062a\u062d\u062f\u062b \u0639\u0646 \u0627\u0644\u0648\u062d\u062f\u0627\u062a \u0627\u0644\u0646\u0642\u062f\u064a\u0629 (\u0648.\u0646.)\u060c \u0648\u0633\u064a\u062a\u0645 \u062a\u062d\u0648\u064a\u0644 \u0647\u0630\u0647 \u0627\u0644\u0648\u062d\u062f\u0627\u062a \u0625\u0644\u0649 \u0646\u0642\u062f \u0641\u064a \u0646\u0647\u0627\u064a\u0629 \u0627\u0644\u062f\u0631\u0627\u0633\u0629 \u0628\u0627\u0644\u0645\u0639\u062f\u0644 \u0627\u0644\u062a\u0627\u0644\u064a:<\/span><\/div>\n\n<div style=\"text-align: center;;text-align:right;direction:rtl\"><br \/>\n<span style=\"font-size:19px;\"><strong>1 \u0648\u062d\u062f\u0629 \u0646\u0642\u062f\u064a\u0629 = 3 \u0631\u064a\u0627\u0644<\/strong><br \/>\n<br \/>\n<strong>2.<\/strong> \u0633\u064a\u0639\u062a\u0645\u062f \u0645\u0628\u0644\u063a \u0627\u0644\u0645\u0627\u0644 \u0639\u0644\u0649 \u0642\u0631\u0627\u0631\u0627\u062a\u0643 \u0641\u064a \u0647\u0630\u0647 \u0627\u0644\u062f\u0631\u0627\u0633\u0629\u060c \u0648\u0641\u064a \u0628\u0639\u0636 \u0627\u0644\u062d\u0627\u0644\u0627\u062a \u0639\u0644\u0649 \u0642\u0631\u0627\u0631\u0627\u062a \u0627\u0644\u0645\u0634\u0627\u0631\u0643\u064a\u0646 \u0627\u0644\u0622\u062e\u0631\u064a\u0646 \u0623\u064a\u0636\u064b\u0627.<br \/>\n<br \/>\n<strong>3.<\/strong> \u062a\u062a\u0643\u0648\u0646 \u0627\u0644\u062f\u0631\u0627\u0633\u0629 \u0645\u0646 7 \u0623\u062c\u0632\u0627\u0621. \u0627\u0644\u0642\u0631\u0627\u0631\u0627\u062a \u0627\u0644\u062a\u064a \u062a\u062a\u062e\u0630\u0647\u0627 \u0641\u064a \u062c\u0632\u0621 \u0648\u0627\u062d\u062f \u0645\u0646 \u0627\u0644\u062f\u0631\u0627\u0633\u0629 \u0644\u0646 \u062a\u0624\u062b\u0631 \u0639\u0644\u0649 \u0627\u0644\u0642\u0631\u0627\u0631\u0627\u062a \u0623\u0648 \u0627\u0644\u0623\u0631\u0628\u0627\u062d \u0641\u064a \u062c\u0632\u0621 \u0622\u062e\u0631 \u0645\u0646 \u0627\u0644\u062f\u0631\u0627\u0633\u0629.<br \/>\n<br \/>\n<strong>4.<\/strong> \u0627\u0644\u062f\u0631\u0627\u0633\u0629 <u><em><strong>\u0633\u0631\u064a\u0629 \u0628\u0646\u0633\u0628\u0629 100%.<\/strong><\/em><\/u> \u0644\u0646 \u064a\u0639\u0631\u0641 \u0623\u062d\u062f \u0642\u0631\u0627\u0631\u0627\u062a\u0643: \u0644\u0627 \u0627\u0644\u0628\u0627\u062d\u062b\u0648\u0646 \u0648\u0644\u0627 \u0627\u0644\u0645\u0634\u0627\u0631\u0643\u0648\u0646 \u0627\u0644\u0622\u062e\u0631\u0648\u0646. \u0648\u0647\u0630\u0627 \u0635\u062d\u064a\u062d \u062d\u062a\u0649 \u0639\u0646\u062f\u0645\u0627 \u062a\u062a\u0641\u0627\u0639\u0644 \u0645\u0639 \u0627\u0644\u0645\u0634\u0627\u0631\u0643\u064a\u0646 \u0627\u0644\u0622\u062e\u0631\u064a\u0646 \u0641\u064a \u0627\u0644\u063a\u0631\u0641\u0629. \u0645\u0646 \u0623\u062c\u0644 \u0633\u062f\u0627\u062f \u0627\u0644\u0645\u0628\u0644\u063a \u0644\u0643\u060c \u064a\u0631\u062c\u0649 \u062a\u062f\u0648\u064a\u0646 \u0627\u0644\u0643\u0648\u062f \u0627\u0644\u0630\u064a \u0633\u064a\u0638\u0647\u0631 \u0639\u0644\u0649 \u0634\u0627\u0634\u062a\u0643 \u0641\u064a \u0627\u0644\u0635\u0641\u062d\u0629 \u0627\u0644\u0623\u062e\u064a\u0631\u0629 \u0645\u0646 \u0627\u0644\u062f\u0631\u0627\u0633\u0629.<br \/>\n<br \/>\n<strong>5.<\/strong> \u064a\u0645\u0646\u0639 \u0645\u0646\u0639\u0627\u064b \u0628\u0627\u062a\u0627\u064b \u0627\u0644\u062a\u0648\u0627\u0635\u0644 \u0628\u064a\u0646 \u0627\u0644\u0645\u0634\u0627\u0631\u0643\u064a\u0646\u060c \u0625\u0630\u0627 \u0643\u0627\u0646 \u0644\u062f\u064a\u0643 \u0623\u064a \u0627\u0633\u062a\u0641\u0633\u0627\u0631\u060c \u0627\u0631\u0641\u0639 \u064a\u062f\u0643 \u0648\u0633\u0646\u0642\u0648\u0645 \u0628\u0627\u0644\u0631\u062f \u0639\u0644\u064a\u0643 \u0628\u0634\u0643\u0644 \u062e\u0627\u0635.<\/span><\/div>\n"},"CS":{"QuestionText":"<div style=\"text-align: center;\"><span style=\"font-size:19px;\"><strong>Obecn\u00e1 pravidla<\/strong><br \/>\n<br \/>\n<strong>1.<\/strong> V t\u00e9to studii vyhrajete skute\u010dn\u00e9 pen\u00edze.<br \/>\nB\u011bhem cel\u00e9 studie budou v\u0161echny \u010d\u00e1stky vyj\u00e1d\u0159en\u00e9 v experiment\u00e1ln\u00edch m\u011bnov\u00fdch jednotk\u00e1ch (EMJ). Tyto EMJ budou na konci t\u00e9to studie p\u0159evedeny na hotovost v tomto kurzu:<\/span><\/div>\n\n<div style=\"text-align: center;\"><br \/>\n<span style=\"font-size:19px;\"><strong>1 EMJ = 1,5 K\u010d<\/strong><br \/>\n<br \/>\n<strong>2.<\/strong> Kolik vyhrajete bude z\u00e1viset na va\u0161ich rozhodnut\u00edch a v n\u011bkter\u00fdch p\u0159\u00edpadech i na rozhodnut\u00ed ostatn\u00edch \u00fa\u010dastn\u00edk\u016f t\u00e9to studie.<br \/>\n<br \/>\n<strong>3.<\/strong> Tato studie m\u00e1 sedm \u010d\u00e1st\u00ed. Rozhodnut\u00ed, kter\u00e1 u\u010din\u00edte v jedn\u00e9 \u010d\u00e1sti studia, neovlivn\u00ed ani va\u0161e rozhodnut\u00ed ani va\u0161e v\u00fdd\u011blky v \u017e\u00e1dn\u00e9 jin\u00e9 \u010d\u00e1sti t\u00e9to studie.<br \/>\n<br \/>\n<strong>4.<\/strong> Tato studie je <u><em><strong>100% anonymn\u00ed.<\/strong><\/em><\/u> Nikdo se nikdy nedozv\u00ed \u017e\u00e1dn\u00e9 va\u0161e rozhodnut\u00ed: ani v\u00fdzkumn\u00edci, ani ostatn\u00ed \u00fa\u010dastn\u00edci. To plat\u00ed i v p\u0159\u00edpadech, kdy budete n\u011bjak\u00fdch zp\u016fsobem interaktovat s ostatn\u00edmi \u00fa\u010dastn\u00edky v t\u00e9to m\u00edstnosti.\u00a0 Proto, abychom V\u00e1m mohli zaplatit, poznamenejte si, pros\u00edm, k\u00f3d, kter\u00fd se na va\u0161\u00ed obrazovce objev\u00ed na posledn\u00ed str\u00e1nce t\u00e9to studie.<br \/>\n<br \/>\n<strong>5.<\/strong> Jak\u00e1koli komunikace s ostatn\u00edmi \u00fa\u010dastn\u00edky je p\u0159\u00edsn\u011b zak\u00e1z\u00e1na. Pokud budete m\u00edt jak\u00fdkoli dotaz, zvedn\u011bte, pros\u00edm, ruku a my v\u00e1m odpov\u00edme v soukrom\u00ed.<\/span><\/div>\n"},"DE":{"QuestionText":"<div style=\"text-align: center;\"><span style=\"font-size:19px;\"><strong>Allgemeine Regeln<\/strong><br>\n<br>\n<strong>1. <\/strong>In dieser Studie gewinnen Sie echtes Geld.<br>\nIn der Studie sprechen wir von Monetary Units (MUs). Die MUs werden am Ende der Studie zu folgendem Kurs in Bargeld umgewandelt:<\/span><\/div><div style=\"text-align: center;\"><span style=\"font-size:19px;\"><br>\n<strong>10 MUs = 1&nbsp;SGD<\/strong><br>\n<br>\n<strong>2.<\/strong> Die H\u00f6he des Geldbetrags h\u00e4ngt von Ihren Entscheidungen in der Studie und in einigen F\u00e4llen auch von den Entscheidungen anderer Teilnehmer ab.<br>\n<br>\n<strong>3. <\/strong>Die Studie besteht aus sieben Teilen. Entscheidungen, die Sie in einem Teil der Studie treffen, haben keinen Einfluss auf Entscheidungen oder Einnahmen in einem anderen Teil der Studie.<br>\n<br>\n<strong>4.<\/strong> Die Studie ist <u><em><strong>100 % anonym. <\/strong><\/em><\/u>Niemand wird jemals Ihre Entscheidungen erfahren: Weder die Forscher noch die anderen Teilnehmer. Dies gilt sogar, wenn Sie mit anderen Teilnehmern im Raum interagieren. Um Sie zu bezahlen, notieren Sie sich bitte einen Code, der auf der letzten Seite der Studie auf Ihrem Bildschirm erscheint.<br>\n<br>\n<strong>5.<\/strong> Die Kommunikation zwischen den Teilnehmern ist streng verboten. Wenn Sie Fragen haben, heben Sie Ihre Hand und wir werden privat antworten.<\/span><\/div>"},"DE-AT":{"QuestionText":"<div style=\"text-align: center;\"><span style=\"font-size:19px;\"><strong>Allgemeine Regeln<\/strong><br \/>\n<br \/>\n<strong>1. <\/strong>In dieser Studie gewinnen Sie echtes Geld.<br \/>\nIn der Studie sprechen wir von Geldeinheiten (GE). Die GE werden am Ende der Studie zu folgendem Kurs in Bargeld umgewandelt:<\/span><\/div>\n\n<div style=\"text-align: center;\"><br \/>\n<span style=\"font-size:19px;\"><strong>10 GE = 1\u00a0EUR<\/strong><br \/>\n<br \/>\n<strong>2.<\/strong> Die H\u00f6he des Geldbetrags h\u00e4ngt von Ihren Entscheidungen in der Studie und in einigen F\u00e4llen auch von den Entscheidungen anderer Teilnehmer ab.<br \/>\n<br \/>\n<strong>3. <\/strong>Die Studie besteht aus sieben Teilen. Entscheidungen, die Sie in einem Teil der Studie treffen, haben keinen Einfluss auf Entscheidungen oder Einnahmen in einem anderen Teil der Studie.<br \/>\n<br \/>\n<strong>4.<\/strong> Die Studie ist <u><em><strong>100 % anonym<\/strong><\/em><\/u><em>. <\/em>Niemand wird jemals Ihre Entscheidungen erfahren: Weder die Forscher noch die anderen Teilnehmer. Dies gilt sogar, wenn Sie mit anderen Teilnehmern im Raum interagieren. Um Sie zu bezahlen, notieren Sie sich bitte einen Code, der auf der letzten Seite der Studie auf Ihrem Bildschirm erscheint.<br \/>\n<br \/>\n<strong>5.<\/strong> Die Kommunikation zwischen den Teilnehmern ist streng verboten. Wenn Sie Fragen haben, heben Sie Ihre Hand und wir werden privat antworten.<\/span><\/div>\n"},"DE-DE":{"QuestionText":"<div style=\"text-align: center;\"><span style=\"font-size:19px;\"><strong>Allgemeine Regeln<\/strong><br \/>\n<br \/>\n<strong>1.<\/strong> Bei dieser Studie gewinnen Sie echtes Geld.<br \/>\nIn der Studie sprechen wir von Geldeinheiten (GE). Die Geldeinheiten werden am Ende der Studie zu folgendem Kurs in Bargeld umgewandelt:<\/span><\/div>\n\n<div style=\"text-align: center;\"><br \/>\n<span style=\"font-size:19px;\"><strong>10 GE = 0.73 \u20ac<\/strong><br \/>\n<br \/>\n<strong>2.<\/strong> Die H\u00f6he des Geldbetrages h\u00e4ngt von Ihren Entscheidungen zur Studie und in einigen F\u00e4llen auch von den Entscheidungen anderer StudienteilnehmerInnen ab.<br \/>\n<br \/>\n<strong>3.<\/strong> Die Studie besteht aus sieben Teilen. Entscheidungen, die Sie in einem Teil der Studie treffen, haben keinen Einfluss auf Entscheidungen oder Einnahmen in einem anderen Teil der Studie.<br \/>\n<br \/>\n<strong>4.<\/strong> Die Studie ist <u><em><strong>100% anonym.<\/strong><\/em><\/u> Niemand wird jemals von Ihren Entscheidungen erfahren: Weder die ForscherInnen noch die anderen TeilnehmerInnen. Dies gilt sogar, wenn Sie mit anderen TeilnehmerInnen im Raum interagieren. Um zu bezahlen, notieren Sie sich bitte den Code, der auf der letzten Seite der Studie auf Ihrem Bildschirm erscheint.<br \/>\n<br \/>\n<strong>5.<\/strong> Die Kommunikation zwischen den TeilnehmerInnen ist strengstens untersagt. Wenn Sie Fragen haben, heben Sie Ihre Hand. Wir werden zu Ihnen kommen und ihre Frage beantworten.<\/span><\/div>\n"},"EL":{"QuestionText":"<div style=\"text-align: center;\"><strong>\u0393\u03b5\u03bd\u03b9\u03ba\u03bf\u03af \u03ba\u03b1\u03bd\u03cc\u03bd\u03b5\u03c2<\/strong><br \/>\n<br \/>\n<strong>1.<\/strong> \u03a3\u03b5 \u03b1\u03c5\u03c4\u03ae \u03c4\u03b7 \u03bc\u03b5\u03bb\u03ad\u03c4\u03b7, \u03b8\u03b1 \u03ba\u03b5\u03c1\u03b4\u03af\u03c3\u03b5\u03c4\u03b5 \u03c7\u03c1\u03ae\u03bc\u03b1\u03c4\u03b1 (\u03b5\u03c5\u03c1\u03ce).<br \/>\n\u0398\u03b1 \u03bc\u03b9\u03bb\u03ac\u03bc\u03b5 \u03c3\u03b5 \u03cc\u03c1\u03bf\u03c5\u03c2 \u039d\u03bf\u03bc\u03b9\u03c3\u03bc\u03b1\u03c4\u03b9\u03ba\u03ce\u03bd \u039c\u03bf\u03bd\u03ac\u03b4\u03c9\u03bd (<strong>\u039d\u039c<\/strong>). \u039f\u03b9 \u039d\u039c \u03b8\u03b1 \u03bc\u03b5\u03c4\u03b1\u03c4\u03c1\u03b1\u03c0\u03bf\u03cd\u03bd \u03c3\u03b5 \u03bc\u03b5\u03c4\u03c1\u03b7\u03c4\u03ac \u03c3\u03c4\u03bf \u03c4\u03ad\u03bb\u03bf\u03c2 \u03c4\u03b7\u03c2 \u03bc\u03b5\u03bb\u03ad\u03c4\u03b7\u03c2 \u03bc\u03b5 \u03c4\u03b7\u03bd \u03b1\u03ba\u03cc\u03bb\u03bf\u03c5\u03b8\u03b7 \u03b9\u03c3\u03bf\u03c4\u03b9\u03bc\u03af\u03b1:<\/div>\n\n<div style=\"text-align: center;\"><br \/>\n<strong>10 \u039d\u039c = 70 \u03c3\u03b5\u03bd\u03c4\u03c2<\/strong><br \/>\n<br \/>\n<strong>2.<\/strong> \u03a4\u03bf \u03c0\u03cc\u03c3\u03b1 \u03c7\u03c1\u03b7\u03bc\u03b1\u03c4\u03b1 \u03b8\u03b1 \u03ba\u03b5\u03c1\u03b4\u03af\u03c3\u03b5\u03b9 \u03ba\u03ac\u03b8\u03b5 \u03c3\u03c5\u03bc\u03bc\u03b5\u03c4\u03ad\u03c7\u03c9\u03bd \u03b8\u03b1 \u03b5\u03be\u03b1\u03c1\u03c4\u03b7\u03b8\u03b5\u03af \u03b1\u03c0\u03cc \u03c4\u03b9\u03c2 \u03b1\u03c0\u03bf\u03c6\u03ac\u03c3\u03b5\u03b9\u03c2 \u03c4\u03bf\u03c5 \u03c3\u03c4\u03b7 \u03bc\u03b5\u03bb\u03ad\u03c4\u03b7, \u03ba\u03b1\u03b9 \u03c3\u03b5 \u03bf\u03c1\u03b9\u03c3\u03bc\u03ad\u03bd\u03b5\u03c2 \u03c0\u03b5\u03c1\u03b9\u03c0\u03c4\u03ce\u03c3\u03b5\u03b9\u03c2 \u03b1\u03c0\u03cc \u03c4\u03b9\u03c2 \u03b1\u03c0\u03bf\u03c6\u03ac\u03c3\u03b5\u03b9\u03c2 \u03ac\u03bb\u03bb\u03c9\u03bd \u03c3\u03c5\u03bc\u03bc\u03b5\u03c4\u03b5\u03c7\u03cc\u03bd\u03c4\u03c9\u03bd \u03b5\u03c0\u03af\u03c3\u03b7\u03c2.<br \/>\n<br \/>\n<strong>3.<\/strong> \u0397 \u03bc\u03b5\u03bb\u03ad\u03c4\u03b7 \u03ad\u03c7\u03b5\u03b9 \u03b5\u03c0\u03c4\u03ac \u03bc\u03ad\u03c1\u03b7. \u039f\u03b9 \u03b1\u03c0\u03bf\u03c6\u03ac\u03c3\u03b5\u03b9\u03c2 \u03c0\u03bf\u03c5 \u03bb\u03b1\u03bc\u03b2\u03ac\u03bd\u03b5\u03c4\u03b5 \u03c3\u03b5 \u03ad\u03bd\u03b1 \u03bc\u03ad\u03c1\u03bf\u03c2 \u03c4\u03b7\u03c2 \u03bc\u03b5\u03bb\u03ad\u03c4\u03b7\u03c2 \u03b4\u03b5\u03bd \u03b5\u03c0\u03b7\u03c1\u03b5\u03ac\u03b6\u03bf\u03c5\u03bd \u03c4\u03b9\u03c2 \u03b1\u03c0\u03bf\u03c6\u03ac\u03c3\u03b5\u03b9\u03c2 \u03ae \u03c4\u03b1 \u03ba\u03ad\u03c1\u03b4\u03b7 \u03c3\u03b1\u03c2 \u03c3\u03c4\u03b1 \u03ac\u03bb\u03bb\u03b1 \u03bc\u03ad\u03c1\u03b7 \u03c4\u03b7\u03c2 \u03bc\u03b5\u03bb\u03ad\u03c4\u03b7\u03c2.<br \/>\n<br \/>\n<strong>4.<\/strong> \u0397 \u03bc\u03b5\u03bb\u03ad\u03c4\u03b7 \u03b5\u03af\u03bd\u03b1\u03b9 <u><em><strong>100% \u03b1\u03bd\u03ce\u03bd\u03c5\u03bc\u03b7.<\/strong><\/em><\/u> \u039a\u03b1\u03bd\u03b5\u03af\u03c2 \u03b4\u03b5\u03bd \u03b8\u03b1 \u03bc\u03ac\u03b8\u03b5\u03b9 \u03c0\u03bf\u03c4\u03ad \u03c4\u03b9\u03c2 \u03b1\u03c0\u03bf\u03c6\u03ac\u03c3\u03b5\u03b9\u03c2 \u03c3\u03b1\u03c2: \u03bf\u03cd\u03c4\u03b5 \u03bf\u03b9 \u03b5\u03c1\u03b5\u03c5\u03bd\u03b7\u03c4\u03ad\u03c2 \u03bf\u03cd\u03c4\u03b5 \u03bf\u03b9 \u03ac\u03bb\u03bb\u03bf\u03b9 \u03c3\u03c5\u03bc\u03bc\u03b5\u03c4\u03ad\u03c7\u03bf\u03bd\u03c4\u03b5\u03c2. \u0391\u03c5\u03c4\u03cc \u03b9\u03c3\u03c7\u03cd\u03b5\u03b9 \u03b1\u03ba\u03cc\u03bc\u03b7 \u03ba\u03b1\u03b9 \u03cc\u03c4\u03b1\u03bd \u03b8\u03b1 \u03c0\u03b1\u03af\u03be\u03b5\u03c4\u03b5 \u03bc\u03b5 \u03ac\u03bb\u03bb\u03bf\u03c5\u03c2 \u03c3\u03c5\u03bc\u03bc\u03b5\u03c4\u03ad\u03c7\u03bf\u03bd\u03c4\u03b5\u03c2 \u03c3\u03c4\u03b7\u03bd \u03b1\u03af\u03b8\u03bf\u03c5\u03c3\u03b1. \u0393\u03b9\u03b1 \u03bd\u03b1 \u03c3\u03b1\u03c2 \u03c0\u03bb\u03b7\u03c1\u03ce\u03c3\u03bf\u03c5\u03bc\u03b5, \u03c3\u03b7\u03bc\u03b5\u03b9\u03ce\u03c3\u03c4\u03b5 \u03ad\u03bd\u03b1\u03bd \u03ba\u03c9\u03b4\u03b9\u03ba\u03cc \u03c0\u03bf\u03c5 \u03b8\u03b1 \u03b5\u03bc\u03c6\u03b1\u03bd\u03b9\u03c3\u03c4\u03b5\u03af \u03c3\u03c4\u03b7\u03bd \u03bf\u03b8\u03cc\u03bd\u03b7 \u03c3\u03b1\u03c2 \u03c3\u03c4\u03b7\u03bd \u03c4\u03b5\u03bb\u03b5\u03c5\u03c4\u03b1\u03af\u03b1 \u03c3\u03b5\u03bb\u03af\u03b4\u03b1 \u03c4\u03b7\u03c2 \u03bc\u03b5\u03bb\u03ad\u03c4\u03b7\u03c2.<br \/>\n<br \/>\n<strong>5.<\/strong> \u0391\u03c0\u03b1\u03b3\u03bf\u03c1\u03b5\u03cd\u03b5\u03c4\u03b1\u03b9 \u03b1\u03c5\u03c3\u03c4\u03b7\u03c1\u03ac \u03b7 \u03b5\u03c0\u03b9\u03ba\u03bf\u03b9\u03bd\u03c9\u03bd\u03af\u03b1 \u03bc\u03b5\u03c4\u03b1\u03be\u03cd \u03c4\u03c9\u03bd \u03c3\u03c5\u03bc\u03bc\u03b5\u03c4\u03b5\u03c7\u03cc\u03bd\u03c4\u03c9\u03bd. \u0395\u03ac\u03bd \u03ad\u03c7\u03b5\u03c4\u03b5 \u03bf\u03c0\u03bf\u03b9\u03b5\u03c3\u03b4\u03ae\u03c0\u03bf\u03c4\u03b5 \u03b5\u03c1\u03c9\u03c4\u03ae\u03c3\u03b5\u03b9\u03c2, \u03c3\u03b7\u03ba\u03ce\u03c3\u03c4\u03b5 \u03c4\u03bf \u03c7\u03ad\u03c1\u03b9 \u03c3\u03b1\u03c2 \u03ba\u03b1\u03b9 \u03b8\u03b1 \u03b1\u03c0\u03b1\u03bd\u03c4\u03ae\u03c3\u03bf\u03c5\u03bc\u03b5 \u03ba\u03b1\u03c4' \u03b9\u03b4\u03af\u03b1\u03bd.<\/div>\n"},"EN-PAK":{"QuestionText":"<div style=\"text-align: center;\"><span style=\"font-size:19px;\"><strong>General rules<\/strong><br \/>\n<br \/>\n<strong>1. <\/strong>In this study, you will win real money.<br \/>\nIn the study, we will speak of Monetary Units (MUs). The MUs will be converted into cash at the end of the study at the following rate:<\/span><\/div>\n\n<div style=\"text-align: center;\"><br \/>\n<span style=\"font-size:19px;\"><strong>1 MUs = 8 Pakistani Ruppes<\/strong><\/span><br \/>\n<br \/>\n<span style=\"font-size:19px;\"><strong>2.<\/strong> The amount of money will depend on your decisions on the study, and in some cases on the decisions of other participants as well.<br \/>\n<br \/>\n<strong>3. <\/strong>The study has seven parts. Decisions that you make in one part of the study will not affect decisions or earnings in another part of the study.<br \/>\n<br \/>\n<strong>4.<\/strong> The study is <u><em><strong>100% anonymous. <\/strong><\/em><\/u>Nobody will ever know your decisions: Neither the researchers nor the other participants. This is true even when you interact with other participants in the room. In order to pay you, please note down a code that will appear on your screen on the final page of the study.<br \/>\n<br \/>\n<strong>5.<\/strong> Communication between the participants is strictly forbidden. If you have any questions, raise your hand and we will respond privately.<\/span><\/div>\n"},"EN-TW":{"QuestionText":"<div style=\"text-align: center;\"><span style=\"font-size:19px;\"><strong>General rules<\/strong><br \/>\n<br \/>\n<strong>1. <\/strong>In this study, you will win real money.<br \/>\nIn the study, we will speak of Monetary Units (MUs). The MUs will be converted into cash at the end of the study at the following rate:<\/span><\/div>\n\n<div style=\"text-align: center;\"><br \/>\n<span style=\"font-size:19px;\"><strong>1 MUs = 2 NTD<\/strong><br \/>\n<br \/>\n<strong>2.<\/strong> The amount of money will depend on your decisions on the study, and in some cases on the decisions of other participants as well.<br \/>\n<br \/>\n<strong>3. <\/strong>The study has seven parts. Decisions that you make in one part of the study will not affect decisions or earnings in another part of the study.<br \/>\n<br \/>\n<strong>4.<\/strong> The study is <u><em><strong>100% anonymous. <\/strong><\/em><\/u>Nobody will ever know your decisions: Neither the researchers nor the other participants. This is true even when you interact with other participants in the room. In order to pay you, please screenshot the final page of the study.<br \/>\n<br \/>\n<strong>5.<\/strong> Communication between the participants is strictly forbidden. If you have any questions, raise your hand and we will respond privately.<\/span><\/div>\n"},"EN-UK":{"QuestionText":"<div style=\"text-align: center;\"><span style=\"font-size:19px;\"><strong>General rules<\/strong><br \/>\n<br \/>\n<strong>1. <\/strong>In this study, you will earn real money.<br \/>\nIn the study, we will speak of Monetary Units (MUs). The MUs will be converted into real money at the end of the study at the following rate:<\/span><\/div>\n\n<div style=\"text-align: center;\"><br \/>\n<span style=\"font-size:19px;\"><strong>100 MUs = \u00a38.50<\/strong><br \/>\n<br \/>\n<strong>2.<\/strong> The amount of money will depend on your decisions in the study, and in some cases on the decisions of other participants as well.<br \/>\n<br \/>\n<strong>3. <\/strong>The study has seven parts. Decisions that you make in one part of the study will not affect decisions or earnings in another part of the study.<br \/>\n<br \/>\n<strong>4.<\/strong> The study is <u><em><strong>100% anonymous. <\/strong><\/em><\/u>Nobody will ever know your decisions: Neither the researchers nor the other participants. This is true even when you interact with other participants in the room. In order to pay you, please note down a code that will appear on your screen on the final page of the study. We will ask you for an email address in order to send you your money via Wise. If you do not yet have a Wise account, this is easy to set up and free of charge. You will receive an email with directions. Please ensure that the email address does not reveal your name.<br \/>\n<br \/>\n<strong>5.<\/strong> Communication between the participants is strictly forbidden. If you have any questions, raise your hand and we will respond privately.<\/span><\/div>\n"},"ES":{"QuestionText":"<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">Este estudio tiene varias partes, para las cuales se le pedir\u00e1 que tome una o m\u00e1s decisiones. Para algunas de ellas, recibir\u00e1 un pago adicional.<br \/>\nGanar\u00e1 Unidades Monetarias (UM). Las UM se convertir\u00e1n en dinero efectivo a la siguiente tasa:<br \/>\n<br \/>\n<span style=\"font-size:16px;\"><strong>1 UM = 3<span style=\"font-family:Calibri,sans-serif\"><span lang=\"ES-TRAD\"> pesos uruguayos<\/span><\/span><\/strong><\/span><br \/>\n<br \/>\nLas decisiones que se tomen en una parte del estudio no afectar\u00e1n las decisiones o ganancias en otra parte del estudio.<br \/>\n\u00a0<\/div>\n"},"ES-AR":{"QuestionText":"<div style=\"text-align: center;\"><span style=\"font-size:19px;\"><strong>Reglas generales<\/strong><br \/>\n<br \/>\n1. En este estudio, ganar\u00e1 dinero real.<br \/>\nEn el estudio hablaremos de Unidades Monetarias (UM). Las UM se convertir\u00e1n en efectivo al final del estudio a la siguiente tasa:<br \/>\n<br \/>\n<strong>1 SOL = 5 UM<\/strong><br \/>\n<br \/>\n<strong>2.<\/strong> La cantidad de dinero depender\u00e1 de sus decisiones a lo largo del estudio y, en algunos casos, tambi\u00e9n de las decisiones de otros participantes.<br \/>\n<br \/>\n3. El estudio consta de siete partes. Las decisiones que tome en una parte del estudio no afectar\u00e1n las decisiones ni los ingresos en otras partes del estudio.<br \/>\n<br \/>\n<strong>4.<\/strong> El estudio es <u><em><strong>100% an\u00f3nimo. <\/strong><\/em><\/u>Nadie sabr\u00e1 jam\u00e1s sus decisiones: ni los investigadores ni los dem\u00e1s participantes. Esto es cierto incluso cuando interact\u00fae con otros participantes en la sala. Para poder pagarle, anote un c\u00f3digo que aparecer\u00e1 en su pantalla en la p\u00e1gina final del estudio.<br \/>\n<br \/>\n<strong>5.<\/strong> Queda terminantemente prohibida la comunicaci\u00f3n entre los participantes. Si tiene alguna pregunta, levante la mano y le responderemos en privado.<\/span><\/div>\n"},"ES-ES":{"QuestionText":"<div style=\"text-align: center;\"><span style=\"font-size:19px;\"><strong>Reglas generales<\/strong><br>\n<br>\n<fuerte>1. <\/strong>En este estudio, ganar\u00e1s dinero real.<br>\nEn el estudio hablaremos de Unidades Monetarias (UM). Las MU se convertir\u00e1n en efectivo al final del estudio a la siguiente tasa:<\/span><\/div><div style=\"text-align: center;\"><span style=\"font-size:19px; \"><br>\n<strong>10 UM = 1\u00a0SGD<\/strong><br>\n<br>\n<strong>2.<\/strong> La cantidad de dinero depender\u00e1 de tus decisiones sobre el estudio y, en algunos casos, tambi\u00e9n de las decisiones de otros participantes.<br>\n<br>\n<fuerte>3. <\/strong>El estudio consta de siete partes. Las decisiones que tome en una parte del estudio no afectar\u00e1n las decisiones ni los ingresos en otra parte del estudio.<br>\n<br>\n<strong>4.<\/strong> El estudio es <u><em><strong>100% an\u00f3nimo. <\/strong><\/em><\/u>Nadie sabr\u00e1 jam\u00e1s tus decisiones: ni los investigadores ni los dem\u00e1s participantes. Esto es cierto incluso cuando interact\u00faa con otros participantes en la sala. Para poder pagarle, anote un c\u00f3digo que aparecer\u00e1 en su pantalla en la p\u00e1gina final del estudio.<br>\n<br>\n<strong>5.<\/strong> Queda terminantemente prohibida la comunicaci\u00f3n entre los participantes. Si tienes alguna pregunta, levanta la mano y te responderemos en privado.<\/span><\/div>"},"FR":{"QuestionText":"<div style=\"text-align: center;\"><span style=\"font-size:19px;\"><strong>R\u00e8gles g\u00e9n\u00e9rales<\/strong><br \/>\n<br \/>\n<strong>1.<\/strong> Dans cette \u00e9tude, vous gagnerez de l\u2019argent r\u00e9el.<br \/>\nDans l'\u00e9tude, nous parlerons d'unit\u00e9s mon\u00e9taires (UM). Les UM seront converties en esp\u00e8ces \u00e0 la fin de l'\u00e9tude au taux suivant :<\/span><\/div>\n\n<div style=\"text-align: center;\"><br \/>\n<span style=\"font-size:19px;\"><strong>1 UM = Ariary<\/strong><br \/>\n<br \/>\n<strong>2.<\/strong> Le montant des gains d\u00e9pendra de vos d\u00e9cisions concernant l\u2019\u00e9tude et, dans certains cas, des d\u00e9cisions des autres participants \u00e9galement.<br \/>\n<br \/>\n<strong>3.<\/strong> L'\u00e9tude comprend sept parties. Les d\u00e9cisions que vous prenez dans une partie de l\u2019\u00e9tude n\u2019affecteront pas les d\u00e9cisions prises ou les revenus g\u00e9n\u00e9r\u00e9s dans les autre parties.<br \/>\n<br \/>\n<strong>4.<\/strong> L'\u00e9tude est <u><em><strong>100 % anonyme.<\/strong><\/em><\/u> Personne ne conna\u00eetra jamais vos d\u00e9cisions : ni les chercheurs ni les autres participants. Cela est vrai m\u00eame lorsque vous interagissez avec d\u2019autres participants dans la salle. Pour recevoir les gains g\u00e9n\u00e9r\u00e9s vous devez noter le code qui appara<span lang=\"FR\"><span style=\"font-family:Arial\">\u00eetra sure votre \u00e9cran sur la derni\u00e8re page de ce questionnaire.\u00a0<\/span><\/span><br \/>\n<br \/>\n<strong>5.<\/strong> La communication entre les participants est strictement interdite. Si vous avez des questions, levez la main et nous y r\u00e9pondrons en priv\u00e9.<\/span><\/div>\n"},"FR-FR":{"QuestionText":"<div style=\"text-align: center;\"><span style=\"font-size:19px;\"><strong>R\u00e8gles g\u00e9n\u00e9rales<\/strong><br \/>\n<br \/>\n<fort>1. Dans cette exp\u00e9rience, vous aller gagner de l'argent r\u00e9el.<br \/>\nDans l'exp\u00e9rience, nous parlerons d'unit\u00e9s mon\u00e9taires (UM). Les UM seront converties en argent r\u00e9el \u00e0 la fin de l'exp\u00e9rience au taux suivant\u00a0:<\/fort><\/span><\/div>\n\n<div style=\"text-align: center;\"><br \/>\n<span style=\"font-size:19px; \"><strong>100 UM = 8,25\u20ac<\/strong><br \/>\n<br \/>\n<strong>2.<\/strong> Le montant de vos gains d\u00e9pendra de vos d\u00e9cisions pendant l'exp\u00e9rience. Dans certains cas, il d\u00e9pendra \u00e9galement des d\u00e9cisions des autres participants. Vous gagnerez au minimum 5\u20ac au cours de l'exp\u00e9rience.<br \/>\n<br \/>\n<strong>3. <\/strong>L'exp\u00e9rience comprend sept parties. Les d\u00e9cisions prises dans une partie de l'exp\u00e9rience n'ont pas d'effet sur la structure et les gains dans les autres parties.<br \/>\n<br \/>\n<strong>4.<\/strong> L'exp\u00e9rience est <strong>compl\u00e8tement anonyme. <\/strong>Personne ne conna\u00eetra jamais vos d\u00e9cisions : ni les chercheurs, ni les autres participants. Cela est vrai m\u00eame lorsque vous interagissez avec d\u2019autres participants dans la salle.<br \/>\n<br \/>\n<strong>5.<\/strong> La communication entre les participants est strictement interdite. Si vous avez une question, levez la main et nous viendrons vous r\u00e9pondre en priv\u00e9.<\/span><\/div>\n"},"HU":{"QuestionText":"<div style=\"text-align: center;\"><span style=\"font-size:19px;\"><strong>\u00c1ltal\u00e1nos szab\u00e1lyok<\/strong><br \/>\n<br \/>\n<strong>1.<\/strong> Ebben a kutat\u00e1sban val\u00f3di p\u00e9nzt fog keresni.<br \/>\nA kutat\u00e1s sor\u00e1n p\u00e9nzegys\u00e9gekr\u0151l (PE) fogunk besz\u00e9lni. A v\u00e9g\u00e9n a PE-ket a k\u00f6vetkez\u0151 \u00e1rfolyamon v\u00e1ltjuk k\u00e9szp\u00e9nzre:<\/span><\/div>\n\n<div style=\"text-align: center;\"><br \/>\n<span style=\"font-size:19px;\"><strong>1 PE = 18 Forint<\/strong><br \/>\n<br \/>\n<strong>2.<\/strong> A megkeresett p\u00e9nz\u00f6sszeg a kutat\u00e1s sor\u00e1n hozott d\u00f6nt\u00e9seit\u0151l, illetve bizonyos esetekben a t\u00f6bbi r\u00e9sztvev\u0151 d\u00f6nt\u00e9s\u00e9t\u0151l is f\u00fcgg.<br \/>\n<br \/>\n<strong>3.<\/strong> A kutat\u00e1s h\u00e9t r\u00e9szb\u0151l \u00e1ll. Az adott r\u00e9sz\u00e9ben hozott d\u00f6nt\u00e9sek nem befoly\u00e1solj\u00e1k a t\u00f6bbi r\u00e9szben hozott d\u00f6nt\u00e9seket vagy megkeresett p\u00e9nz\u00f6sszegeket.<br \/>\n<br \/>\n<strong>4.<\/strong> A kutat\u00e1s\u00a0<u><em><strong>100%-ban anonim.<\/strong><\/em><\/u> Soha senki nem fogja tudni, hogy \u00d6n hozta a d\u00f6nt\u00e9seket: sem a kutat\u00f3k, sem a t\u00f6bbi r\u00e9sztvev\u0151. Ez akkor is igaz, ha a teremben l\u00e9v\u0151 m\u00e1s r\u00e9sztvev\u0151kkel egy\u00fctt hoz d\u00f6nt\u00e9st. A kifizet\u00e9shez k\u00e9rj\u00fck, jegyezze fel azt a k\u00f3dot, amelyik majd az utols\u00f3 oldalon jelenik meg.<br \/>\n<br \/>\n<strong>5.<\/strong> A r\u00e9sztvev\u0151k k\u00f6z\u00f6tti kommunik\u00e1ci\u00f3 szigor\u00faan tilos. Ha k\u00e9rd\u00e9se van, emelje fel a kez\u00e9t, \u00e9s odamegy\u00fcnk \u00d6nh\u00f6z.<\/span><\/div>\n"},"IT":{"QuestionText":"<div style=\"text-align: center;\"><span style=\"font-size:19px;\"><strong>Regole generali<\/strong><br \/>\n<br \/>\n<strong>1.<\/strong> In questo studio guadagnerai soldi veri.<br \/>\nNello studio parleremo di Unit\u00e0 Monetarie (MU). Le MU verranno convertite in contanti al termine dello studio al seguente tasso:<\/span><\/div>\n\n<div style=\"text-align: center;\"><br \/>\n<span style=\"font-size:19px;\"><strong>1 MU =\u00a070 centesimi<\/strong><br \/>\n<br \/>\n<strong>2.<\/strong> L'importo del denaro dipender\u00e0 dalle tue decisioni sullo studio e, in alcuni casi, anche dalle decisioni degli altri partecipanti.<br \/>\n<br \/>\n<strong>3.<\/strong> Lo studio si compone di sette parti. Le decisioni prese in una parte dello studio non influenzeranno le decisioni o i guadagni in un'altra parte dello studio.<br \/>\n<br \/>\n<strong>4.<\/strong> Lo studio \u00e8 <u><em><strong>anonimo al 100%.<\/strong><\/em><\/u> Nessuno conoscer\u00e0 mai le tue decisioni: n\u00e9 i ricercatori n\u00e9 gli altri partecipanti. Questo \u00e8 vero anche quando interagisci con gli altri partecipanti nella stanza. Per pagarti annota un codice che apparir\u00e0 sul tuo schermo nella pagina finale dello studio.<br \/>\n<br \/>\n<strong>5.<\/strong> \u00c8 severamente vietata la comunicazione tra i partecipanti. Se hai domande alza la mano e ti risponderemo in privato.<\/span><\/div>\n"},"JA":{"QuestionText":"<div style=\"text-align: center;\"><span style=\"font-size:19px;\"><strong>\u4e00\u822c\u30eb\u30fc\u30eb<\/strong><br \/>\n<br \/>\n<strong>1. <\/strong>\u3053\u306e\u8abf\u67fb\u3067\u306f\u3001\u5b9f\u969b\u306e\u304a\u91d1\u304c\u3082\u3089\u3048\u307e\u3059\u3002<br \/>\n\u3053\u306e\u8abf\u67fb\u3067\u306f\u3001\u901a\u8ca8\u5358\u4f4d (MU) \u306b\u3064\u3044\u3066\u304a\u8a71\u3057\u307e\u3059\u3002MU \u306f\u3001\u8abf\u67fb\u7d42\u4e86\u6642\u306b\u6b21\u306e\u30ec\u30fc\u30c8\u3067\u73fe\u91d1\u306b\u5909\u63db\u3055\u308c\u307e\u3059:<\/span><\/div>\n\n<div style=\"text-align: center;\"><br \/>\n<span style=\"font-size:19px;\"><strong>1 MU = 12 \u5186<\/strong><br \/>\n<br \/>\n<strong>2.<\/strong> \u91d1\u984d\u306f\u3001\u8abf\u67fb\u306b\u95a2\u3059\u308b\u3042\u306a\u305f\u306e\u6c7a\u5b9a\u306b\u3088\u3063\u3066\u6c7a\u307e\u308a\u307e\u3059\u304c\u3001\u5834\u5408\u306b\u3088\u3063\u3066\u306f\u4ed6\u306e\u53c2\u52a0\u8005\u306e\u6c7a\u5b9a\u306b\u3088\u3063\u3066\u3082\u6c7a\u307e\u308a\u307e\u3059\u3002<br \/>\n<br \/>\n<strong>3. <\/strong>\u3053\u306e\u8abf\u67fb\u306f 7 \u3064\u306e\u30d1\u30fc\u30c8\u306b\u5206\u304b\u308c\u3066\u3044\u307e\u3059\u3002\u8abf\u67fb\u306e\u3042\u308b\u90e8\u5206\u3067\u3042\u306a\u305f\u304c\u4e0b\u3057\u305f\u6c7a\u5b9a\u306f\u3001\u8abf\u67fb\u306e\u5225\u306e\u90e8\u5206\u3067\u306e\u6c7a\u5b9a\u3084\u53ce\u5165\u306b\u306f\u5f71\u97ff\u3057\u307e\u305b\u3093\u3002<br \/>\n<br \/>\n<strong>4.<\/strong> \u8abf\u67fb\u306f <u><em><strong>100% \u533f\u540d<\/strong><\/em><\/u>\u3067\u3059\u3002\u3042\u306a\u305f\u306e\u6c7a\u5b9a\u306f\u3001\u7814\u7a76\u8005\u3082\u4ed6\u306e\u53c2\u52a0\u8005\u3082\u77e5\u308b\u3053\u3068\u306f\u3042\u308a\u307e\u305b\u3093\u3002\u540c\u3058\u90e8\u5c4b\u3067\u4ed6\u306e\u53c2\u52a0\u8005\u3068\u3084\u308a\u53d6\u308a\u3059\u308b\u5834\u5408\u3082\u540c\u69d8\u3067\u3059\u3002\u5831\u916c\u3092\u53d7\u3051\u53d6\u308b\u306b\u306f\u3001\u8abf\u67fb\u306e\u6700\u7d42\u30da\u30fc\u30b8\u3067\u753b\u9762\u306b\u8868\u793a\u3055\u308c\u308b\u30b3\u30fc\u30c9\u3092\u66f8\u304d\u7559\u3081\u3066\u304f\u3060\u3055\u3044\u3002<br \/>\n<br \/>\n<strong>5.<\/strong> \u53c2\u52a0\u8005\u9593\u306e\u30b3\u30df\u30e5\u30cb\u30b1\u30fc\u30b7\u30e7\u30f3\u306f\u56fa\u304f\u7981\u3058\u3089\u308c\u3066\u3044\u307e\u3059\u3002\u8cea\u554f\u304c\u3042\u308b\u5834\u5408\u306f\u3001\u624b\u3092\u6319\u3052\u3066\u3044\u305f\u3060\u3051\u308c\u3070\u3001\u500b\u5225\u306b\u56de\u7b54\u3044\u305f\u3057\u307e\u3059\u3002<\/span><\/div>\n"},"KO":{"QuestionText":"<div style=\"text-align: center;\"><span style=\"font-size:19px;\"><strong>\uc77c\ubc18 \uaddc\uce59<\/strong><br \/>\n<br \/>\n<strong>1. <\/strong>\uc774 \uc5f0\uad6c\uc5d0\uc11c\ub294 \uc2e4\uc81c \ub3c8\uc744 \uc5bb\uac8c \ub429\ub2c8\ub2e4.<br \/>\n\uc774 \uc5f0\uad6c\uc5d0 \uc4f0\uc774\ub294 \ud1b5\ud654 \ub2e8\uc704\ub294 MU(Monetary Units)\ub77c\uace0 \ubd80\ub985\ub2c8\ub2e4. MU\ub294 \uc5f0\uad6c\uac00 \ub05d\ub098\uba74 \ub2e4\uc74c \ube44\uc728\ub85c \ud604\uae08\uc73c\ub85c \uc804\ud658\ub429\ub2c8\ub2e4.<\/span><\/div>\n\n<div style=\"text-align: center;\"><br \/>\n<span style=\"font-size:19px;\"><strong>1 MU = 100\uc6d0<\/strong><br \/>\n<br \/>\n<strong>2.<\/strong> \uae08\uc561\uc740 \uadc0\ud558\uac00 \uc5f0\uad6c \uc9c4\ud589\uc911\uc5d0 \ud0dd\ud55c \uacb0\uc815\uc5d0 \ub530\ub77c \ub2ec\ub77c\uc9c0\uba70, \uc5b4\ub5a4 \uacbd\uc6b0\uc5d0\ub294 \ub2e4\ub978 \ucc38\uac00\uc790\uc758 \uacb0\uc815\uc5d0 \uc758\ud574\uc11c\ub3c4 \ub2ec\ub77c\uc9d1\ub2c8\ub2e4.<br \/>\n<br \/>\n<strong>3. <\/strong>\uc774 \uc5f0\uad6c\ub294 7\uac1c \ubd80\ubd84\uc73c\ub85c \uad6c\uc131\ub418\uc5b4 \uc788\uc2b5\ub2c8\ub2e4. \uc5f0\uad6c\uc758 \ud55c \ubd80\ubd84\uc5d0\uc11c \ub0b4\ub9b0 \uacb0\uc815\uc740 \uc5f0\uad6c\uc758 \ub2e4\ub978 \ubd80\ubd84\uc5d0\uc11c \ub0b4\ub9b0 \uacb0\uc815\uc774\ub098 \uc218\uc785\uc5d0 \uc601\ud5a5\uc744 \ubbf8\uce58\uc9c0 \uc54a\uc2b5\ub2c8\ub2e4.<br \/>\n<br \/>\n<strong>4.<\/strong> \uc5f0\uad6c\ub294 <u><em><strong>100% \uc775\uba85\uc785\ub2c8\ub2e4.<\/strong><\/em><\/u>\u00a0\uc544\ubb34\ub3c4 \ub2f9\uc2e0\uc758 \uacb0\uc815\uc744 \uc54c \uc218 \uc5c6\uc2b5\ub2c8\ub2e4. \uc5f0\uad6c\uc6d0\uc774\ub098 \ub2e4\ub978 \ucc38\uac00\uc790\ub3c4 \ub9c8\ucc2c\uac00\uc9c0\uc785\ub2c8\ub2e4. \ubc29\uc5d0\uc11c \ub2e4\ub978 \ucc38\uac00\uc790\uc640 \uc0c1\ud638 \uc791\uc6a9\ud560 \ub54c\uc5d0\ub3c4 \ub9c8\ucc2c\uac00\uc9c0\uc785\ub2c8\ub2e4. \uc9c0\ubd88\uc744 \ubc1b\uc73c\ub824\uba74 \uc5f0\uad6c\uc758 \ub9c8\uc9c0\ub9c9 \ud398\uc774\uc9c0\uc5d0 \uc788\ub294 \ud654\uba74\uc5d0 \ub098\ud0c0\ub0a0 \ucf54\ub4dc\ub97c \uc801\uc5b4 \ub450\uc2ed\uc2dc\uc624.<br \/>\n<br \/>\n<strong>5.<\/strong> \ucc38\uac00\uc790 \uac04\uc758 \uc18c\ud1b5\uc740 \uc5c4\uaca9\ud788 \uae08\uc9c0\ub418\uc5b4 \uc788\uc2b5\ub2c8\ub2e4. \uc9c8\ubb38\uc774 \uc788\uc73c\uba74 \uc190\uc744 \ub4e4\uc5b4 \uc8fc\uc138\uc694. \uc5f0\uad6c \uc9c4\ud589\uc790\uac00 \uac1c\ubcc4\uc801\uc73c\ub85c \ub2f5\ubcc0\ud574 \ub4dc\ub9ac\uaca0\uc2b5\ub2c8\ub2e4.<\/span><\/div>\n"},"KZ-RU":{"QuestionText":"<div style=\"text-align: center;\"><span style=\"font-size:19px;\"><strong>\u041e\u0441\u043d\u043e\u0432\u043d\u044b\u0435 \u043f\u0440\u0430\u0432\u0438\u043b\u0430<\/strong><br \/>\n<br \/>\n<strong>1.<\/strong> \u0412 \u044d\u0442\u043e\u043c \u0438\u0441\u0441\u043b\u0435\u0434\u043e\u0432\u0430\u043d\u0438\u0438 \u0432\u044b \u0432\u044b\u0438\u0433\u0440\u0430\u0435\u0442\u0435 \u0440\u0435\u0430\u043b\u044c\u043d\u044b\u0435 \u0434\u0435\u043d\u044c\u0433\u0438.<br \/>\n\u0412 \u0438\u0441\u0441\u043b\u0435\u0434\u043e\u0432\u0430\u043d\u0438\u0438 \u043c\u044b \u0431\u0443\u0434\u0435\u043c \u0433\u043e\u0432\u043e\u0440\u0438\u0442\u044c \u043e \u0434\u0435\u043d\u0435\u0436\u043d\u044b\u0445 \u0435\u0434\u0438\u043d\u0438\u0446\u0430\u0445 (\u0414\u0415). \u0414\u0415 \u0431\u0443\u0434\u0443\u0442 \u043a\u043e\u043d\u0432\u0435\u0440\u0442\u0438\u0440\u043e\u0432\u0430\u043d\u044b \u0432 \u0440\u0443\u0431\u043b\u0438 \u0432 \u043a\u043e\u043d\u0446\u0435 \u0438\u0441\u0441\u043b\u0435\u0434\u043e\u0432\u0430\u043d\u0438\u044f \u043f\u043e \u0441\u043b\u0435\u0434\u0443\u044e\u0449\u0435\u0439 \u0441\u0442\u0430\u0432\u043a\u0435:<\/span><\/div>\n\n<div style=\"text-align: center;\"><br \/>\n<span style=\"font-size:19px;\"><strong>1 \u0414\u0415 = 20 \u0442\u0435\u043d\u0433\u0435<\/strong><br \/>\n<br \/>\n<strong>2.<\/strong> \u0421\u0443\u043c\u043c\u0430 \u0434\u0435\u043d\u0435\u0433 \u0431\u0443\u0434\u0435\u0442 \u0437\u0430\u0432\u0438\u0441\u0435\u0442\u044c \u043e\u0442 \u0432\u0430\u0448\u0435\u0433\u043e \u0440\u0435\u0448\u0435\u043d\u0438\u044f \u043f\u043e \u0438\u0441\u0441\u043b\u0435\u0434\u043e\u0432\u0430\u043d\u0438\u044e, \u0430 \u0432 \u043d\u0435\u043a\u043e\u0442\u043e\u0440\u044b\u0445 \u0441\u043b\u0443\u0447\u0430\u044f\u0445 \u0438 \u043e\u0442 \u0440\u0435\u0448\u0435\u043d\u0438\u0439 \u0434\u0440\u0443\u0433\u0438\u0445 \u0443\u0447\u0430\u0441\u0442\u043d\u0438\u043a\u043e\u0432.<br \/>\n<br \/>\n<strong>3.<\/strong> \u0418\u0441\u0441\u043b\u0435\u0434\u043e\u0432\u0430\u043d\u0438\u0435 \u0441\u043e\u0441\u0442\u043e\u0438\u0442 \u0438\u0437 \u0441\u0435\u043c\u0438 \u0447\u0430\u0441\u0442\u0435\u0439. \u0420\u0435\u0448\u0435\u043d\u0438\u044f, \u043a\u043e\u0442\u043e\u0440\u044b\u0435 \u0432\u044b \u043f\u0440\u0438\u043d\u0438\u043c\u0430\u0435\u0442\u0435 \u0432 \u043e\u0434\u043d\u043e\u0439 \u0447\u0430\u0441\u0442\u0438 \u0438\u0441\u0441\u043b\u0435\u0434\u043e\u0432\u0430\u043d\u0438\u044f, \u043d\u0435 \u043f\u043e\u0432\u043b\u0438\u044f\u044e\u0442 \u043d\u0430 \u0440\u0435\u0448\u0435\u043d\u0438\u044f \u0438\u043b\u0438 \u0434\u043e\u0445\u043e\u0434\u044b \u0432 \u0434\u0440\u0443\u0433\u043e\u0439 \u0447\u0430\u0441\u0442\u0438 \u0438\u0441\u0441\u043b\u0435\u0434\u043e\u0432\u0430\u043d\u0438\u044f.<br \/>\n<br \/>\n<strong>4.<\/strong> \u0418\u0441\u0441\u043b\u0435\u0434\u043e\u0432\u0430\u043d\u0438\u0435 \u044f\u0432\u043b\u044f\u0435\u0442\u0441\u044f <u><em><strong>100% \u0430\u043d\u043e\u043d\u0438\u043c\u043d\u044b\u043c.<\/strong><\/em><\/u> \u041d\u0438\u043a\u0442\u043e \u043d\u0438\u043a\u043e\u0433\u0434\u0430 \u043d\u0435 \u0443\u0437\u043d\u0430\u0435\u0442 \u043e \u0432\u0430\u0448\u0438\u0445 \u0440\u0435\u0448\u0435\u043d\u0438\u044f\u0445: \u043d\u0438 \u0438\u0441\u0441\u043b\u0435\u0434\u043e\u0432\u0430\u0442\u0435\u043b\u0438, \u043d\u0438 \u0434\u0440\u0443\u0433\u0438\u0435 \u0443\u0447\u0430\u0441\u0442\u043d\u0438\u043a\u0438. \u042d\u0442\u043e \u0432\u0435\u0440\u043d\u043e, \u0434\u0430\u0436\u0435 \u043a\u043e\u0433\u0434\u0430 \u0432\u044b \u0432\u0437\u0430\u0438\u043c\u043e\u0434\u0435\u0439\u0441\u0442\u0432\u0443\u0435\u0442\u0435 \u0441 \u0434\u0440\u0443\u0433\u0438\u043c\u0438 \u0443\u0447\u0430\u0441\u0442\u043d\u0438\u043a\u0430\u043c\u0438 \u043a\u043e\u043c\u043d\u0430\u0442\u044b. \u0427\u0442\u043e\u0431\u044b \u0437\u0430\u043f\u043b\u0430\u0442\u0438\u0442\u044c \u0432\u0430\u043c, \u0437\u0430\u043f\u0438\u0448\u0438\u0442\u0435 \u043a\u043e\u0434, \u043a\u043e\u0442\u043e\u0440\u044b\u0439 \u043f\u043e\u044f\u0432\u0438\u0442\u0441\u044f \u043d\u0430 \u0432\u0430\u0448\u0435\u043c \u044d\u043a\u0440\u0430\u043d\u0435 \u043d\u0430 \u043f\u043e\u0441\u043b\u0435\u0434\u043d\u0435\u0439 \u0441\u0442\u0440\u0430\u043d\u0438\u0446\u0435 \u0438\u0441\u0441\u043b\u0435\u0434\u043e\u0432\u0430\u043d\u0438\u044f.<br \/>\n<br \/>\n<strong>5.<\/strong> \u041e\u0431\u0449\u0435\u043d\u0438\u0435 \u043c\u0435\u0436\u0434\u0443 \u0443\u0447\u0430\u0441\u0442\u043d\u0438\u043a\u0430\u043c\u0438 \u0441\u0442\u0440\u043e\u0433\u043e \u0437\u0430\u043f\u0440\u0435\u0449\u0435\u043d\u043e. \u0415\u0441\u043b\u0438 \u0443 \u0432\u0430\u0441 \u0435\u0441\u0442\u044c \u0432\u043e\u043f\u0440\u043e\u0441\u044b, \u043f\u043e\u0434\u043d\u0438\u043c\u0438\u0442\u0435 \u0440\u0443\u043a\u0443, \u0438 \u043c\u044b \u043e\u0442\u0432\u0435\u0442\u0438\u043c \u0412\u0430\u043c \u0432 \u043f\u0440\u0438\u0432\u0430\u0442\u043d\u043e\u043c \u043f\u043e\u0440\u044f\u0434\u043a\u0435.<\/span><\/div>\n"},"PL":{"QuestionText":"<div style=\"text-align: center;\"><span style=\"font-size:19px;\"><strong>G\u0142\u00f3wne zasady<\/strong><br \/>\n<br \/>\n<strong>1.<\/strong> W tym badaniu wygrasz prawdziwe pieni\u0105dze.<br \/>\nW badaniu b\u0119dziemy m\u00f3wi\u0107 o jednostkach monetarnych (MU). Pod koniec badania jednostki MU zostan\u0105 zamienione na got\u00f3wk\u0119 wed\u0142ug nast\u0119puj\u0105cego kursu:<\/span><\/div>\n\n<div style=\"text-align: center;\"><br \/>\n<span style=\"font-size:19px;\"><strong>1 MU = 0,25 PLN<\/strong><br \/>\n<br \/>\n<strong>2.<\/strong> Wysoko\u015b\u0107 kwoty uzale\u017cniona b\u0119dzie od Twoich decyzji w trakcie badania, a w niekt\u00f3rych przypadkach tak\u017ce od decyzji innych uczestnik\u00f3w.<br \/>\n<br \/>\n<strong>3.<\/strong> Opracowanie sk\u0142ada si\u0119 z siedmiu cz\u0119\u015bci. Decyzje podj\u0119te w jednej cz\u0119\u015bci badania nie b\u0119d\u0105 mia\u0142y wp\u0142ywu na decyzje ani zarobki w innych cz\u0119\u015bciach badania.<br \/>\n<br \/>\n<strong>4.<\/strong> Badanie jest <u><em><strong>w 100% anonimowe.<\/strong><\/em><\/u> Nikt nigdy nie b\u0119dzie zna\u0142 twoich decyzji: ani badacze, ani pozostali uczestnicy. Dzieje si\u0119 tak nawet wtedy, gdy wchodzisz w interakcj\u0119 z innymi uczestnikami pokoju. Aby dokona\u0107 p\u0142atno\u015bci, prosimy o zanotowanie kodu, kt\u00f3ry pojawi si\u0119 na ekranie na ostatniej stronie badania.<br \/>\n<br \/>\n<strong>5.<\/strong> Zabroniona jest komunikacja pomi\u0119dzy uczestnikami. Je\u015bli masz jakie\u015b pytania, podnie\u015b r\u0119k\u0119, a my odpowiemy prywatnie.<\/span><\/div>\n"},"PT":{"QuestionText":"<div><span style=\"font-size:19px;\"><strong>Regras gerais<\/strong><br \/>\n<br \/>\n<forte>1. Neste estudo, ganhar\u00e1 dinheiro real.<br \/>\nNo estudo falaremos de Unidades Monet\u00e1rias (UMs). As UMs ser\u00e3o convertidas em dinheiro no final do estudo \u00e0 seguinte taxa:<\/forte><\/span><\/div>\n\n<div><br \/>\n<span style=\"font-size:19px;\"><strong>100 UM = 6,375 \u20ac<\/strong><\/span><br \/>\n<br \/>\n<span style=\"font-size:19px; \"><strong>2.<\/strong> A quantidade de dinheiro depender\u00e1 das suas decis\u00f5es no estudo e, em alguns casos, tamb\u00e9m das decis\u00f5es de outros participantes.<br \/>\n<br \/>\n<forte>3. O estudo tem sete partes. As decis\u00f5es que tomar numa parte do estudo n\u00e3o afetar\u00e3o as decis\u00f5es ou os ganhos nas outras partes do estudo.<br \/>\n<br \/>\n<strong>4.<\/strong> O estudo \u00e9 <u><em><strong>100% an\u00f4nimo.<\/strong><\/em><\/u><strong>\u00a0<\/strong><\/forte><forte>Nunca ningu\u00e9m saber\u00e1 as suas decis\u00f5es: nem os investigadores nem os demais participantes. Isto \u00e9 verdade mesmo quando interage com outros participantes na sala. Para receber o pagamento, por favor anote o c\u00f3digo que ir\u00e1 aparecer no ecr\u00e3 da p\u00e1gina final do estudo.<\/forte><forte><br \/>\n<br \/>\n<strong>5.<\/strong> A comunica\u00e7\u00e3o entre os participantes \u00e9 estritamente proibida. Se tiver alguma d\u00favida, levante a m\u00e3o e responderemos em privado.<\/forte><\/span><\/div>\n"},"RU":{"QuestionText":"<div style=\"text-align: center;\"><span style=\"font-size:19px;\"><strong>\u041e\u0441\u043d\u043e\u0432\u043d\u044b\u0435 \u043f\u0440\u0430\u0432\u0438\u043b\u0430<\/strong><br \/>\n<br \/>\n<strong>1.<\/strong> \u0412 \u044d\u0442\u043e\u043c \u0438\u0441\u0441\u043b\u0435\u0434\u043e\u0432\u0430\u043d\u0438\u0438 \u0432\u044b \u0432\u044b\u0438\u0433\u0440\u0430\u0435\u0442\u0435 \u0440\u0435\u0430\u043b\u044c\u043d\u044b\u0435 \u0434\u0435\u043d\u044c\u0433\u0438.<br \/>\n\u0412 \u0438\u0441\u0441\u043b\u0435\u0434\u043e\u0432\u0430\u043d\u0438\u0438 \u043c\u044b \u0431\u0443\u0434\u0435\u043c \u0433\u043e\u0432\u043e\u0440\u0438\u0442\u044c \u043e \u0434\u0435\u043d\u0435\u0436\u043d\u044b\u0445 \u0435\u0434\u0438\u043d\u0438\u0446\u0430\u0445 (\u0414\u0415). \u0414\u0415 \u0431\u0443\u0434\u0443\u0442 \u043a\u043e\u043d\u0432\u0435\u0440\u0442\u0438\u0440\u043e\u0432\u0430\u043d\u044b \u0432 \u0440\u0443\u0431\u043b\u0438 \u0432 \u043a\u043e\u043d\u0446\u0435 \u0438\u0441\u0441\u043b\u0435\u0434\u043e\u0432\u0430\u043d\u0438\u044f \u043f\u043e \u0441\u043b\u0435\u0434\u0443\u044e\u0449\u0435\u0439 \u0441\u0442\u0430\u0432\u043a\u0435:<\/span><\/div>\n\n<div style=\"text-align: center;\"><br \/>\n<span style=\"font-size:19px;\"><strong>1 \u0414\u0415 = 3.35 \u0440\u0443\u0431\u043b\u044f<\/strong><br \/>\n<br \/>\n<strong>2.<\/strong> \u0421\u0443\u043c\u043c\u0430 \u0434\u0435\u043d\u0435\u0433 \u0431\u0443\u0434\u0435\u0442 \u0437\u0430\u0432\u0438\u0441\u0435\u0442\u044c \u043e\u0442 \u0432\u0430\u0448\u0435\u0433\u043e \u0440\u0435\u0448\u0435\u043d\u0438\u044f \u043f\u043e \u0438\u0441\u0441\u043b\u0435\u0434\u043e\u0432\u0430\u043d\u0438\u044e, \u0430 \u0432 \u043d\u0435\u043a\u043e\u0442\u043e\u0440\u044b\u0445 \u0441\u043b\u0443\u0447\u0430\u044f\u0445 \u0438 \u043e\u0442 \u0440\u0435\u0448\u0435\u043d\u0438\u0439 \u0434\u0440\u0443\u0433\u0438\u0445 \u0443\u0447\u0430\u0441\u0442\u043d\u0438\u043a\u043e\u0432.<br \/>\n<br \/>\n<strong>3.<\/strong> \u0418\u0441\u0441\u043b\u0435\u0434\u043e\u0432\u0430\u043d\u0438\u0435 \u0441\u043e\u0441\u0442\u043e\u0438\u0442 \u0438\u0437 \u0441\u0435\u043c\u0438 \u0447\u0430\u0441\u0442\u0435\u0439. \u0420\u0435\u0448\u0435\u043d\u0438\u044f, \u043a\u043e\u0442\u043e\u0440\u044b\u0435 \u0432\u044b \u043f\u0440\u0438\u043d\u0438\u043c\u0430\u0435\u0442\u0435 \u0432 \u043e\u0434\u043d\u043e\u0439 \u0447\u0430\u0441\u0442\u0438 \u0438\u0441\u0441\u043b\u0435\u0434\u043e\u0432\u0430\u043d\u0438\u044f, \u043d\u0435 \u043f\u043e\u0432\u043b\u0438\u044f\u044e\u0442 \u043d\u0430 \u0440\u0435\u0448\u0435\u043d\u0438\u044f \u0438\u043b\u0438 \u0434\u043e\u0445\u043e\u0434\u044b \u0432 \u0434\u0440\u0443\u0433\u043e\u0439 \u0447\u0430\u0441\u0442\u0438 \u0438\u0441\u0441\u043b\u0435\u0434\u043e\u0432\u0430\u043d\u0438\u044f.<br \/>\n<br \/>\n<strong>4.<\/strong> \u0418\u0441\u0441\u043b\u0435\u0434\u043e\u0432\u0430\u043d\u0438\u0435 \u044f\u0432\u043b\u044f\u0435\u0442\u0441\u044f <u><em><strong>100% \u0430\u043d\u043e\u043d\u0438\u043c\u043d\u044b\u043c.<\/strong><\/em><\/u> \u041d\u0438\u043a\u0442\u043e \u043d\u0438\u043a\u043e\u0433\u0434\u0430 \u043d\u0435 \u0443\u0437\u043d\u0430\u0435\u0442 \u043e \u0432\u0430\u0448\u0438\u0445 \u0440\u0435\u0448\u0435\u043d\u0438\u044f\u0445: \u043d\u0438 \u0438\u0441\u0441\u043b\u0435\u0434\u043e\u0432\u0430\u0442\u0435\u043b\u0438, \u043d\u0438 \u0434\u0440\u0443\u0433\u0438\u0435 \u0443\u0447\u0430\u0441\u0442\u043d\u0438\u043a\u0438. \u042d\u0442\u043e \u0432\u0435\u0440\u043d\u043e, \u0434\u0430\u0436\u0435 \u043a\u043e\u0433\u0434\u0430 \u0432\u044b \u0432\u0437\u0430\u0438\u043c\u043e\u0434\u0435\u0439\u0441\u0442\u0432\u0443\u0435\u0442\u0435 \u0441 \u0434\u0440\u0443\u0433\u0438\u043c\u0438 \u0443\u0447\u0430\u0441\u0442\u043d\u0438\u043a\u0430\u043c\u0438 \u043a\u043e\u043c\u043d\u0430\u0442\u044b. \u0427\u0442\u043e\u0431\u044b \u0437\u0430\u043f\u043b\u0430\u0442\u0438\u0442\u044c \u0432\u0430\u043c, \u0437\u0430\u043f\u0438\u0448\u0438\u0442\u0435 \u043a\u043e\u0434, \u043a\u043e\u0442\u043e\u0440\u044b\u0439 \u043f\u043e\u044f\u0432\u0438\u0442\u0441\u044f \u043d\u0430 \u0432\u0430\u0448\u0435\u043c \u044d\u043a\u0440\u0430\u043d\u0435 \u043d\u0430 \u043f\u043e\u0441\u043b\u0435\u0434\u043d\u0435\u0439 \u0441\u0442\u0440\u0430\u043d\u0438\u0446\u0435 \u0438\u0441\u0441\u043b\u0435\u0434\u043e\u0432\u0430\u043d\u0438\u044f.<br \/>\n<br \/>\n<strong>5.<\/strong> \u041e\u0431\u0449\u0435\u043d\u0438\u0435 \u043c\u0435\u0436\u0434\u0443 \u0443\u0447\u0430\u0441\u0442\u043d\u0438\u043a\u0430\u043c\u0438 \u0441\u0442\u0440\u043e\u0433\u043e \u0437\u0430\u043f\u0440\u0435\u0449\u0435\u043d\u043e. \u0415\u0441\u043b\u0438 \u0443 \u0432\u0430\u0441 \u0435\u0441\u0442\u044c \u0432\u043e\u043f\u0440\u043e\u0441\u044b, \u043f\u043e\u0434\u043d\u0438\u043c\u0438\u0442\u0435 \u0440\u0443\u043a\u0443, \u0438 \u043c\u044b \u043e\u0442\u0432\u0435\u0442\u0438\u043c \u0412\u0430\u043c \u0432 \u043f\u0440\u0438\u0432\u0430\u0442\u043d\u043e\u043c \u043f\u043e\u0440\u044f\u0434\u043a\u0435.<\/span><\/div>\n"},"TR":{"QuestionText":"<div style=\"text-align: center;\"><span style=\"font-size:19px;\"><strong>Genel kurallar<\/strong><br \/>\n<br \/>\n<strong>1.<\/strong> Bu deneyin sonunda ger\u00e7ek para kazanacaks\u0131n\u0131z.<br \/>\nDeneyde elde edece\u011finiz kazan\u00e7lar Deney Para Birimi (DPB) cinsinden olacakt\u0131r. DPB-T\u00fcrk Liras\u0131 kuru a\u015fa\u011f\u0131da belirtildi\u011fi gibidir:\u00a0<\/span><\/div>\n\n<div style=\"text-align: center;\"><br \/>\n<span style=\"font-size:19px;\"><strong>1 DPB = 0.85 T\u00fcrk Liras\u0131<\/strong><br \/>\n<br \/>\n<strong>2.<\/strong>\u00a0Deneyde elde edece\u011finiz kazan\u00e7, deney s\u00fcresince sizin alaca\u011f\u0131n\u0131z kararlara ve bazen de di\u011fer kat\u0131l\u0131mc\u0131lar\u0131n alaca\u011f\u0131 kararlara ba\u011fl\u0131 olacakt\u0131r.<br \/>\n<br \/>\n<strong>3.<\/strong> Deney yedi b\u00f6l\u00fcmden olu\u015fmaktad\u0131r. Deneyin bir b\u00f6l\u00fcm\u00fcnde alaca\u011f\u0131n\u0131z kararlar, di\u011fer b\u00f6l\u00fcmlerdeki kararlar\u0131 veya kazan\u00e7lar\u0131 etkilemeyecektir.<br \/>\n<br \/>\n<strong>4.<\/strong> \u00c7al\u0131\u015fma <u><em><strong>tamamen anonimdir.<\/strong><\/em><\/u>\u00a0Alaca\u011f\u0131n\u0131z kararlar ile kimlik bilgileriniz deney s\u00fcresince veya sonras\u0131nda asla e\u015fle\u015ftirilmemektedir. Deney bitti\u011finde size \u00f6deme yap\u0131labilmesi i\u00e7in l\u00fctfen \u00e7al\u0131\u015fman\u0131n son sayfas\u0131nda ekran\u0131n\u0131zda g\u00f6r\u00fcnecek size \u00f6zel kodu not edin.<br \/>\n<br \/>\n<strong>5.<\/strong> Di\u011fer kat\u0131l\u0131mc\u0131lar ile deney s\u00fcresince ileti\u015fim kurman\u0131z kesinlikle yasakt\u0131r. Herhangi bir sorunuz olursa, l\u00fctfen elinizi kald\u0131r\u0131n ve deney g\u00f6revlilerinden birinin yan\u0131n\u0131za gelmesini bekleyin. Sorular\u0131n\u0131z bireysel olarak yan\u0131tlanacakt\u0131r.<\/span><\/div>\n"},"ZH-HK":{"QuestionText":"<zh-t>\n<div style=\"text-align: center;\"><span style=\"font-size:19px;\"><strong>\u4e00\u822c\u898f\u5247<\/strong><br \/>\n<br \/>\n1. \u5be6\u9a57\u4e2d\uff0c\u6f5b\u5728\u5831\u916c\u4ee5\u00a0\u5be6\u9a57\u8ca8\u5e63\u55ae\u4f4d<strong>MU\u00a0<\/strong>\u8868\u793a\u3002\u5be6\u9a57\u7d50\u675f\u5f8c\uff0c\u60a8\u5c07\u5f97\u5230\u60a8\u65bc\u5be6\u9a57\u4e2d\u7372\u5f97\u7684<strong>MU<\/strong>\u6240\u514c\u63db\u4e4b\u6e2f\u5e63\uff08<strong>MU<\/strong>\u70ba\u672c\u5be6\u9a57\u7684\u5be6\u9a57\u8ca8\u5e63\u55ae\u4f4d\uff09\u3002<br \/>\n<br \/>\n<strong>1 MU = 0.69\u6e2f\u5e63<\/strong><br \/>\n<br \/>\n2. \u60a8\u5728\u5be6\u9a57\u4e2d\u80fd\u7372\u5f97\u7684MU\u6703\u6839\u64da\u60a8\u7684\u6c7a\u7b56\u3001\u5225\u4eba\u7684\u6c7a\u7b56\u4ee5\u53ca\u96a8\u6a5f\u6578\u6c7a\u5b9a\u3002<br \/>\n<br \/>\n3. \u5be6\u9a57\u5206\u70ba\u4e03\u500b\u90e8\u5206\u3002\u60a8\u5728\u5be6\u9a57\u4efb\u4f55\u90e8\u5206\u6240\u505a\u7684\u6c7a\u7b56\u4e0d\u6703\u5f71\u97ff\u5176\u4ed6\u90e8\u5206\u7684\u6c7a\u7b56\u6216\u5831\u916c\u3002<br \/>\n<br \/>\n4. \u5be6\u9a57\u904e\u7a0b<strong><u>\u5b8c\u5168\u533f\u540d<\/u>\u3002<\/strong>\u6c92\u6709\u4eba\u80fd\u5f97\u77e5\u60a8\u7684\u6c7a\u7b56\uff0c\u4e0d\u8ad6\u662f\u5be6\u9a57\u4eba\u54e1\u9084\u662f\u5176\u4ed6\u53d7\u8a66\u8005\uff0c\u5373\u4f7f\u60a8\u8207\u6559\u5ba4\u5167\u5176\u4ed6\u53d7\u8a66\u8005\u4e92\u52d5\u4e5f\u662f\u5982\u6b64\u3002\u70ba\u4e86\u4ed8\u6b3e\u7d66\u60a8\uff0c\u8acb\u8a18\u4e0b\u5be6\u9a57\u756b\u9762\u6700\u5f8c\u4e00\u9801\u986f\u793a\u7684\u4ee3\u78bc\u3002\u6bcf\u500b\u4eba\u90fd\u6703\u500b\u5225\u7368\u81ea\u9818\u53d6\u5831\u916c\uff0c\u60a8\u6c92\u6709\u7fa9\u52d9\u544a\u77e5\u5176\u4ed6\u4eba\u60a8\u7684\u5831\u916c\u591a\u5be1\u3002<br \/>\n<br \/>\n5. \u672c\u5be6\u9a57\u5168\u7a0b\u8acb\u52ff\u4ea4\u8ac7\u3002\u5982\u679c\u60a8\u6709\u4efb\u4f55\u554f\u984c\u8acb\u8209\u624b\uff0c\u6211\u5011\u6703\u79c1\u4e0b\u56de\u7b54\u3002<\/span><\/div>\n<\/zh-t>"},"ZH-S":{"QuestionText":"<div style=\"text-align: center;\"><span style=\"font-size:19px;\"><strong>\u4e00\u822c\u89c4\u5219<\/strong><br \/>\n<br \/>\n<strong>1. <\/strong>\u5728\u672c\u7814\u7a76\u4e2d\uff0c\u60a8\u5c06\u8d62\u5f97\u73b0\u91d1\u3002<br \/>\n\u5728\u7814\u7a76\u4e2d\uff0c\u6211\u4eec\u5c06\u4f7f\u7528\u8d27\u5e01\u5355\u4f4d (MU)\u3002\u7814\u7a76\u7ed3\u675f\u65f6\uff0cMU \u5c06\u6309\u4ee5\u4e0b\u6c47\u7387\u5151\u6362\u6210\u73b0\u91d1\uff1a<\/span><\/div>\n\n<div style=\"text-align: center;\"><br \/>\n<span style=\"font-size:19px;\"><strong>1 MU = 0.25\u00a0\u5143<\/strong><br \/>\n<br \/>\n<strong>2.<\/strong>\u00a0\u91d1\u94b1\u6570\u989d\u53d6\u51b3\u4e8e\u60a8\u5728\u7814\u7a76\u4e2d\u7684\u51b3\u7b56\uff0c\u5728\u67d0\u4e9b\u60c5\u51b5\u4e0b\u4e5f\u53d6\u51b3\u4e8e\u5176\u4ed6\u53c2\u4e0e\u8005\u7684\u51b3\u7b56\u3002<br \/>\n<br \/>\n<strong>3. <\/strong>\u672c\u7814\u7a76\u5206\u4e3a\u4e03\u4e2a\u90e8\u5206\u3002\u60a8\u5728\u7814\u7a76\u4e2d\u7684\u67d0\u4e00\u90e8\u5206\u505a\u51fa\u7684\u51b3\u7b56\u4e0d\u4f1a\u5f71\u54cd\u7814\u7a76\u4e2d\u53e6\u4e00\u90e8\u5206\u7684\u51b3\u7b56\u6216\u6536\u5165\u3002<br \/>\n<br \/>\n<strong>4.<\/strong> \u8fd9\u9879\u7814\u7a76\u662f<u><em><strong>100% \u533f\u540d\u7684\u3002<\/strong><\/em><\/u>\u6ca1\u6709\u4eba\u4f1a\u77e5\u9053\u60a8\u7684\u51b3\u7b56\uff1a\u7814\u7a76\u4eba\u5458\u548c\u5176\u4ed6\u53c2\u4e0e\u8005\u90fd\u4e0d\u77e5\u9053\u3002\u5373\u4f7f\u60a8\u4e0e\u623f\u95f4\u4e2d\u7684\u5176\u4ed6\u53c2\u4e0e\u8005\u8fdb\u884c\u8fc7\u4e92\u52a8\uff0c\u4e5f\u662f\u5982\u6b64\u3002\u4e3a\u4e86\u5411\u60a8\u4ed8\u6b3e\uff0c\u8bf7\u8bb0\u4e0b\u7814\u7a76\u6700\u540e\u4e00\u9875\u5c4f\u5e55\u4e0a\u663e\u793a\u7684\u4ee3\u7801\u3002<br \/>\n<br \/>\n<strong>5.<\/strong> \u53c2\u4e0e\u8005\u4e4b\u95f4\u7684\u4ea4\u6d41\u662f\u4e25\u683c\u7981\u6b62\u7684\u3002\u5982\u679c\u60a8\u6709\u4efb\u4f55\u7591\u95ee\uff0c\u8bf7\u4e3e\u624b\uff0c\u6211\u4eec\u5c06\u79c1\u4e0b\u56de\u590d\u3002<\/span><\/div>\n"},"ZH-T":{"QuestionText":"<div style=\"text-align: center;\"><span style=\"font-size:19px;\"><strong>\u4e00\u822c\u898f\u5247<\/strong><br \/>\n<br \/>\n1. \u5be6\u9a57\u4e2d\uff0c\u6f5b\u5728\u5831\u916c\u4ee5<strong>\u300c\u6cd5\u5e63\u300d<\/strong>\u8868\u793a\u3002\u5be6\u9a57\u7d50\u675f\u5f8c\uff0c\u60a8\u5c07\u5f97\u5230\u60a8\u65bc\u5be6\u9a57\u4e2d\u7372\u5f97\u7684<strong>\u300c\u6cd5\u5e63\u300d<\/strong>\u6240\u514c\u63db\u4e4b\u65b0\u53f0\u5e63\uff08<strong>\u300c\u6cd5\u5e63\u300d<\/strong>\u70ba\u672c\u5be6\u9a57\u7684\u5be6\u9a57\u8ca8\u5e63\u55ae\u4f4d\uff09\u3002<br \/>\n<br \/>\n<strong>1 \u6cd5\u5e63 = 2 \u65b0\u53f0\u5e63<\/strong><br \/>\n<br \/>\n2. \u60a8\u5728\u5be6\u9a57\u4e2d\u80fd\u7372\u5f97\u7684\u6cd5\u5e63\u6703\u6839\u64da\u60a8\u7684\u6c7a\u7b56\u3001\u5225\u4eba\u7684\u6c7a\u7b56\u4ee5\u53ca\u96a8\u6a5f\u4e82\u6578\u6c7a\u5b9a\u3002<br \/>\n<br \/>\n3. \u5be6\u9a57\u5206\u70ba\u4e03\u500b\u90e8\u5206\u3002\u60a8\u5728\u5be6\u9a57\u4efb\u4f55\u90e8\u5206\u6240\u505a\u7684\u6c7a\u7b56\u4e0d\u6703\u5f71\u97ff\u5176\u4ed6\u90e8\u5206\u7684\u6c7a\u7b56\u6216\u5831\u916c\u3002<br \/>\n<br \/>\n4. \u5be6\u9a57\u904e\u7a0b<strong><u>\u5b8c\u5168\u533f\u540d\u3002 <\/u><\/strong>\u6c92\u6709\u4eba\u80fd\u5f97\u77e5\u60a8\u7684\u6c7a\u7b56\uff0c\u4e0d\u8ad6\u662f\u5be6\u9a57\u4eba\u54e1\u9084\u662f\u5176\u4ed6\u53d7\u8a66\u8005\uff0c\u5373\u4f7f\u60a8\u8207\u6559\u5ba4\u5167\u5176\u4ed6\u53d7\u8a66\u8005\u4e92\u52d5\u4e5f\u662f\u5982\u6b64\u3002\u70ba\u4e86\u4ed8\u6b3e\u7d66\u60a8\uff0c\u8acb\u622a\u5716\u5be6\u9a57\u756b\u9762\u6700\u5f8c\u4e00\u9801\uff08\u6709\u60a8\u7684\u53d7\u8a66\u8005\u4ee3\u78bc\uff09\u3002\u6bcf\u500b\u4eba\u90fd\u6703\u500b\u5225\u7368\u81ea\u9818\u53d6\u5831\u916c\uff0c\u60a8\u6c92\u6709\u7fa9\u52d9\u544a\u77e5\u5176\u4ed6\u4eba\u60a8\u7684\u5831\u916c\u591a\u5be1\u3002<br \/>\n<br \/>\n5. \u672c\u5be6\u9a57\u5168\u7a0b\u8acb\u52ff\u4ea4\u8ac7\u3002\u5982\u679c\u60a8\u6709\u4efb\u4f55\u554f\u984c\u8acb\u8209\u624b\uff0c\u6211\u5011\u6703\u79c1\u4e0b\u56de\u7b54\u3002<\/span><\/div>\n"}},"NextChoiceId":18,"NextAnswerId":1,"QuestionText_Unsafe":"<div style=\"text-align: center;\"><span style=\"font-size:19px;\"><strong>General rules<\/strong><br>\n<br>\n<strong>1. <\/strong>In this study, you will win real money.<br>\nIn the study, we will speak of Monetary Units (MUs). The MUs will be converted into cash at the end of the study at the following rate:<\/span><\/div><div style=\"text-align: center;\"><span style=\"font-size:19px;\"><br>\n<strong>1 MUs = 3 Riyal<\/strong><br>\n<br>\n<strong>2.<\/strong> The amount of money will depend on your decisions on the study, and in some cases on the decisions of other participants as well.<br>\n<br>\n<strong>3. <\/strong>The study has seven parts. Decisions that you make in one part of the study will not affect decisions or earnings in another part of the study.<br>\n<br>\n<strong>4.<\/strong> The study is <u><em><strong>100% anonymous. <\/strong><\/em><\/u>Nobody will ever know your decisions: Neither the researchers nor the other participants. This is true even when you interact with other participants in the room. In order to pay you, please note down a code that will appear on your screen on the final page of the study.<br>\n<br>\n<strong>5.<\/strong> Communication between the participants is strictly forbidden. If you have any questions, raise your hand and we will respond privately.<\/span><\/div>"}},{"SurveyID":"SV_b3mHBVkuioRMhng","Element":"SQ","PrimaryAttribute":"QID20","SecondaryAttribute":"Please answer the following three questions.","T