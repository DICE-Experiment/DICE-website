":{"Display":"$e{6}"}}},"TR":{"QuestionText":"$e{10*9} + $e{6} + $e{10*7} + $e{4} = ???","Choices":{"1":{"Display":"$e{10*9+6+ 70+4}"},"2":{"Display":"$e{10*9+6+ 70+4 - ${rand:\/\/int\/1:9}}"},"3":{"Display":"$e{10*9+6+ 70+4 - ${rand:\/\/int\/1:9}}"},"4":{"Display":"$e{9*10}"},"5":{"Display":"$e{6}"}}},"ZH-HK":[],"KZ-RU":[],"AR":[],"DE-DE":{"QuestionText":"$e{10*9} + $e{6} + $e{10*7} + $e{4} = ???","Choices":{"1":{"Display":"$e{10*9+6+ 70+4}"},"2":{"Display":"$e{10*9+6+ 70+4 - ${rand:\/\/int\/1:9}}"},"3":{"Display":"$e{10*9+6+ 70+4 - ${rand:\/\/int\/1:9}}"},"4":{"Display":"$e{9*10}"},"5":{"Display":"$e{6}"}}},"ES-AR":{"QuestionText":"$e{10*9} + $e{6} + $e{10*7} + $e{4} = ???","Choices":{"1":{"Display":"$e{10*9+6+ 70+4}"},"2":{"Display":"$e{10*9+6+ 70+4 - ${rand:\/\/int\/1:9}}"},"3":{"Display":"$e{10*9+6+ 70+4 - ${rand:\/\/int\/1:9}}"},"4":{"Display":"$e{9*10}"},"5":{"Display":"$e{6}"}}}},"NextAnswerId":1,"NextChoiceId":7,"QuestionDescription":"$e{10*9} + $e{6} + $e{10*7} + $e{4} = ???","QuestionID":"QID109","QuestionText":"$e{10*9} + $e{6} + $e{10*7} + $e{4} = ???","QuestionText_Unsafe":"$e{10*9} + $e{6} + $e{10*7} + $e{4} = ???","QuestionType":"MC","Randomization":{"Advanced":null,"TotalRandSubset":"","Type":"All"},"RecodeValues":{"1":"0","2":"-1","3":"1","4":"99","5":"9"},"Selector":"SAHR","SubSelector":"TX","Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}}}},{"SurveyID":"SV_b3mHBVkuioRMhng","Element":"SQ","PrimaryAttribute":"QID11","SecondaryAttribute":"PART 2 In this part, we want you to guess what most of the people in this session (room) think it...","TertiaryAttribute":null,"Payload":{"QuestionText":"<div style=\"text-align: center;\"><b>PART 2<\/b><\/div>\n<br \/>\nIn this part, we want you to guess what most of the people in this session (room) think it is socially appropriate and what it is not. We don&#39;t want to know your opinion, but what the majority thinks is socially appropriate. If you guess correctly what the majority thinks, you will earn an additional<b> 50 MU.<\/b>","DefaultChoices":false,"DataExportTag":"Part 2_Instr1","QuestionID":"QID11","QuestionType":"DB","Selector":"TB","Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"PART 2 In this part, we want you to guess what most of the people in this session (room) think it...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":{"EL":{"QuestionText":"<div style=\"text-align: center;\"><strong>\u039c\u0395\u03a1\u039f\u03a3 2<\/strong><\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">\u03a3\u03b5 \u03b1\u03c5\u03c4\u03cc \u03c4\u03bf \u03bc\u03ad\u03c1\u03bf\u03c2, \u03b8\u03ad\u03bb\u03bf\u03c5\u03bc\u03b5 \u03bd\u03b1 \u03bc\u03b1\u03bd\u03c4\u03ad\u03c8\u03b5\u03c4\u03b5 \u03c4\u03b9 \u03c0\u03b9\u03c3\u03c4\u03b5\u03cd\u03bf\u03c5\u03bd \u03c4\u03b1 \u03c0\u03b5\u03c1\u03b9\u03c3\u03c3\u03cc\u03c4\u03b5\u03c1\u03b1 \u03ac\u03c4\u03bf\u03bc\u03b1 \u03c3\u03b5 \u03b1\u03c5\u03c4\u03ae\u03bd \u03c4\u03b7\u03bd \u03b1\u03af\u03b8\u03bf\u03c5\u03c3\u03b1 \u03cc\u03c4\u03b9 \u03b5\u03af\u03bd\u03b1\u03b9 <strong>\u03ba\u03bf\u03b9\u03bd\u03c9\u03bd\u03b9\u03ba\u03ac \u03b1\u03c0\u03bf\u03b4\u03b5\u03ba\u03c4\u03cc<\/strong> \u03ba\u03b1\u03b9 \u03c4\u03b9 \u03cc\u03c7\u03b9. \u0394\u03b5\u03bd \u03b6\u03b7\u03c4\u03ac\u03bc\u03b5 \u03bd\u03b1 \u03bc\u03ac\u03b8\u03bf\u03c5\u03bc\u03b5 \u03c4\u03b7 \u03b4\u03b9\u03ba\u03b9\u03ac \u03c3\u03b1\u03c2 \u03b3\u03bd\u03ce\u03bc\u03b7, \u03b1\u03bb\u03bb\u03ac \u03c4\u03b7\u03bd \u03b5\u03ba\u03c4\u03af\u03bc\u03b7\u03c3\u03ae \u03c3\u03b1\u03c2 \u03c3\u03c7\u03b5\u03c4\u03b9\u03ba\u03ac \u03bc\u03b5 \u03b1\u03c5\u03c4\u03cc \u03c0\u03bf\u03c5 \u03c0\u03b9\u03c3\u03c4\u03b5\u03cd\u03b5\u03b9 \u03b7 \u03c0\u03bb\u03b5\u03b9\u03bf\u03c8\u03b7\u03c6\u03af\u03b1. \u0395\u03ac\u03bd \u03bc\u03b1\u03bd\u03c4\u03ad\u03c8\u03b5\u03c4\u03b5 \u03c3\u03c9\u03c3\u03c4\u03ac \u03c4\u03b9 \u03c0\u03b9\u03c3\u03c4\u03b5\u03cd\u03b5\u03b9 \u03b7 \u03c0\u03bb\u03b5\u03b9\u03bf\u03c8\u03b7\u03c6\u03af\u03b1, \u03b8\u03b1 \u03ba\u03b5\u03c1\u03b4\u03af\u03c3\u03b5\u03c4\u03b5 \u03b5\u03c0\u03b9\u03c0\u03bb\u03ad\u03bf\u03bd <b>50 \u039d\u039c.<\/b><\/div>\n"},"ES":{"QuestionText":"<div style=\"text-align: center;\"><strong>PARTE 2<\/strong><\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">En esta parte, queremos que adivine lo que piensa la mayor\u00eda de las personas en esta sala sobre lo que es socialmente correcto e incorrecto. No queremos saber su opini\u00f3n, sino lo que piensa la mayor\u00eda. Si adivina lo que piensa la mayor\u00eda en esta sala, ganar\u00e1 usted\u00a0<strong>50 UM.<\/strong><\/div>\n"},"FR":{"QuestionText":"<div style=\"text-align: center;\"><b>PARTIE 2<\/b><\/div>\n\n<div><br \/>\n<span style=\"line-height:130%\"><span style=\"font-family:Arial\"><span lang=\"FR\" style=\"color:#525252\">Dans cette partie, nous voulons vous faire deviner et avoir votre avis sur ce que la plupart des personnes pr\u00e9sentes dans cette salle pensent de ce qui est socialement acceptable et ce qui ne l\u2019est pas.\u00a0Nous ne voulons pas directement conna\u00eetre votre opinion personnelle, mais vous devez imaginer ce que les autres pensent de ce qui est socialement acceptable. Si vous devinez correctement ce que pense la majorit\u00e9, vous gagnerez <b>50 UM <\/b>suppl\u00e9mentaires.<\/span><\/span><\/span><\/div>\n"},"CS":{"QuestionText":"<div style=\"text-align: center;\"><b>\u010c\u00c1ST 2<\/b><\/div>\n<br \/>\nV t\u00e9to \u010d\u00e1sti V\u00e1s po\u017e\u00e1d\u00e1me, abyste n\u00e1m \u0159ekl(a), co si mysl\u00edte, \u017ee v\u011bt\u0161ina lid\u00ed v t\u00e9to m\u00edstnosti pova\u017euje za spole\u010densky p\u0159ijateln\u00e9 a co ne. Nept\u00e1me se na V\u00e1\u0161 vlastn\u00ed n\u00e1zor, ale na to, co si mysl\u00edte, \u017ee v\u011bt\u0161ina pova\u017euje za spole\u010densky p\u0159ijateln\u00e9. Pokud uhodnete spr\u00e1vn\u011b, co si mysl\u00ed v\u011bt\u0161ina, z\u00edsk\u00e1te <b>50 EMJ <\/b>nav\u00edc."},"RU":{"QuestionText":"<div style=\"text-align: center;\"><b>\u0427\u0410\u0421\u0422\u042c 2<\/b><\/div>\n<br \/>\n\u0412 \u044d\u0442\u043e\u0439 \u0447\u0430\u0441\u0442\u0438 \u043c\u044b \u0445\u043e\u0442\u0438\u043c, \u0447\u0442\u043e\u0431\u044b \u0412\u044b \u0443\u0433\u0430\u0434\u0430\u043b\u0438, \u0447\u0442\u043e \u0431\u043e\u043b\u044c\u0448\u0438\u043d\u0441\u0442\u0432\u043e \u043b\u044e\u0434\u0435\u0439 \u0432 \u044d\u0442\u043e\u0439 \u044d\u043a\u0441\u043f\u0435\u0440\u0438\u043c\u0435\u043d\u0442\u0430\u043b\u044c\u043d\u043e\u0439 \u0441\u0435\u0441\u0441\u0438\u0438\u00a0 (\u043a\u043e\u043c\u043d\u0430\u0442\u0435) \u0441\u0447\u0438\u0442\u0430\u044e\u0442 \u0441\u043e\u0446\u0438\u0430\u043b\u044c\u043d\u043e \u043f\u0440\u0438\u0435\u043c\u043b\u0435\u043c\u044b\u043c, \u0430 \u0447\u0442\u043e \u043d\u0435\u0442. \u041c\u044b \u0445\u043e\u0442\u0438\u043c \u0437\u043d\u0430\u0442\u044c \u043d\u0435 \u0412\u0430\u0448\u0435 \u043c\u043d\u0435\u043d\u0438\u0435, \u0430 \u0442\u043e, \u0447\u0442\u043e, \u0441 \u0412\u0430\u0448\u0435\u0439 \u0442\u043e\u0447\u043a\u0438 \u0437\u0440\u0435\u043d\u0438\u044f, \u0431\u043e\u043b\u044c\u0448\u0438\u043d\u0441\u0442\u0432\u043e \u0441\u0447\u0438\u0442\u0430\u0435\u0442 \u0441\u043e\u0446\u0438\u0430\u043b\u044c\u043d\u043e \u043f\u0440\u0438\u0435\u043c\u043b\u0435\u043c\u044b\u043c. \u0415\u0441\u043b\u0438 \u0412\u044b \u043f\u0440\u0430\u0432\u0438\u043b\u044c\u043d\u043e \u0443\u0433\u0430\u0434\u0430\u0435\u0442\u0435, \u0447\u0442\u043e \u0434\u0443\u043c\u0430\u0435\u0442 \u0431\u043e\u043b\u044c\u0448\u0438\u043d\u0441\u0442\u0432\u043e, \u0432\u044b \u0437\u0430\u0440\u0430\u0431\u043e\u0442\u0430\u0435\u0442\u0435 \u0434\u043e\u043f\u043e\u043b\u043d\u0438\u0442\u0435\u043b\u044c\u043d\u043e <b>50 \u0414E.<\/b>"},"HU":{"QuestionText":"<div style=\"text-align: center;\"><b>2. R\u00c9SZ<\/b><\/div>\n<br \/>\nEbben a r\u00e9szben azt szeretn\u00e9nk, ha megbecs\u00fcln\u00e9, hogy a jelenl\u00e9v\u0151k t\u00f6bbs\u00e9ge szerint mi az, ami t\u00e1rsadalmilag elfogadott, \u00e9s mi az, ami nem. Nem az \u00d6n v\u00e9lem\u00e9ny\u00e9t szeretn\u00e9nk megtudni, hanem azt, hogy a t\u00f6bbs\u00e9g szerint mi t\u00e1rsadalmilag elfogadott. Ha j\u00f3l tippeli meg, hogy a t\u00f6bbs\u00e9g mit gondol, akkor tov\u00e1bbi <b>50 PE-t kap.<\/b>"},"IT":{"QuestionText":"<div style=\"text-align: center;\"><b>PARTE 2<\/b><\/div>\n<br \/>\nIn questa parte, vogliamo che indovini cosa la maggior parte delle persone in questa sessione (stanza) pensa che sia socialmente appropriato, e cosa non lo sia. Non vogliamo conoscere la tua opinione, ma ci\u00f2 che la maggioranza ritiene socialmente appropriato. Se indovini correttamente ci\u00f2 che pensa la maggioranza, guadagnerai altri <b>50 MU.<\/b>"},"PL":{"QuestionText":"<div style=\"text-align: center;\"><b>CZ\u0118\u015a\u0106 2<\/b><\/div><br \/> W tej cz\u0119\u015bci chcemy, aby\u015b zgad\u0142, co wi\u0119kszo\u015b\u0107 os\u00f3b bior\u0105cych udzia\u0142 w tej sesji (sali) uwa\u017ca za spo\u0142ecznie w\u0142a\u015bciwe, a co nie. Nie chcemy zna\u0107 Twojej opinii, ale to, co wi\u0119kszo\u015b\u0107 uwa\u017ca za spo\u0142ecznie w\u0142a\u015bciwe. Je\u015bli poprawnie odgadniesz, co my\u015bli wi\u0119kszo\u015b\u0107, zarobisz dodatkowe <b>50 MU.<\/b>"},"PT":{"QuestionText":"<div style=\"text-align: center;\"><b>PARTE 2<\/b><\/div>\n<br \/>\nNesta parte, queremos que adivinhe o que a maioria das pessoas nesta sess\u00e3o (sala) considera socialmente apropriado e o que n\u00e3o \u00e9. N\u00e3o queremos saber a sua opini\u00e3o, mas sim o que a maioria pensa que \u00e9 socialmente apropriado. Se adivinhar corretamente o que a maioria pensa, ganhar\u00e1 <strong>50 UM<\/strong> adicionais."},"ZH-S":{"QuestionText":"<div style=\"text-align: center;\"><b>\u7b2c 2 \u90e8\u5206<\/b><\/div>\n<br \/>\n\u5728\u8fd9\u4e00\u90e8\u5206\uff0c\u6211\u4eec\u5e0c\u671b\u60a8\u80fd\u731c\u6d4b\u672c\u573a\u5b9e\u9a8c\uff08\u623f\u95f4\uff09\u4e2d\u7684\u5927\u591a\u6570\u4eba\u8ba4\u4e3a\u4ec0\u4e48\u662f\u7b26\u5408\u793e\u4ea4\u89c4\u8303\u7684\uff0c\u4ec0\u4e48\u662f\u4e0d\u7b26\u5408\u793e\u4ea4\u89c4\u8303\u7684\u3002\u6211\u4eec\u4e0d\u60f3\u77e5\u9053\u60a8\u7684\u60f3\u6cd5\uff0c\u4f46\u60f3\u77e5\u9053\u5927\u591a\u6570\u4eba\u8ba4\u4e3a\u4ec0\u4e48\u662f\u7b26\u5408\u793e\u4ea4\u89c4\u8303\u7684\u3002\u5982\u679c\u60a8\u6b63\u786e\u731c\u6d4b\u51fa\u5927\u591a\u6570\u4eba\u7684\u60f3\u6cd5\uff0c\u60a8\u5c06\u83b7\u5f97\u989d\u5916\u7684<b> 50 MU\u3002<\/b>"},"FR-FR":{"QuestionText":"<div style=\"text-align: center;\"><b>PARTIE 2<\/b><\/div>\n<br \/>\nDans cette partie, vous allez devoir essayer de deviner ce que la plupart des personnes pr\u00e9sentes dans votre session de l'exp\u00e9rience pensent \u00eatre socialement appropri\u00e9 ou non. Vous ne devez pas juste donner votre opinion sur ce qui est socialement appropri\u00e9, mais essayer de pr\u00e9dire ce que pense la majorit\u00e9 des participants sur ce sujet. Si vous pr\u00e9disez correctement ce que pense la majorit\u00e9, vous gagnerez <b> 50 UM suppl\u00e9mentaires.<\/b>"},"ES-ES":{"QuestionText":"<div style=\"text-align: center;\"><b>PARTE 2<\/b><\/div>\n<br \/>\nEn esta parte, queremos que adivines qu\u00e9 es lo que la mayor\u00eda de las personas en esta sesi\u00f3n (sala) considera socialmente apropiado y qu\u00e9 no lo es. No queremos saber tu opini\u00f3n, sino lo que la mayor\u00eda piensa que es socialmente apropiado. Si adivinas correctamente lo que piensa la mayor\u00eda, ganar\u00e1s<b> 50 MU adicionales.<\/b>"},"ES-AR":{"QuestionText":"<div style=\"text-align: center;\"><b>PARTE 2<\/b><br \/>\n<br \/>\nEn esta parte, queremos que adivine qu\u00e9 es lo que la mayor\u00eda de las personas en esta sesi\u00f3n (aula) considera socialmente apropiado y qu\u00e9 no lo es. No queremos saber su opini\u00f3n, sino lo que la mayor\u00eda piensa que es socialmente apropiado. Si adivina correctamente lo que piensa la mayor\u00eda, ganar\u00e1<b>\u00a050 UM adicionales.<\/b><\/div>\n"},"JA":{"QuestionText":"<div style=\"text-align: center;\"><b>\u30d1\u30fc\u30c8 2<\/b><\/div>\n<br \/>\n\u3053\u306e\u30d1\u30fc\u30c8\u3067\u306f\u3001\u3053\u306e\u30bb\u30c3\u30b7\u30e7\u30f3 (\u90e8\u5c4b) \u306b\u3044\u308b\u307b\u3068\u3093\u3069\u306e\u4eba\u304c\u793e\u4f1a\u7684\u306b\u9069\u5207\u3060\u3068\u601d\u3046\u3053\u3068\u3068\u305d\u3046\u3067\u306a\u3044\u3068\u601d\u3046\u3053\u3068\u3092\u63a8\u6e2c\u3057\u3066\u3044\u305f\u3060\u304d\u307e\u3059\u3002\u79c1\u305f\u3061\u304c\u77e5\u308a\u305f\u3044\u306e\u306f\u3001\u3042\u306a\u305f\u306e\u610f\u898b\u3067\u306f\u306a\u304f\u3001\u5927\u591a\u6570\u306e\u4eba\u304c\u793e\u4f1a\u7684\u306b\u9069\u5207\u3060\u3068\u601d\u3046\u3053\u3068\u3067\u3059\u3002\u5927\u591a\u6570\u306e\u4eba\u304c\u8003\u3048\u3066\u3044\u308b\u3053\u3068\u3092\u6b63\u3057\u304f\u63a8\u6e2c\u3059\u308b\u3068\u3001<b> 50 MU<\/b> \u304c\u8ffd\u52a0\u3067\u7372\u5f97\u3067\u304d\u307e\u3059\u3002"},"DE":{"QuestionText":"<div style=\"text-align: center;\"><b>TEIL 2<\/b><\/div>\n<br \/>\nIn diesem Teil m\u00f6chten wir, dass Sie erraten, was die meisten Leute in dieser Sitzung (diesem Raum) f\u00fcr sozial angemessen halten und was nicht. Wir m\u00f6chten nicht Ihre Meinung wissen, sondern was die Mehrheit f\u00fcr sozial angemessen h\u00e4lt. Wenn Sie richtig erraten, was die Mehrheit denkt, erhalten Sie zus\u00e4tzlich <b>50 MU<\/b>."},"ZH-T":{"QuestionText":"<div style=\"text-align: center;\"><b>\u7b2c 2 \u90e8\u5206<\/b><\/div>\n<br \/>\n\u5728\u9019\u4e00\u90e8\u5206\uff0c\u8acb\u60a8\u63a8\u6e2c\u5728\u672c\u5834\u5be6\u9a57\uff08\u6559\u5ba4\u5167\uff09\u591a\u6578\u4eba\u5fc3\u76ee\u4e2d\uff0c\u54ea\u4e9b\u884c\u70ba\u662f\u7b26\u5408\u793e\u6703\u898f\u7bc4\u7684\uff0c\u54ea\u4e9b\u4e0d\u662f\u7b26\u5408\u793e\u6703\u898f\u7bc4\u7684\u3002\u6211\u5011\u95dc\u5fc3\u7684\u4e0d\u662f\u60a8\u500b\u4eba\u7684\u770b\u6cd5\uff0c\u800c\u662f\u591a\u6578\u4eba\u5fc3\u76ee\u4e2d\u7684\u793e\u6703\u898f\u7bc4\u3002\u5982\u679c\u60a8\u731c\u4e2d\u591a\u6578\u4eba\u7684\u60f3\u6cd5\uff0c\u60a8\u6703\u984d\u5916\u7372\u5f97<b> 50 \u6cd5\u5e63\u3002<\/b>"},"KO":{"QuestionText":"<div style=\"text-align: center;\"><b>2\ubd80<\/b><\/div>\n<br \/>\n2\ubd80\uc5d0\uc11c\ub294 \uc774 \uc138\uc158(\ubc29)\uc5d0 \uc788\ub294 \uc0ac\ub78c\ub4e4\uc774 \uc0ac\ud68c\uc801\uc73c\ub85c \uc801\uc808\ud558\ub2e4\uace0 \uc0dd\uac01\ud558\ub294 \uac83\uacfc \uadf8\ub807\uc9c0 \uc54a\ub2e4\uace0 \uc0dd\uac01\ud558\ub294 \uac83\uc744 \ucd94\uce21\ud558\uac8c \ub429\ub2c8\ub2e4. \uc6b0\ub9ac\ub294 \uc5ec\ub7ec\ubd84\uc758 \uac1c\uac1c\uc778\uc758 \uc758\uacac\uc774 \uc544\ub2c8\ub77c, \ub300\ub2e4\uc218\uac00 \uc0ac\ud68c\uc801\uc73c\ub85c \uc801\uc808\ud558\ub2e4\uace0 \uc0dd\uac01\ud558\ub294 \uac83\uc774 \ubb34\uc5c7\uc778\uc9c0 \uc54c\uace0\uc790 \ud569\ub2c8\ub2e4. \ub300\ub2e4\uc218\uac00 \uc0dd\uac01\ud558\ub294 \uac83\uc744 \uc815\ud655\ud558\uac8c \ucd94\uce21\ud558\uba74 \ucd94\uac00\ub85c <b> 50 MU<\/b>\ub97c \ud68d\ub4dd\ud558\uac8c \ub429\ub2c8\ub2e4."},"DE-AT":{"QuestionText":"<div style=\"text-align: center;\"><b>TEIL 2<\/b><\/div>\n<br \/>\nIn diesem Teil bitten wir Sie zu sch\u00e4tzen, was die meisten Leute in dieser Sitzung (diesem Raum) f\u00fcr sozial angemessen halten und was nicht. Wir m\u00f6chten nicht Ihre Meinung wissen, sondern was die Mehrheit f\u00fcr sozial angemessen h\u00e4lt. Wenn Sie richtig erraten, was die Mehrheit denkt, erhalten Sie zus\u00e4tzlich <b>50 GE<\/b>."},"TR":{"QuestionText":"<div style=\"text-align: center;\"><b>B\u00d6L\u00dcM 2<\/b><\/div>\n<br \/>\nBu b\u00f6l\u00fcmde, bu seanstaki kat\u0131l\u0131mc\u0131lar\u0131n \u00e7o\u011funlu\u011funun, neyin toplumsal olarak uygun ve neyin toplumsal olarak uygun olmad\u0131\u011f\u0131 hakk\u0131ndaki g\u00f6r\u00fc\u015flerini tahmin etmenizi istiyoruz. Bildirmeniz gereken, belirtilen durumlara dair sizin kendi fikriniz de\u011fil, bu deneye kat\u0131lanlar\u0131n \u00e7o\u011funlu\u011funun ne d\u00fc\u015f\u00fcnd\u00fc\u011f\u00fcne dair tahmininizdir. \u00c7o\u011funlu\u011fun ne d\u00fc\u015f\u00fcnd\u00fc\u011f\u00fcn\u00fc do\u011fru tahmin ederseniz, ek olarak <b>50 DPB kazanacaks\u0131n\u0131z.<\/b>"},"EN-UK":{"QuestionText":"<div style=\"text-align: center;\"><b>PART 2<\/b><\/div>\n<br \/>\nIn this part, we want you to guess what most of the people in this session (room) think is socially appropriate and what is not. We don't want to know your opinion, but <strong>what you think the majority thinks<\/strong> is socially appropriate. If you guess correctly what the majority thinks, you will earn an additional<b> 50 MU.<\/b>"},"ZH-HK":{"QuestionText":"<div style=\"text-align: center;\"><b>\u7b2c\u4e8c\u90e8\u5206<\/b><\/div>\n\u00a0\n\n<p>\u60a8\u63a8\u6e2c\u5728\u672c\u5834\u5be6\u9a57\uff08\u6559\u5ba4\u5167\uff09\u591a\u6578\u4eba\u5fc3\u76ee\u4e2d\uff0c\u54ea\u4e9b\u884c\u70ba\u662f\u7b26\u5408\u793e\u6703\u898f\u7bc4\u7684\uff0c\u54ea\u4e9b\u4e0d\u662f\u7b26\u5408\u793e\u6703\u898f\u7bc4\u7684\u3002\u6211\u5011\u95dc\u5fc3\u7684\u4e0d\u662f\u60a8\u500b\u4eba\u7684\u770b\u6cd5\uff0c\u800c\u662f\u591a\u6578\u4eba\u5fc3\u76ee\u4e2d\u7684\u793e\u6703\u898f\u7bc4\u3002\u5982\u679c\u60a8\u731c\u4e2d\u591a\u6578\u4eba\u7684\u60f3\u6cd5\uff0c\u60a8\u6703\u984d\u5916\u7372\u5f97<b>50 MU\u3002<\/b><\/p>\n"},"KZ-RU":[],"AR":{"QuestionText":"<div style=\"text-align: center;;text-align:right;direction:rtl\"><b>\u0627\u0644\u062c\u0632\u0621 \u0627\u0644\u062b\u0627\u0646\u064a<\/b><\/div>\n<br \/>\n\u0641\u064a \u0647\u0630\u0627 \u0627\u0644\u062c\u0632\u0621\u060c \u0646\u0631\u064a\u062f \u0645\u0646\u0643 \u0623\u0646 \u062a\u062e\u0645\u0646 \u0645\u0627 \u064a\u0639\u062a\u0642\u062f\u0647 \u0623\u063a\u0644\u0628 \u0627\u0644\u0623\u0634\u062e\u0627\u0635 \u0641\u064a \u0647\u0630\u0647 \u0627\u0644\u062c\u0644\u0633\u0629 (\u0627\u0644\u063a\u0631\u0641\u0629) \u0623\u0646\u0647 \u0645\u0646\u0627\u0633\u0628 \u0623\u0648 \u063a\u064a\u0631 \u0645\u0646\u0627\u0633\u0628 \u0627\u062c\u062a\u0645\u0627\u0639\u064a\u064b\u0627. \u0644\u0627 \u0646\u0631\u064a\u062f \u0623\u0646 \u0646\u0639\u0631\u0641 \u0631\u0623\u064a\u0643\u060c \u0628\u0644 \u0645\u0627 \u064a\u0639\u062a\u0642\u062f\u0647 \u0627\u0644\u0623\u063a\u0644\u0628\u064a\u0629 \u0623\u0646\u0647 \u0645\u0646\u0627\u0633\u0628 \u0627\u062c\u062a\u0645\u0627\u0639\u064a\u064b\u0627. \u0625\u0630\u0627 \u0643\u0627\u0646 \u062a\u062e\u0645\u064a\u0646\u0643 \u0635\u062d\u064a\u062d\u0627 \u0628\u0634\u0623\u0646 \u0645\u0627 \u064a\u0639\u062a\u0642\u062f\u0647 \u0627\u0644\u0623\u063a\u0644\u0628\u064a\u0629\u060c \u0641\u0633\u062a\u0631\u0628\u062d <b>50 \u0648\u062d\u062f\u0629 \u0646\u0642\u062f\u064a\u0629 \u0625\u0636\u0627\u0641\u064a\u0629.<\/b>"},"DE-DE":{"QuestionText":"<div style=\"text-align: center;\"><b>TEIL 2<\/b><\/div>\n<br \/>\nIn diesem Teil m\u00f6chten wir, dass Sie erraten, was die Mehrheit der Personen in dieser Sitzung (diesem Raum) f\u00fcr sozial angemessen h\u00e4lt und was nicht. Wir m\u00f6chten nicht Ihre Meinung wissen, sondern was die Mehrheit f\u00fcr sozial angemessen h\u00e4lt. Wenn Sie richtig erraten, was die Mehrheit denkt, erhalten Sie zus\u00e4tzlich <b>50 GE.<\/b>"}},"NextChoiceId":4,"NextAnswerId":1,"DataVisibility":{"Private":false,"Hidden":false},"QuestionText_Unsafe":"<div style=\"text-align: center;\"><b>PART 2<\/b><\/div>\n<br \/>\nIn this part, we want you to guess what most of the people in this session (room) think it is socially appropriate and what it is not. We don&#39;t want to know your opinion, but what the majority thinks is socially appropriate. If you guess correctly what the majority thinks, you will earn an additional<b> 50 MU.<\/b>"}},{"SurveyID":"SV_b3mHBVkuioRMhng","Element":"SQ","PrimaryAttribute"