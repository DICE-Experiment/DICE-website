627f\u64d4\uff1f","Choices":{"4":{"Display":"<strong>\u6b77\u53f2\u4e0a<\/strong>\u6392\u653e\u5927\u91cf\u4e8c\u6c27\u5316\u78b3\u5230\u5927\u6c23\u5c64\u7684\u570b\u5bb6\u3002"},"5":{"Display":"<strong>\u76ee\u524d<\/strong>\u6392\u653e\u5927\u91cf\u4e8c\u6c27\u5316\u78b3\u5230\u5927\u6c23\u5c64\u7684\u570b\u5bb6"},"6":{"Display":"\u6240\u6709\u570b\u5bb6\u61c9\u8a72\u505a\u51fa<strong>\u5e73\u7b49<\/strong>\u7684\u8ca2\u737b"},"7":{"Display":"\u6240\u6709\u570b\u5bb6\u90fd\u61c9\u8a72\u6839\u64da\u5404\u81ea\u7684\u7e3d\u9ad4 GDP\uff08\u5e73\u5747\u6536\u5165\u6c34\u6e96\uff09\uff0c<strong>\u6309\u6bd4\u4f8b<\/strong>\u8ca2\u737b\u3002"},"8":{"Display":"\u53d7\u6c23\u5019\u8b8a\u9077\u5f71\u97ff<strong>\u6700\u56b4\u91cd<\/strong>\u7684\u570b\u5bb6"},"9":{"Display":"\u6bcf\u500b\u570b\u5bb6\u90fd\u61c9\u8a72<strong>\u81ea\u7531<\/strong>\u6c7a\u5b9a\u8ca2\u737b\u591a\u5c11"}},"Answers":{"1":{"Display":"\u5f37\u70c8\u53cd\u5c0d"},"2":{"Display":"\u53cd\u5c0d"},"3":{"Display":"\u65e2\u4e0d\u540c\u610f\u4e5f\u4e0d\u53cd\u5c0d"},"4":{"Display":"\u540c\u610f"},"5":{"Display":"\u5f37\u70c8\u540c\u610f"}}},"KO":{"QuestionText":"\ub9c8\uc9c0\ub9c9\uc73c\ub85c, \uae30\ud6c4 \ubcc0\ud654\ub97c \uc644\ud654\ud558\uae30 \uc704\ud574\uc11c\ub294 \uc5d0\ub108\uc9c0 \uc18c\ube44 \uac10\uc18c\ub098 \uccad\uc815 \uc5d0\ub108\uc9c0 \ucc3d\ucd9c\uc744 \uc704\ud55c \ub300\uaddc\ubaa8 \ud22c\uc790\uc640 \uac19\uc740 \ud070 \uae08\uc804\uc801 \ube44\uc6a9\uc774 \uc694\uad6c\ub429\ub2c8\ub2e4. \ub204\uac00 \uc774\ub7ec\ud55c \ube44\uc6a9\uc744 \ubd80\ub2f4\ud574\uc57c \ud55c\ub2e4\uace0 \uc0dd\uac01\ud558\uc2ed\ub2c8\uae4c?","Choices":{"4":{"Display":"<strong>\uc9c0\uae08\uae4c\uc9c0\u00a0<\/strong>\ub300\uae30 \uc911\uc73c\ub85c \ub9ce\uc740 \uc591\uc758 \uc774\uc0b0\ud654\ud0c4\uc18c\ub97c \ubc30\ucd9c\ud55c \uad6d\uac00"},"5":{"Display":"<strong>\ud604\uc7ac<\/strong> \ub300\uae30 \uc911\uc73c\ub85c \ub9ce\uc740 \uc591\uc758 \uc774\uc0b0\ud654\ud0c4\uc18c\ub97c \ubc30\ucd9c\ud558\ua