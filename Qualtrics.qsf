c1\u03b9\u03b8\u03bc\u03cc 3 (30 \u039d\u039c \u03b3\u03b9\u03b1 \u03c4\u03bf \u03ac\u03c4\u03bf\u03bc\u03bf \u0391)"},"2":{"Display":"...\u03ba\u03b1\u03b9 \u03b4\u03ae\u03bb\u03c9\u03c3\u03b5 \u03c4\u03bf\u03bd \u03b1\u03c1\u03b9\u03b8\u03bc\u03cc 4 (40 \u039d\u039c \u03b3\u03b9\u03b1 \u03c4\u03bf \u03ac\u03c4\u03bf\u03bc\u03bf \u0391)"},"3":{"Display":"...\u03ba\u03b1\u03b9 \u03b4\u03ae\u03bb\u03c9\u03c3\u03b5 \u03c4\u03bf\u03bd \u03b1\u03c1\u03b9\u03b8\u03bc\u03cc 5 (50 \u039d\u039c \u03b3\u03b9\u03b1 \u03c4\u03bf \u03ac\u03c4\u03bf\u03bc\u03bf \u0391)"}},"Answers":{"1":{"Display":"\u03a0\u03bf\u03bb\u03cd \u03ba\u03bf\u03b9\u03bd\u03c9\u03bd\u03b9\u03ba\u03ac <strong>\u03b1<\/strong>\u03ba\u03b1\u03c4\u03ac\u03bb\u03bb\u03b7\u03bb\u03bf"},"2":{"Display":"\u039a\u03ac\u03c0\u03c9\u03c2 \u03ba\u03bf\u03b9\u03bd\u03c9\u03bd\u03b9\u03ba\u03ac <strong>\u03b1<\/strong>\u03ba\u03b1\u03c4\u03ac\u03bb\u03bb\u03b7\u03bb\u03bf"},"3":{"Display":"\u039a\u03ac\u03c0\u03c9\u03c2 \u03ba\u03bf\u03b9\u03bd\u03c9\u03bd\u03b9\u03ba\u03ac \u03ba\u03b1\u03c4\u03ac\u03bb\u03bb\u03b7\u03bb\u03bf"},"4":{"Display":"\u03a0\u03bf\u03bb\u03cd \u03ba\u03bf\u03b9\u03bd\u03c9\u03bd\u03b9\u03ba\u03ac \u03ba\u03b1\u03c4\u03ac\u03bb\u03bb\u03b7\u03bb\u03bf"}}},"FR":{"QuestionText":"<div style=\"text-align: center;\"><b>Situation 4.<\/b><\/div>\nSupposons que l'individu A ait obtenu le chiffre <strong>\u00ab 3 \u00bb<\/strong> lors du jeu de d\u00e9s pr\u00e9c\u00e9dent,","Choices":{"1":{"Display":"...et a r\u00e9pondu au chiffre 3 (30 UM pour l'individu A)"},"2":{"Display":"...et a r\u00e9pondu au chiffre 4 (40 UM pour l'individu A)"},"3":{"Display":"...et a r\u00e9pondu au chiffre 5 (50 UM pour l'individu A)"}},"Answers":{"1":{"Display":"Socialement inacceptable"},"2":{"Display":"Socialement peu acceptable"},"3":{"Display":"Socialement acceptable"},"4":{"Display":"Socialement tout \u00e0 fait acceptable"}}},"CS":{"QuestionText":"<div style=\"text-align: center;\"><b>Situace 4.<\/b><\/div>\nP\u0159edstavte si, \u017ee osoba A hodila v \u010c\u00e1sti 1 \u010d\u00edslo\u00a0<strong>\u201e3\u201c<\/strong>","Choices":{"1":{"Display":"...a uvedla, \u017ee hodila \u010d\u00edslo 3 (a obdr\u017eela tak 30 EMJ)"},"2":{"Display":"...a uvedla, \u017ee hodila \u010d\u00edslo 4 (a obdr\u017eela tak 40 EMJ)"},"3":{"Display":"...a uvedla, \u017ee hodila \u010d\u00edslo 5 (a obdr\u017eela tak 50 EMJ)"}},"Answers":{"1":{"Display":"Spole\u010densky rozhodn\u011b nep\u0159ijateln\u00e9"},"2":{"Display":"Spole\u010densky\u00a0pon\u011bkud nep\u0159ijateln\u00e9"},"3":{"Display":"Spole\u010densky\u00a0pon\u011bkud p\u0159ijateln\u00e9"},"4":{"Display":"Spole\u010densky\u00a0rozhodn\u011b p\u0159ijateln\u00e9"}}},"RU":{"QuestionText":"<div style=\"text-align: center;\"><strong>\u0421\u0438\u0442\u0443\u0430\u0446\u0438\u044f 4.<\/strong><\/div>\n\u041f\u0440\u0435\u0434\u043f\u043e\u043b\u043e\u0436\u0438\u043c, \u0447\u0442\u043e \u0443 \u0447\u0435\u043b\u043e\u0432\u0435\u043a\u0430 \u0410 \u0432 \u0445\u043e\u0434\u0435 \u0438\u0433\u0440\u044b \u043d\u0430 \u0438\u0433\u0440\u0430\u043b\u044c\u043d\u043e\u0439 \u043a\u043e\u0441\u0442\u0438 \u0432\u044b\u043f\u0430\u043b\u043e \u0447\u0438\u0441\u043b\u043e <strong>\u00ab3\u00bb<\/strong>, \u0438 \u043e\u043d(\u0430)","Choices":{"1":{"Display":"...\u0441\u043e\u043e\u0431\u0449\u0438\u043b(\u0430) \u0447\u0442\u043e \u0432\u044b\u043f\u0430\u043b\u043e \u0447\u0438\u0441\u043b\u043e 3 (30 \u0414\u0415 \u0434\u043b\u044f \u0447\u0435\u043b\u043e\u0432\u0435\u043a\u0430 \u0410)"},"2":{"Display":"...\u0441\u043e\u043e\u0431\u0449\u0438\u043b(\u0430) \u0447\u0442\u043e \u0432\u044b\u043f\u0430\u043b\u043e \u0447\u0438\u0441\u043b\u043e 4 (40 \u0414\u0415 \u0434\u043b\u044f \u0447\u0435\u043b\u043e\u0432\u0435\u043a\u0430 \u0410)"},"3":{"Display":"...\u0441\u043e\u043e\u0431\u0449\u0438\u043b(\u0430) \u0447\u0442\u043e \u0432\u044b\u043f\u0430\u043b\u043e \u0447\u0438\u0441\u043b\u043e 5 (50 \u0414\u0415 \u0434\u043b\u044f \