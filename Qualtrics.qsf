9*10+8}"},"4":{"Display":"$e{9*10}"},"5":{"Display":"$e{8}"}}}},"NextAnswerId":1,"NextChoiceId":6,"QuestionDescription":"$e{9*10} + $e{8} = ???","QuestionID":"QID96","QuestionText":"$e{9*10} + $e{8} = ???","QuestionText_Unsafe":"$e{9*10} + $e{8} = ???","QuestionType":"MC","Randomization":{"Advanced":null,"TotalRandSubset":"","Type":"All"},"RecodeValues":{"1":"0","2":"-1","3":"1","4":"99","5":"9"},"Selector":"SAHR","SubSelector":"TX","Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}}}},{"SurveyID":"SV_b3mHBVkuioRMhng","Element":"SQ","PrimaryAttribute":"QID97","SecondaryAttribute":"Timing","TertiaryAttribute":null,"Payload":{"QuestionText":"Timing","DefaultChoices":false,"DataExportTag":"sum2.32","QuestionID":"QID97","QuestionType":"Timing","Selector":"PageTimer","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","Seconds":20},"QuestionDescription":"Timing","Choices":{"1":{"Display":"First Click"},"2":{"Display":"Last Click"},"3":{"Display":"Page Submit"},"4":{"Display":"Click Count"}},"Validation":"None","GradingData":[],"Language":{"ES":{"QuestionText":"Momento"}},"NextChoiceId":204,"NextAnswerId":1}},{"SurveyID":"SV_b3mHBVkuioRMhng","Element":"SQ","PrimaryAttribute":"QID98","SecondaryAttribute":"The first block is now over. You will now begin the second one. It has 10 more questions and it l...","TertiaryAttribute":null,"Payload":{"ChoiceOrder":[],"Configuration":{"QuestionDescriptionOption":"UseText"},"DataExportTag":"RestBetweenMaths np","DataVisibility":{"Hidden":false,"Private":false},"DefaultChoices":false,"GradingData":[],"Language":{"ES":{"QuestionText":"<div style=\"text-align: center;\">El primer bloque ya ha terminado. Ahora comenzar\u00e1 el segundo.<br \/>\nTiene 10 preguntas m\u00e1s y dura 20 segundos.<br \/>\n<br \/>\n\u00bfListo\/a?<\/div>\n"},"EL":{"QuestionText":"<div style=\"text-align: center;\">\u03a4\u03bf \u03c0\u03c1\u03ce\u03c4\u03bf \u03bc\u03c0\u03bb\u03bf\u03ba \u03c4\u03ad\u03bb\u03b5\u03b9\u03c9\u03c3\u03b5. \u03a4\u03ce\u03c1\u03b1 \u03b8\u03b1 \u03be\u03b5\u03ba\u03b9\u03bd\u03ae\u03c3\u03b5\u03c4\u03b5 \u03c4\u03bf \u03b4\u03b5\u03cd\u03c4\u03b5\u03c1\u03bf.<br \/>\n\u0388\u03c7\u03b5\u03b9 \u03b1\u03ba\u03cc\u03bc\u03b1 10 \u03b5\u03c1\u03c9\u03c4\u03ae\u03c3\u03b5\u03b9\u03c2 \u03ba\u03b1\u03b9 \u03b4\u03b9\u03b1\u03c1\u03ba\u03b5\u03af \u03be\u03b1\u03bd\u03ac 20 \u03b4\u03b5\u03c5\u03c4\u03b5\u03c1\u03cc\u03bb\u03b5\u03c0\u03c4\u03b1.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">'\u0395\u03c4\u03bf\u03b9\u03bc\u03bf\u03b9?<\/div>\n"},"FR":{"QuestionText":"<div style=\"text-align: center;\">Le premier bloc est d\u00e9sormais termin\u00e9. Vous allez maintenant commencer le deuxi\u00e8me.<br> Il comporte 10 questions suppl\u00e9mentaires et dure 20 secondes.<\/div><div style=\"text-align: center;\"><br><\/div><div style=\"text-align: center;\"> Pr\u00eat?<\/div>"},"CS":{"QuestionText":"<div style=\"text-align: center;\">Prvn\u00ed blok je nyn\u00ed u konce. Nyn\u00ed za\u010dnete blok druh\u00fd.<br \/>\nSkl\u00e1d\u00e1 se z 10 dal\u0161\u00edch ot\u00e1zek a trv\u00e1 20 sekund.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">P\u0159ipraven(a)?<\/div>\n"},"RU":{"QuestionText":"<div style=\"text-align: center;\">\u041f\u0435\u0440\u0432\u044b\u0439 \u0431\u043b\u043e\u043a \u0443\u0436\u0435 \u043f\u043e\u0437\u0430\u0434\u0438. \u0422\u0435\u043f\u0435\u0440\u044c \u0432\u044b \u043f\u0440\u0438\u0441\u0442\u0443\u043f\u0430\u0435\u0442\u0435 \u043a\u043e \u0432\u0442\u043e\u0440\u043e\u043c\u0443.<br \/>\n\u0412 \u043d\u0435\u043c \u0435\u0449\u0435 10 \u0432\u043e\u043f\u0440\u043e\u0441\u043e\u0432 \u0438 \u043e\u043d \u0434\u043b\u0438\u0442\u0441\u044f 20 \u0441\u0435\u043a\u0443\u043d\u0434.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">\u0413\u043e\u0442\u043e\u0432\u044b?<\/div>\n"},"HU":{"QuestionText":"<div style=\"text-align: center;\">Az els\u0151 blokk v\u00e9get \u00e9rt. Most j\u00f6n a m\u00e1sodik.<br \/>\nEbben is 10 k\u00e9rd\u00e9s lesz, \u00e9s 20 m\u00e1sodpercig tart.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">K\u00e9szen \u00e1ll?<\/div>\n"},"IT":{"QuestionText":"<div style=\"text-align: center;\">Il primo blocco \u00e8 ormai terminato. Ora inizierai il secondo.<br> Ha altre 10 domande e dura 20 secondi.<\/div><div style=\"text-align: center;\"><br><\/div><div style=\"text-align: center;\"> Pronto?<\/div>"},"PL":{"QuestionText":"<div style=\"text-align: center;\">Pierwszy blok ju\u017c za nami. Teraz zaczniesz drugi.<br> Zawiera 10 dodatkowych pyta\u0144 i trwa 20 sekund.<\/div><div style=\"text-align: center;\"><br><\/div><div style=\"text-align: center;\"> Gotowy?<\/div>"},"PT":{"QuestionText":"<div style=\"text-align: center;\">O primeiro bloco acabou. Agora come\u00e7ar\u00e1 o segundo bloco.<br \/>\nTem mais 10 perguntas com a dura\u00e7\u00e3o de 20 segundos.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">Preparado?<\/div>\n"},"ZH-S":{"QuestionText":"<div style=\"text-align: center;\">\u7b2c\u4e00\u7ec4\u95ee\u9898\u73b0\u5df2\u7ed3\u675f\u3002\u73b0\u5728\u60a8\u5c06\u5f00\u59cb\u7b2c\u4e8c\u7ec4\u95ee\u9898\u3002<br \/>\n\u5b83\u8fd8\u6709 10 \u4e2a\u95ee\u9898\uff0c\u6301\u7eed 20 \u79d2\u3002<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">\u51c6\u5907\u597d\u4e86\u5417\uff1f<\/div>\n"},"FR-FR":{"QuestionText":"<div style=\"text-align: center;\">Le premier bloc est maintenant termin\u00e9. Lorsque vous \u00eates pr\u00eat, vous pourrez passez au second bloc.<br \/>\nIl contient 10\u00a0questions suppl\u00e9mentaires et dure 20\u00a0secondes.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">Pr\u00eat\u00a0?<\/div>\n"},"ES-ES":{"QuestionText":"<div style=\"text-align: center;\">El primer bloque ya termin\u00f3. Ahora comenzar\u00e1s el segundo.<br>\nTiene 10 preguntas m\u00e1s y dura 20 segundos.<\/div><div style=\"text-align: center;\"><br><\/div><div style=\"text-align: center;\">\u00bfListo? <\/div>"},"ES-AR":{"QuestionText":"<div style=\"text-align: center;\">El primer bloque ya termin\u00f3. Ahora comenzar\u00e1 el segundo.<br \/>\nTiene 10 preguntas m\u00e1s y dura 20 segundos.<br \/>\n<br \/>\n\u00bfListo?<\/div>\n"},"JA":{"QuestionText":"<div style=\"text-align: center;\">\u6700\u521d\u306e\u30d6\u30ed\u30c3\u30af\u306f\u3053\u308c\u3067\u7d42\u4e86\u3067\u3059\u30022 \u756a\u76ee\u306e\u30d6\u30ed\u30c3\u30af\u3092\u958b\u59cb\u3057\u307e\u3059\u3002<br>\n2 \u756a\u76ee\u306e\u30d6\u30ed\u30c3\u30af\u306b\u306f\u3042\u3068 10 \u500b\u306e\u8cea\u554f\u304c\u3042\u308a\u300120 \u79d2\u9593\u7d9a\u304d\u307e\u3059\u3002<\/div><div style=\"text-align: center;\"><br><\/div><div style=\"text-align: center;\">\u6e96\u5099\u306f\u3044\u3044\u3067\u3059\u304b?<\/div>"},"DE":{"QuestionText":"<div style=\"text-align: center;\">Der erste Block ist nun vorbei. Sie beginnen jetzt mit dem zweiten.<br>\nEr enth\u00e4lt noch 10 Fragen und dauert 20 Sekunden.<\/div><div style=\"text-align: center;\"><br><\/div><div style=\"text-align: center;\">Bereit?<\/div>"},"ZH-T":{"QuestionText":"<div style=\"text-align: center;\">\u7b2c\u4e00\u7d44\u554f\u984c\u5df2\u7d50\u675f\u3002\u60a8\u73fe\u5728\u5c07\u958b\u59cb\u7b2c\u4e8c\u7d44\u3002<br \/>\n\u7b2c\u4e8c\u7d44\u5171\u6709 10 \u9053\u984c\u76ee\uff0c\u9650\u6642 20 \u79d2\u3002<br \/>\n<br \/>\n\u6e96\u5099\u597d\u4e86\u55ce\uff1f<\/div>\n"},"KO":{"QuestionText":"<div style=\"text-align: center;\">\uccab \ubc88\uc9f8 \ubb36\uc74c\uc774 \ub05d\ub0ac\uc2b5\ub2c8\ub2e4. \uc774\uc81c \ub450 \ubc88\uc9f8 \ubb36\uc74c\uc744 \uc2dc\uc791\ud569\ub2c8\ub2e4.<br \/>\n10\uac1c\uc758 \ubb38\uc81c\uac00 \ub354 \uc788\uace0 20\ucd08 \ub3d9\uc548 \uc9c4\ud589\ub429\ub2c8\ub2e4.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">\uc900\ube44\ub418\uc168\ub098\uc694?<\/div>\n"},"DE-AT":{"QuestionText":"<div style=\"text-align: center;\">Der erste Block ist nun beendet. Jetzt beginnen Sie mit dem zweiten.<br> Es enth\u00e4lt 10 weitere Fragen und dauert 20 Sekunden.<\/div><div style=\"text-align: center;\"><br><\/div><div style=\"text-align: center;\"> Bereit?<\/div>"},"TR":{"QuestionText":"<div style=\"text-align: center;\">\n<div style=\"text-align: center;\">\u0130lk blok sona erdi. Haz\u0131r oldu\u011funuzda, ikinci blo\u011fa devam edebilirsiniz.<br \/>\n\u0130kinci bloktaki 10 soru i\u00e7in de toplam 20 saniyeniz oldu\u011funu unutmay\u0131n\u0131z.<br \/>\n\u00a0<\/div>\n\n<div style=\"text-align: center;\">Haz\u0131r oldu\u011funuzda ba\u015flayabilirsiniz.<\/div>\n<\/div>\n"},"ZH-HK":{"QuestionText":"<div style=\"text-align: center;\">\n<p>\u7b2c\u4e00\u7d44\u554f\u984c\u5df2\u7d50\u675f\u3002\u60a8\u73fe\u5728\u5c07\u958b\u59cb\u7b2c\u4e8c\u7d44\u3002<\/p>\n\n<p>\u7b2c\u4e8c\u7d44\u5171\u6709 10 \u9053\u984c\u76ee\uff0c\u9650\u6642 20 \u79d2\u3002<\/p>\n<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">\u6e96\u5099\u597d\u4e86\u55ce\uff1f<\/div>\n"},"KZ-RU":[],"AR":{"QuestionText":"<div style=\"text-align: center;;text-align:right;direction:rtl\">\u0644\u0642\u062f \u0627\u0646\u062a\u0647\u064a \u0627\u0644\u0622\u0646 \u0627\u0644\u062c\u0632\u0621 \u0627\u0644\u0623\u0648\u0644. \u0633\u064a\u0628\u062f\u0623 \u0627\u0644\u0622\u0646 \u0627\u0644\u062c\u0632\u0621 \u0627\u0644\u062b\u0627\u0646\u064a.<br \/>\n\u064a\u062d\u062a\u0648\u064a \u0639\u0644\u0649 10 \u0623\u0633\u0626\u0644\u0629 \u0625\u0636\u0627\u0641\u064a\u0629 \u0648\u064a\u0633\u062a\u0645\u0631 \u0644\u0645\u062f\u0629 20 \u062b\u0627\u0646\u064a\u0629.<\/div>\n\n<div style=\"text-align: center;;text-align:right;direction:rtl\">\u00a0<\/div>\n\n<div style=\"text-align: center;;text-align:right;direction:rtl\">\u0645\u0633\u062a\u0639\u062f\u061f<\/div>\n"},"DE-DE":{"QuestionText":"<div style=\"text-align: center;\">Der erste Block ist nun beendet. Jetzt beginnen Sie mit dem zweiten.<br \/>\nDieser enth\u00e4lt 10 weitere Fragen und dauert 20 Sekunden.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">Bereit?<\/div>\n"}},"NextAnswerId":1,"NextChoiceId":4,"QuestionDescription":"The first block is now over. You will now begin the second one. It has 10 more questions and it l...","QuestionID":"QID98","QuestionText":"<div style=\"text-align: center;\">The first block is now over. You will now begin the second one.<br>\nIt has 10 more questions and it lasts 20 seconds.<\/div><div style=\"text-align: center;\"><br><\/div><div style=\"text-align: center;\">Ready?<\/div>","QuestionText_Unsafe":"<div style=\"text-align: center;\">The first block is now over. You will now begin the second one.<br>\nIt has 10 more questions and it lasts 20 seconds.<\/div><div style=\"text-align: center;\"><br><\/div><div style=\"text-align: center;\">Ready?<\/div>","QuestionType":"DB","Selector":"TB","Validation":{"Settings":{"Type":"None"}}}},{"SurveyID":"SV_b3mHBVkuioRMhng","Element":"SQ","PrimaryAttribute":"QID99","SecondaryAttribute":"Timing","TertiaryAttribute":null,"Payload":{"Choices":{"1":{"Display":"Primer clic"},"2":{"Display":"\u00daltimo clic"},"3":{"Display":"Env\u00edo de p\u00e1gina"},"4":{"Display":"Recuento de clics"}},"Configuration":{"CountDirection":"Decrementing","MaxSeconds":20,"MinSeconds":10,"QuestionDescriptionOption":"UseText","Seconds":20,"ShowTimer":true},"DataExportTag":"sum3.1","DataVisibility":{"Hidden":false,"Private":false},"DefaultChoices":false,"GradingData":[],"Language":{"CS":{"QuestionText":"Na\u010dasov\u00e1n\u00ed"},"EL":{"QuestionText":"\u03a3\u03c5\u03b3\u03c7\u03c1\u03bf\u03bd\u03b9\u03c3\u03bc\u03cc\u03c2"},"ES":{"QuestionText":"