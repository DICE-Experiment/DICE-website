c9c0 \uc81c\ucd9c"},"4":{"Display":"\ud074\ub9ad \uc218"}}},"DE-AT":{"QuestionText":"Timing","Choices":{"1":{"Display":"Erster Klick"},"2":{"Display":"Letzter Klick"},"3":{"Display":"Seite \u00fcbermitteln"},"4":{"Display":"Klickanzahl"}}},"TR":{"QuestionText":"Zamanlama","Choices":{"1":{"Display":"\u0130lk T\u0131klama"},"2":{"Display":"Son T\u0131klama"},"3":{"Display":"Sayfa G\u00f6nder"},"4":{"Display":"T\u0131klama Say\u0131s\u0131"}}},"ZH-HK":[],"KZ-RU":[],"AR":[],"DE-DE":{"QuestionText":"Timing","Choices":{"1":{"Display":"Erster Klick"},"2":{"Display":"Letzter Klick"},"3":{"Display":"Seite \u00fcbermitteln"},"4":{"Display":"Klickanzahl"}}}},"NextChoiceId":16,"NextAnswerId":1,"QuestionText_Unsafe":"Timing"}},{"SurveyID":"SV_b3mHBVkuioRMhng","Element":"SQ","PrimaryAttribute":"QID31","SecondaryAttribute":"You will have to throw a dice twice. Your first throw decides how much you receive, and the secon...","TertiaryAttribute":null,"Payload":{"QuestionText":"<div style=\"text-align: center;\">\n<div style=\"text-align: center;\"><\/div>You will have to throw a dice twice. Your first throw decides how much you receive, and the second throw only serves to make sure that the dice is working properly. In fact, you may throw the dice more than twice. However, only the first throw counts.<\/div><div style=\"text-align: center;\"><br><\/div><div style=\"text-align: center;\">he maximum payoff you can receive is 50 Monetary Units (MUs) and the minimum 0. You can see the exact payoff from the following table.<div style=\"text-align: center;\"><\/div>\n\n<div style=\"text-align: center;\">&nbsp;<\/div>\n\n<div style=\"text-align: center;\">The table also describes that the money not earned by you (50 MUs minus MUs for you)  will be sent to the Department of the Treasury as a donation in order to help finance public goods in the USA. At the end of the session, the sum of money gathered from all participants will be sent via a direct transfer.<\/div>\n\n<div style=\"text-align: center;\">&nbsp;<\/div>\n\n<div style=\"text-align: center;\">The table will remain on the screen until you entered your throw. If you have any questions, please raise your hand. If you are ready, please continue to the next page.<\/div>\n&nbsp;\n\n<table style=\"width:250px;\" cellspacing=\"1\" cellpadding=\"1\" border=\"1\" align=\"center\">\n\t<thead>\n\t\t<tr>\n\t\t\t<th scope=\"row\">Number thrown<\/th>\n\t\t\t<th scope=\"col\">MUs for you<\/th>\n\t\t\t<th scope=\"col\">MUs for the Department of the Treasury<\/th>\n\t\t<\/tr>\n\t<\/thead>\n\t<tbody>\n\t\t<tr>\n\t\t\t<th scope=\"row\">1<\/th>\n\t\t\t<td>10<\/td>\n\t\t\t<td>40<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">2<\/th>\n\t\t\t<td>20<\/td>\n\t\t\t<td>30<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">3<\/th>\n\t\t\t<td>30<\/td>\n\t\t\t<td>20<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">4<\/th>\n\t\t\t<td>40<\/td>\n\t\t\t<td>10<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">5<\/th>\n\t\t\t<td>50<\/td>\n\t\t\t<td>0<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">6<\/th>\n\t\t\t<td>0<\/td>\n\t\t\t<td>50<\/td>\n\t\t<\/tr>\n\t<\/tbody>\n<\/table>\n<\/div>\n\n<div style=\"text-align: center;\">&nbsp;<\/div>","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"You will have to throw a dice twice. Your first throw decides how much you receive, and the secon...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":{"AR":[],"CS":{"QuestionText":"<div style=\"text-align: center;\">\n<div style=\"text-align: center;\">\n<div style=\"text-align: center;\">Po\u017e\u00e1d\u00e1me V\u00e1s, abyste dvakr\u00e1t hodil(a) kostkou. V\u00e1\u0161 prvn\u00ed hod rozhodne o tom, kolik dostanete. Druh\u00fd hod slou\u017e\u00ed pouze k tomu, abyste se ujistil(a), \u017ee kostky funguj\u00ed spr\u00e1vn\u011b. Ve skute\u010dnosti m\u016f\u017eete hodit kostkou, kolikr\u00e1t chcete, ale po\u010d\u00edt\u00e1 se pouze V\u00e1\u0161 prvn\u00ed hod.\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">Maxim\u00e1ln\u00ed \u010d\u00e1stka, kterou m\u016f\u017eete v t\u00e9to \u010d\u00e1sti obdr\u017eet, je 50 experiment\u00e1ln\u00edch m\u011bnov\u00fdch jednotek (EMJ) a minim\u00e1ln\u00ed je 0 EMJ. N\u00e1sleduj\u00edc\u00ed tabulka popisuje, kolik p\u0159esn\u011b m\u016f\u017eete vyhr\u00e1t.<\/div>\n<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">Tabulka tak\u00e9 ukazuje, \u017ee pen\u00edze, kter\u00e9 nevyhrajete Vy (50 EMJ m\u00ednus EMJ pro V\u00e1s) budou darov\u00e1ny \u010desk\u00e9mu Ministerstvu financ\u00ed na pomoc s financov\u00e1n\u00edm ve\u0159ejn\u00e9ho dluhu \u010cesk\u00e9 Republiky. Po skon\u010den\u00ed tohoto experimentu po\u0161leme pen\u00edze takto z\u00edskan\u00e9 od v\u0161ech \u00fa\u010dastn\u00edk\u016f p\u0159evodem na \u00fa\u010det rezervn\u00edho fondu Ministerstva financ\u00ed \u010d\u00edslo: 123-3328001\/0710.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">Tato tabulka bude zobrazena na Va\u0161\u00ed obrazovce, dokud nebudete cht\u00edt napsat, kolik jste hodil(a). Pokud m\u00e1te n\u011bjak\u00e9 ot\u00e1zky, zvedn\u011bte, pros\u00edm, ruku. Pokud jste p\u0159ipraven(a), pokra\u010dujte na dal\u0161\u00ed str\u00e1nku.<\/div>\n<\/div>\n\u00a0\n\n<table align=\"center\" border=\"1\" cellpadding=\"1\" cellspacing=\"1\" style=\"width:250px;\">\n\t<thead>\n\t\t<tr>\n\t\t\t<th scope=\"row\">\u010c\u00edslo vr\u017eeno<\/th>\n\t\t\t<th scope=\"col\">EMJ pro v\u00e1s<\/th>\n\t\t\t<th scope=\"col\">EMJ pro Ministerstvo financ\u00ed<\/th>\n\t\t<\/tr>\n\t<\/thead>\n\t<tbody>\n\t\t<tr>\n\t\t\t<th scope=\"row\">1<\/th>\n\t\t\t<td>10<\/td>\n\t\t\t<td>40<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">2<\/th>\n\t\t\t<td>20<\/td>\n\t\t\t<td>30<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">3<\/th>\n\t\t\t<td>30<\/td>\n\t\t\t<td>20<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">4<\/th>\n\t\t\t<td>40<\/td>\n\t\t\t<td>10<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">5<\/th>\n\t\t\t<td>50<\/td>\n\t\t\t<td>0<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">6<\/th>\n\t\t\t<td>0<\/td>\n\t\t\t<td>50<\/td>\n\t\t<\/tr>\n\t<\/tbody>\n<\/table>\n<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n"},"DE":{"QuestionText":"<div style=\"text-align: center;\">\n<div style=\"text-align: center;\">Du musst zweimal w\u00fcrfeln. Dein erster Wurf entscheidet, wie viel du erh\u00e4ltst, und der zweite Wurf dient nur dazu, sicherzustellen, dass der W\u00fcrfel richtig funktioniert. Tats\u00e4chlich kannst du mehr als zweimal w\u00fcrfeln. Allerdings z\u00e4hlt nur der erste Wurf.<\/div>\n\n<div style=\"text-align: center;\">&nbsp;<\/div>\n\n<div style=\"text-align: center;\">Die maximale Auszahlung, die Sie erhalten k\u00f6nnen, betr\u00e4gt 50 W\u00e4hrungseinheiten (MUs) und die minimale 0.&nbsp;Die genaue Auszahlung k\u00f6nnen Sie der folgenden Tabelle entnehmen.<\/div>\n\n<div style=\"text-align: center;\">&nbsp;<\/div>\n\n<div style=\"text-align: center;\">Die Tabelle beschreibt auch, dass das von Ihnen nicht verdiente Geld (50 MUs abz\u00fcglich MUs f\u00fcr Sie) als Spende an das Finanzministerium von Singapur gesendet wird, um zur Finanzierung \u00f6ffentlicher G\u00fcter in Singapur beizutragen. Am Ende der Sitzung wird der von allen Teilnehmern gesammelte Geldbetrag per Direkt\u00fcberweisung (Kontonummer=0010468669) \u00fcberwiesen.<\/div>\n\n<div style=\"text-align: center;\">&nbsp;<\/div>\n\n<div style=\"text-align: center;\">Die Tabelle bleibt auf dem Bildschirm, bis Sie Ihren Wurf eingegeben haben. Wenn Sie Fragen haben, heben Sie bitte Ihre Hand. Wenn Sie bereit sind, fahren Sie bitte mit der n\u00e4chsten Seite fort.<\/div>\n&nbsp;\n\n<table align=\"center\" border=\"1\" cellpadding=\"1\" cellspacing=\"1\" style=\"width:250px;\">\n<thead>\n<tr>\n<th scope=\"row\">Gew\u00fcrfelte Zahl<\/th>\n<th scope=\"col\">MUs f\u00fcr Sie<\/th>\n<th scope=\"col\">MUs f\u00fcr das Finanzministerium<\/th>\n<\/tr>\n<\/thead>\n<tbody>\n<tr>\n<th scope=\"row\">1<\/th>\n<td>10<\/td>\n<td>40<\/td>\n<\/tr>\n<tr>\n<th scope=\"row\">2<\/th>\n<td>20<\/td>\n<td>30<\/td>\n<\/tr>\n<tr>\n<th scope=\"row\">3<\/th>\n<td>30<\/td>\n<td>20<\/td>\n<\/tr>\n<tr>\n<th scope=\"row\">4<\/th>\n<td>40<\/td>\n<td>10<\/td>\n<\/tr>\n<tr>\n<th scope=\"row\">5<\/th>\n<td>50<\/td>\n<td>0<\/td>\n<\/tr>\n<tr>\n<th scope=\"row\">6<\/th>\n<td>0<\/td>\n<td>50<\/td>\n<\/tr>\n<\/tbody>\n<\/table>\n<\/div>\n\n<div style=\"text-align: center;\">&nbsp;<\/div>"},"DE-AT":{"QuestionText":"<div style=\"text-align: center;\">\n<div style=\"text-align: center;\">\n<div style=\"text-align: center;\">\n<div style=\"text-align: center;\">Nachfolgend werden Sie aufgefordert, zweimal zu w\u00fcrfeln. Ihr erster Wurf entscheidet, wie viel Sie erhalten; der zweite Wurf dient nur dazu, sicherzustellen, dass der W\u00fcrfel richtig funktioniert. Tats\u00e4chlich k\u00f6nnen Sie die W\u00fcrfel mehr als zweimal werfen. Allerdings z\u00e4hlt nur der erste Wurf.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">Die maximale Auszahlung, die Sie erhalten k\u00f6nnen, betr\u00e4gt 50 Geldeinheiten (GE) und die minimale Auszahlung betr\u00e4gt 0. Die genaue Auszahlung k\u00f6nnen Sie der folgenden Tabelle entnehmen.<\/div>\n<\/div>\n<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">In der Tabelle ist au\u00dferdem beschrieben, dass der nicht von Ihnen verdiente Betrag (50 GE minus GE f\u00fcr Sie) als Spende an den \u00f6sterreichischen Staat gesendet wird, um zur Finanzierung \u00f6ffentlicher G\u00fcter in \u00d6sterreich beizutragen. Am Ende der Sitzung wird der von allen Teilnehmern gesammelte Geldbetrag an die Alpha+ (Stiftung des Wissenschaftsfonds FWF) \u00fcberwiesen.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">Die Tabelle wird auf dem Bildschirm angezeigt , bis Sie Ihren Wurf eingegeben haben. Wenn Sie Fragen haben, heben Sie bitte Ihre Hand. Wenn Sie bereit sind, fahren Sie bitte mit der n\u00e4chsten Seite fort.<br \/>\n\u00a0<\/div>\n\n<table align=\"center\" border=\"1\" cellpadding=\"1\" cellspacing=\"1\" style=\"width:400px;\">\n\t<thead>\n\t\t<tr>\n\t\t\t<th scope=\"row\">Geworfene Zahl<\/th>\n\t\t\t<th scope=\"col\">GE f\u00fcr Sie<\/th>\n\t\t\t<th scope=\"col\">GE\u00a0f\u00fcr den Staat<\/th>\n\t\t<\/tr>\n\t<\/thead>\n\t<tbody>\n\t\t<tr>\n\t\t\t<th scope=\"row\">1<\/th>\n\t\t\t<td>10<\/td>\n\t\t\t<td>40<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">2<\/th>\n\t\t\t<td>20<\/td>\n\t\t\t<td>30<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">3<\/th>\n\t\t\t<td>30<\/td>\n\t\t\t<td>20<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">4<\/th>\n\t\t\t<td>40<\/td>\n\t\t\t<td>10<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">5<\/th>\n\t\t\t<td>50<\/td>\n\t\t\t<td>0<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">6<\/th>\n\t\t\t<td>0<\/td>\n\t\t\t<td>50<\/td>\n\t\t<\/tr>\n\t<\/tbody>\n<\/table>\n<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n"},"DE-DE":{"QuestionText":"<div style=\"text-align: center;\">\n<div style=\"text-align: center;\">Sie m\u00fcssen zweimal w\u00fcrfeln. Der erste Wurf entscheidet, wie viel Sie erhalten, und der zweite Wurf dient nur dazu, zu pr\u00fcfen, ob der W\u00fcrfel richtig funktioniert. Sie d\u00fcrfen sogar \u00f6fter w\u00fcrfeln. Allerdings z\u00e4hlt nur der erste Wurf.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">Die maximale Auszahlung, die Sie erhalten k\u00f6nnen, betr\u00e4gt 50 Geldeinheint (GE), die minimale 0. Die genaue Auszahlung k\u00f6nnen Sie der folgenden Tabelle entnehmen.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">Die Tabelle beschreibt auch, dass das von Ihnen nicht verdiente Geld (50 GE minus GE f\u00fcr Sie) als Spende an das Bundesministerium der Finanzen gesendet wird, um zur Finanzierung \u00f6ffentlicher G\u00fcter in Deutschland beizutragen. Am Ende der Sitzung wird der von allen TeilnehmerInnen gesammelte Geldbetrag per Direkt\u00fcberweisung gesendet.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">Die Tabelle bleibt auf dem Bildschirm, bis Sie Ihren Wurf eingegeben haben. Wenn Sie Fragen haben, heben Sie bitte Ihre Hand. Wenn Sie bereit sind, fahren Sie bitte mit der n\u00e4chsten Seite fort.<\/div>\n\n<table align=\"center\" border=\"1\" cellpadding=\"1\" cellspacing=\"1\" style=\"width:250px;\">\n\t<thead>\n\t\t<tr>\n\t\t\t<th scope=\"row\">Geworfene Zahl<\/th>\n\t\t\t<th scope=\"col\">GE\u00a0f\u00fcr Sie<\/th>\n\t\t\t<th scope=\"col\">GE\u00a0f\u00fcr das Bundesministerium der Finanzen<\/th>\n\t\t<\/tr>\n\t<\/thead>\n\t<tbody>\n\t\t<tr>\n\t\t\t<th scope=\"row\">1<\/th>\n\t\t\t<td>10<\/td>\n\t\t\t<td>40<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">2<\/th>\n\t\t\t<td>20<\/td>\n\t\t\t<td>30<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">3<\/th>\n\t\t\t<td>30<\/td>\n\t\t\t<td>20<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">4<\/th>\n\t\t\t<td>40<\/td>\n\t\t\t<td>10<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">5<\/th>\n\t\t\t<td>50<\/td>\n\t\t\t<td>0<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">6<\/th>\n\t\t\t<td>0<\/td>\n\t\t\t<td>50<\/td>\n\t\t<\/tr>\n\t<\/tbody>\n<\/table>\n<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n"},"EL":{"QuestionText":"<div style=\"text-align: center;\">\n<div style=\"text-align: center;\">\n<div style=\"text-align: center;\">\n<div style=\"text-align: center;\">\u0398\u03b1 \u03c0\u03c1\u03ad\u03c0\u03b5\u03b9 \u03bd\u03b1 \u03c1\u03af\u03be\u03b5\u03c4\u03b5 \u03c4\u03bf \u03b6\u03ac\u03c1\u03b9 \u03b4\u03cd\u03bf \u03c6\u03bf\u03c1\u03ad\u03c2. \u0397 \u03c0\u03c1\u03ce\u03c4\u03b7 \u03c6\u03bf\u03c1\u03ac \u03b8\u03b1 \u03ba\u03b1\u03b8\u03bf\u03c1\u03af\u03c3\u03b5\u03b9 \u03c0\u03cc\u03c3\u03b1 \u03c7\u03c1\u03ae\u03bc\u03b1\u03c4\u03b1 \u03b8\u03b1 \u03bb\u03ac\u03b2\u03b5\u03c4\u03b5 \u03ba\u03b1\u03b9 \u03b7 \u03b4\u03b5\u03cd\u03c4\u03b5\u03c1\u03b7 \u03c6\u03bf\u03c1\u03ac \u03c7\u03c1\u03b7\u03c3\u03b9\u03bc\u03b5\u03cd\u03b5\u03b9 \u03bc\u03cc\u03bd\u03bf \u03b3\u03b9\u03b1 \u03bd\u03b1 \u03b2\u03b5\u03b2\u03b1\u03b9\u03c9\u03b8\u03b5\u03af\u03c4\u03b5 \u03cc\u03c4\u03b9 \u03c4\u03bf \u03b6\u03ac\u03c1\u03b9 \u03bb\u03b5\u03b9\u03c4\u03bf\u03c5\u03c1\u03b3\u03b5\u03af \u03c3\u03c9\u03c3\u03c4\u03ac. \u03a3\u03c4\u03b7\u03bd \u03c0\u03c1\u03b1\u03b3\u03bc\u03b1\u03c4\u03b9\u03ba\u03cc\u03c4\u03b7\u03c4\u03b1, \u03bc\u03c0\u03bf\u03c1\u03b5\u03af\u03c4\u03b5 \u03bd\u03b1 \u03c1\u03af\u03be\u03b5\u03c4\u03b5 \u03c4\u03bf \u03b6\u03ac\u03c1\u03b9 \u03c0\u03b5\u03c1\u03b9\u03c3\u03c3\u03cc\u03c4\u03b5\u03c1\u03b5\u03c2 \u03b1\u03c0\u03cc \u03b4\u03cd\u03bf \u03c6\u03bf\u03c1\u03ad\u03c2. \u03a9\u03c3\u03c4\u03cc\u03c3\u03bf, \u03bc\u03cc\u03bd\u03bf \u03b7 \u03c0\u03c1\u03ce\u03c4\u03b7 \u03c6\u03bf\u03c1\u03ac \u03bc\u03b5\u03c4\u03c1\u03ac\u03b5\u03b9.<\/div>\n\n<div style=\"text-align: center;\">\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">\u0397 \u03bc\u03ad\u03b3\u03b9\u03c3\u03c4\u03b7 \u03c0\u03bb\u03b7\u03c1\u03c9\u03bc\u03ae \u03c0\u03bf\u03c5 \u03bc\u03c0\u03bf\u03c1\u03b5\u03af\u03c4\u03b5 \u03bd\u03b1 \u03bb\u03ac\u03b2\u03b5\u03c4\u03b5 \u03b5\u03af\u03bd\u03b1\u03b9 50 \u039d\u03bf\u03bc\u03b9\u03c3\u03bc\u03b1\u03c4\u03b9\u03ba\u03ad\u03c2 \u039c\u03bf\u03bd\u03ac\u03b4\u03b5\u03c2 (\u039d\u039c) \u03ba\u03b1\u03b9 \u03b7 \u03b5\u03bb\u03ac\u03c7\u03b9\u03c3\u03c4\u03b7 0. \u039c\u03c0\u03bf\u03c1\u03b5\u03af\u03c4\u03b5 \u03bd\u03b1 \u03b4\u03b5\u03af\u03c4\u03b5 \u03c4\u03b7\u03bd \u03b1\u03ba\u03c1\u03b9\u03b2\u03ae \u03c0\u03bb\u03b7\u03c1\u03c9\u03bc\u03ae \u03b1\u03c0\u03cc \u03c4\u03bf\u03bd \u03c0\u03b1\u03c1\u03b1\u03ba\u03ac\u03c4\u03c9 \u03c0\u03af\u03bd\u03b1\u03ba\u03b1.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n<\/div>\n<\/div>\n\n<div style=\"text-align: center;\">\u039f \u03c0\u03af\u03bd\u03b1\u03ba\u03b1\u03c2 \u03c0\u03b5\u03c1\u03b9\u03b3\u03c1\u03ac\u03c6\u03b5\u03b9 \u03b5\u03c0\u03af\u03c3\u03b7\u03c2 \u03cc\u03c4\u03b9 \u03c4\u03b1 \u03c7\u03c1\u03ae\u03bc\u03b1\u03c4\u03b1 \u03c0\u03bf\u03c5 \u03b4\u03b5 \u03b8\u03b1 \u03ba\u03b5\u03c1\u03b4\u03af\u03c3\u03b5\u03c4\u03b5 \u03b5\u03c3\u03b5\u03af\u03c2 (50 \u039d\u039c \u03bc\u03b5\u03af\u03bf\u03bd \u03c4\u03b9\u03c2 \u039d\u039c \u03c0\u03bf\u03c5 \u03b8\u03b1 \u03bb\u03ac\u03b2\u03b5\u03c4\u03b5 \u03b5\u03c3\u03b5\u03af\u03c2) \u03b8\u03b1 \u03c3\u03c4\u03b1\u03bb\u03bf\u03cd\u03bd \u03c3\u03c4\u03bf \u03a5\u03c0\u03bf\u03c5\u03c1\u03b3\u03b5\u03af\u03bf \u039f\u03b9\u03ba\u03bf\u03bd\u03bf\u03bc\u03b9\u03ba\u03ce\u03bd \u03c4\u03b7\u03c2 \u0395\u03bb\u03bb\u03ac\u03b4\u03bf\u03c2 \u03c9\u03c2 \u03b4\u03c9\u03c1\u03b5\u03ac \u03b3\u03b9\u03b1 \u03c4\u03b7 \u03c7\u03c1\u03b7\u03bc\u03b1\u03c4\u03bf\u03b4\u03cc\u03c4\u03b7\u03c3\u03b7 \u03b4\u03b7\u03bc\u03cc\u03c3\u03b9\u03c9\u03bd \u03b1\u03b3\u03b1\u03b8\u03ce\u03bd \u03c3\u03c4\u03b7\u03bd \u03c7\u03ce\u03c1\u03b1. \u03a3\u03c4\u03bf \u03c4\u03ad\u03bb\u03bf\u03c2 \u03c4\u03b7\u03c2 \u03ad\u03c1\u03b5\u03c5\u03bd\u03b1\u03c2, \u03c4\u03bf \u03c7\u03c1\u03b7\u03bc\u03b1\u03c4\u03b9\u03ba\u03cc \u03c0\u03bf\u03c3\u03cc \u03c0\u03bf\u03c5 \u03b8\u03b1 \u03c3\u03c5\u03b3\u03ba\u03b5\u03bd\u03c4\u03c1\u03c9\u03b8\u03b5\u03af \u03b1\u03c0\u03cc \u03cc\u03bb\u03bf\u03c5\u03c2 \u03c4\u03bf\u03c5\u03c2 \u03c3\u03c5\u03bc\u03bc\u03b5\u03c4\u03ad\u03c7\u03bf\u03bd\u03c4\u03b5\u03c2 \u03b8\u03b1 \u03b1\u03c0\u03bf\u03c3\u03c4\u03b1\u03bb\u03b5\u03af \u03bc\u03b5 \u03c4\u03c1\u03b1\u03c0\u03b5\u03b6\u03b9\u03ba\u03ae \u03bc\u03b5\u03c4\u03b1\u03c6\u03bf\u03c1\u03ac (\u03b1\u03c1\u03b9\u03b8\u03bc\u03cc\u03c2 IBAN: GR89 0100 0230 0000 02 341216317).<br \/>\n<br \/>\n\u039f \u03c0\u03af\u03bd\u03b1\u03ba\u03b1\u03c2 \u03b8\u03b1 \u03c0\u03b1\u03c1\u03b1\u03bc\u03b5\u03af\u03bd\u03b5\u03b9 \u03c3\u03c4\u03b7\u03bd \u03bf\u03b8\u03cc\u03bd\u03b7 \u03bc\u03ad\u03c7\u03c1\u03b9 \u03bd\u03b1 \u03c3\u03b1\u03c2 \u03b6\u03b7\u03c4\u03b7\u03b8\u03b5\u03af \u03bd\u03b1 \u03b3\u03c1\u03ac\u03c8\u03c4\u03b5 \u03c4\u03bf \u03bd\u03bf\u03cd\u03bc\u03b5\u03c1\u03bf \u03c0\u03bf\u03c5 \u03c3\u03b1\u03c2 \u03ad\u03c4\u03c5\u03c7\u03b5. \u0391\u03bd \u03ad\u03c7\u03b5\u03c4\u03b5 \u03b5\u03c1\u03c9\u03c4\u03ae\u03c3\u03b5\u03b9\u03c2, \u03c3\u03b7\u03ba\u03ce\u03c3\u03c4\u03b5 \u03c4\u03bf \u03c7\u03ad\u03c1\u03b9 \u03c3\u03b1\u03c2. \u0395\u03ac\u03bd \u03c0\u03ac\u03bb\u03b9 \u03b5\u03af\u03c3\u03c4\u03b5 \u03ad\u03c4\u03bf\u03b9\u03bc\u03bf\u03b9, \u03c3\u03c5\u03bd\u03b5\u03c7\u03af\u03c3\u03c4\u03b5 \u03c3\u03c4\u03b7\u03bd \u03b5\u03c0\u03cc\u03bc\u03b5\u03bd\u03b7 \u03c3\u03b5\u03bb\u03af\u03b4\u03b1.<\/div>\n<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<table align=\"center\" border=\"1\" cellpadding=\"1\" cellspacing=\"1\" style=\"width:250px;\">\n\t<thead>\n\t\t<tr>\n\t\t\t<th scope=\"row\">\u0391\u03c1\u03b9\u03b8\u03bc\u03cc\u03c2 \u03c4\u03bf\u03c5 \u03b6\u03b1\u03c1\u03b9\u03bf\u03cd<\/th>\n\t\t\t<th scope=\"col\">\u039d\u039c\u00a0\u03b3\u03b9\u03b1 \u03b5\u03c3\u03ac\u03c2<\/th>\n\t\t\t<th scope=\"col\">\u039d\u039c \u03b3\u03b9\u03b1 \u03c4\u03bf \u03a5\u03c0\u03bf\u03c5\u03c1\u03b3\u03b5\u03af\u03bf \u039f\u03b9\u03ba\u03bf\u03bd\u03bf\u03bc\u03b9\u03ba\u03ce\u03bd<\/th>\n\t\t<\/tr>\n\t<\/thead>\n\t<tbody>\n\t\t<tr>\n\t\t\t<th scope=\"row\">1<\/th>\n\t\t\t<td>10<\/td>\n\t\t\t<td>40<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">2<\/th>\n\t\t\t<td>20<\/td>\n\t\t\t<td>30<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">3<\/th>\n\t\t\t<td>30<\/td>\n\t\t\t<td>20<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">4<\/th>\n\t\t\t<td>40<\/td>\n\t\t\t<td>10<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">5<\/th>\n\t\t\t<td>50<\/td>\n\t\t\t<td>0<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">6<\/th>\n\t\t\t<td>0<\/td>\n\t\t\t<td>50<\/td>\n\t\t<\/tr>\n\t<\/tbody>\n<\/table>\n<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n"},"EN-PAK":{"QuestionText":"<div style=\"text-align: center;\">\n<div style=\"text-align: center;\">You will have to throw a dice twice. Your first throw decides how much you receive, and the second throw only serves to make sure that the dice is working properly. In fact, you may throw the dice more than twice. However, only the first throw counts.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">The maximum payoff you can receive is 50 Monetary Units (MUs) and the minimum 0.\u00a0You can see the exact payoff from the following table.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">The table also describes that the money not earned by you (50 MUs minus MUs for you) will be sent to the Ministry of Finance of Pakistan as a donation in order to help finance public goods in Pakistan. At the end of the session, the sum of money gathered from all participants will be sent via a direct transfer.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">The table will remain on the screen until you entered your throw. If you have any questions, please raise your hand. If you are ready, please continue to the next page.<\/div>\n\u00a0\n\n<table align=\"center\" border=\"1\" cellpadding=\"1\" cellspacing=\"1\" style=\"width:250px;\">\n\t<thead>\n\t\t<tr>\n\t\t\t<th scope=\"row\">Number thrown<\/th>\n\t\t\t<th scope=\"col\">MUs for you<\/th>\n\t\t\t<th scope=\"col\">MUs for the Ministry of Finance<\/th>\n\t\t<\/tr>\n\t<\/thead>\n\t<tbody>\n\t\t<tr>\n\t\t\t<th scope=\"row\">1<\/th>\n\t\t\t<td>10<\/td>\n\t\t\t<td>40<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">2<\/th>\n\t\t\t<td>20<\/td>\n\t\t\t<td>30<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">3<\/th>\n\t\t\t<td>30<\/td>\n\t\t\t<td>20<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">4<\/th>\n\t\t\t<td>40<\/td>\n\t\t\t<td>10<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">5<\/th>\n\t\t\t<td>50<\/td>\n\t\t\t<td>0<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">6<\/th>\n\t\t\t<td>0<\/td>\n\t\t\t<td>50<\/td>\n\t\t<\/tr>\n\t<\/tbody>\n<\/table>\n<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n"},"EN-TW":{"QuestionText":"<div style=\"text-align: center;\">\n<div style=\"text-align: center;\">You will have to throw a dice twice. Your first throw decides how much you receive, and the second throw only serves to make sure that the dice is working properly. In fact, you may throw the dice more than twice. However, only the first throw counts.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">The maximum payoff you can receive is 50 Monetary Units (MUs) and the minimum 0.\u00a0You can see the exact payoff from the following table.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">The table also describes that the money not earned by you (50 MUs minus MUs for you) will be sent to the Taiwan Ministry of Health and Welfare as a donation in order to help fund public projects. The sum of money gathered from all participants will be sent to the Ministry of Health and Welfare account after the experiment ends (account number: 003001727277).<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">The table will remain on the screen until you entered your throw. If you have any questions, please raise your hand. If you are ready, please continue to the next page.<\/div>\n\u00a0\n\n<table align=\"center\" border=\"1\" cellpadding=\"1\" cellspacing=\"1\" style=\"width:250px;\">\n\t<thead>\n\t\t<tr>\n\t\t\t<th scope=\"row\">Number thrown<\/th>\n\t\t\t<th scope=\"col\">MUs for you<\/th>\n\t\t\t<th scope=\"col\">MUs for the Ministry of Health and Welfare<\/th>\n\t\t<\/tr>\n\t<\/thead>\n\t<tbody>\n\t\t<tr>\n\t\t\t<th scope=\"row\">1<\/th>\n\t\t\t<td>10<\/td>\n\t\t\t<td>40<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">2<\/th>\n\t\t\t<td>20<\/td>\n\t\t\t<td>30<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">3<\/th>\n\t\t\t<td>30<\/td>\n\t\t\t<td>20<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">4<\/th>\n\t\t\t<td>40<\/td>\n\t\t\t<td>10<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">5<\/th>\n\t\t\t<td>50<\/td>\n\t\t\t<td>0<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">6<\/th>\n\t\t\t<td>0<\/td>\n\t\t\t<td>50<\/td>\n\t\t<\/tr>\n\t<\/tbody>\n<\/table>\n<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n"},"EN-UK":{"QuestionText":"<div style=\"text-align: center;\">\n<div style=\"text-align: center;\">You will have to throw a die twice. Your first throw decides how much you receive, and the second throw only serves to make sure that the die is working properly. In fact, you may throw the die more than twice. However, only the first throw counts.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">The maximum payoff you can receive is 50 Monetary Units (MUs) and the minimum 0.\u00a0You can see the exact payoff in the table below.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">The table also describes that the money not earned by you (50 MUs minus MUs for you) will be sent to the HM Treasury as a donation in order to help finance public goods in the UK. At the end of the session, the sum of money gathered from all participants will be sent via a direct transfer.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">The table will remain on the screen until you entered your throw. If you have any questions, please raise your hand. If you are ready, please continue to the next page.<\/div>\n\u00a0\n\n<table align=\"center\" border=\"1\" cellpadding=\"1\" cellspacing=\"1\" style=\"width:250px;\">\n\t<thead>\n\t\t<tr>\n\t\t\t<th scope=\"row\">Number thrown<\/th>\n\t\t\t<th scope=\"col\">MUs for you<\/th>\n\t\t\t<th scope=\"col\">MUs for the HM Treasury<\/th>\n\t\t<\/tr>\n\t<\/thead>\n\t<tbody>\n\t\t<tr>\n\t\t\t<th scope=\"row\">1<\/th>\n\t\t\t<td>10<\/td>\n\t\t\t<td>40<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">2<\/th>\n\t\t\t<td>20<\/td>\n\t\t\t<td>30<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">3<\/th>\n\t\t\t<td>30<\/td>\n\t\t\t<td>20<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">4<\/th>\n\t\t\t<td>40<\/td>\n\t\t\t<td>10<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">5<\/th>\n\t\t\t<td>50<\/td>\n\t\t\t<td>0<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">6<\/th>\n\t\t\t<td>0<\/td>\n\t\t\t<td>50<\/td>\n\t\t<\/tr>\n\t<\/tbody>\n<\/table>\n<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n"},"ES":{"QuestionText":"<div style=\"text-align: center;\">\n<div style=\"text-align: center;\">Tendr\u00e1 que lanzar el dado dos veces. Su primer lanzamiento decide cu\u00e1nto recibe usted, y el segundo lanzamiento solo sirve para asegurarse de que el dado funciona correctamente. De hecho, puede tirar el dado m\u00e1s de dos veces. Sin embargo, solo cuenta el primer lanzamiento.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">El pago m\u00e1ximo que puede recibir usted es de 50 Unidades Monetarias (UM) y el m\u00ednimo de 0. Puede ver el pago exacto en la siguiente tabla.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">La tabla tambi\u00e9n describe que el dinero que no gane (50 UM menos las UM para usted) se enviar\u00e1 a \"Rentas Generales\" del <strong>Ministerio de Econom\u00eda y Finanzas <\/strong>de Uruguay como donaci\u00f3n para ayudar a financiar bienes y servicios de car\u00e1cter p\u00fablico.<br \/>\nAl finalizar la sesi\u00f3n, la suma de dinero recaudada entre todos los participantes se enviar\u00e1 mediante transferencia directa a\u00a0Rentas Generales cuenta 05 004 11 152 0028920<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">La tabla permanecer\u00e1 en la pantalla hasta que ingrese su lanzamiento. Si tiene alguna pregunta, por favor levante su mano. Si est\u00e1 listo, presione OK.<br \/>\n\u00a0<\/div>\n\n<table align=\"center\" border=\"1\" cellpadding=\"1\" cellspacing=\"1\" style=\"width:250px;\">\n\t<thead>\n\t\t<tr>\n\t\t\t<th scope=\"row\">N\u00famero lanzado<\/th>\n\t\t\t<th scope=\"col\">UM para usted<\/th>\n\t\t\t<th scope=\"col\">UM para el Ministerio de Econom\u00eda y Finanzas<\/th>\n\t\t<\/tr>\n\t<\/thead>\n\t<tbody>\n\t\t<tr>\n\t\t\t<th scope=\"row\">1<\/th>\n\t\t\t<td>10<\/td>\n\t\t\t<td>40<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">2<\/th>\n\t\t\t<td>20<\/td>\n\t\t\t<td>30<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">3<\/th>\n\t\t\t<td>30<\/td>\n\t\t\t<td>20<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">4<\/th>\n\t\t\t<td>40<\/td>\n\t\t\t<td>10<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">5<\/th>\n\t\t\t<td>50<\/td>\n\t\t\t<td>0<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">6<\/th>\n\t\t\t<td>0<\/td>\n\t\t\t<td>50<\/td>\n\t\t<\/tr>\n\t<\/tbody>\n<\/table>\n<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n"},"ES-AR":{"QuestionText":"<div>Tendr\u00e1 que lanzar el dado dos veces. Su primer lanzamiento decide cu\u00e1nto recibe, y el segundo lanzamiento solo sirve para asegurarse de que los dados funcionan correctamente. De hecho, puede tirar el dado m\u00e1s de dos veces. Sin embargo, solo cuenta el primer lanzamiento.<br \/>\n\u00a0<br \/>\nEl pago m\u00e1ximo que puede recibir es de 50 Unidades Monetarias (UM) y el m\u00ednimo de 0. Puede ver el pago exacto en la siguiente tabla.<br \/>\n<br \/>\nLa tabla tambi\u00e9n describe que el dinero que no reciba (50 UM menos las UM para usted) se donar\u00e1 a una entidad del Gobierno del Per\u00fa destinada a proveer bienes p\u00fablicos. Al finalizar la sesi\u00f3n, la suma de dinero recaudada entre todos los participantes ser\u00e1 enviada mediante transferencia directa a dicha entidad del Gobierno del Per\u00fa, a la cuenta: 00000339539 del Banco de la Naci\u00f3n.<br \/>\n<br \/>\nLa tabla permanecer\u00e1 en la pantalla hasta que ingrese su lanzamiento. Si tiene alguna pregunta, por favor levante su mano. Si est\u00e1 listo, presione OK.<br \/>\n\u00a0<\/div>\n\n<table align=\"center\" border=\"1\" cellpadding=\"1\" cellspacing=\"1\">\n\t<thead>\n\t\t<tr>\n\t\t\t<th scope=\"row\">\u00a0N\u00famero\u00a0<br \/>\n\t\t\tlanzado<\/th>\n\t\t\t<th scope=\"col\">\u00a0UM para\u00a0<br \/>\n\t\t\tusted<\/th>\n\t\t\t<th scope=\"col\">UM para entidad<br \/>\n\t\t\tdel Gobierno del Per\u00fa\u00a0<\/th>\n\t\t<\/tr>\n\t<\/thead>\n\t<tbody>\n\t\t<tr>\n\t\t\t<th scope=\"row\">1<\/th>\n\t\t\t<td style=\"text-align: center;\">10<\/td>\n\t\t\t<td style=\"text-align: center;\">40<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">2<\/th>\n\t\t\t<td style=\"text-align: center;\">20<\/td>\n\t\t\t<td style=\"text-align: center;\">30<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">3<\/th>\n\t\t\t<td style=\"text-align: center;\">30<\/td>\n\t\t\t<td style=\"text-align: center;\">20<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">4<\/th>\n\t\t\t<td style=\"text-align: center;\">40<\/td>\n\t\t\t<td style=\"text-align: center;\">10<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">5<\/th>\n\t\t\t<td style=\"text-align: center;\">50<\/td>\n\t\t\t<td style=\"text-align: center;\">0<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">6<\/th>\n\t\t\t<td style=\"text-align: center;\">0<\/td>\n\t\t\t<td style=\"text-align: center;\">50<\/td>\n\t\t<\/tr>\n\t<\/tbody>\n<\/table>\n\n<div>\u00a0<\/div>\n"},"ES-ES":{"QuestionText":"Tendr\u00e1 que lanzar el dado dos veces. Su primer lanzamiento decide cu\u00e1nto recibe usted, y el segundo lanzamiento solo sirve para asegurarse de que el dado funciona correctamente. De hecho, puede tirar el dado m\u00e1s de dos veces. Sin embargo, solo cuenta el primer lanzamiento.<br \/>\n<br \/>\nEl pago m\u00e1ximo que puede recibir usted es de 50 Unidades Monetarias (UM) y el m\u00ednimo de 0. Puede ver el pago exacto en la siguiente tabla.<br \/>\n<br \/>\nLa tabla tambi\u00e9n describe que el dinero que no gane (50 UM menos las UM para usted) se enviar\u00e1 al Ministerio de Hacienda de Chile como donaci\u00f3n para ayudar a financiar\u00a0 a una obra espec\u00edfica de car\u00e1cter p\u00fablico.<br \/>\nAl finalizar la sesi\u00f3n, la suma de dinero recaudada entre todos los participantes se enviar\u00e1 mediante transferencia directa a\u00a0<strong>Pago de Donaciones Ley N\u00b0 20.444<\/strong><br \/>\nPara informarse mejor sobre c\u00f3mo opera esta ley,\u00a0https:\/\/donaciones.hacienda.gob.cl\/\u00a0\u00a0<br \/>\n<br \/>\nLa tabla permanecer\u00e1 en la pantalla hasta que ingrese su lanzamiento. Si tiene alguna pregunta, por favor levante su mano. Si est\u00e1 listo, presione OK.<br \/>\n\u00a0\n<table align=\"center\" border=\"1\" cellpadding=\"1\" cellspacing=\"1\">\n\t<thead>\n\t\t<tr>\n\t\t\t<th scope=\"row\">N\u00famero<br \/>\n\t\t\tlanzado<\/th>\n\t\t\t<th scope=\"col\">UM para<br \/>\n\t\t\tusted<\/th>\n\t\t\t<th scope=\"col\">UM para el<br \/>\n\t\t\tMinisterio de Finanzas<\/th>\n\t\t<\/tr>\n\t<\/thead>\n\t<tbody>\n\t\t<tr>\n\t\t\t<th scope=\"row\">1<\/th>\n\t\t\t<td style=\"text-align: center;\">10<\/td>\n\t\t\t<td style=\"text-align: center;\">40<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">2<\/th>\n\t\t\t<td style=\"text-align: center;\">20<\/td>\n\t\t\t<td style=\"text-align: center;\">30<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">3<\/th>\n\t\t\t<td style=\"text-align: center;\">30<\/td>\n\t\t\t<td style=\"text-align: center;\">20<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">4<\/th>\n\t\t\t<td style=\"text-align: center;\">40<\/td>\n\t\t\t<td style=\"text-align: center;\">10<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">5<\/th>\n\t\t\t<td style=\"text-align: center;\">50<\/td>\n\t\t\t<td style=\"text-align: center;\">0<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">6<\/th>\n\t\t\t<td style=\"text-align: center;\">0<\/td>\n\t\t\t<td style=\"text-align: center;\">50<\/td>\n\t\t<\/tr>\n\t<\/tbody>\n<\/table>\n"},"FR":{"QuestionText":"<div style=\"text-align: center;\">\n<div style=\"text-align: center;\">Vous devrez lancer un d\u00e9 deux fois. Votre premier lancer d\u00e9cide du montant que vous recevez, et le deuxi\u00e8me lancer sert uniquement \u00e0 vous assurer que les d\u00e9s fonctionnent correctement. En fait, vous pouvez lancer les d\u00e9s plus de deux fois. Cependant, seul le premier lancer compte.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">Le gain maximum que vous pouvez recevoir est de 50 unit\u00e9s mon\u00e9taires (UM) et le minimum de 0. Vous pouvez voir le gain exact dans le tableau suivant.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">Le tableau indique \u00e9galement que l'argent que vous n'avez pas gagn\u00e9 (50 UM moins les UM pour vous) sera envoy\u00e9 au minist\u00e8re des Finances de Madagascar sous forme de don afin d'aider \u00e0 financer les biens publics \u00e0 Madagascar . A la fin de la s\u00e9ance, la somme d'argent r\u00e9colt\u00e9e aupr\u00e8s de tous les participants sera envoy\u00e9e par virement direct (num\u00e9ro de compte : 652146021???).<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">Le tableau restera \u00e0 l'\u00e9cran jusqu'\u00e0 ce que vous saisissiez votre lancer. Si vous avez des questions, veuillez lever la main. Si vous \u00eates pr\u00eat, veuillez passer \u00e0 la page suivante.<\/div>\n\n<table align=\"center\" border=\"1\" cellpadding=\"1\" cellspacing=\"1\" style=\"width:250px;\">\n\t<thead>\n\t\t<tr>\n\t\t\t<th scope=\"row\">Num\u00e9ro lanc\u00e9<\/th>\n\t\t\t<th scope=\"col\">Des UM pour vous<\/th>\n\t\t\t<th scope=\"col\">UM pour le Minist\u00e8re des Finances<\/th>\n\t\t<\/tr>\n\t<\/thead>\n\t<tbody>\n\t\t<tr>\n\t\t\t<th scope=\"row\">1<\/th>\n\t\t\t<td>10<\/td>\n\t\t\t<td>40<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">2<\/th>\n\t\t\t<td>20<\/td>\n\t\t\t<td>30<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">3<\/th>\n\t\t\t<td>30<\/td>\n\t\t\t<td>20<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">4<\/th>\n\t\t\t<td>40<\/td>\n\t\t\t<td>10<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">5<\/th>\n\t\t\t<td>50<\/td>\n\t\t\t<td>0<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">6<\/th>\n\t\t\t<td>0<\/td>\n\t\t\t<td>50<\/td>\n\t\t<\/tr>\n\t<\/tbody>\n<\/table>\n<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n"},"FR-FR":{"QuestionText":"<div style=\"text-align: center;\">\n<div style=\"text-align: center;\">\n<div style=\"text-align: center;\">Vous allez \u00eatre invit\u00e9 \u00e0 lancer votre d\u00e9 deux fois. Le r\u00e9sultat du premier lancer d\u00e9termine le montant que vous allez obtenir. Le deuxi\u00e8me lancer sert uniquement \u00e0 vous assurer que le d\u00e9 n'est pas truqu\u00e9. Vous pouvez m\u00eame lancer les d\u00e9s plus de deux fois. Cependant, seul le premier lancer compte.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">Le gain maximum que vous pouvez obtenir est de 50 unit\u00e9s mon\u00e9taires (UM), et le minimum est de 0 UM. Le tableau ci-dessous d\u00e9crit les gains exacts en fonction du r\u00e9sultat du d\u00e9.<\/div>\n\n<div style=\"text-align: center;\"><br \/>\nLe tableau d\u00e9crit \u00e9galement que l'argent que vous n'avez pas gagn\u00e9 (50 UM moins les UM pour vous) sera envoy\u00e9 \u00e0 un compte rattach\u00e9 au minist\u00e8re des Finances fran\u00e7ais \u00e0 titre de don afin d'aider \u00e0 financer les biens publics en France. A la fin de la session, la somme d'argent cumul\u00e9e par tous les participants sera envoy\u00e9e via un virement.\n<div style=\"text-align: center;\">\u00a0<\/div>\n<\/div>\n\n<div style=\"text-align: center;\">Si vous avez une question, veuillez lever la main. Si vous \u00eates pr\u00eat, vous pouvez passer \u00e0 la page suivante.<\/div>\n<\/div>\n\u00a0 <t\u00eate> <\/t\u00eate><corps> <\/corps>\n\n<table align=\"center\" border=\"1\" cellpacing=\"1\" cellpadding=\"1\" style=\"largeur:250px;\">\n\t<tbody>\n\t\t<tr>\n\t\t\t<th scope=\"row\">R\u00e9sultat du d\u00e9<\/th>\n\t\t\t<th scope=\"col\">UM pour vous<\/th>\n\t\t\t<th scope=\"col\">UM pour le Minist\u00e8re des Finances<\/th>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">1<\/th>\n\t\t\t<td>10<\/td>\n\t\t\t<td>40<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">2<\/th>\n\t\t\t<td>20<\/td>\n\t\t\t<td>30<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">3<\/th>\n\t\t\t<td>30<\/td>\n\t\t\t<td>20<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">4<\/th>\n\t\t\t<td>40<\/td>\n\t\t\t<td>10<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">5<\/th>\n\t\t\t<td>50<\/td>\n\t\t\t<td>0<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">6<\/th>\n\t\t\t<td>0<\/td>\n\t\t\t<td>50<\/td>\n\t\t<\/tr>\n\t<\/tbody>\n<\/table>\n<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n"},"HU":{"QuestionText":"<div style=\"text-align: center;\">\n<div style=\"text-align: center;\">\n<div style=\"text-align: center;\">\u00a0K\u00e9tszer kell dobnia egy kock\u00e1val. Az els\u0151 dob\u00e1s hat\u00e1rozza meg, hogy mennyit kap, a m\u00e1sodik pedig csak arra szolg\u00e1l, hogy megbizonyosodjon arr\u00f3l, hogy a kocka megfelel\u0151en m\u0171k\u00f6dik. Ak\u00e1r t\u00f6bbsz\u00f6r is dobhat a kock\u00e1val, azonban csak az els\u0151 dob\u00e1s sz\u00e1m\u00edt.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">A legnagyobb kifizet\u00e9s 50 p\u00e9nzegys\u00e9g (PE), a legkisebb pedig 0. A pontos kifizet\u00e9st a k\u00f6vetkez\u0151 t\u00e1bl\u00e1zat mutatja.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">A t\u00e1bl\u00e1zat azt is mutatja, hogy az \u00d6n \u00e1ltal nem megnyert p\u00e9nzt (50 PE m\u00ednusz az \u00d6n \u00e1ltal nyert PE) adom\u00e1nyk\u00e9nt elk\u00fcldj\u00fck egy korm\u00e1nyzati szervnek, hogy abb\u00f3l a k\u00f6z jav\u00e1t el\u0151mozd\u00edtsa. A lek\u00e9rdez\u00e9s v\u00e9g\u00e9n az \u00f6sszes r\u00e9sztvev\u0151t\u0151l beszedett p\u00e9nz\u00f6sszeget k\u00f6zvetlen \u00e1tutaljuk (sz\u00e1mlasz\u00e1m: 11711034-20084376).<\/div>\n<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">A t\u00e1bl\u00e1zat addig lesz majd l\u00e1that\u00f3, am\u00edg meg nem adja a dobott sz\u00e1mot. Ha k\u00e9rd\u00e9se van, k\u00e9rj\u00fck, emelje fel a kez\u00e9t. Ha k\u00e9szen \u00e1ll, l\u00e9pjen a k\u00f6vetkez\u0151 oldalra.<\/div>\n\n<table align=\"center\" border=\"1\" cellpadding=\"1\" cellspacing=\"1\" style=\"width:250px;\">\n\t<thead>\n\t\t<tr>\n\t\t\t<th scope=\"row\">Dobott sz\u00e1m<\/th>\n\t\t\t<th scope=\"col\">Nyert PE<\/th>\n\t\t\t<th scope=\"col\">PE a korm\u00e1nyzati szervnek<\/th>\n\t\t<\/tr>\n\t<\/thead>\n\t<tbody>\n\t\t<tr>\n\t\t\t<th scope=\"row\">1<\/th>\n\t\t\t<td>10<\/td>\n\t\t\t<td>40<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">2<\/th>\n\t\t\t<td>20<\/td>\n\t\t\t<td>30<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">3<\/th>\n\t\t\t<td>30<\/td>\n\t\t\t<td>20<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">4<\/th>\n\t\t\t<td>40<\/td>\n\t\t\t<td>10<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">5<\/th>\n\t\t\t<td>50<\/td>\n\t\t\t<td>0<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">6<\/th>\n\t\t\t<td>0<\/td>\n\t\t\t<td>50<\/td>\n\t\t<\/tr>\n\t<\/tbody>\n<\/table>\n<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n"},"IT":{"QuestionText":"<div style=\"text-align: center;\">\n<div style=\"text-align: center;\">Dovrai lanciare un dado due volte. Il tuo primo lancio decide quanto ricevi, mentre il secondo serve solo per assicurarti che i dadi funzionino correttamente. In sostanza, puoi lanciare i dadi pi\u00f9 di due volte. Tuttavia conta solo il primo tiro.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">Il guadagno massimo che puoi ricevere \u00e8 50 unit\u00e0 monetarie (MU) e il minimo \u00e8 0. Puoi vedere il guadagno esatto dalla tabella seguente.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">La tabella descrive anche il denaro non guadagnato da te (50 MU meno MU da te guardagnato) che verr\u00e0 inviato al Ministero delle Finanze dell'Italia come donazione per aiutare a finanziare i beni pubblici in Italia. Al termine della sessione, la somma di denaro raccolta da tutti i partecipanti verr\u00e0 inviata tramite bonifico diretto.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">Il tabella rimarr\u00e0 sullo schermo finch\u00e9 non inserirai il tuo numero. Se hai domande, per favore alzate la mano. Se sei pronto, continua alla pagina successiva.<\/div>\n\n<table align=\"center\" border=\"1\" cellpadding=\"1\" cellspacing=\"1\" style=\"width:250px;\">\n\t<thead>\n\t\t<tr>\n\t\t\t<th scope=\"row\">Numero uscito<\/th>\n\t\t\t<th scope=\"col\">MU per te<\/th>\n\t\t\t<th scope=\"col\">MU per il Ministero delle Finanze<\/th>\n\t\t<\/tr>\n\t<\/thead>\n\t<tbody>\n\t\t<tr>\n\t\t\t<th scope=\"row\">1<\/th>\n\t\t\t<td>10<\/td>\n\t\t\t<td>40<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">2<\/th>\n\t\t\t<td>20<\/td>\n\t\t\t<td>30<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">3<\/th>\n\t\t\t<td>30<\/td>\n\t\t\t<td>20<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">4<\/th>\n\t\t\t<td>40<\/td>\n\t\t\t<td>10<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">5<\/th>\n\t\t\t<td>50<\/td>\n\t\t\t<td>0<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">6<\/th>\n\t\t\t<td>0<\/td>\n\t\t\t<td>50<\/td>\n\t\t<\/tr>\n\t<\/tbody>\n<\/table>\n<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n"},"JA":{"QuestionText":"<div style=\"text-align: center;\">\n<div style=\"text-align: center;\">\u30b5\u30a4\u30b3\u30ed\u3092 2 \u56de\u6295\u3052\u308b\u5fc5\u8981\u304c\u3042\u308a\u307e\u3059\u30021 \u56de\u76ee\u306e\u6295\u3052\u3067\u7372\u5f97\u3067\u304d\u308b\u91d1\u984d\u304c\u6c7a\u307e\u308a\u30012 \u56de\u76ee\u306e\u6295\u3052\u306f\u30b5\u30a4\u30b3\u30ed\u304c\u6b63\u3057\u304f\u6a5f\u80fd\u3057\u3066\u3044\u308b\u304b\u3069\u3046\u304b\u3092\u78ba\u8a8d\u3059\u308b\u305f\u3081\u3060\u3051\u306b\u884c\u308f\u308c\u307e\u3059\u3002\u5b9f\u969b\u3001\u30b5\u30a4\u30b3\u30ed\u3092 2 \u56de\u4ee5\u4e0a\u6295\u3052\u308b\u3053\u3068\u3082\u3067\u304d\u307e\u3059\u3002\u305f\u3060\u3057\u3001\u30ab\u30a6\u30f3\u30c8\u3055\u308c\u308b\u306e\u306f\u6700\u521d\u306e\u6295\u3052\u3060\u3051\u3067\u3059\u3002<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">\u53d7\u3051\u53d6\u308c\u308b\u6700\u5927\u306e\u5831\u916c\u306f 50 \u901a\u8ca8\u5358\u4f4d (MU)\u3001\u6700\u5c0f\u306f 0 \u3067\u3059\u3002\u6b63\u78ba\u306a\u5831\u916c\u306f\u6b21\u306e\u8868\u3067\u78ba\u8a8d\u3067\u304d\u307e\u3059\u3002<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">\u3053\u306e\u8868\u306b\u306f\u3001\u3042\u306a\u305f\u304c\u7a3c\u3052\u306a\u304b\u3063\u305f\u304a\u91d1 (50 MU \u304b\u3089\u3042\u306a\u305f\u306e MU \u3092\u5dee\u3057\u5f15\u3044\u305f\u91d1\u984d) \u304c\u65e5\u672c\u653f\u5e9c\u3092\u901a\u3058\u305f\u6771\u65e5\u672c\u5927\u9707\u707d\u7fa9\u63f4\u91d1\u3068\u3057\u3066\u65e5\u672c\u653f\u5e9c\u306b\u9001\u3089\u308c\u308b\u3053\u3068\u3082\u8a18\u8f09\u3055\u308c\u3066\u3044\u307e\u3059\u3002\u30bb\u30c3\u30b7\u30e7\u30f3\u306e\u6700\u5f8c\u306b\u3001\u53c2\u52a0\u8005\u5168\u54e1\u304b\u3089\u96c6\u3081\u3089\u308c\u305f\u91d1\u984d\u306f\u3001\u76f4\u63a5\u632f\u8fbc\u3067\u9001\u91d1\u3055\u308c\u307e\u3059 (\u3086\u3046\u3061\u3087\u9280\u884c\u3001\u53e3\u5ea7\u756a\u53f7 = 00130-6-623461\u3001\u53e3\u5ea7\u540d\u7fa9\uff1d\u6771\u65e5\u672c\u5927\u9707\u707d\u7fa9\u63f4\u91d1\u653f\u5e9c\u7a93\u53e3)\u3002<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">\u30c6\u30fc\u30d6\u30eb\u306f\u3001\u3042\u306a\u305f\u304c\u6295\u3052\u308b\u306e\u3092\u5165\u529b\u3059\u308b\u307e\u3067\u753b\u9762\u306b\u8868\u793a\u3055\u308c\u305f\u307e\u307e\u306b\u306a\u308a\u307e\u3059\u3002\u8cea\u554f\u304c\u3042\u308b\u5834\u5408\u306f\u3001\u624b\u3092\u6319\u3052\u3066\u304f\u3060\u3055\u3044\u3002\u6e96\u5099\u304c\u3067\u304d\u305f\u3089\u3001\u6b21\u306e\u30da\u30fc\u30b8\u306b\u9032\u3093\u3067\u304f\u3060\u3055\u3044\u3002<\/div>\n\u00a0\n\n<table align=\"center\" border=\"1\" cellpadding=\"1\" cellspacing=\"1\" style=\"width:250px;\">\n\t<thead>\n\t\t<tr>\n\t\t\t<th scope=\"row\">\u6295\u3052\u3089\u308c\u305f\u6570<\/th>\n\t\t\t<th scope=\"col\">\u3042\u306a\u305f\u306e MU<\/th>\n\t\t\t<th scope=\"col\">\u65e5\u672c\u653f\u5e9c\u306e MU<\/th>\n\t\t<\/tr>\n\t<\/thead>\n\t<tbody>\n\t\t<tr>\n\t\t\t<th scope=\"row\">1<\/th>\n\t\t\t<td>10<\/td>\n\t\t\t<td>40<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">2<\/th>\n\t\t\t<td>20<\/td>\n\t\t\t<td>30<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">3<\/th>\n\t\t\t<td>30<\/td>\n\t\t\t<td>20<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">4<\/th>\n\t\t\t<td>40<\/td>\n\t\t\t<td>10<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">5<\/th>\n\t\t\t<td>50<\/td>\n\t\t\t<td>0<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">6<\/th>\n\t\t\t<td>0<\/td>\n\t\t\t<td>50<\/td>\n\t\t<\/tr>\n\t<\/tbody>\n<\/table>\n<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n"},"KO":{"QuestionText":"<div style=\"text-align: center;\">\n<div style=\"text-align: center;\">\uadc0\ud558\ub294 \uc8fc\uc0ac\uc704\ub97c \ucd5c\uc18c\ud55c \ub450 \ubc88 \uad74\ub824\uc57c \ud569\ub2c8\ub2e4. \uc8fc\uc0ac\uc704\ub97c \ucc98\uc74c \uad74\ub824 \uc5bb\uc740 \uacb0\uacfc\ub97c \uc785\ub825\ud558\uc5ec \ubcf4\uc0c1\uc744 \ubc1b\uc2b5\ub2c8\ub2e4. \uc8fc\uc0ac\uc704\uac00 \uc81c\ub300\ub85c \uc791\ub3d9\ud558\ub294 \uc9c0 \ud655\uc778\ud558\uae30 \uc704\ud574 \uc8fc\uc0ac\uc704\ub97c \ucd5c\uc18c\ud55c \ud55c \ubc88 \uc774\uc0c1 \ucd94\uac00\ub85c \uad74\ub824\uc57c \ud569\ub2c8\ub2e4. \uadf8\ub7ec\ub098 \uccab \ubc88\uc9f8 \uad74\ub9ac\uae30\ub9cc \ubcf4\uc0c1\uc5d0 \ubc18\uc601\ub429\ub2c8\ub2e4.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">\ubc1b\uc744 \uc218 \uc788\ub294 \ucd5c\ub300 \ubcf4\uc0c1\uc740 50\ud654\ud3d0 \ub2e8\uc704(MU)\uc774\uace0 \ucd5c\uc18c \ubcf4\uc0c1\uc740 0\uc785\ub2c8\ub2e4.\u00a0\ub2e4\uc74c \ud45c\uc5d0\uc11c \uc815\ud655\ud55c \ubcf4\uc0c1\uc744 \ud655\uc778\ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">\ub610\ud55c \uc544\ub798 \ud45c\uc5d0\uc11c \ud655\uc778\ud560 \uc218 \uc788\ub4ef, \uadc0\ud558\uac00 \uc5bb\uc9c0 \ubabb\ud55c \ub3c8(50MU\uc5d0\uc11c \uadc0\ud558\uc758 MU\ub97c \ube80 \uae08\uc561)\uc740 \uc815\ubd80\uc5d0 \uae30\ubd80\uae08\uc73c\ub85c \ubcf4\ub0b4\uc838, \uacf5\uacf5\uc7ac\uc5d0 \uc790\uae08\uc744 \uc9c0\uc6d0\ud558\ub294 \ub370 \uc0ac\uc6a9\ub429\ub2c8\ub2e4. \uc138\uc158\uc774 \ub05d\ub098\uba74 \ubaa8\ub4e0 \ucc38\uac00\uc790\ub85c\ubd80\ud130 \ubaa8\uc740 \uae08\uc561\uc774 \uc9c1\uc811 \uc774\uccb4\ub97c \ud1b5\ud574 \uc804\uc1a1\ub429\ub2c8\ub2e4.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">\uc8fc\uc0ac\uc704\ub97c \uad74\ub9b0 \uacb0\uacfc\ub97c \uc785\ub825\ud560 \ub54c\uae4c\uc9c0 \uc544\ub798\uc758 \ud45c\uac00 \ud654\uba74\uc5d0 \ud45c\uc2dc\ub429\ub2c8\ub2e4. \uc9c8\ubb38\uc774 \uc788\uc73c\uba74 \uc190\uc744 \ub4e4\uc5b4\uc8fc\uc138\uc694. \uc900\ube44\uac00 \ub418\uc5c8\ub2e4\uba74 \ub2e4\uc74c \ud398\uc774\uc9c0\ub85c \ub118\uc5b4\uac00\uc138\uc694.<\/div>\n\u00a0\n\n<table align=\"center\" border=\"1\" cellpadding=\"1\" cellspacing=\"1\" style=\"width:250px;\">\n\t<thead>\n\t\t<tr>\n\t\t\t<th scope=\"row\">\uc8fc\uc0ac\uc704 \uacb0\uacfc<\/th>\n\t\t\t<th scope=\"col\">\uadc0\ud558\uac00 \uc5bb\uac8c \ub418\ub294 MU<\/th>\n\t\t\t<th scope=\"col\">\uc815\ubd80\uac00 \uc5bb\uac8c \ub418\ub294 MU<\/th>\n\t\t<\/tr>\n\t<\/thead>\n\t<tbody>\n\t\t<tr>\n\t\t\t<th scope=\"row\">1<\/th>\n\t\t\t<td>10<\/td>\n\t\t\t<td>40<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">2<\/th>\n\t\t\t<td>20<\/td>\n\t\t\t<td>30<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">3<\/th>\n\t\t\t<td>30<\/td>\n\t\t\t<td>20<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">4<\/th>\n\t\t\t<td>40<\/td>\n\t\t\t<td>10<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th>5<\/th>\n\t\t\t<td>50<\/td>\n\t\t\t<td>0<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th>6<\/th>\n\t\t\t<td>0<\/td>\n\t\t\t<td>50<\/td>\n\t\t<\/tr>\n\t<\/tbody>\n<\/table>\n<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n"},"KZ-RU":{"QuestionText":"<div style=\"text-align: center;\">\n<div style=\"text-align: center;\">\n<div style=\"text-align: center;\">\n<div style=\"text-align: center;\">\u00a0\n<div style=\"text-align: center;\">\n<div style=\"text-align: center;\">\n<div style=\"text-align: center;\">\u0412\u0430\u043c \u043d\u0430\u0434\u043e \u0431\u0443\u0434\u0435\u0442 \u0431\u0440\u043e\u0441\u0438\u0442\u044c \u0438\u0433\u0440\u0430\u043b\u044c\u043d\u0443\u044e \u043a\u043e\u0441\u0442\u044c \u0434\u0432\u0430\u0436\u0434\u044b. \u0412\u0430\u0448 \u043f\u0435\u0440\u0432\u044b\u0439 \u0431\u0440\u043e\u0441\u043e\u043a \u043e\u043f\u0440\u0435\u0434\u0435\u043b\u044f\u0435\u0442, \u0441\u043a\u043e\u043b\u044c\u043a\u043e \u0412\u044b \u043f\u043e\u043b\u0443\u0447\u0438\u0442\u0435, \u0430 \u0432\u0442\u043e\u0440\u043e\u0439 \u0431\u0440\u043e\u0441\u043e\u043a \u0441\u043b\u0443\u0436\u0438\u0442 \u0442\u043e\u043b\u044c\u043a\u043e \u0434\u043b\u044f \u0442\u043e\u0433\u043e, \u0447\u0442\u043e\u0431\u044b \u0443\u0431\u0435\u0434\u0438\u0442\u044c\u0441\u044f, \u0447\u0442\u043e \u043a\u043e\u0441\u0442\u044c \u0440\u0430\u0431\u043e\u0442\u0430\u0435\u0442 \u043f\u0440\u0430\u0432\u0438\u043b\u044c\u043d\u043e. \u0424\u0430\u043a\u0442\u0438\u0447\u0435\u0441\u043a\u0438, \u0412\u044b \u043c\u043e\u0436\u0435\u0442\u0435 \u0431\u0440\u043e\u0441\u0438\u0442\u044c \u043a\u043e\u0441\u0442\u044c \u0438 \u0431\u043e\u043b\u0435\u0435 \u0434\u0432\u0443\u0445 \u0440\u0430\u0437. \u041e\u0434\u043d\u0430\u043a\u043e \u0437\u0430\u0441\u0447\u0438\u0442\u044b\u0432\u0430\u0435\u0442\u0441\u044f \u0442\u043e\u043b\u044c\u043a\u043e \u043f\u0435\u0440\u0432\u044b\u0439 \u0431\u0440\u043e\u0441\u043e\u043a.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">\u041c\u0430\u043a\u0441\u0438\u043c\u0430\u043b\u044c\u043d\u044b\u0439 \u0432\u044b\u0438\u0433\u0440\u044b\u0448, \u043a\u043e\u0442\u043e\u0440\u044b\u0439 \u0412\u044b \u043c\u043e\u0436\u0435\u0442\u0435 \u043f\u043e\u043b\u0443\u0447\u0438\u0442\u044c, \u0441\u043e\u0441\u0442\u0430\u0432\u043b\u044f\u0435\u0442 50 \u0434\u0435\u043d\u0435\u0436\u043d\u044b\u0445 \u0435\u0434\u0438\u043d\u0438\u0446 (\u0414\u0415), \u0430 \u043c\u0438\u043d\u0438\u043c\u0430\u043b\u044c\u043d\u044b\u0439 \u2014 0. \u0422\u043e\u0447\u043d\u044b\u0439 \u0432\u044b\u0438\u0433\u0440\u044b\u0448 \u0412\u044b \u043c\u043e\u0436\u0435\u0442\u0435 \u0443\u0432\u0438\u0434\u0435\u0442\u044c \u0438\u0437 \u0441\u043b\u0435\u0434\u0443\u044e\u0449\u0435\u0439 \u0442\u0430\u0431\u043b\u0438\u0446\u044b.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n<\/div>\n\u0412 \u0442\u0430\u0431\u043b\u0438\u0446\u0435 \u0442\u0430\u043a\u0436\u0435 \u0443\u043a\u0430\u0437\u0430\u043d\u043e, \u0447\u0442\u043e \u0442\u043e \u0447\u0442\u043e \u0412\u044b \u043d\u0435 \u0437\u0430\u0440\u0430\u0431\u043e\u0442\u0430\u0435\u0442\u0435 (50 \u0414\u0415 \u043c\u0438\u043d\u0443\u0441 \u0414\u0415 \u0434\u043b\u044f \u0412\u0430\u0441) \u0431\u0443\u0434\u0443\u0442 \u043e\u0442\u043f\u0440\u0430\u0432\u043b\u0435\u043d\u044b \u0432 \u0433\u043e\u0441\u0443\u0434\u0430\u0440\u0441\u0442\u0432\u0435\u043d\u043d\u044b\u0439 \u0424\u043e\u043d\u0434 \u041f\u043e\u0434\u0434\u0435\u0440\u0436\u043a\u0438 \u041f\u0440\u0435\u0437\u0438\u0434\u0435\u043d\u0442\u0441\u043a\u0438\u0445 \u041f\u0440\u043e\u0433\u0440\u0430\u043c\u043c\u00a0 (https:\/\/fppp.kz\/) \u0434\u043b\u044f \u0444\u0438\u043d\u0430\u043d\u0441\u0438\u0440\u043e\u0432\u0430\u043d\u0438\u044f \u043e\u0431\u0449\u0435\u0441\u0442\u0432\u0435\u043d\u043d\u044b\u0445 \u0431\u043b\u0430\u0433 \u0432 \u041a\u0430\u0437\u0430\u0445\u0441\u0442\u0430\u043d\u0435. \u041f\u043e \u043e\u043a\u043e\u043d\u0447\u0430\u043d\u0438\u0438 \u0441\u0435\u0441\u0441\u0438\u0438 \u0441\u0443\u043c\u043c\u0430 \u0434\u0435\u043d\u0435\u0433, \u0441\u043e\u0431\u0440\u0430\u043d\u043d\u0430\u044f \u043e\u0442 \u0432\u0441\u0435\u0445 \u0443\u0447\u0430\u0441\u0442\u043d\u0438\u043a\u043e\u0432, \u0431\u0443\u0434\u0435\u0442 \u043e\u0442\u043f\u0440\u0430\u0432\u043b\u0435\u043d\u0430 \u200b\u200b\u043f\u0440\u044f\u043c\u044b\u043c \u043f\u0435\u0440\u0435\u0432\u043e\u0434\u043e\u043c \u0447\u0435\u0440\u0435\u0437 \u0441\u0430\u0439\u0442 \u0444\u043e\u043d\u0434\u0430 https:\/\/fppp.kz\/donate<b>.<\/b>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">\u0422\u0430\u0431\u043b\u0438\u0446\u0430 \u0431\u0443\u0434\u0435\u0442 \u043e\u0441\u0442\u0430\u0432\u0430\u0442\u044c\u0441\u044f \u043d\u0430 \u044d\u043a\u0440\u0430\u043d\u0435 \u0434\u043e \u0442\u0435\u0445 \u043f\u043e\u0440, \u043f\u043e\u043a\u0430 \u0412\u044b \u043d\u0435 \u0432\u0432\u0435\u0434\u0435\u0442\u0435 \u0440\u0435\u0437\u0443\u043b\u044c\u0442\u0430\u0442 \u0412\u0430\u0448\u0435\u0433\u043e \u0431\u0440\u043e\u0441\u043a\u0430. \u0415\u0441\u043b\u0438 \u0443 \u0412\u0430\u0441 \u0435\u0441\u0442\u044c \u0432\u043e\u043f\u0440\u043e\u0441\u044b, \u043f\u043e\u0436\u0430\u043b\u0443\u0439\u0441\u0442\u0430, \u043f\u043e\u0434\u043d\u0438\u043c\u0438\u0442\u0435 \u0440\u0443\u043a\u0443. \u0415\u0441\u043b\u0438 \u0412\u044b \u0433\u043e\u0442\u043e\u0432\u044b, \u043f\u0435\u0440\u0435\u0439\u0434\u0438\u0442\u0435 \u043d\u0430 \u0441\u043b\u0435\u0434\u0443\u044e\u0449\u0443\u044e \u0441\u0442\u0440\u0430\u043d\u0438\u0446\u0443.<\/div>\n<\/div>\n\u00a0\n\n<table align=\"center\" border=\"1\" cellpadding=\"1\" cellspacing=\"1\" style=\"width:250px;\">\n\t<thead>\n\t\t<tr>\n\t\t\t<th scope=\"row\">\u0427\u0438\u0441\u043b\u043e \u0432\u044b\u043f\u0430\u0432\u0448\u0438\u0445 \u043e\u0447\u043a\u043e\u0432<\/th>\n\t\t\t<th scope=\"col\">\u0414\u0415 \u0434\u043b\u044f \u0412\u0430\u0441<\/th>\n\t\t\t<th scope=\"col\">\u0414\u0415 \u0434\u043b\u044f \u0433\u043e\u0441\u0443\u0434\u0430\u0440\u0441\u0442\u0432\u0435\u043d\u043d\u043e\u0433\u043e \u0444\u043e\u043d\u0434\u0430<\/th>\n\t\t<\/tr>\n\t<\/thead>\n\t<tbody>\n\t\t<tr>\n\t\t\t<th scope=\"row\">1<\/th>\n\t\t\t<td>10<\/td>\n\t\t\t<td>40<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">2<\/th>\n\t\t\t<td>20<\/td>\n\t\t\t<td>30<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">3<\/th>\n\t\t\t<td>30<\/td>\n\t\t\t<td>20<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">4<\/th>\n\t\t\t<td>40<\/td>\n\t\t\t<td>10<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">5<\/th>\n\t\t\t<td>50<\/td>\n\t\t\t<td>0<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">6<\/th>\n\t\t\t<td>0<\/td>\n\t\t\t<td>50<\/td>\n\t\t<\/tr>\n\t<\/tbody>\n<\/table>\n<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n<\/div>\n<\/div>\n<\/div>\n"},"PL":{"QuestionText":"<div style=\"text-align: center;\">\n<div style=\"text-align: center;\">B\u0119dziesz musia\u0142 rzuci\u0107 kostk\u0105 dwa razy. Tw\u00f3j pierwszy rzut decyduje o tym, ile otrzymasz, a drugi rzut s\u0142u\u017cy jedynie upewnieniu si\u0119, \u017ce kostka dzia\u0142a prawid\u0142owo. W rzeczywisto\u015bci mo\u017cesz rzuci\u0107 kostk\u0105 wi\u0119cej ni\u017c dwa razy. Jednak liczy si\u0119 tylko pierwszy rzut.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">Maksymalna wyp\u0142ata, jak\u0105 mo\u017cesz otrzyma\u0107, to 50 jednostek monetarnych (MU), a minimalna 0. Dok\u0142adn\u0105 wyp\u0142at\u0119 mo\u017cesz zobaczy\u0107 w poni\u017cszej tabeli.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">Tabela opisuje r\u00f3wnie\u017c, \u017ce niezarobione przez Ciebie pieni\u0105dze (50 MU minus MU dla Ciebie) zostan\u0105 przes\u0142ane do Ministerstwa Finans\u00f3w RP jako darowizna, aby pom\u00f3c w finansowaniu d\u00f3br publicznych w Polsce. Na koniec sesji suma pieni\u0119dzy zebrana od wszystkich uczestnik\u00f3w zostanie przes\u0142ana przelewem.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">Tabela pozostanie na ekranie, dop\u00f3ki nie wykonasz rzutu. Je\u015bli masz jakie\u015b pytania, podnie\u015b r\u0119k\u0119. Je\u015bli jeste\u015b gotowy, przejd\u017a do nast\u0119pnej strony.<\/div>\n\n<table align=\"center\" border=\"1\" cellpadding=\"1\" cellspacing=\"1\" style=\"width:250px;\">\n\t<thead>\n\t\t<tr>\n\t\t\t<th scope=\"row\">Wyrzucony numer<\/th>\n\t\t\t<th scope=\"col\">MU dla Ciebie<\/th>\n\t\t\t<th scope=\"col\">MU dla Ministerstwa Finans\u00f3w<\/th>\n\t\t<\/tr>\n\t<\/thead>\n\t<tbody>\n\t\t<tr>\n\t\t\t<th scope=\"row\">1<\/th>\n\t\t\t<td>10<\/td>\n\t\t\t<td>40<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">2<\/th>\n\t\t\t<td>20<\/td>\n\t\t\t<td>30<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">3<\/th>\n\t\t\t<td>30<\/td>\n\t\t\t<td>20<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">4<\/th>\n\t\t\t<td>40<\/td>\n\t\t\t<td>10<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">5<\/th>\n\t\t\t<td>50<\/td>\n\t\t\t<td>0<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">6<\/th>\n\t\t\t<td>0<\/td>\n\t\t\t<td>50<\/td>\n\t\t<\/tr>\n\t<\/tbody>\n<\/table>\n<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n"},"PT":{"QuestionText":"<div style=\"text-align: center;\">\n<div style=\"text-align: center;\">Ter\u00e1 que lan\u00e7ar um dado duas vezes. O seu primeiro lan\u00e7amento determina quanto recebe, e o segundo lan\u00e7amento serve apenas para garantir que o dado est\u00e1 a funcionar corretamente. Na verdade, pode lan\u00e7ar o dado mais do que duas vezes. No entanto, apenas o primeiro lan\u00e7amento conta.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">O pagamento m\u00e1ximo que pode receber \u00e9 50 Unidades Monet\u00e1rias (UMs) e o m\u00ednimo 0. Pode ver o pagamento exato na tabela seguinte.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">A tabela tamb\u00e9m descreve que o dinheiro n\u00e3o ganho por si (50 UMs menos as UMs para si) ser\u00e1 enviado para o Minist\u00e9rio das Finan\u00e7as de Portugal como uma doa\u00e7\u00e3o para ajudar a financiar bens p\u00fablicos. No final da sess\u00e3o, o valor arrecadado de todos os participantes ser\u00e1 enviado por transfer\u00eancia banc\u00e1ria.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">A tabela permanecer\u00e1 no ecr\u00e3 at\u00e9 que insira o seu lan\u00e7amento. Se tiver alguma d\u00favida, por favor levante a m\u00e3o. Se est\u00e1 preparado, continue para a p\u00e1gina seguinte.\u00a0\u00a0<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<table align=\"center\" border=\"1\" cellpacing=\"1\" cellpadding=\"1\" style=\"largura:250px;\">\n\t<thead>\n\t\t<tr>\n\t\t\t<th scope=\"row\">N\u00famero lan\u00e7ado<\/th>\n\t\t\t<th scope=\"col\">UMs para si<\/th>\n\t\t\t<th scope=\"col\">UMs para o Minist\u00e9rio das Finan\u00e7as<\/th>\n\t\t<\/tr>\n\t<\/thead>\n\t<tbody>\n\t\t<tr>\n\t\t\t<th escopo=\"linha\">1<\/th>\n\t\t\t<td>10<\/td>\n\t\t\t<td>40<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th escopo=\"linha\">2<\/th>\n\t\t\t<td>20<\/td>\n\t\t\t<td>30<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th escopo=\"linha\">3<\/th>\n\t\t\t<td>30<\/td>\n\t\t\t<td>20<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th escopo=\"linha\">4<\/th>\n\t\t\t<td>40<\/td>\n\t\t\t<td>10<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th escopo=\"linha\">5<\/th>\n\t\t\t<td>50<\/td>\n\t\t\t<td>0<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th escopo=\"linha\">6<\/th>\n\t\t\t<td>0<\/td>\n\t\t\t<td>50<\/td>\n\t\t<\/tr>\n\t<\/tbody>\n<\/table>\n<br \/>\n\u00a0<\/div>\n"},"RU":{"QuestionText":"<div style=\"text-align: center;\">\n<div style=\"text-align: center;\">\u00a0\n<div style=\"text-align: center;\">\n<div style=\"text-align: center;\">\n<div style=\"text-align: center;\">\u0412\u0430\u043c \u043d\u0430\u0434\u043e \u0431\u0443\u0434\u0435\u0442 \u0431\u0440\u043e\u0441\u0438\u0442\u044c \u0438\u0433\u0440\u0430\u043b\u044c\u043d\u0443\u044e \u043a\u043e\u0441\u0442\u044c \u0434\u0432\u0430\u0436\u0434\u044b. \u0412\u0430\u0448 \u043f\u0435\u0440\u0432\u044b\u0439 \u0431\u0440\u043e\u0441\u043e\u043a \u043e\u043f\u0440\u0435\u0434\u0435\u043b\u044f\u0435\u0442, \u0441\u043a\u043e\u043b\u044c\u043a\u043e \u0412\u044b \u043f\u043e\u043b\u0443\u0447\u0438\u0442\u0435, \u0430 \u0432\u0442\u043e\u0440\u043e\u0439 \u0431\u0440\u043e\u0441\u043e\u043a \u0441\u043b\u0443\u0436\u0438\u0442 \u0442\u043e\u043b\u044c\u043a\u043e \u0434\u043b\u044f \u0442\u043e\u0433\u043e, \u0447\u0442\u043e\u0431\u044b \u0443\u0431\u0435\u0434\u0438\u0442\u044c\u0441\u044f, \u0447\u0442\u043e \u043a\u043e\u0441\u0442\u044c \u0440\u0430\u0431\u043e\u0442\u0430\u0435\u0442 \u043f\u0440\u0430\u0432\u0438\u043b\u044c\u043d\u043e. \u0424\u0430\u043a\u0442\u0438\u0447\u0435\u0441\u043a\u0438, \u0412\u044b \u043c\u043e\u0436\u0435\u0442\u0435 \u0431\u0440\u043e\u0441\u0438\u0442\u044c \u043a\u043e\u0441\u0442\u044c \u0438 \u0431\u043e\u043b\u0435\u0435 \u0434\u0432\u0443\u0445 \u0440\u0430\u0437. \u041e\u0434\u043d\u0430\u043a\u043e \u0437\u0430\u0441\u0447\u0438\u0442\u044b\u0432\u0430\u0435\u0442\u0441\u044f \u0442\u043e\u043b\u044c\u043a\u043e \u043f\u0435\u0440\u0432\u044b\u0439 \u0431\u0440\u043e\u0441\u043e\u043a.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">\u041c\u0430\u043a\u0441\u0438\u043c\u0430\u043b\u044c\u043d\u044b\u0439 \u0432\u044b\u0438\u0433\u0440\u044b\u0448, \u043a\u043e\u0442\u043e\u0440\u044b\u0439 \u0412\u044b \u043c\u043e\u0436\u0435\u0442\u0435 \u043f\u043e\u043b\u0443\u0447\u0438\u0442\u044c, \u0441\u043e\u0441\u0442\u0430\u0432\u043b\u044f\u0435\u0442 50 \u0434\u0435\u043d\u0435\u0436\u043d\u044b\u0445 \u0435\u0434\u0438\u043d\u0438\u0446 (\u0414\u0415), \u0430 \u043c\u0438\u043d\u0438\u043c\u0430\u043b\u044c\u043d\u044b\u0439 \u2014 0. \u0422\u043e\u0447\u043d\u044b\u0439 \u0432\u044b\u0438\u0433\u0440\u044b\u0448 \u0412\u044b \u043c\u043e\u0436\u0435\u0442\u0435 \u0443\u0432\u0438\u0434\u0435\u0442\u044c \u0438\u0437 \u0441\u043b\u0435\u0434\u0443\u044e\u0449\u0435\u0439 \u0442\u0430\u0431\u043b\u0438\u0446\u044b.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n<\/div>\n\u0412 \u0442\u0430\u0431\u043b\u0438\u0446\u0435 \u0442\u0430\u043a\u0436\u0435 \u0443\u043a\u0430\u0437\u0430\u043d\u043e, \u0447\u0442\u043e \u0442\u043e \u0447\u0442\u043e \u0412\u044b \u043d\u0435 \u0437\u0430\u0440\u0430\u0431\u043e\u0442\u0430\u0435\u0442\u0435 (50 \u0414\u0415 \u043c\u0438\u043d\u0443\u0441 \u0414\u0415 \u0434\u043b\u044f \u0412\u0430\u0441) \u0431\u0443\u0434\u0443\u0442 \u043e\u0442\u043f\u0440\u0430\u0432\u043b\u0435\u043d\u044b \u0432 \u0433\u043e\u0441\u0443\u0434\u0430\u0440\u0441\u0442\u0432\u0435\u043d\u043d\u044b\u0439 \u0424\u043e\u043d\u0434 \u041f\u043e\u0434\u0434\u0435\u0440\u0436\u043a\u0438 \u041f\u0440\u0435\u0437\u0438\u0434\u0435\u043d\u0442\u0441\u043a\u0438\u0445 \u041f\u0440\u043e\u0433\u0440\u0430\u043c\u043c (https:\/\/fppp.kz) \u0434\u043b\u044f \u0444\u0438\u043d\u0430\u043d\u0441\u0438\u0440\u043e\u0432\u0430\u043d\u0438\u044f \u043e\u0431\u0449\u0435\u0441\u0442\u0432\u0435\u043d\u043d\u044b\u0445 \u0431\u043b\u0430\u0433 \u0432 \u041a\u0430\u0437\u0430\u0445\u0441\u0442\u0430\u043d\u0435. \u041f\u043e \u043e\u043a\u043e\u043d\u0447\u0430\u043d\u0438\u0438 \u0441\u0435\u0441\u0441\u0438\u0438 \u0441\u0443\u043c\u043c\u0430 \u0434\u0435\u043d\u0435\u0433, \u0441\u043e\u0431\u0440\u0430\u043d\u043d\u0430\u044f \u043e\u0442 \u0432\u0441\u0435\u0445 \u0443\u0447\u0430\u0441\u0442\u043d\u0438\u043a\u043e\u0432, \u0431\u0443\u0434\u0435\u0442 \u043e\u0442\u043f\u0440\u0430\u0432\u043b\u0435\u043d\u0430 \u200b\u200b\u043f\u0440\u044f\u043c\u044b\u043c \u043f\u0435\u0440\u0435\u0432\u043e\u0434\u043e\u043c \u0447\u0435\u0440\u0435\u0437 \u0441\u0430\u0439\u0442 \u0444\u043e\u043d\u0434\u0430.\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">\u0422\u0430\u0431\u043b\u0438\u0446\u0430 \u0431\u0443\u0434\u0435\u0442 \u043e\u0441\u0442\u0430\u0432\u0430\u0442\u044c\u0441\u044f \u043d\u0430 \u044d\u043a\u0440\u0430\u043d\u0435 \u0434\u043e \u0442\u0435\u0445 \u043f\u043e\u0440, \u043f\u043e\u043a\u0430 \u0412\u044b \u043d\u0435 \u0432\u0432\u0435\u0434\u0435\u0442\u0435 \u0440\u0435\u0437\u0443\u043b\u044c\u0442\u0430\u0442 \u0412\u0430\u0448\u0435\u0433\u043e \u0431\u0440\u043e\u0441\u043a\u0430. \u0415\u0441\u043b\u0438 \u0443 \u0412\u0430\u0441 \u0435\u0441\u0442\u044c \u0432\u043e\u043f\u0440\u043e\u0441\u044b, \u043f\u043e\u0436\u0430\u043b\u0443\u0439\u0441\u0442\u0430, \u043f\u043e\u0434\u043d\u0438\u043c\u0438\u0442\u0435 \u0440\u0443\u043a\u0443. \u0415\u0441\u043b\u0438 \u0412\u044b \u0433\u043e\u0442\u043e\u0432\u044b, \u043f\u0435\u0440\u0435\u0439\u0434\u0438\u0442\u0435 \u043d\u0430 \u0441\u043b\u0435\u0434\u0443\u044e\u0449\u0443\u044e \u0441\u0442\u0440\u0430\u043d\u0438\u0446\u0443.<\/div>\n\n<table align=\"center\" border=\"1\" cellpadding=\"1\" cellspacing=\"1\" style=\"width:250px;\">\n\t<thead>\n\t\t<tr>\n\t\t\t<th scope=\"row\">\u0427\u0438\u0441\u043b\u043e \u0432\u044b\u043f\u0430\u0432\u0448\u0438\u0445 \u043e\u0447\u043a\u043e\u0432<\/th>\n\t\t\t<th scope=\"col\">\u0414\u0415 \u0434\u043b\u044f \u0412\u0430\u0441<\/th>\n\t\t\t<th scope=\"col\">\u0414\u0415 \u0434\u043b\u044f \u0424\u043e\u043d\u0434\u0430 \u041f\u043e\u0434\u0434\u0435\u0440\u0436\u043a\u0438 \u041f\u0440\u0435\u0437\u0438\u0434\u0435\u043d\u0442\u0441\u043a\u0438\u0445 \u041f\u0440\u043e\u0433\u0440\u0430\u043c\u043c<\/th>\n\t\t<\/tr>\n\t<\/thead>\n\t<tbody>\n\t\t<tr>\n\t\t\t<th scope=\"row\">1<\/th>\n\t\t\t<td>10<\/td>\n\t\t\t<td>40<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">2<\/th>\n\t\t\t<td>20<\/td>\n\t\t\t<td>30<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">3<\/th>\n\t\t\t<td>30<\/td>\n\t\t\t<td>20<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">4<\/th>\n\t\t\t<td>40<\/td>\n\t\t\t<td>10<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">5<\/th>\n\t\t\t<td>50<\/td>\n\t\t\t<td>0<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">6<\/th>\n\t\t\t<td>0<\/td>\n\t\t\t<td>50<\/td>\n\t\t<\/tr>\n\t<\/tbody>\n<\/table>\n<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n<\/div>\n<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n"},"TR":{"QuestionText":"<div style=\"text-align: center;\">\n<div style=\"text-align: center;\">\n<div style=\"text-align: center;\">\n<div style=\"text-align: center;\">\n<div style=\"text-align: center;\">\n<div style=\"text-align: center;\">Bu b\u00f6l\u00fcmde, size verilen zar\u0131 iki kez atman\u0131z istenmektedir. Elde edece\u011finiz kazanc\u0131 zar\u0131 ilk at\u0131\u015f\u0131n\u0131z\u0131n sonucu belirleyecektir. \u0130kinci at\u0131\u015f ise sadece zar\u0131n d\u00fczg\u00fcn \u00e7al\u0131\u015ft\u0131\u011f\u0131ndan emin olman\u0131z i\u00e7indir. Dilerseniz zar\u0131 iki kereden fazla da atabilirsiniz. Ancak, kazanc\u0131n\u0131z\u0131 sadece ilk at\u0131\u015f\u0131n\u0131z\u0131n sonucu belirleyecektir.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">Bu b\u00f6l\u00fcmde elde edebilece\u011finiz en y\u00fcksek kazan\u00e7 50 Deney Para Birimi (DPB), en d\u00fc\u015f\u00fck kazan\u00e7 0 DPB'dir. A\u015fa\u011f\u0131daki tabloda ataca\u011f\u0131n\u0131z ilk zar\u0131n sonucuna g\u00f6re kazanaca\u011f\u0131n\u0131z DPB'ler yer almaktad\u0131r.<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n<\/div>\n\n<div style=\"text-align: center;\">Olas\u0131 en y\u00fcksek kazan\u00e7 olan 50 DPB'den ataca\u011f\u0131n\u0131z ilk zar\u0131n sonucuna g\u00f6re kazanaca\u011f\u0131n\u0131z DPB tutar\u0131 \u00e7\u0131kar\u0131lacak, bu tutar T\u00fcrkiye Cumhuriyeti'nde bir Bakanl\u0131\u011f\u0131'a, kamu hizmetlerinin finanse edilmesine destek amac\u0131yla ba\u011f\u0131\u015flanacakt\u0131r.<br \/>\n\u00a0<\/div>\n<\/div>\n<\/div>\n<\/div>\n\n<div style=\"text-align: center;\">Tabloda sizin DPB kazanc\u0131n\u0131z\u0131n yan\u0131 s\u0131ra bakanl\u0131\u011fa g\u00f6nderilecek tutarlar (50 DPB'den sizin kazanc\u0131n\u0131z \u00e7\u0131kar\u0131ld\u0131\u011f\u0131nda kalan tutarlar) yer almaktad\u0131r. Oturumun sonunda, bakanl\u0131\u011fa ba\u011f\u0131\u015flanmas\u0131 i\u00e7in t\u00fcm kat\u0131l\u0131mc\u0131lardan toplanan paran\u0131n tamam\u0131 banka transferi yoluyla g\u00f6nderilecektir. (IBAN:\u00a0TR600001001745032156205014)<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">Att\u0131\u011f\u0131n\u0131z ilk zar\u0131n sonucunu girene kadar tablo ekranda kalacakt\u0131r. Herhangi bir sorunuz varsa l\u00fctfen elinizi kald\u0131r\u0131n. Haz\u0131r oldu\u011funuzda l\u00fctfen bir sonraki sayfaya ge\u00e7in.<br \/>\n\u00a0<\/div>\n\n<table align=\"center\" border=\"1\" cellpadding=\"1\" cellspacing=\"1\" style=\"width:250px;\">\n\t<thead>\n\t\t<tr>\n\t\t\t<th scope=\"row\">Zar\u0131n Sonucu<\/th>\n\t\t\t<th scope=\"col\">DPB kazanc\u0131n\u0131z<\/th>\n\t\t\t<th scope=\"col\">Bakanl\u0131\u011f\u0131n\u00a0DPB kazanc\u0131<\/th>\n\t\t<\/tr>\n\t<\/thead>\n\t<tbody>\n\t\t<tr>\n\t\t\t<th scope=\"row\">1<\/th>\n\t\t\t<td>10<\/td>\n\t\t\t<td>40<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">2<\/th>\n\t\t\t<td>20<\/td>\n\t\t\t<td>30<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">3<\/th>\n\t\t\t<td>30<\/td>\n\t\t\t<td>20<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">4<\/th>\n\t\t\t<td>40<\/td>\n\t\t\t<td>10<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">5<\/th>\n\t\t\t<td>50<\/td>\n\t\t\t<td>0<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">6<\/th>\n\t\t\t<td>0<\/td>\n\t\t\t<td>50<\/td>\n\t\t<\/tr>\n\t<\/tbody>\n<\/table>\n<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n"},"ZH-HK":{"QuestionText":"<div style=\"text-align: center;\">\n<div style=\"text-align: center;\">\n<div style=\"text-align: center;\">\n<p>\u60a8\u5fc5\u9808\u64f2\u5169\u6b21\u9ab0\u5b50\u3002\u7b2c\u4e00\u6b21\u64f2\u9ab0\u5b50\u6703\u6c7a\u5b9a\u4f60\u7372\u5f97\u7684MU\u6578\u91cf\uff0c\u7b2c\u4e8c\u6b21\u64f2\u9ab0\u5b50\u53ea\u662f\u70ba\u4e86\u78ba\u8a8d\u9ab0\u5b50\u6b63\u5e38\u904b\u4f5c\u3002\u4e8b\u5be6\u4e0a\uff0c\u60a8\u53ef\u4ee5\u64f2\u9ab0\u5b50\u5169\u6b21\u4ee5\u4e0a\u3002\u4f46\u662f\uff0c\u53ea\u6709\u7b2c\u4e00\u6b21\u64f2\u9ab0\u5b50\u7b97\u6578\u3002<\/p>\n<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">\n<p>\u60a8\u53ef\u4ee5\u7372\u5f97\u7684MU\u6578\u91cf\u6700\u591a\u70ba 50\uff0c\u6700\u5c11\u70ba 0 \u3002\u4e0b\u65b9\u7684\u8868\u683c\u986f\u793a\u8457\u78ba\u5207\u5c0d\u61c9\u7684MU\u6578\u91cf\u3002<\/p>\n<\/div>\n<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">\u8868\u683c\u4e5f\u6307\u51fa\uff0c\u60a8\u5c11\u7372\u5f97\u7684MU\uff0850 MU \u6e1b\u53bb\u60a8\u7372\u5f97\u7684 MU\uff09\u6703\u6350\u8d08\u7d66\u9999\u6e2f\u7684\u8ca1\u7d93\u4e8b\u52d9\u53ca\u5eab\u52d9\u5c40\uff0c\u4ee5\u5e6b\u52a9\u8cc7\u52a9\u5361\u9054\u7684\u516c\u5171\u7522\u54c1\u3002\u4ee5\u8cc7\u52a9\u5176\u63d0\u4f9b\u516c\u5171\u8ca1\u653f\u7d66\u9999\n<p>\u6e2f\u3002\u5be6\u9a57\u7d50\u675f\u5f8c\uff0c\u4f86\u81ea\u6240\u6709\u53c3\u8207\u8005\u5011\u7684\u6350\u8d08\u5c07\u5168\u984d\u76f4\u63a5\u8f49\u5e33\u7d66\u8ca1\u7d93\u4e8b\u52d9\u53ca\u5eab\u52d9\u5c40\u3002<\/p>\n<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">\u8868\u683c\u5c07\u4fdd\u7559\u5728\u87a2\u5e55\u4e0a\uff0c\u76f4\u5230\u60a8\u8f38\u5165\u64f2\u51fa\u7684\u6570\u5b57\u3002\u5982\u679c\u60a8\u6709\u4efb\u4f55\u7591\u554f\uff0c\u8acb\u8209\u624b\u3002\u5982\u679c\u60a8\u6e96\u5099\u597d\u4e86\uff0c\u8acb\u7e7c\u7e8c\u95b1\u8b80\u4e0b\u4e00\u9801\u3002<\/div>\n\n<table align=\"center\" border=\"1\" cellpadding=\"1\" cellspacing=\"1\" style=\"width:250px;\">\n\t<thead>\n\t\t<tr>\n\t\t\t<th scope=\"row\">\n\t\t\t<p><b>\u64f2\u51fa\u7684\u6570\u5b57<\/b><\/p>\n\t\t\t<\/th>\n\t\t\t<th scope=\"col\">\n\t\t\t<p><strong>\u60a8\u7372\u5f97\u7684<\/strong><\/p>\n\t\t\t<strong>MU<\/strong><\/th>\n\t\t\t<th scope=\"col\"><strong>\u8ca1\u7d93\u4e8b\u52d9\u53ca\u5eab\u52d9\u5c40\u7372\u5f97\u7684 MU<\/strong><\/th>\n\t\t<\/tr>\n\t<\/thead>\n\t<tbody>\n\t\t<tr>\n\t\t\t<th scope=\"row\">1<\/th>\n\t\t\t<td>10<\/td>\n\t\t\t<td>40<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">2<\/th>\n\t\t\t<td>20<\/td>\n\t\t\t<td>30<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">3<\/th>\n\t\t\t<td>30<\/td>\n\t\t\t<td>20<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">4<\/th>\n\t\t\t<td>40<\/td>\n\t\t\t<td>10<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">5<\/th>\n\t\t\t<td>50<\/td>\n\t\t\t<td>0<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">6<\/th>\n\t\t\t<td>0<\/td>\n\t\t\t<td>50<\/td>\n\t\t<\/tr>\n\t<\/tbody>\n<\/table>\n<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n"},"ZH-S":{"QuestionText":"<div style=\"text-align: center;\">\n<div style=\"text-align: center;\">\u60a8\u9700\u8981\u63b7\u4e24\u6b21\u9ab0\u5b50\u3002\u7b2c\u4e00\u6b21\u63b7\u9ab0\u5b50\u51b3\u5b9a\u60a8\u80fd\u5f97\u5230\u591a\u5c11\u4e2a MU\uff0c\u7b2c\u4e8c\u6b21\u63b7\u9ab0\u5b50\u53ea\u662f\u4e3a\u4e86\u786e\u4fdd\u9ab0\u5b50\u662f\u6ca1\u95ee\u9898\u7684\u3002\u4e8b\u5b9e\u4e0a\uff0c\u60a8\u53ef\u4ee5\u63b7\u9ab0\u5b50\u4e24\u6b21\u4ee5\u4e0a\u3002\u4f46\u662f\uff0c\u53ea\u6709\u7b2c\u4e00\u6b21\u63b7\u9ab0\u5b50\u7684\u7ed3\u679c\u624d\u7b97\u6570\u3002<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">\u60a8\u80fd\u5f97\u5230\u7684\u6700\u5927\u6536\u76ca\u662f 50\u00a0\u4e2a\u8d27\u5e01\u5355\u4f4d (MU)\uff0c\u6700\u5c0f\u6536\u76ca\u662f 0 \u4e2a\u3002\u60a8\u53ef\u4ee5\u4ece\u4e0b\u8868\u4e2d\u770b\u5230\u786e\u5207\u7684\u6536\u76ca\u3002<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">\u8be5\u8868\u8fd8\u63cf\u8ff0\u4e86\u60a8\u672a\u8d5a\u5230\u7684\u8d27\u5e01\u5355\u4f4d\uff0850 MU \u51cf\u53bb\u60a8\u7684 MU\uff09\u5c06\u4f5c\u4e3a\u6350\u6b3e\u6350\u8d60\u7ed9\u4e2d\u534e\u4eba\u6c11\u5171\u548c\u56fd\u5e94\u6025\u7ba1\u7406\u90e8\uff0c\u4ee5\u5e2e\u52a9\u8d44\u52a9\u4e2d\u56fd\u9762\u5bf9\u7a81\u53d1\u4e8b\u4ef6\u7684\u5e94\u6025\u63f4\u6551\u5de5\u4f5c\u3002\u4f1a\u8bdd\u7ed3\u675f\u65f6\uff0c\u4ece\u6240\u6709\u53c2\u4e0e\u8005\u90a3\u91cc\u7b79\u96c6\u7684\u8d44\u91d1\u5c06\u901a\u8fc7\u76f4\u63a5\u8f6c\u8d26\u7684\u65b9\u5f0f\u6350\u8d60 (\u8d26\u53f7: 11050160560008000004)\u3002<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">\u8868\u683c\u5c06\u4fdd\u7559\u5728\u5c4f\u5e55\u4e0a\uff0c\u76f4\u5230\u60a8\u8f93\u5165\u60a8\u7684\u63b7\u9ab0\u5b50\u7ed3\u679c\u3002\u5982\u679c\u60a8\u6709\u4efb\u4f55\u7591\u95ee\uff0c\u8bf7\u4e3e\u624b\u3002\u5982\u679c\u60a8\u51c6\u5907\u597d\u4e86\uff0c\u8bf7\u7ee7\u7eed\u4e0b\u4e00\u9875\u3002<\/div>\n\u00a0\n\n<table align=\"center\" border=\"1\" cellpadding=\"1\" cellspacing=\"1\" style=\"width:250px;\">\n\t<thead>\n\t\t<tr>\n\t\t\t<th scope=\"row\">\u629b\u51fa\u7684\u6570\u5b57<\/th>\n\t\t\t<th scope=\"col\">\u60a8\u7684 MU<\/th>\n\t\t\t<th scope=\"col\">\u5e94\u6025\u7ba1\u7406\u90e8\u7684 MU<\/th>\n\t\t<\/tr>\n\t<\/thead>\n\t<tbody>\n\t\t<tr>\n\t\t\t<th scope=\"row\">1<\/th>\n\t\t\t<td>10<\/td>\n\t\t\t<td>40<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">2<\/th>\n\t\t\t<td>20<\/td>\n\t\t\t<td>30<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">3<\/th>\n\t\t\t<td>30<\/td>\n\t\t\t<td>20<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">4<\/th>\n\t\t\t<td>40<\/td>\n\t\t\t<td>10<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">5<\/th>\n\t\t\t<td>50<\/td>\n\t\t\t<td>0<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">6<\/th>\n\t\t\t<td>0<\/td>\n\t\t\t<td>50<\/td>\n\t\t<\/tr>\n\t<\/tbody>\n<\/table>\n<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n"},"ZH-T":{"QuestionText":"<div style=\"text-align: center;\">\n<div style=\"text-align: center;\">\u60a8\u5fc5\u9808\u64f2\u5169\u6b21\u9ab0\u5b50\u3002\u7b2c\u4e00\u6b21\u64f2\u9ab0\u5b50\u6703\u6c7a\u5b9a\u60a8\u7372\u5f97\u7684\u6cd5\u5e63\u6578\u91cf\uff0c\u7b2c\u4e8c\u6b21\u64f2\u9ab0\u5b50\u53ea\u662f\u70ba\u4e86\u78ba\u8a8d\u9ab0\u5b50\u7684\u516c\u6b63\u6027\u3002\u4e8b\u5be6\u4e0a\uff0c\u60a8\u53ef\u4ee5\u64f2\u9ab0\u5b50\u5169\u6b21\u4ee5\u4e0a\u3002\u4f46\u662f\uff0c\u53ea\u6709\u7b2c\u4e00\u6b21\u64f2\u9ab0\u5b50\u7b97\u6578\u3002\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">\u60a8\u53ef\u4ee5\u7372\u5f97\u7684\u6cd5\u5e63\u6578\u91cf\u6700\u591a\u70ba 50\uff0c\u6700\u5c11\u70ba 0 \u3002\u4e0b\u65b9\u7684\u8868\u683c\u986f\u793a\u8457\u78ba\u5207\u7684\u6cd5\u5e63\u6578\u91cf\u5c0d\u61c9\u3002\n<div style=\"text-align: center;\">\u8868\u683c\u4e5f\u6307\u51fa\uff0c\u60a8\u5c11\u7372\u5f97\u7684\u91d1\u984d\uff08\u4f86\u81ea50 \u6cd5\u5e63\u6e1b\u53bb\u60a8\u7372\u5f97\u7684\u6cd5\u5e63\uff09\u6703\u6350\u81f3\u53f0\u7063\u7684\u885b\u751f\u798f\u5229 \u90e8\uff0c\u4ee5\u8cc7\u52a9\u5176\u63d0\u4f9b\u707d\u5bb3\u63f4\u52a9\u7d66\u53d7\u707d\u5730\u5340\u53ca\u707d\u6c11\u3002\u9019\u4e9b\u4f86\u81ea\u53d7\u8a66\u8005\u5011\u7684\u7e3d\u91d1\u984d\u5c07\u65bc\u5be6\u9a57\u7d50 \u675f\u5f8c\u532f\u6b3e\u81f3\u300c\u885b\u751f\u798f\u5229\u90e8\u8cd1\u707d\u5c08\u6236\u300d\u3002<\/div>\n<\/div>\n\n<div style=\"text-align: center;\">\n<div style=\"text-align: center;\">\n<div style=\"text-align: center;\">\u00a0<\/div>\n\n<div style=\"text-align: center;\">\n<div style=\"text-align: center;\">\u8868\u683c\u6703\u505c\u7559\u5728\u87a2\u5e55\u4e0a\uff0c\u76f4\u5230\u60a8\u8f38\u5165\u64f2\u51fa\u7684\u6578\u5b50\u3002\u5982\u679c\u60a8\u6709\u4efb\u4f55\u7591\u554f\uff0c\u8acb\u8209\u624b\u3002\u5982\u679c\u60a8\u6e96\u5099\u597d\u4e86\uff0c\u8acb\u7e7c\u7e8c\u95b1\u8b80\u4e0b\u4e00\u9801\u3002<\/div>\n\n<table align=\"center\" border=\"1\" cellpadding=\"1\" cellspacing=\"1\">\n\t<thead>\n\t\t<tr>\n\t\t\t<th scope=\"row\">\u00a0\u64f2\u51fa\u7684\u6570\u5b57\u00a0<\/th>\n\t\t\t<th scope=\"col\">\u00a0\u60a8\u7372\u5f97\u7684\u6cd5\u5e63\u00a0<\/th>\n\t\t\t<th scope=\"col\">\u00a0\u885b\u751f\u798f\u5229\u90e8\u6536\u5230\u7684\u6cd5\u5e63\u00a0<\/th>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">1<\/th>\n\t\t\t<td>10<\/td>\n\t\t\t<td>40<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">2<\/th>\n\t\t\t<td>20<\/td>\n\t\t\t<td>30<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">3<\/th>\n\t\t\t<td>30<\/td>\n\t\t\t<td>20<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">4<\/th>\n\t\t\t<td>40<\/td>\n\t\t\t<td>10<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">5<\/th>\n\t\t\t<td>50<\/td>\n\t\t\t<td>0<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">6<\/th>\n\t\t\t<td>0<\/td>\n\t\t\t<td>50<\/td>\n\t\t<\/tr>\n\t<\/thead>\n<\/table>\n<\/div>\n\n<div style=\"text-align: center;\">\u00a0<\/div>\n<\/div>\n<\/div>\n<\/div>\n<\/div>\n"}},"NextChoiceId":4,"NextAnswerId":1,"QuestionText_Unsafe":"<div style=\"text-align: center;\">\n<div style=\"text-align: center;\">You will have to throw a dice twice. Your first throw decides how much you receive, and the second throw only serves to make sure that the dice is working properly. In fact, you may throw the dice more than twice. However, only the first throw counts.<\/div>\n\n<div style=\"text-align: center;\">&nbsp;<\/div>\n\n<div style=\"text-align: center;\">The maximum payoff you can receive is 50 Monetary Units (MUs) and the minimum 0.&nbsp;You can see the exact payoff from the following table.<\/div>\n\n<div style=\"text-align: center;\">&nbsp;<\/div>\n\n<div style=\"text-align: center;\">The table also describes that the money not earned by you (50 MUs minus MUs for you)  will be sent to the Ministry of Finance of Qatar as a donation in order to help finance public goods in Qatar. At the end of the session, the sum of money gathered from all participants will be sent via a direct transfer.<\/div>\n\n<div style=\"text-align: center;\">&nbsp;<\/div>\n\n<div style=\"text-align: center;\">The table will remain on the screen until you entered your throw. If you have any questions, please raise your hand. If you are ready, please continue to the next page.<\/div>\n&nbsp;\n\n<table style=\"width:250px;\" cellspacing=\"1\" cellpadding=\"1\" border=\"1\" align=\"center\">\n\t<thead>\n\t\t<tr>\n\t\t\t<th scope=\"row\">Number thrown<\/th>\n\t\t\t<th scope=\"col\">MUs for you<\/th>\n\t\t\t<th scope=\"col\">MUs for the Ministry of Finance<\/th>\n\t\t<\/tr>\n\t<\/thead>\n\t<tbody>\n\t\t<tr>\n\t\t\t<th scope=\"row\">1<\/th>\n\t\t\t<td>10<\/td>\n\t\t\t<td>40<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">2<\/th>\n\t\t\t<td>20<\/td>\n\t\t\t<td>30<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">3<\/th>\n\t\t\t<td>30<\/td>\n\t\t\t<td>20<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">4<\/th>\n\t\t\t<td>40<\/td>\n\t\t\t<td>10<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">5<\/th>\n\t\t\t<td>50<\/td>\n\t\t\t<td>0<\/td>\n\t\t<\/tr>\n\t\t<tr>\n\t\t\t<th scope=\"row\">6<\/th>\n\t\t\t<td>0<\/td>\n\t\t\t<td>50<\/td>\n\t\t<\/tr>\n\t<\/tbody>\n<\/table>\n<\/div>\n\n<div style=\"text-align: center;\">&nbsp;<\/div>","DataExportTag":"T3: Gov_1","QuestionID":"QID31"}},{"SurveyID":"SV_b3mHBVkuioRMhng","Element":"SQ","PrimaryAttribute":"QID310","SecondaryAttribute":"Timing","TertiaryAttribute":null,"Payload":{"QuestionText":"Timing","DefaultChoices":false,"DataExportTag":"Q303","QuestionID":"QID310","QuestionType":"Timing","Selector":"PageTimer","Configuration":{"QuestionDescriptionOption":"UseText","MinSeconds":"0","MaxSeconds":"0"},"QuestionDescription":"Timing","Choices":{"1":{"Display":"First Click"},"2":{"Display":"Last Click"},"3":{"Display":"Page Submit"},"4":{"Display":"Click Count"}},"Validation":"None","GradingData":[],"Language":{"ES":[],"EL":{"QuestionText":"\u03a3\u03c5\u03b3\u03c7\u03c1\u03bf\u03bd\u03b9\u03c3\u03bc\u03cc\u03c2","Choices":{"1":{"Display":"\u03a0\u03c1\u03ce\u03c4\u03bf \u03ba\u03bb\u03b9\u03ba"},"2":{"Display":"\u03a4\u03b5\u03bb\u03b5\u03c5\u03c4\u03b1\u03af\u03bf \u03ba\u03bb\u03b9\u03ba"},"3":{"Display":"\u03a5\u03c0\u03bf\u03b2\u03b