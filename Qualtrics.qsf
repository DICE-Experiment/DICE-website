lama"},"3":{"Display":"Sayfa G\u00f6nder"},"4":{"Display":"T\u0131klama Say\u0131s\u0131"}}},"ZH-HK":[],"KZ-RU":[],"AR":[],"DE-DE":{"QuestionText":"Timing","Choices":{"1":{"Display":"Erster Klick"},"2":{"Display":"Letzter Klick"},"3":{"Display":"Seite \u00fcbermitteln"},"4":{"Display":"Klickanzahl"}}}},"NextChoiceId":28,"NextAnswerId":1,"QuestionText_Unsafe":"Timing"}},{"SurveyID":"SV_b3mHBVkuioRMhng","Element":"SQ","PrimaryAttribute":"QID3","SecondaryAttribute":"PART 1 \u00a0 In this part, you will receive a payoff. This payoff is not the same for every participa..","TertiaryAttribute":null,"Payload":{"QuestionText":"<div style=\"text-align: center;\"><strong>PART 1<\/strong><br>\n&nbsp;<\/div>\n\n<div style=\"text-align: center;\">In this part, you will receive a payoff. This payoff is not the same for every participant. You determine your own payoff by throwing a die as soon as you are asked to.<\/div>","DefaultChoices":false,"DataExportTag":"Intro Part 1","QuestionID":"QID3","QuestionType":"DB","Selector":"TB","Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"PART 1 \u00a0 In this part, you will receive a payoff. This payoff is not the same for every participa...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":{"ES":{"QuestionText":"<div style=\"text-align: center;\"><strong>PARTE 1<\/strong><br \/>\n\u00a0<\/div>\n\n<div style=\"text-align: center;\">En esta parte, recibir\u00e1 un pago. Este pago no es el mismo para todos los participantes. Usted determina su propio pago lanzando el dado tan pronto como se le solicite.<\/div>\n"},"EL":{"QuestionText":"<div style=\"text-align: center;\"><strong>\u039c\u0395\u03a1\u039f\u03a3 1<\/strong><\/div>\n\n<div style=\"text-align: center;\">\u03a3\u03b5 \u03b1\u03c5\u03c4\u03cc \u03c4\u03bf \u03bc\u03ad\u03c1\u03bf\u03c2, \u03b8\u03b1 \u03ba\u03b5\u03c1\u03b4\u03af\u03c3\u03b5\u03c4\u03b5 \u03c7\u03c1\u03ae\u03bc\u03b1\u03c4\u03b1. \u038c\u03bb\u03bf\u03b9 \u03bf\u03b9 \u03c3\u03c5\u03bc\u03bc\u03b5\u03c4\u03ad\u03c7\u03bf\u03bd\u03c4\u03b5\u03c2 \u03b4\u03b5\u03bd \u03b8\u03b1 \u03ba\u03b5\u03c1\u03b4\u03af\u03c3\u03bf\u03c5\u03bd \u03c4\u03b1 \u03af\u03b4\u03b9\u03b1 \u03c7\u03c1\u03ae\u03bc\u03b1\u03c4\u03b1. \u03a4\u03bf \u03c0\u03cc\u03c3\u03b1 \u03b8\u03b1 \u03ba\u03b5\u03c1\u03b4\u03af\u03c3\u03b5\u03b9 \u03ba\u03ac\u03b8\u03b5 \u03ad\u03bd\u03b1\u03c2, \u03b8\u03b1 \u03ba\u03b1\u03b8\u03bf\u03c1\u03b9\u03c3\u03c4\u03b5\u03af \u03c1\u03af\u03c7\u03bd\u03bf\u03bd\u03c4\u03b1\u03c2 \u03c4\u03bf \u03b6\u03ac\u03c1\u03b9.<\/div>\n"},"FR":{"QuestionText":"<div style=\"text-align: center;\"><strong>PARTIE 1<\/strong><\/div>\n\n<div style=\"text-align: center;\">Dans cette partie, vous recevrez un gain. Ce gain n'est pas le m\u00eame pour chaque participant. <span lang=\"FR\"><span style=\"font-family:Arial\"><span style=\"letter-spacing:-.15pt\">Vous <\/span>allez d\u00e9terminer le montant de votre propre gain en lan\u00e7ant un d\u00e9 d\u00e8s qu'on vous <span style=\"letter-spacing:-.35pt\">le <\/span>demandera.<\/span><\/span><\/div>\n"},"CS":{"QuestionText":"<div style=\"text-align: center;\"><strong>\u010c\u00c1ST 1<\/strong><\/div>\n\n<div style=\"text-align: center;\">V t\u00e9to \u010d\u00e1sti m\u016f\u017eete z\u00edskat pen\u00edze. Kdo kolik z\u00edsk\u00e1 se bude li\u0161it mezi \u00fa\u010dastn\u00edky. \u010c\u00e1stka, kterou m\u016f\u017eete z\u00edskat pr\u00e1v\u011b Vy, bude z\u00e1le\u017eet na tom, kolik hod\u00edte kostkou, a\u017e o to budete po\u017e\u00e1d\u00e1n(a).<\/div>\n"},"RU":{"QuestionText":"<div style=\"text-align: center;\"><strong>\u0427\u0410\u0421\u0422\u042c 1<\/strong><\/div>\n\n<div style=\"text-align: center;\">\u0412 \u044d\u0442\u043e\u0439 \u0447\u0430\u0441\u0442\u0438 \u0412\u044b \u043f\u043e\u043b\u0443\u0447\u0438\u0442\u0435 \u0432\u043e\u0437\u043d\u0430\u0433\u0440\u0430\u0436\u0434\u0435\u043d\u0438\u0435. \u042d\u0442\u043e\u0442 \u0432\u044b\u0438\u0433\u0440\u044b\u0448 \u043d\u0435 \u043e\u0434\u0438\u043d\u0430\u043a\u043e\u0432 \u0434\u043b\u044f \u043a\u0430\u0436\u0434\u043e\u0433\u043e \u0443\u0447\u0430\u0441\u0442\u043d\u0438\u043a\u0430. \u0412\u044b \u0441\u0430\u043c\u0438 \u043e\u043f\u0440\u0435\u0434\u0435\u043b\u044f\u0435\u0442\u0435 \u0441\u0432\u043e\u0439 \u0432\u044b\u0438\u0433\u0440\u044b\u0448, \u0431\u0440\u043e\u0441\u0430\u044f \u0438\u0433\u0440\u0430\u043b\u044c\u043d\u0443\u044e \u043a\u043e\u0441\u0442\u044c, \u043a\u0430\u043a \u0442\u043e\u043b\u044c\u043a\u043e \u0412\u0430\u0441 \u043e\u0431 \u044d\u0442\u043e\u043c \u043f\u043e\u043f\u0440\u043e\u0441\u044f\u0442.<\/div>\n"},"HU":{"QuestionText":"<div style=\"text-align: center;\"><strong>1. R\u00c9SZ<\/strong><\/div>\n\n<div style=\"text-align: center;\">Ebben a r\u00e9szben p\u00e9nzt kereshet. A p\u00e9nz\u00f6sszeg nem minden r\u00e9sztvev\u0151 sz\u00e1m\u00e1ra azonos. Majd megk\u00e9rj\u00fck, hogy dobjon egy kock\u00e1val, \u00e9s a dobott sz\u00e1m hat\u00e1rozza meg a p\u00e9nznyerem\u00e9ny\u00e9t.<\/div>\n"},"IT":{"QuestionText":"<div style=\"text-align: center;\"><strong>PARTE 1<\/strong><\/div>\n\n<div style=\"text-align: center;\">In questa parte riceverai un compenso. Questo compenso non \u00e8 lo stesso per ogni partecipante. Determinerai il tuo compenso lanciando un dado non appena ti verr\u00e0 chiesto di farlo.<\/div>\n"},"PL":{"QuestionText":"<div style=\"text-align: center;\"><strong>CZ\u0118\u015a\u0106 1<\/strong><br><\/div><div style=\"text-align: center;\"> W tej cz\u0119\u015bci otrzymasz wyp\u0142at\u0119. Wyp\u0142ata ta nie jest taka sama dla ka\u017cdego uczestnika. Sam okre\u015blasz swoj\u0105 wyp\u0142at\u0119, rzucaj\u0105c kostk\u0105, gdy tylko zostaniesz o to poproszony.<\/div>"},"PT":{"QuestionText":"<div style=\"text-align: center;\"><strong>PARTE 1<\/strong><br \/>\n\u00a0<\/div>\n\n<div style=\"text-align: center;\">Nesta parte, receber\u00e1 um pagamento em UMs. Este montante n\u00e3o \u00e9 igual para todos os participantes.\u00a0Determinar\u00e1 o seu pr\u00f3prio pagamento ao lan\u00e7ar um dado assim que lhe for solicitado.<\/div>\n"},"ZH-S":{"QuestionText":"<div style=\"text-align: center;\"><strong>\u7b2c 1 \u90e8\u5206<\/strong><br>\n&nbsp;<\/div>\n\n<div style=\"text-align: center;\">\u5728\u6b64\u90e8\u5206\uff0c\u60a8\u5c06\u83b7\u5f97\u56de\u62a5\u3002\u6b64\u56de\u62a5\u5bf9\u4e8e\u6bcf\u4e2a\u53c2\u4e0e\u8005\u6765\u8bf4\u90fd\u4e0d\u4e00\u6837\u3002\u60a8\u53ef\u4ee5\u901a\u8fc7\u5728\u88ab\u8981\u6c42\u65f6\u6295\u63b7\u9ab0\u5b50\u6765\u786e\u5b9a\u81ea\u5df1\u7684\u56de\u62a5\u3002<\/div>"},"FR-FR":{"QuestionText":"<div style=\"text-align: center;\"><strong>PARTIE 1<\/strong><br \/>\n\u00a0<\/div>\n\n<div style=\"text-align: center;\">Dans cette partie, vous recevrez un certain montant d'UM. Ce montant n'est pas le m\u00eame pour tous les participants. Le montant sera d\u00e9termin\u00e9 en lan\u00e7ant votre d\u00e9 lorsque cela vous sera demand\u00e9.<\/div>\n"},"ES-ES":{"QuestionText":"<div style=\"text-align: center;\"><strong>PARTE 1<\/strong><br>\n&nbsp;<\/div>\n\n<div style=\"text-align: center;\">En esta parte, recibir\u00e1s una recompensa. Esta recompensa no es la misma para todos los participantes. Usted determina su propia recompensa lanzando un dado tan pronto como se lo piden.<\/div>"},"ES-AR":{"QuestionText":"<div style=\"text-align: center;\"><strong>PARTE 1<\/strong><br \/>\n<br \/>\nEn esta parte, recibir\u00e1 una recompensa. Esta recompensa no es la misma para todos los participantes. Usted determinar\u00e1 su propia recompensa lanzando un dado cuando se lo pidan.<\/div>\n"},"JA":{"QuestionText":"<div style=\"text-align: center;\"><strong>\u30d1\u30fc\u30c8 1<\/strong><br>\n&nbsp;<\/div>\n\n<div style=\"text-align: center;\">\u3053\u306e\u30d1\u30fc\u30c8\u3067\u306f\u3001\u5831\u916c\u3092\u53d7\u3051\u53d6\u308a\u307e\u3059\u3002\u3053\u306e\u5831\u916c\u306f\u53c2\u52a0\u8005\u3054\u3068\u306b\u7570\u306a\u308a\u307e\u3059\u3002\u6307\u793a\u3055\u308c\u305f\u3089\u3059\u3050\u306b\u30b5\u30a4\u30b3\u30ed\u3092\u632f\u3063\u3066\u3001\u81ea\u5206\u306e\u5831\u916c\u3092\u6c7a\u5b9a\u3057\u307e\u3059\u3002<\/div>"},"DE":{"QuestionText":"<div style=\"text-align: center;\"><strong>TEIL 1<\/strong><br>\n&nbsp;<\/div>\n\n<div style=\"text-align: center;\">In diesem Teil erh\u00e4ltst du eine Auszahlung. Diese Auszahlung ist nicht f\u00fcr alle Teilnehmer gleich. Du bestimmst deine eigene Auszahlung, indem du w\u00fcrfelst, sobald du dazu aufgefordert wirst.<\/div>"},"ZH-T":{"QuestionText":"<div style=\"text-align: center;\"><strong>\u7b2c 1 \u90e8\u5206<\/strong><br \/>\n\u00a0<\/div>\n\n<div style=\"text-align: center;\">\u672c\u90e8\u5206\u6bcf\u500b\u4eba\u7684\u5831\u916c\u4e0d\u4e00\u5b9a\u76f8\u540c\u3002\u8acb\u4f9d\u7167\u6307\u793a\uff0c\u900f\u904e\u64f2\u9ab0\u5b50\u4f86\u6c7a\u5b9a\u81ea\u5df1\u7684\u5831\u916c\u3002<\/div>\n"},"KO":{"QuestionText":"<div style=\"text-align: center;\"><strong>1\ubd80<\/strong><br \/>\n\u00a0<\/div>\n\n<div style=\"text-align: center;\">1\ubd80\uc5d0\uc11c\ub294 \uadc0\ud558\uc758 \uacb0\uc815\uc5d0 \ub530\ub77c \ubcf4\uc0c1\uc744 \ubc1b\uac8c \ub429\ub2c8\ub2e4. \uc774 \ubcf4\uc0c1\uc740 \ubaa8\ub4e0 \ucc38\uac00\uc790\uc5d0\uac8c \ub3d9\uc77c\ud558\uc9c0 \uc54a\uc2b5\ub2c8\ub2e4. \uc2e4\ud5d8 \ucc38\uc5ec\uc2dc \ubc1b\uc73c\uc168\ub358 \uc8fc\uc0ac\uc704\ub97c \uad74\ub824 \ubcf4\uc0c1\uc744 \uacb0\uc815\ud558\uac8c \ub429\ub2c8\ub2e4.<\/div>\n"},"DE-AT":{"QuestionText":"<div style=\"text-align: center;\"><strong>TEIL 1<\/strong><br>\n&nbsp;<\/div>\n\n<div style=\"text-align: center;\">In diesem Teil erh\u00e4ltst du eine Auszahlung. Diese Auszahlung ist nicht f\u00fcr alle Teilnehmer gleich. Du bestimmst deine eigene Auszahlung, indem du w\u00fcrfelst, sobald du dazu aufgefordert wirst.<\/div>"},"TR":{"QuestionText":"<div style=\"text-align: center;\"><strong>B\u00d6L\u00dcM 1<\/strong><\/div>\n\n<div style=\"text-align: center;\">Bu b\u00f6l\u00fcmde elde edece\u011finiz kazan\u00e7 bireyseldir ve sizin yapaca\u011f\u0131n\u0131z bir zar at\u0131\u015f\u0131 ile belirlenecektir.<\/div>\n"},"ZH-HK":{"QuestionText":"<div style=\"text-align: center;\"><strong>\u7b2c 1 \u90e8\u5206<\/strong><\/div>\n\n<div style=\"text-align: center;\">\n<p>\u672c\u90e8\u5206\u6bcf\u500b\u4eba\u7684\u5831\u916c\u4e0d\u4e00\u5b9a\u76f8\u540c\u3002\u8acb\u4f9d\u7167\u6307\u793a\uff0c\u900f\u904e\u64f2\u9ab0\u5b50\u4f86\u6c7a\u5b9a\u81ea\u5df1\u7684\u5831\u916c\u3002<\/p>\n<\/div>\n"},"KZ-RU":[],"AR":{"QuestionText":"<div style=\"text-align: center;;text-align:right;direction:rtl\"><strong>\u0627\u0644\u062c\u0632\u0621 \u0627\u0644\u0623\u0648\u0644<\/strong><\/div>\n\n<div style=\"text-align: center;;text-align:right;direction:rtl\">\u0641\u064a \u0647\u0630\u0627 \u0627\u0644\u062c\u0632\u0621\u060c \u0633\u0648\u0641 \u062a\u062d\u0635\u0644 \u0639\u0644\u0649 \u0645\u0643\u0627\u0641\u0623\u0629. \u0647\u0630\u0647 \u0627\u0644\u0645\u0643\u0627\u0641\u0623\u0629 \u0644\u064a\u0633\u062a \u0645\u062a\u0645\u0627\u062b\u0644\u0629 \u0644\u0643\u0644 \u0627\u0644\u0645\u0634\u0627\u0631\u0643\u064a\u0646. \u064a\u0645\u0643\u0646\u0643 \u062a\u062d\u062f\u064a\u062f \u0627\u0644\u0645\u0643\u0627\u0641\u0623\u0629 \u0628\u0646\u0641\u0633\u0643 \u0639\u0646 \u0637\u0631\u064a\u0642 \u0631\u0645\u064a \u0627\u0644\u0632\u0647\u0631 \u0628\u0645\u062c\u0631\u062f \u0623\u0646 \u064a\u064f\u0637\u0644\u0628 \u0645\u0646\u0643 \u0630\u0644\u0643.<\/div>\n"},"DE-DE":{"QuestionText":"<div style=\"text-align: center;\"><strong>TEIL 1<\/strong><\/div>\n\n<div style=\"text-align: center;\">In diesem Teil erhalten Sie eine Auszahlung. Diese Auszahlung ist nicht f\u00fcr alle TeilnehmerInnen gleich. Sie bestimmen Ihre Auszahlung selbst, indem Sie w\u00fcrfeln, sobald Sie dazu aufgefordert werden.<\/div>\n"}},"NextChoiceId":4,"NextAnswerId":1,"DataVisibility":{"Private":false,"Hidden":false},"QuestionText_Unsafe":"<div style=\"text-align: center;\"><strong>PART 1<\/strong><br>\n&nbsp;<\/div>\n\n<div style=\"text-align: center;\">In this part, you will receive a payoff. This payoff is not the same for every participant. You determine your own payoff by throwing a die as soon as you are asked to.<\/div>"}},{"SurveyID":"SV_b3mHBVkuioRMhng","Element":"SQ","PrimaryAttribute":"QID300","SecondaryAttribute":"Timing","TertiaryAttribute":null,"Payload":{"QuestionText":"Timing","DefaultChoices":false,"DataExportTag":"Q293","QuestionID":"QID300","QuestionType":"Timing","Selector":"PageTimer","Configuration":{"QuestionDescriptionOption":"UseText","MinSeconds":"0","MaxSeconds":"0"},"QuestionDescription":"Timing","Choices":{"1":{"Display":"First Click"},"2":{"Display":"Last Click"},"3":{"Display":"Page Submit"},"4":{"Display":"Click Count"}},"GradingData":[],"Language":{"ES":[],"EL":{"QuestionText":"\u03a3\u03c5\u03b3\u03c7\u03c1\u03bf\u03bd\u03b9\u03c3\u03bc\u03cc\u03c2","Choices":{"1":{"Display":"\u03a0\u03c1\u03ce\u03c4\u03bf \u03ba\u03bb\u03b9\u03ba"},"2":{"Display":"\u03a4\u03b5\u03bb\u03b5\u03c5\u03c4\u03b1\u03af\u03bf \u03ba\u03bb\u03b9\u03ba"},"3":{"Display":"\u03a5\u03c0\u03bf\u03b2\u03bf\u03bb\u03ae \u03c3\u03b5\u03bb\u03af\u03b4\u03b1\u03c2"},"4":{"Display":"\u039a\u03ac\u03bd\u03c4\u03b5 \u03ba\u03bb\u03b9\u03ba \u03c3\u03c4\u03bf Count"}}},"FR":{"QuestionText":"Horaire","Choices":{"1":{"Display":"Premier clic"},"2":{"Display":"Dernier clic"},"3":{"Display":"Soumettre la page"},"4":{"Display":"Nombre de clics"}}},"CS":{"QuestionText":"Na\u010dasov\u00e1n\u00ed","Choices":{"1":{"Display":"Prvn\u00ed kliknut\u00ed"},"2":{"Display":"Posledn\u00ed kliknut\u00ed"},"3":{"Display":"Odeslat str\u00e1nku"},"4":{"Display":"Klepn\u011bte na tla\u010d\u00edtko Po\u010det"}}},"RU":{"QuestionText":"\u0422\u0430\u0439\u043c\u0438\u043d\u0433","Choices":{"1":{"Display":"\u041f\u0435\u0440\u0432\u044b\u0439 \u043a\u043b\u0438\u043a"},"2":{"Display":"\u041f\u043e\u0441\u043b\u0435\u0434\u043d\u0438\u04